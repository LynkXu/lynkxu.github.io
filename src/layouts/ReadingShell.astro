---
import Base from './Base.astro';
import { SITE_TITLE } from '../consts';
import '../styles/reading.scss';

interface Props {
	title: string;
	description: string;
	className?: string;
}

const { title, description, className = '' } = Astro.props;
const currentPath = Astro.url.pathname;

const navItems = [
	{ href: '/blog', label: '归档' },
	{ href: '/shuoshuo', label: '碎语' },
	{ href: '/message', label: '留言' },
	{ href: '/about', label: '关于' },
];

const featureLinks = [
	{ href: '/photography', label: '摄影' },
	{ href: '/media', label: '书影音' },
	{ href: '/travel', label: '旅行' },
	{ href: '/sports', label: '运动' },
	{ href: '/tools', label: '工具' },
	{ href: '/index.xml', label: 'RSS' },
];

function normalizePath(path: string) {
	return path.endsWith('/') && path !== '/' ? path.slice(0, -1) : path;
}

function isActive(href: string) {
	const current = normalizePath(currentPath);
	const target = normalizePath(href);
	if (target === '/') return current === '/';
	return current === target || current.startsWith(`${target}/`);
}
---

<Base
	title={title}
	description={description}
	className={`reading-surface-root ${className}`}
	hideHeader={true}
	hideFooter={true}
	useCard={false}
	readingSurface={true}
	hideUtilities={true}
>
	<slot name="head" slot="head" />

	<div class="reading-shell">
		<header class="reading-shell__header">
			<a href="/" class="reading-shell__brand" aria-label={`${SITE_TITLE} 首页`}>
				LynkXu
			</a>

			<nav class="reading-shell__nav" aria-label="主导航">
				{navItems.map((item) => (
					<a href={item.href} class:list={[{ active: isActive(item.href) }]}>
						{item.label}
					</a>
				))}
			</nav>

			<div class="reading-shell__tools">
				<button
					id="search-fab"
					class="reading-shell__ctrl"
					type="button"
					aria-label="搜索文章"
					aria-keyshortcuts="Meta+K Control+K"
					title="搜索 ⌘K"
				>
					<svg viewBox="0 0 24 24" width="18" height="18" focusable="false" aria-hidden="true">
						<path d="M10.5 3a7.5 7.5 0 0 1 5.93 12.1l3.74 3.73a1 1 0 0 1-1.42 1.42l-3.73-3.74A7.5 7.5 0 1 1 10.5 3Zm0 2a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11Z"></path>
					</svg>
				</button>
				<button
					id="theme-toggle-fab"
					class="reading-shell__ctrl reading-shell__ctrl--theme"
					type="button"
					aria-label="切换深色模式"
					aria-pressed="false"
					title="切换主题"
				>
					<span class="theme-toggle-icon theme-toggle-icon--moon" aria-hidden="true">
						<svg viewBox="0 0 24 24" width="18" height="18" focusable="false" aria-hidden="true">
							<path d="M21 14.5a8.5 8.5 0 0 1-11.5-11A9 9 0 1 0 21 14.5Z"></path>
						</svg>
					</span>
					<span class="theme-toggle-icon theme-toggle-icon--sun" aria-hidden="true">
						<svg viewBox="0 0 24 24" width="18" height="18" focusable="false" aria-hidden="true">
							<path d="M12 18a6 6 0 1 0 0-12 6 6 0 0 0 0 12Zm0-16 1 2h-2l1-2Zm0 20-1-2h2l-1 2ZM2 13l2-1v2l-2-1Zm20-1 2 1-2 1v-2ZM4.22 19.78l1.42-1.42 1.41 1.41-1.41 1.42-1.42-1.41Zm14.14-14.14 1.42-1.42 1.41 1.41-1.41 1.42-1.42-1.41ZM4.22 4.22 5.64 5.64 4.22 7.05 2.81 5.64 4.22 4.22Zm14.14 14.14 1.42 1.42-1.42 1.41-1.41-1.41 1.41-1.42Z"></path>
						</svg>
					</span>
				</button>
			</div>
		</header>

		<main class="reading-shell__main">
			<slot />
		</main>

		<footer class="reading-shell__footer">
			<div class="reading-shell__footer-links" aria-label="专题与订阅">
				{featureLinks.map((item) => (
					<a href={item.href}>{item.label}</a>
				))}
			</div>
			<p class="reading-shell__copy">
				© {new Date().getFullYear()} LynkXu · Powered by <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a>, Design by Lynk
			</p>
		</footer>
	</div>
</Base>
