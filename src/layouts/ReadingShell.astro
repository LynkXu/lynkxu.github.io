---
import Base from './Base.astro';
import { SITE_TITLE } from '../consts';
import '../styles/reading.scss';

interface Props {
	title: string;
	description: string;
	className?: string;
}

const { title, description, className = '' } = Astro.props;
const currentPath = Astro.url.pathname;

const navItems = [
	{ href: '/', label: '首页' },
	{ href: '/blog', label: '归档' },
	{ href: '/shuoshuo', label: '碎语' },
	{ href: '/message', label: '留言' },
	{ href: '/about', label: '关于' },
];

const featureLinks = [
	{ href: '/tags', label: '标签' },
	{ href: '/photography', label: '摄影' },
	{ href: '/media', label: '书影音' },
	{ href: '/travel', label: '旅行' },
	{ href: '/sports', label: '运动' },
	{ href: '/tools', label: '工具' },
	{ href: '/index.xml', label: 'RSS' },
	{ href: '/copyright', label: '版权' },
];

function normalizePath(path: string) {
	return path.endsWith('/') && path !== '/' ? path.slice(0, -1) : path;
}

function isActive(href: string) {
	const current = normalizePath(currentPath);
	const target = normalizePath(href);
	if (target === '/') return current === '/';
	return current === target || current.startsWith(`${target}/`);
}
---

<Base
	title={title}
	description={description}
	className={`reading-surface-root ${className}`}
	hideHeader={true}
	hideFooter={true}
	useCard={false}
	readingSurface={true}
	hideUtilities={true}
>
	<link
		slot="head"
		href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:ital,wght@0,400;0,500;0,600;1,400&family=Noto+Serif+SC:wght@400;500;600&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,500;0,8..60,600;1,8..60,400&display=swap"
		rel="stylesheet"
	/>
	<slot name="head" slot="head" />

	<div class="reading-shell">
		<header class="reading-shell__header">
			<a href="/" class="reading-shell__brand" aria-label={`${SITE_TITLE} 首页`}>
				{SITE_TITLE}
			</a>

			<nav class="reading-shell__nav" aria-label="主导航">
				{navItems.map((item) => (
					<a href={item.href} class:list={[{ active: isActive(item.href) }]}>
						{item.label}
					</a>
				))}
				<div class="reading-shell__tools">
					<button
						id="search-fab"
						class="reading-shell__ctrl"
						type="button"
						aria-label="搜索文章"
						aria-keyshortcuts="Meta+K Control+K"
						title="搜索 ⌘K"
					>
						搜索
					</button>
					<button
						id="theme-toggle-fab"
						class="reading-shell__ctrl"
						type="button"
						aria-label="Toggle dark mode"
						aria-pressed="false"
						title="主题"
					>
						主题
					</button>
				</div>
			</nav>
		</header>

		<main class="reading-shell__main">
			<slot />
		</main>

		<footer class="reading-shell__footer">
			<div class="reading-shell__footer-links" aria-label="专题与订阅">
				{featureLinks.map((item) => (
					<a href={item.href}>{item.label}</a>
				))}
			</div>
			<p class="reading-shell__copy">© {new Date().getFullYear()} LynkXu</p>
		</footer>
	</div>
</Base>
