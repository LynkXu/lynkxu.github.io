---
import type { CollectionEntry } from 'astro:content';
import MagazineShell from './MagazineShell.astro';
import Comments from '../components/Comments.astro';

type Props = CollectionEntry<'page'>['data'] & {
	content?: string;
};

const { title } = Astro.props;
---

<MagazineShell title={title} description={title}>
	<div class="message-card">
		<Comments showLinuxDo={false} manualTwikooLoad={true} />
	</div>
</MagazineShell>

<style>
	.message-card {
		border: 1px solid var(--paper-card-border-soft);
		border-radius: var(--paper-card-radius);
		background: var(--paper-card-bg);
		box-shadow: var(--paper-card-shadow);
		padding: clamp(1.2rem, 3vw, 1.8rem);
		animation: fade-up 0.5s ease-out 0.1s both;
	}

	@keyframes fade-up {
		from { opacity: 0; transform: translateY(10px); }
		to { opacity: 1; transform: translateY(0); }
	}

	@media (prefers-reduced-motion: reduce) {
		.message-card {
			animation: none;
		}
	}
</style>
