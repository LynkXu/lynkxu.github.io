---
import type { CollectionEntry } from 'astro:content';
import MagazineShell from './MagazineShell.astro';
import Comments from '../components/Comments.astro';

type Props = CollectionEntry<'page'>['data'] & {
	content?: string;
};

const { title } = Astro.props;
---

<MagazineShell title={title} description={title} className="message-surface" showProfileCard={false}>
	<section class="message-panel" aria-labelledby="message-title">
		<header class="message-panel__header">
			<p class="magazine-section-label">Messages</p>
			<h1 id="message-title" class="sr-only">Leaves</h1>
			<!-- <p>Notes left by visitors. Comments load only when needed.</p> -->
		</header>

		<div class="message-comments">
			<Comments showLinuxDo={false} manualTwikooLoad={true} />
		</div>
	</section>

	<div slot="sidebar-extra" class="message-rail">
		<section class="magazine-rail-card message-contact-card" aria-labelledby="message-contact-title">
			<p id="message-contact-title" class="magazine-section-label">Contact</p>
			<p class="message-contact-intro">公开留言适合文章反馈、问题和随手想到的想法；如果不想公开，可以换到下面的平台。</p>
			<div class="message-action-list" aria-label="Contact actions">
				<a href="#twikoo-lazygate">Write here</a>
				<a href="https://mastodon.social/@lynkxu" target="_blank" rel="noopener noreferrer">Mastodon</a>
				<a href="https://github.com/LynkXu" target="_blank" rel="noopener noreferrer">GitHub</a>
			</div>
		</section>
	</div>
</MagazineShell>

<style is:global>
	.message-surface {
		--blog-shell-width: 1160px;
		--blog-shell-sidebar-width: 16.5rem;
	}

	.message-panel {
		min-height: min(40rem, calc(100vh - 10rem));
	}

	.message-panel__header {
		margin-bottom: clamp(var(--space-lg), 3vw, var(--space-xl));
	}

	.message-panel__header p:last-child {
		margin: 0.72rem 0 0;
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: 0.88rem;
		font-weight: var(--weight-medium);
		line-height: 1.5;
	}

	.message-comments {
		border-radius: var(--paper-card-radius);
	}

	.message-comments .comments.single {
		margin: 0;
	}

	.message-comments .twikoo-shell {
		border: 0;
		border-radius: 0;
		background: transparent;
		overflow: visible;
	}

	.message-comments .twikoo-shell[data-load-state="loaded"] {
		border: 0;
		background: transparent;
		overflow: visible;
	}

	.message-comments .twikoo-lazygate {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-sm);
		padding: 0.62rem 0 0.72rem;
	}

	.message-comments .twikoo-lazygate__meta {
		margin: 0;
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: 0.82rem;
		font-weight: var(--weight-regular);
		line-height: 1.5;
	}

	.message-comments .twikoo-load-button {
		min-width: 5.8rem;
		min-height: 1.95rem;
		border: 1px solid var(--paper-card-border-soft);
		border-radius: 999px;
		background: transparent;
		color: color-mix(in oklab, var(--heading-color) 88%, var(--gray-color));
		font-family: var(--ui-font);
		font-size: 0.76rem;
		font-weight: var(--weight-regular);
		cursor: pointer;
	}

	.message-comments .twikoo-load-button:hover:not(:disabled) {
		border-color: var(--paper-hover-border);
		background: var(--paper-hover-bg);
		color: var(--heading-color);
	}

	.message-rail {
		display: flex;
		flex-direction: column;
		gap: 0.72rem;
	}

	.message-contact-card {
		display: flex;
		flex-direction: column;
		gap: 0.82rem;
	}

	.message-contact-intro {
		margin: 0;
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: 0.78rem;
		font-weight: var(--weight-regular);
		line-height: 1.62;
	}

	.message-action-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.42rem;
	}

	.message-action-list a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 1.78rem;
		padding: 0.24rem 0.62rem;
		border: 1px solid var(--paper-card-border-soft) !important;
		border-radius: 999px;
		background: color-mix(in oklab, var(--paper-card-bg-soft) 72%, transparent) !important;
		color: color-mix(in oklab, var(--heading-color) 88%, var(--gray-color));
		font-family: var(--ui-font);
		font-size: 0.72rem;
		font-weight: var(--weight-regular);
		line-height: 1.2;
		text-decoration: none;
	}

	.message-action-list a:hover {
		color: var(--heading-color);
		border-color: var(--paper-hover-border) !important;
		background: var(--paper-hover-bg) !important;
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	@media (max-width: 640px) {
		.message-panel {
			padding-inline: var(--page-inline);
		}

		.message-comments .twikoo-lazygate {
			flex-direction: column;
			align-items: stretch;
		}

		.message-comments .twikoo-load-button {
			width: 100%;
		}
	}
</style>

<style is:global>
	.blog-surface-layout .message-panel {
		min-height: 0 !important;
	}

	.blog-surface-layout .message-panel__header {
		margin-bottom: clamp(1rem, 3vw, 1.6rem) !important;
		padding-bottom: 0.65rem !important;
		border-bottom: 1px solid var(--paper-card-border-soft) !important;
	}

	.blog-surface-layout .message-comments .twikoo-lazygate {
		padding: 1rem 0 !important;
		border-bottom: 1px solid var(--paper-card-border-soft) !important;
	}

	.blog-surface-layout .message-comments .twikoo-load-button {
		border-radius: 0 !important;
		background: transparent !important;
	}

	.blog-surface-layout .message-action-list {
		display: flex !important;
		flex-direction: column !important;
		flex-wrap: nowrap !important;
		gap: 0 !important;
		border-top: 1px solid var(--paper-card-border-soft) !important;
	}

	.blog-surface-layout .message-action-list a {
		justify-content: flex-start !important;
		min-height: 0 !important;
		padding: 0.55rem 0 !important;
		border: 0 !important;
		border-bottom: 1px solid var(--paper-card-border-soft) !important;
		border-radius: 0 !important;
		background: transparent !important;
		color: var(--gray-color) !important;
	}
</style>

