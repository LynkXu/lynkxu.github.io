---
import type { CollectionEntry } from 'astro:content';
import MagazineShell from './MagazineShell.astro';
import Comments from '../components/Comments.astro';

type Props = CollectionEntry<'page'>['data'] & {
	content?: string;
};

const { title } = Astro.props;
---

<MagazineShell title={title} description={title} className="message-surface" showProfileCard={false}>
	<section class="message-panel postcard-sheet" aria-labelledby="message-title">
		<header class="message-panel__header">
			<p class="magazine-section-label">Guestbook</p>
			<p class="message-panel__sub">公开留言 · 纸笺</p>
			<h1 id="message-title" class="sr-only">留言</h1>
		</header>

		<div class="message-comments">
			<Comments showLinuxDo={false} manualTwikooLoad={true} />
		</div>
	</section>

	<div slot="sidebar-extra" class="message-rail">
		<section class="magazine-rail-card message-contact-card" aria-labelledby="message-contact-title">
			<p id="message-contact-title" class="magazine-section-label">联系</p>
			<p class="message-contact-intro">公开留言适合文章反馈、问题和随手想到的想法；如果不想公开，可以换到下面的平台。</p>
			<div class="message-action-list" aria-label="联系方式">
				<a href="#twikoo-lazygate">在此留言</a>
				<a href="https://mastodon.social/@lynkxu" target="_blank" rel="noopener noreferrer">Mastodon</a>
				<a href="https://github.com/LynkXu" target="_blank" rel="noopener noreferrer">GitHub</a>
			</div>
		</section>
	</div>
</MagazineShell>

<style is:global>
	.message-panel {
		min-height: 0;
		max-width: var(--blog-content-max);
		padding: clamp(1.15rem, 2.6vw, 1.55rem);
	}

	.message-panel__header {
		display: flex;
		flex-direction: column;
		gap: 0.3rem;
		margin-bottom: clamp(1rem, 3vw, 1.6rem);
		padding-bottom: 0.75rem;
		border-bottom: 1px solid var(--sheet-edge);
	}

	.message-panel__header .magazine-section-label {
		font-family: var(--field-font);
		font-size: 0.62rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--faint-color);
	}

	.message-panel__sub {
		margin: 0;
		font-family: var(--display-font);
		font-size: 1.15rem;
		font-weight: 600;
		letter-spacing: -0.015em;
		color: var(--heading-color);
	}

	.message-comments {
		border-radius: var(--paper-card-radius);
	}

	.message-comments .comments.single {
		margin: 0;
	}

	.message-comments .twikoo-shell {
		border: 0;
		border-radius: 0;
		background: transparent;
		overflow: visible;
	}

	.message-comments .twikoo-shell[data-load-state="loaded"] {
		border: 0;
		background: transparent;
		box-shadow: none;
		overflow: visible;
	}

	.message-comments .twikoo-lazygate {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-sm);
		padding: 1rem 0;
		border-bottom: 1px solid var(--paper-card-border-soft);
	}

	.message-comments .twikoo-lazygate__meta {
		margin: 0;
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: 0.78rem;
		font-weight: var(--weight-regular);
		line-height: 1.5;
	}

	.message-comments .twikoo-load-button {
		min-height: 2rem;
		border: 1px solid var(--paper-card-border-soft);
		border-radius: 0;
		background: transparent;
		color: var(--heading-color);
		font-family: var(--ui-font);
		font-size: 0.76rem;
		font-weight: var(--weight-regular);
		cursor: pointer;
	}

	.message-comments .twikoo-load-button:hover:not(:disabled) {
		border-color: var(--paper-hover-border);
		background: transparent;
		color: var(--heading-color);
	}

	.message-rail {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.message-contact-card {
		display: flex;
		flex-direction: column;
		gap: 0.85rem;
	}

	.message-contact-intro {
		margin: 0;
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: 0.78rem;
		font-weight: var(--weight-regular);
		line-height: 1.65;
	}

	.message-action-list {
		display: flex;
		flex-direction: column;
		gap: 0;
		border-top: 1px solid var(--paper-card-border-soft);
	}

	.message-action-list a {
		display: inline-flex;
		align-items: center;
		justify-content: flex-start;
		min-height: 0;
		padding: 0.55rem 0;
		border: 0 !important;
		border-bottom: 1px solid var(--paper-card-border-soft) !important;
		border-radius: 0;
		background: transparent !important;
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: 0.78rem;
		font-weight: var(--weight-regular);
		line-height: 1.2;
		text-decoration: none;
	}

	.message-action-list a:hover {
		color: var(--heading-color);
		background: transparent !important;
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	@media (max-width: 640px) {
		.message-panel {
			padding-inline: 0;
		}

		.message-comments .twikoo-lazygate {
			flex-direction: column;
			align-items: stretch;
		}

		.message-comments .twikoo-load-button {
			width: 100%;
		}
	}
</style>
