---
import type { CollectionEntry } from 'astro:content';
import Base from './Base.astro';
import Comments from '../components/Comments.astro';

type Props = CollectionEntry<'page'>['data'] & {
	content?: string;
};

const { title } = Astro.props;
---

<Base title={title} description={title} className="blog-surface-layout">
	<div class="content-limit-width list-stack page-shell">
		<section class="list-surface list-surface--lead">
			<header class="page-rail">
				<h1 id='page-title'>{title}</h1>
				<p class="page-rail__meta">leave a note</p>
			</header>
			<div class="list-main list-main--spacer" aria-hidden="true"></div>
		</section>

		<div class="list-ledger guestbook-ledger paper-ledger">
			<div class="post-content content page-prose guestbook-intro">
				<slot />
			</div>
			<div class="comments-wrapper">
				<Comments showLinuxDo={false} />
			</div>
		</div>
	</div>
</Base>
