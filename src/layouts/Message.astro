---
import type { CollectionEntry } from 'astro:content';
import MagazineShell from './MagazineShell.astro';
import ListingFrame from '../components/ListingFrame.astro';
import Comments from '../components/Comments.astro';

type Props = CollectionEntry<'page'>['data'] & {
	content?: string;
};

const { title } = Astro.props;
---

<MagazineShell title={title} description={title}>
	<ListingFrame
		eyebrow="Leaves"
		title={title}
		description="Notes, messages, and small conversations left at the edge of the site."
	>
		<div class="message-card">
			<Comments showLinuxDo={false} manualTwikooLoad={true} />
		</div>
	</ListingFrame>
</MagazineShell>

<style>
	.message-card {
		padding: clamp(0.25rem, 1vw, 0.6rem) 0 clamp(1.8rem, 4vw, 2.6rem);
		animation: fade-up 0.5s ease-out 0.1s both;
	}

	@keyframes fade-up {
		from { opacity: 0; transform: translateY(10px); }
		to { opacity: 1; transform: translateY(0); }
	}

	@media (prefers-reduced-motion: reduce) {
		.message-card {
			animation: none;
		}
	}
</style>
