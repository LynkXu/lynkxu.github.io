---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import MagazineShell from './MagazineShell.astro';
import { marked } from 'marked';
import { INCLUDE_DRAFTS, filterDrafts } from '../utils/drafts';
import fs from 'fs';
import path from 'path';
import LikeButton from '../components/LikeButton.astro';

type Props = CollectionEntry<'page'>['data'] & {
	content?: string;
};

const { title } = Astro.props;

const fileGossips = filterDrafts(await getCollection('gossips'));

let mastodonGossips: any[] = [];
try {
	const mastodonDataPath = path.join(process.cwd(), 'src/data/mastodon.json');
	if (fs.existsSync(mastodonDataPath)) {
		const mastodonData = JSON.parse(fs.readFileSync(mastodonDataPath, 'utf-8'));
		mastodonGossips = mastodonData.map((status: any) => ({
			data: {
				pubDate: new Date(status.created_at),
				slug: `mastodon-${status.id}`,
				draft: false,
				tag: 'mastodon',
			},
			body: status.content_markdown,
			_raw: status,
		}));
	}
} catch (error) {
	console.warn('Failed to load Mastodon data:', error);
}

const gossips = [...fileGossips, ...mastodonGossips].sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const pageSize = 10;
const totalPages = gossips.length > 0 ? Math.ceil(gossips.length / pageSize) : 0;

marked.setOptions({
	breaks: true,
	gfm: true,
});

function getDateParts(date: Date) {
	const options: Intl.DateTimeFormatOptions = { timeZone: 'Asia/Shanghai' };
	const day = new Intl.DateTimeFormat('en-US', { ...options, day: '2-digit' }).format(date);
	const monthNum = new Intl.DateTimeFormat('en-US', { ...options, month: '2-digit' }).format(date);
	const year = new Intl.DateTimeFormat('en-US', { ...options, year: 'numeric' }).format(date);
	const time = new Intl.DateTimeFormat('en-US', { ...options, hour: '2-digit', minute: '2-digit', hour12: false }).format(date);
	return { day, monthNum, year, time };
}

const memoItems = gossips.map((gossip: any, index) => {
	const { day, monthNum, year, time } = getDateParts(gossip.data.pubDate);
	return {
		gossip,
		index,
		page: Math.floor(index / pageSize) + 1,
		dayStamp: `${monthNum}-${day}`,
		monthLabel: `${year}.${monthNum}`,
		monthId: `memos-${year}-${monthNum}`,
		year,
		time,
		attachments: gossip._raw?.media_attachments || [],
	};
});

const pagedGroups = Array.from({ length: totalPages }, (_, pageIndex) => {
	const page = pageIndex + 1;
	const groups = new Map<string, { label: string; id: string; year: string; items: typeof memoItems }>();

	memoItems
		.filter((item) => item.page === page)
		.forEach((item) => {
			if (!groups.has(item.monthId)) {
				groups.set(item.monthId, {
					label: item.monthLabel,
					id: item.monthId,
					year: item.year,
					items: [],
				});
			}
			groups.get(item.monthId)?.items.push(item);
		});

	return { page, groups: Array.from(groups.values()) };
});

---

<link rel="stylesheet" href="/lightgallery/css/lightgallery.min.css" slot="head" />
<style is:global slot="head">
    .media-grid {
        display: grid;
        gap: 4px;
        margin-top: 8px;
        width: min(100%, 430px);
    }
    .media-item {
        display: block;
        border: 1px solid color-mix(in oklab, var(--gray-color) 14%, transparent);
        overflow: hidden;
        background: var(--code-background-color);
        cursor: zoom-in;
    }
    .media-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .grid-1 { grid-template-columns: 1fr; }
    .grid-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .grid-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .grid-4 { grid-template-columns: repeat(2, minmax(0, 1fr)); }

    .grid-1 .media-item {
        aspect-ratio: 16 / 10;
        max-height: 220px;
    }

    .grid-2 .media-item,
    .grid-3 .media-item,
    .grid-4 .media-item {
        aspect-ratio: 4 / 3;
        max-height: 140px;
    }

    @media (max-width: 600px) {
        .media-grid {
            gap: 3px;
            width: 100%;
        }
        .grid-3 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .grid-1 .media-item {
            max-height: 190px;
        }
        .grid-2 .media-item,
        .grid-3 .media-item,
        .grid-4 .media-item {
            max-height: 120px;
        }
    }
</style>

<MagazineShell title={title} description={title} className="memos-surface">
	<div id='shuoshuo' class="memos-feed">
		{
			gossips.length === 0 ? (
				<div class='empty-state'>No memos yet.</div>
			) : (
				pagedGroups.map(({ page, groups }) => (
					<div class="memos-page" data-page={page}>
						{groups.map((group) => (
							<section class="memos-month" id={group.id} data-year={group.year} aria-labelledby={`${group.id}-title`}>
								<h2 class="memos-month-title" id={`${group.id}-title`}>{group.label}</h2>
								<div class="memos-month-list" role="list">
									{group.items.map((item) => {
										const { gossip, attachments, dayStamp, time, index } = item;
										return (
											<article class='memo-item' data-index={index} role="listitem">
												<time class="memo-stamp" datetime={gossip.data.pubDate.toISOString()}>
													<span class="memo-date">{dayStamp}</span>
													<span class='memo-time'>{time}</span>
												</time>
												<div class='memo-body'>
													<div class='memo-content markdown-body' set:html={marked.parse(gossip.body || '')} />

													{attachments.length > 0 && (
														<div class={`media-grid grid-${Math.min(attachments.length, 4)}`}>
															{attachments.slice(0, 4).map((media: any) => (
																<a href={media.url} class="media-item" data-src={media.url}  data-sub-html={media.description}>
																	<img src={media.preview_url || media.url} alt={media.description || ""} loading="lazy" />
																</a>
															))}
														</div>
													)}
													<div class="memo-footer">
														{gossip.data.tag && <span class="memo-tag">{gossip.data.tag}</span>}
														{INCLUDE_DRAFTS && gossip.data.draft && <span class="draft-indicator">draft</span>}
														<LikeButton id={gossip.data.slug} type="gossip" />
													</div>
												</div>
											</article>
										)
									})}
								</div>
							</section>
						))}
					</div>
				))
			)
		}
	</div>
	
	{totalPages > 1 && (
		<nav class='pagination' id='shuoshuo-pagination' aria-label='Pagination'>
			<div class='pagination-pages'>
				{Array.from({ length: totalPages }, (_, index) => {
					const pageNumber = index + 1;
					return (
						<a class='page-link' href={`?page=${pageNumber}`} data-page={pageNumber}>
							{pageNumber}
						</a>
					);
				})}
			</div>
		</nav>
	)}
</MagazineShell>

<script is:inline src="/lightgallery/js/lightgallery.min.js" defer></script>
<script is:inline>
    function initGallery() {
        if (!window.lightGallery) return;
        const grids = document.querySelectorAll('.media-grid');
        grids.forEach(grid => {
            window.lightGallery(grid, {
                selector: '.media-item',
                speed: 500,
                download: false
            });
        });
    }

    function onReady() {
        if (window.lightGallery) {
            initGallery();
        } else {
            setTimeout(onReady, 100);
        }
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', onReady);
    } else {
        onReady();
    }
</script>

<script is:inline define:vars={{ totalPages }}>
	(() => {
		const pages = Array.from(document.querySelectorAll('#shuoshuo .memos-page'));
		const pagination = document.getElementById('shuoshuo-pagination');
		const pageLinks = Array.from(document.querySelectorAll('#shuoshuo-pagination a[data-page]'));

		if (!pagination || !pages.length || totalPages <= 1) {
			if (pagination) pagination.style.display = 'none';
			return;
		}

		const params = new URLSearchParams(window.location.search);
		const initialPage = Math.min(totalPages, Math.max(1, Number(params.get('page')) || 1));
		const clampPage = (page) => Math.min(totalPages, Math.max(1, page));

		function renderPage(page) {
			const currentPage = clampPage(page);

			pages.forEach((pageNode) => {
				const visible = Number(pageNode.dataset.page) === currentPage;
				pageNode.hidden = !visible;
			});

			pageLinks.forEach((link) => {
				const linkPage = Number(link.dataset.page);
				const active = linkPage === currentPage;
				link.classList.toggle('active', active);
				if (active) {
					link.setAttribute('aria-current', 'page');
				} else {
					link.removeAttribute('aria-current');
				}
			});

			params.set('page', String(currentPage));
			const nextUrl = `${window.location.pathname}?${params.toString()}${window.location.hash}`;
			window.history.replaceState({}, '', nextUrl);
            
            if (window.scrollY > 100) {
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }
		}

		renderPage(initialPage);

		pageLinks.forEach((link) => {
			link.addEventListener('click', (event) => {
				event.preventDefault();
				const targetPage = Number(link.dataset.page);
				if (!Number.isFinite(targetPage)) return;
				renderPage(targetPage);
			});
		});
	})();
</script>

<style>
	:global(.memos-surface) {
		--memos-section-gap: 1.75rem;
	}

	:global(.memos-surface .magazine-main) {
		gap: var(--memos-section-gap);
	}

	.memos-feed {
		display: flex;
		flex-direction: column;
		gap: var(--space-xl);
		margin-top: 0 !important;
		animation: fade-up 0.5s ease-out 0.08s both;
	}

	.memos-page {
		display: flex;
		flex-direction: column;
		gap: var(--memos-section-gap);
	}

	.memos-page[hidden] {
		display: none;
	}

	.memos-month {
		display: grid;
		grid-template-columns: minmax(4.5rem, 5.25rem) minmax(0, 1fr);
		gap: var(--space-sm);
		position: relative;
	}

	.memos-month-title {
		position: sticky;
		top: var(--space-lg);
		align-self: start;
		margin: 0;
		padding-top: 1rem;
		font-family: var(--field-font);
		font-size: 0.78rem;
		font-weight: 500;
		line-height: 1.35;
		color: var(--heading-color);
		letter-spacing: 0.035em;
		font-variant-numeric: tabular-nums;
	}

	.memos-month-list {
		display: flex;
		flex-direction: column;
		gap: var(--space-sm);
	}

	.memo-item {
		display: grid;
		grid-template-columns: minmax(4rem, 4.6rem) minmax(0, 1fr);
		gap: var(--space-xs);
		padding: 0.82rem 0.9rem;
		position: relative;
		border: 1px solid var(--paper-card-border-soft);
		border-radius: var(--paper-card-radius);
		background: var(--paper-card-bg);
		box-shadow: var(--paper-card-shadow);
		transition: background 0.2s ease, border-color 0.2s ease;
	}

	.memo-item:hover {
		background: color-mix(in oklab, var(--accent-soft-bg) 18%, var(--paper-card-bg));
		border-color: color-mix(in oklab, var(--accent-color) 10%, var(--paper-card-border-soft));
	}

	.memo-stamp {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.08rem;
		padding-top: 0.18rem;
		font-family: var(--field-font);
		line-height: 1.35;
		color: var(--gray-color);
		font-variant-numeric: tabular-nums;
	}

	.memo-date {
		color: var(--heading-color);
		font-size: 0.74rem;
		font-weight: 500;
		letter-spacing: 0.035em;
	}

	.memo-time {
		font-size: 0.66rem;
		opacity: 0.78;
	}

	.memo-body {
		min-width: 0;
	}

	.memo-content {
		color: var(--text-color);
		font-size: 0.92rem;
		line-height: 1.68;
		letter-spacing: 0;
	}

	.memo-content :global(p) {
		margin: 0.14rem 0;
	}

	.memo-content :global(p:first-child) {
		margin-top: 0;
	}

	.memo-content :global(p:last-child) {
		margin-bottom: 0;
	}

	.memo-content :global(strong) {
		color: var(--heading-color);
		font-weight: 600;
	}

	.memo-content :global(a) {
		text-underline-offset: 0.14em;
		text-decoration-thickness: 0.05em;
	}

	.memo-content :global(img) {
		max-width: 100%;
		margin-top: 6px;
		opacity: 0.92;
		border-radius: 3px;
	}

	.memo-content :global(blockquote) {
		margin: 0.28rem 0;
		padding-left: 0.62rem;
		border-left: 1px solid color-mix(in oklab, var(--gray-color) 38%, transparent);
		color: var(--gray-color);
		font-size: 0.82rem;
		line-height: 1.48;
	}

	.memo-footer {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: var(--space-xs);
		opacity: 0;
		position: absolute;
		right: 0.9rem;
		bottom: 0.48rem;
		transition: opacity 0.2s ease;
	}

	.memo-item:hover .memo-footer,
	.memo-item:focus-within .memo-footer {
		opacity: 1;
	}

	.memo-tag,
	.draft-indicator {
		font-family: var(--field-font);
		font-size: 0.65rem;
		line-height: 1.35;
		color: var(--gray-color);
		letter-spacing: 0.035em;
	}

	.memo-tag::before {
		content: "#";
		opacity: 0.55;
	}

	.draft-indicator {
		color: color-mix(in oklab, var(--color-warning) 74%, var(--text-color));
		text-transform: lowercase;
	}

	.empty-state {
		text-align: center;
		padding: 3rem 1rem;
		color: var(--gray-color);
		font-size: 0.9rem;
	}

	.pagination {
		display: flex;
		justify-content: center;
		margin-top: var(--space-md);
	}

	.pagination-pages {
		display: inline-flex;
		align-items: center;
		gap: 0.12rem;
		padding: 0.18rem;
		border: 1px solid var(--paper-card-border-soft);
		border-radius: var(--paper-card-radius);
		background: color-mix(in oklab, var(--paper-card-bg-soft) 72%, transparent);
	}

	.pagination .page-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 1.55rem;
		height: 1.45rem;
		padding: 0 0.38rem;
		font-family: var(--field-font);
		font-size: 0.68rem;
		line-height: 1;
		color: var(--gray-color);
		text-decoration: none;
		border: 1px solid transparent;
		border-radius: calc(var(--paper-card-radius) - 1px);
		background: transparent;
		font-variant-numeric: tabular-nums;
		transition: color 0.18s ease, background 0.18s ease, border-color 0.18s ease;
	}

	.pagination .page-link:hover {
		color: color-mix(in oklab, var(--heading-color) 88%, var(--gray-color));
		background: color-mix(in oklab, var(--paper-card-bg) 72%, var(--page-bg));
	}

	.pagination .page-link.active {
		color: var(--heading-color);
		border-color: color-mix(in oklab, var(--gray-color) 18%, transparent);
		background: var(--paper-card-bg);
		position: relative;
	}

	.pagination .page-link.active::before,
	.pagination .page-link.active::after {
		content: none;
	}

	.pagination .page-link:focus-visible {
		outline: 2px solid var(--accent-color);
		outline-offset: 2px;
	}

	@keyframes fade-up {
		from { opacity: 0; transform: translateY(10px); }
		to { opacity: 1; transform: translateY(0); }
	}

	@media (max-width: 720px) {
		:global(.memos-surface) {
			--memos-section-gap: 1.375rem;
		}

		:global(.memos-surface .magazine-main) {
			gap: var(--memos-section-gap);
		}

		.memos-page {
			gap: var(--space-lg);
		}

		.memos-month {
			grid-template-columns: 1fr;
			gap: var(--space-sm);
		}

		.memos-month-title {
			position: static;
			padding-top: 0;
			font-size: 0.74rem;
		}

		.memo-item {
			grid-template-columns: 1fr;
			gap: var(--space-xs);
			padding: 0.78rem 0.82rem;
		}

		.memo-stamp {
			flex-direction: row;
			align-items: baseline;
			gap: 0.45rem;
			padding-top: 0;
		}

		.memo-content {
			font-size: 0.88rem;
			line-height: 1.6;
		}

		.memo-footer {
			position: static;
			margin-top: 0.15rem;
			opacity: 0.72;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.memos-feed {
			animation: none;
		}
	}
</style>
