---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import MagazineShell from './MagazineShell.astro';
import { marked } from 'marked';
import { INCLUDE_DRAFTS, filterDrafts } from '../utils/drafts';
import fs from 'fs';
import path from 'path';
import LikeButton from '../components/LikeButton.astro';

type Props = CollectionEntry<'page'>['data'] & {
	content?: string;
};

const { title } = Astro.props;

const fileGossips = filterDrafts(await getCollection('gossips'));

let mastodonGossips: any[] = [];
try {
	const mastodonDataPath = path.join(process.cwd(), 'src/data/mastodon.json');
	if (fs.existsSync(mastodonDataPath)) {
		const mastodonData = JSON.parse(fs.readFileSync(mastodonDataPath, 'utf-8'));
		mastodonGossips = mastodonData.map((status: any) => ({
			data: {
				pubDate: new Date(status.created_at),
				slug: `mastodon-${status.id}`,
				draft: false,
				tag: 'mastodon',
			},
			body: status.content_markdown,
			_raw: status,
		}));
	}
} catch (error) {
	console.warn('Failed to load Mastodon data:', error);
}

const gossips = [...fileGossips, ...mastodonGossips].sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const pageSize = 10;
const totalPages = gossips.length > 0 ? Math.ceil(gossips.length / pageSize) : 0;

marked.setOptions({
	breaks: true,
	gfm: true,
});

function getDateParts(date: Date) {
	const options: Intl.DateTimeFormatOptions = { timeZone: 'Asia/Shanghai' };
	const day = new Intl.DateTimeFormat('en-US', { ...options, day: '2-digit' }).format(date);
	const monthNum = new Intl.DateTimeFormat('en-US', { ...options, month: '2-digit' }).format(date);
	const year = new Intl.DateTimeFormat('en-US', { ...options, year: 'numeric' }).format(date);
	const time = new Intl.DateTimeFormat('en-US', { ...options, hour: '2-digit', minute: '2-digit', hour12: false }).format(date);
	return { day, monthNum, year, time };
}

const memoItems = gossips.map((gossip: any, index) => {
	const { day, monthNum, year, time } = getDateParts(gossip.data.pubDate);
	return {
		gossip,
		index,
		page: Math.floor(index / pageSize) + 1,
		dateLabel: `${year}.${monthNum}.${day}`,
		monthLabel: `${year}.${monthNum}`,
		year,
		time,
		attachments: gossip._raw?.media_attachments || [],
	};
});

function formatMemoDate(date?: Date) {
	if (!date) return '—';
	return new Intl.DateTimeFormat('zh-CN', {
		timeZone: 'Asia/Shanghai',
		year: 'numeric',
		month: '2-digit',
		day: '2-digit',
	}).format(date).replace(/\//g, '.');
}

const currentYear = new Intl.DateTimeFormat('en-US', { timeZone: 'Asia/Shanghai', year: 'numeric' }).format(new Date());
const activeMonthCount = new Set(memoItems.map((item) => item.monthLabel)).size;
const mediaMemoCount = memoItems.filter((item) => item.attachments.length > 0).length;
const thisYearMemoCount = memoItems.filter((item) => item.year === currentYear).length;
const latestMemo = memoItems[0];
const earliestMemo = memoItems.length > 0 ? memoItems[memoItems.length - 1] : undefined;
const memoStats = [
	{ label: 'Memos', value: gossips.length },
	{ label: 'This year', value: thisYearMemoCount },
	{ label: 'Months', value: activeMonthCount },
	{ label: 'Media', value: mediaMemoCount },
];
const sourceStats = [
	{ label: 'Local', value: fileGossips.length },
	{ label: 'Mastodon', value: mastodonGossips.length },
];
const monthStats = Array.from(
	memoItems.reduce((map, item) => {
		const entry = map.get(item.monthLabel) || { label: item.monthLabel, count: 0, media: 0 };
		entry.count += 1;
		if (item.attachments.length > 0) entry.media += 1;
		map.set(item.monthLabel, entry);
		return map;
	}, new Map<string, { label: string; count: number; media: number }>())
	.values()
).slice(0, 4);
const maxMonthCount = Math.max(1, ...monthStats.map((item) => item.count));
const latestMemoLabel = formatMemoDate(latestMemo?.gossip.data.pubDate);
const earliestMemoYear = earliestMemo?.year || '—';

const pagedMemoPages = Array.from({ length: totalPages }, (_, pageIndex) => {
	const page = pageIndex + 1;
	return {
		page,
		items: memoItems.filter((item) => item.page === page),
	};
});

---

<link rel="stylesheet" href="/lightgallery/css/lightgallery.min.css" slot="head" />
<style is:global slot="head">
    .media-grid {
        display: grid;
        gap: 4px;
        margin-top: 8px;
        width: min(100%, 430px);
    }
    .media-item {
        display: block;
        border: 1px solid color-mix(in oklab, var(--gray-color) 14%, transparent);
        overflow: hidden;
        background: var(--code-background-color);
        cursor: zoom-in;
    }
    .media-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .grid-1 { grid-template-columns: 1fr; }
    .grid-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .grid-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .grid-4 { grid-template-columns: repeat(2, minmax(0, 1fr)); }

    .grid-1 .media-item {
        aspect-ratio: 16 / 10;
        max-height: 220px;
    }

    .grid-2 .media-item,
    .grid-3 .media-item,
    .grid-4 .media-item {
        aspect-ratio: 4 / 3;
        max-height: 140px;
    }

    @media (max-width: 600px) {
        .media-grid {
            gap: 3px;
            width: 100%;
        }
        .grid-3 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .grid-1 .media-item {
            max-height: 190px;
        }
        .grid-2 .media-item,
        .grid-3 .media-item,
        .grid-4 .media-item {
            max-height: 120px;
        }
    }
</style>

