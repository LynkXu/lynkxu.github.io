<MagazineShell title={title} description={title} className="memos-surface" showProfileCard={false}>
	<section class="memos-panel" aria-labelledby="memos-title">
		<header class="memos-panel__header">
			<p class="magazine-section-label">Timeline</p>
			<h1 id="memos-title" class="sr-only">Memos</h1>
			<!-- <p>Short notes gathered by time, with source and month context kept aside.</p> -->
		</header>

		<div class="memos-layout">
			<div class="memos-feed-column">
			<div id='shuoshuo' class="memos-feed">
				{
					gossips.length === 0 ? (
						<div class='empty-state'>No memos yet.</div>
					) : (
						pagedMemoPages.map(({ page, items }) => (
							<div class="memos-page" data-page={page}>
								<div class="memos-page-list" role="list">
									{items.map((item) => {
										const { gossip, attachments, dateLabel, time, index } = item;
										return (
											<article class='memo-item' data-index={index} role="listitem">
												<a href="/" class="memo-avatar-link" aria-label="LynkXu">
													<img src="/ava4.png" alt="" class="memo-avatar" loading={index === 0 ? 'eager' : 'lazy'} width="40" height="40" />
												</a>
												<div class='memo-body'>
													<header class="memo-header">
														<div class="memo-header-top">
															<div class="memo-author-line">
																<span class="memo-author">LynkXu</span>
																{gossip.data.tag && <span class="memo-source">{gossip.data.tag}</span>}
															</div>
															<div class="memo-actions">
																{INCLUDE_DRAFTS && gossip.data.draft && <span class="draft-indicator">draft</span>}
																<LikeButton id={gossip.data.slug} type="gossip" />
															</div>
														</div>
														<time class="memo-meta-time" datetime={gossip.data.pubDate.toISOString()}>
															{dateLabel} · {time}
														</time>
													</header>

													<div class='memo-content markdown-body' set:html={marked.parse(gossip.body || '')} />

													{attachments.length > 0 && (
														<div class={`media-grid grid-${Math.min(attachments.length, 4)}`}>
															{attachments.slice(0, 4).map((media: any) => (
																<a href={media.url} class="media-item" data-src={media.url}  data-sub-html={media.description}>
																	<img src={media.preview_url || media.url} alt={media.description || ""} loading="lazy" />
																</a>
															))}
														</div>
													)}
												</div>
											</article>
										)
									})}
								</div>
							</div>
						))
					)
				}
			</div>

			{totalPages > 1 && (
				<nav class='pagination' id='shuoshuo-pagination' aria-label='Pagination'>
					<div class='pagination-pages'>
						{Array.from({ length: totalPages }, (_, index) => {
							const pageNumber = index + 1;
							return (
								<a class='page-link' href={`?page=${pageNumber}`} data-page={pageNumber}>
									{pageNumber}
								</a>
							);
						})}
					</div>
				</nav>
			)}
		</div>
	</div>
	</section>

	<div slot="sidebar-extra" class="memos-rail">
		<section class="magazine-rail-card memos-rail-card" aria-labelledby="memos-snapshot-title">
			<p id="memos-snapshot-title" class="magazine-section-label">Snapshot</p>
			<dl class="memos-summary-list">
				{memoStats.map((item) => (
					<div class="memos-stat-row">
						<dt>{item.label}</dt>
						<dd>{item.value}</dd>
					</div>
				))}
			</dl>
			<p id="memos-month-title" class="magazine-section-label memos-subsection-label">Months</p>
			<div class="memos-month-list">
				{monthStats.map((month) => (
					<div class="memos-month-row">
						<strong>{month.label}</strong>
						<span class="memos-month-meter" style={`--month-size: ${(month.count / maxMonthCount) * 100}%`} aria-hidden="true"></span>
						<em>{month.count}</em>
					</div>
				))}
			</div>
			<p id="memos-source-title" class="magazine-section-label memos-subsection-label">Sources</p>
			<dl class="memos-source-list">
				{sourceStats.map((item) => (
					<div class="memos-source-row">
						<dt>{item.label}</dt>
						<dd>{item.value}</dd>
					</div>
				))}
			</dl>
		</section>
	</div>
</MagazineShell>

<script is:inline src="/lightgallery/js/lightgallery.min.js" defer></script>
<script is:inline>
    function initGallery() {
        if (!window.lightGallery) return;
        const grids = document.querySelectorAll('.media-grid');
        grids.forEach(grid => {
            window.lightGallery(grid, {
                selector: '.media-item',
                speed: 500,
                download: false
            });
        });
    }

    function onReady() {
        if (window.lightGallery) {
            initGallery();
        } else {
            setTimeout(onReady, 100);
        }
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', onReady);
    } else {
        onReady();
    }
</script>

<script is:inline define:vars={{ totalPages }}>
	(() => {
		const pages = Array.from(document.querySelectorAll('#shuoshuo .memos-page'));
		const pagination = document.getElementById('shuoshuo-pagination');
		const pageLinks = Array.from(document.querySelectorAll('#shuoshuo-pagination a[data-page]'));

		if (!pagination || !pages.length || totalPages <= 1) {
			if (pagination) pagination.style.display = 'none';
			return;
		}

		const params = new URLSearchParams(window.location.search);
		const initialPage = Math.min(totalPages, Math.max(1, Number(params.get('page')) || 1));
		const clampPage = (page) => Math.min(totalPages, Math.max(1, page));

		function renderPage(page) {
			const currentPage = clampPage(page);

			pages.forEach((pageNode) => {
				const visible = Number(pageNode.dataset.page) === currentPage;
				pageNode.hidden = !visible;
			});

			pageLinks.forEach((link) => {
				const linkPage = Number(link.dataset.page);
				const active = linkPage === currentPage;
				link.classList.toggle('active', active);
				if (active) {
					link.setAttribute('aria-current', 'page');
				} else {
					link.removeAttribute('aria-current');
				}
			});

			params.set('page', String(currentPage));
			const nextUrl = `${window.location.pathname}?${params.toString()}${window.location.hash}`;
			window.history.replaceState({}, '', nextUrl);
            
            if (window.scrollY > 100) {
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }
		}

		renderPage(initialPage);

		pageLinks.forEach((link) => {
			link.addEventListener('click', (event) => {
				event.preventDefault();
				const targetPage = Number(link.dataset.page);
				if (!Number.isFinite(targetPage)) return;
				renderPage(targetPage);
			});
		});
	})();
</script>

