---
import type { CollectionEntry } from 'astro:content';
import MagazineShell from './MagazineShell.astro';
import { marked } from 'marked';
import LikeButton from '../components/LikeButton.astro';
import { INCLUDE_DRAFTS } from '../utils/drafts';
import { getAllGossips } from '../utils/gossips';

type Props = CollectionEntry<'page'>['data'] & {
	content?: string;
};

const { title } = Astro.props;

const gossips = await getAllGossips();

const pageSize = 10;
const totalPages = gossips.length > 0 ? Math.ceil(gossips.length / pageSize) : 0;

marked.setOptions({
	breaks: true,
	gfm: true,
});

function getDateParts(date: Date) {
	const options: Intl.DateTimeFormatOptions = { timeZone: 'Asia/Shanghai' };
	const day = new Intl.DateTimeFormat('en-US', { ...options, day: '2-digit' }).format(date);
	const monthNum = new Intl.DateTimeFormat('en-US', { ...options, month: '2-digit' }).format(date);
	const year = new Intl.DateTimeFormat('en-US', { ...options, year: 'numeric' }).format(date);
	const time = new Intl.DateTimeFormat('en-US', { ...options, hour: '2-digit', minute: '2-digit', hour12: false }).format(date);
	return { day, monthNum, year, time };
}

const memoItems = gossips.map((gossip: any, index) => {
	const { day, monthNum, year, time } = getDateParts(gossip.data.pubDate);
	return {
		gossip,
		index,
		page: Math.floor(index / pageSize) + 1,
		dateLabel: `${year}.${monthNum}.${day}`,
		monthLabel: `${year}.${monthNum}`,
		year,
		time,
		attachments: gossip._raw?.media_attachments || [],
	};
});

const pagedMemoPages = Array.from({ length: totalPages }, (_, pageIndex) => {
	const page = pageIndex + 1;
	return {
		page,
		items: memoItems.filter((item) => item.page === page),
	};
});

---

<link rel="stylesheet" href="/lightgallery/css/lightgallery.min.css" slot="head" />
<style is:global slot="head">
    .media-grid {
        display: grid;
        gap: 4px;
        margin-top: 8px;
        width: min(100%, 430px);
    }
    .media-item {
        display: block;
        border: 1px solid color-mix(in oklab, var(--gray-color) 14%, transparent);
        overflow: hidden;
        background: var(--code-background-color);
        cursor: zoom-in;
    }
    .media-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .grid-1 { grid-template-columns: 1fr; }
    .grid-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .grid-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .grid-4 { grid-template-columns: repeat(2, minmax(0, 1fr)); }

    .grid-1 .media-item {
        aspect-ratio: 16 / 10;
        max-height: 220px;
    }

    .grid-2 .media-item,
    .grid-3 .media-item,
    .grid-4 .media-item {
        aspect-ratio: 4 / 3;
        max-height: 140px;
    }

    @media (max-width: 600px) {
        .media-grid {
            gap: 3px;
            width: 100%;
        }
        .grid-3 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .grid-1 .media-item {
            max-height: 190px;
        }
        .grid-2 .media-item,
        .grid-3 .media-item,
        .grid-4 .media-item {
            max-height: 120px;
        }
    }
</style>


<MagazineShell title={title} description={title} className="memos-surface" showProfileCard={false}>
	<section class="memos-panel postcard-sheet" aria-labelledby="memos-title">
		<header class="memos-panel__header">
			<h1 id="memos-title" class="memos-panel__title">碎语</h1>
		</header>

		<div class="memos-layout">
			<div class="memos-feed-column">
			<div id='shuoshuo' class="memos-feed">
				{
					gossips.length === 0 ? (
						<div class='empty-state'>还没有碎语。</div>
					) : (
						pagedMemoPages.map(({ page, items }) => (
							<div class="memos-page" data-page={page}>
								<div class="memos-page-list" role="list">
									{items.map((item) => {
										const { gossip, attachments, dateLabel, time, index } = item;
										return (
											<article class='memo-item' data-index={index} role="listitem">
												<header class="memo-header">
													<div class="memo-header-top">
														<div class="memo-meta-line">
															<time class="memo-meta-time" datetime={gossip.data.pubDate.toISOString()}>
																{dateLabel} · {time}
															</time>
															{gossip.data.tag && <span class="memo-source">{gossip.data.tag}</span>}
															{INCLUDE_DRAFTS && gossip.data.draft && <span class="draft-indicator">draft</span>}
														</div>
														<div class="memo-actions">
															<LikeButton id={gossip.data.slug} type="gossip" />
														</div>
													</div>
												</header>

												<div class='memo-content markdown-body' set:html={marked.parse(gossip.body || '')} />

												{attachments.length > 0 && (
													<div class={`media-grid grid-${Math.min(attachments.length, 4)}`}>
														{attachments.slice(0, 4).map((media: any) => (
															<a href={media.url} class="media-item" data-src={media.url}  data-sub-html={media.description}>
																<img src={media.preview_url || media.url} alt={media.description || ""} loading="lazy" />
															</a>
														))}
													</div>
												)}
											</article>
										)
									})}
								</div>
							</div>
						))
					)
				}
			</div>

			{totalPages > 1 && (
				<nav class='pagination' id='shuoshuo-pagination' aria-label='Pagination'>
					<div class='pagination-pages'>
						{Array.from({ length: totalPages }, (_, index) => {
							const pageNumber = index + 1;
							return (
								<a class='page-link' href={`?page=${pageNumber}`} data-page={pageNumber}>
									{pageNumber}
								</a>
							);
						})}
					</div>
				</nav>
			)}
		</div>
	</div>
	</section>
</MagazineShell>

<script is:inline src="/lightgallery/js/lightgallery.min.js" defer></script>
<script is:inline>
    function initGallery() {
        if (!window.lightGallery) return;
        const grids = document.querySelectorAll('.media-grid');
        grids.forEach(grid => {
            window.lightGallery(grid, {
                selector: '.media-item',
                speed: 500,
                download: false
            });
        });
    }

    function onReady() {
        if (window.lightGallery) {
            initGallery();
        } else {
            setTimeout(onReady, 100);
        }
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', onReady);
    } else {
        onReady();
    }
</script>

<script is:inline define:vars={{ totalPages }}>
	(() => {
		const pages = Array.from(document.querySelectorAll('#shuoshuo .memos-page'));
		const pagination = document.getElementById('shuoshuo-pagination');
		const pageLinks = Array.from(document.querySelectorAll('#shuoshuo-pagination a[data-page]'));

		if (!pagination || !pages.length || totalPages <= 1) {
			if (pagination) pagination.style.display = 'none';
			return;
		}

		const params = new URLSearchParams(window.location.search);
		const initialPage = Math.min(totalPages, Math.max(1, Number(params.get('page')) || 1));
		const clampPage = (page) => Math.min(totalPages, Math.max(1, page));

		function renderPage(page) {
			const currentPage = clampPage(page);

			pages.forEach((pageNode) => {
				const visible = Number(pageNode.dataset.page) === currentPage;
				pageNode.hidden = !visible;
			});

			pageLinks.forEach((link) => {
				const linkPage = Number(link.dataset.page);
				const active = linkPage === currentPage;
				link.classList.toggle('active', active);
				if (active) {
					link.setAttribute('aria-current', 'page');
				} else {
					link.removeAttribute('aria-current');
				}
			});

			params.set('page', String(currentPage));
			const nextUrl = `${window.location.pathname}?${params.toString()}${window.location.hash}`;
			window.history.replaceState({}, '', nextUrl);
            
            if (window.scrollY > 100) {
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }
		}

		renderPage(initialPage);

		pageLinks.forEach((link) => {
			link.addEventListener('click', (event) => {
				event.preventDefault();
				const targetPage = Number(link.dataset.page);
				if (!Number.isFinite(targetPage)) return;
				renderPage(targetPage);
			});
		});
	})();
</script>


<style is:global>
	.memos-surface {
		--memos-section-gap: 0;
		--memo-inline-pad: 0.1rem;
		--memo-block-pad: clamp(0.85rem, 1.8vw, 1.05rem);
	}

	.memos-surface #shuoshuo {
		width: 100%;
		margin: 0;
	}

	.memos-panel {
		min-height: 0;
		max-width: var(--blog-content-max);
		padding: clamp(1rem, 2.2vw, 1.35rem);
	}

	.memos-panel > .memos-panel__header {
		display: block;
		margin-bottom: 0.85rem;
		padding: 0 0 0.65rem;
		border-bottom: 1px solid var(--sheet-edge);
	}

	.memos-panel__title {
		margin: 0;
		font-family: var(--display-font);
		font-size: clamp(1.25rem, 2.2vw, 1.45rem);
		font-weight: 600;
		letter-spacing: -0.015em;
		line-height: 1.2;
		color: var(--heading-color);
	}

	.memos-layout,
	.memos-feed-column,
	.memos-feed,
	.memos-page,
	.memos-page-list {
		width: 100%;
		min-width: 0;
	}

	.memos-feed-column,
	.memos-feed,
	.memos-page,
	.memos-page-list {
		display: flex;
		flex-direction: column;
		gap: var(--memos-section-gap);
	}

	.memos-page[hidden] {
		display: none;
	}

	.memo-item {
		position: relative;
		display: flex;
		flex-direction: column;
		min-width: 0;
		padding: var(--memo-block-pad) var(--memo-inline-pad);
		border: 0;
		border-bottom: 1px solid color-mix(in oklab, var(--paper-card-border-soft) 85%, transparent);
		border-radius: 0;
		background: transparent;
		box-shadow: none;
	}

	.memo-item:last-child {
		border-bottom: 0;
	}

	.memo-item::before {
		content: none;
	}

	.memo-header {
		display: flex;
		flex-direction: column;
		align-items: stretch;
		margin: 0 0 0.35rem;
		padding: 0;
		border: 0;
		line-height: 1.35;
	}

	.memos-surface .memo-header {
		margin: 0 0 0.35rem;
		padding: 0;
		border: 0;
	}

	.memo-header-top {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.65rem;
		width: 100%;
		min-width: 0;
	}

	.memo-meta-line {
		display: inline-flex;
		align-items: baseline;
		flex-wrap: wrap;
		gap: 0.35rem 0.5rem;
		min-width: 0;
	}

	.memo-source {
		color: var(--faint-color);
		font-family: var(--ui-font);
		font-size: 0.68rem;
		line-height: 1.2;
	}

	.memo-source::before {
		content: "·";
		margin-right: 0.35rem;
		color: var(--faint-color);
	}

	.memo-actions {
		display: inline-flex;
		align-items: center;
		justify-content: flex-end;
		flex-shrink: 0;
		opacity: 0.45;
		transition: opacity 0.2s ease;
	}

	.memo-item:hover .memo-actions,
	.memo-item:focus-within .memo-actions {
		opacity: 1;
	}

	.memo-meta-time {
		margin: 0;
		color: var(--gray-color);
		font-family: var(--code-font);
		font-size: 0.72rem;
		line-height: 1.28;
		font-variant-numeric: tabular-nums;
	}

	.memo-content {
		color: var(--text-color);
		font-size: 0.86rem;
		line-height: 1.62;
		letter-spacing: 0;
	}

	.memo-content :global(p) {
		margin: 0.26rem 0;
	}

	.memos-surface .memo-content p {
		margin: 0.24rem 0;
	}

	.memo-content :global(p:first-child) {
		margin-top: 0;
	}

	.memos-surface .memo-content p:first-child {
		margin-top: 0;
	}

	.memo-content :global(p:last-child) {
		margin-bottom: 0;
	}

	.memos-surface .memo-content p:last-child {
		margin-bottom: 0;
	}

	.memo-content :global(strong) {
		color: var(--heading-color);
		font-weight: var(--weight-medium);
	}

	.memo-content :global(a) {
		text-underline-offset: 0.14em;
		text-decoration-thickness: 0.05em;
	}

	.memo-content :global(img) {
		max-width: 100%;
		margin-top: 6px;
		border-radius: 3px;
		opacity: 0.92;
	}

	.memo-content :global(blockquote) {
		margin: 0.28rem 0;
		padding-left: 0.62rem;
		border-left: 1px solid color-mix(in oklab, var(--gray-color) 38%, transparent);
		color: var(--gray-color);
		font-size: 0.78rem;
		line-height: 1.48;
	}

	.draft-indicator {
		color: color-mix(in oklab, var(--color-warning) 74%, var(--text-color));
		font-family: var(--field-font);
		font-size: 0.65rem;
		line-height: 1.35;
		letter-spacing: 0.035em;
		text-transform: lowercase;
	}

	.empty-state {
		padding: 3rem 1rem;
		color: var(--gray-color);
		font-size: 0.84rem;
		text-align: center;
	}

	.pagination {
		display: flex;
		justify-content: flex-start;
		margin-top: 1.2rem;
	}

	.pagination-pages {
		display: flex;
		gap: 0.45rem;
		padding: 0;
		border: 0;
		border-radius: 0;
		background: transparent;
	}

	.pagination .page-link {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 1.4rem;
		height: 1.4rem;
		border: 0 !important;
		border-radius: 0;
		background: transparent !important;
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: 0.76rem;
		text-decoration: none;
	}

	.pagination .page-link.active {
		color: var(--heading-color);
		text-decoration: underline;
		text-underline-offset: 0.22em;
	}

	.pagination .page-link:focus-visible {
		outline: 2px solid var(--accent-color);
		outline-offset: 2px;
	}

	@media (max-width: 720px) {
		.memos-surface {
			--memo-inline-pad: 0.05rem;
			--memo-block-pad: 0.8rem;
		}

		.memo-actions {
			opacity: 0.72;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.memo-actions {
			transition: none;
		}
	}
</style>
