---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import Base from './Base.astro';
import { marked } from 'marked';
import { INCLUDE_DRAFTS, filterDrafts } from '../utils/drafts';
import fs from 'fs';
import path from 'path';

type Props = CollectionEntry<'page'>['data'] & {
	content?: string;
};

const { title } = Astro.props;

// 读取 Markdown 文件中的碎碎念
const fileGossips = filterDrafts(await getCollection('gossips'));

// 读取 Mastodon 数据
let mastodonGossips: any[] = [];
try {
	const mastodonDataPath = path.join(process.cwd(), 'src/data/mastodon.json');
	if (fs.existsSync(mastodonDataPath)) {
		const mastodonData = JSON.parse(fs.readFileSync(mastodonDataPath, 'utf-8'));
		mastodonGossips = mastodonData.map((status: any) => ({
			data: {
				pubDate: new Date(status.created_at),
				slug: `mastodon-${status.id}`,
				draft: false,
				tag: 'mastodon',
			},
			body: status.content_markdown,
			_raw: status, // 保留原始数据用于扩展
		}));
	}
} catch (error) {
	console.warn('Failed to load Mastodon data:', error);
}

// 合并两个数据源并按日期排序
const gossips = [...fileGossips, ...mastodonGossips].sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const pageSize = 10;
const totalPages = gossips.length > 0 ? Math.ceil(gossips.length / pageSize) : 0;

marked.setOptions({
	breaks: true,
	gfm: true,
});

// 解析日期，返回终端风格日期字段
function getDateParts(date: Date) {
    const options: Intl.DateTimeFormatOptions = { timeZone: 'Asia/Shanghai' };
    const day = new Intl.DateTimeFormat('en-US', { ...options, day: '2-digit' }).format(date);
    const monthNum = new Intl.DateTimeFormat('en-US', { ...options, month: '2-digit' }).format(date);
    const year = new Intl.DateTimeFormat('en-US', { ...options, year: 'numeric' }).format(date);
    const time = new Intl.DateTimeFormat('en-US', { ...options, hour: '2-digit', minute: '2-digit', hour12: false }).format(date);
    return { day, monthNum, year, time };
}
---

<link rel="stylesheet" href="/lightgallery/css/lightgallery.min.css" slot="head" />
<style is:global slot="head">
    .media-grid {
        display: grid;
        gap: 4px;
        margin-top: 8px;
        width: min(100%, 430px);
    }
    .media-item {
        display: block;
        border: 1px solid color-mix(in oklab, var(--gray-color) 14%, transparent);
        overflow: hidden;
        background: var(--code-background-color);
        cursor: zoom-in;
    }
    .media-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .grid-1 { grid-template-columns: 1fr; }
    .grid-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .grid-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .grid-4 { grid-template-columns: repeat(2, minmax(0, 1fr)); }

    .grid-1 .media-item {
        aspect-ratio: 16 / 10;
        max-height: 220px;
    }

    .grid-2 .media-item,
    .grid-3 .media-item,
    .grid-4 .media-item {
        aspect-ratio: 4 / 3;
        max-height: 140px;
    }

    @media (max-width: 600px) {
        .media-grid {
            gap: 3px;
            width: 100%;
        }
        .grid-3 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .grid-1 .media-item {
            max-height: 190px;
        }
        .grid-2 .media-item,
        .grid-3 .media-item,
        .grid-4 .media-item {
            max-height: 120px;
        }
    }
</style>

<Base title={title} description={title}>
	<div class='gossip-page terminal-shell'>
        <p></p>
        <h2>–</h2>
        <div class="terminal-head" aria-hidden="true">
            <span class="terminal-file">&gt; shuoshuo --stream</span>
            <span class="terminal-count">[{gossips.length}] entries</span>
        </div>

		<div id='shuoshuo' class="feed-container terminal-stream" role="list">
            {
                gossips.length === 0 ? (
                    <div class='empty-state'>暂无碎碎念</div>
                ) : (
                    gossips.map((gossip: any, index) => {
                        const { day, monthNum, year, time } = getDateParts(gossip.data.pubDate);
                        const dateStamp = `${year}-${monthNum}-${day}`;
                        const attachments = gossip._raw?.media_attachments || [];
                        return (
                            <article class='feed-item terminal-entry' data-index={index} role="listitem">
                                <div class='feed-card entry-panel'>
                                    <div class="entry-meta">
                                        <span class="entry-date">{dateStamp}</span>
                                        <span class='card-time'>{time}</span>
                                        {INCLUDE_DRAFTS && gossip.data.draft && <span class="draft-indicator">draft</span>}
                                    </div>
                                    <div class='card-body markdown-body' set:html={marked.parse(gossip.body || '')} />
                                    
                                    {attachments.length > 0 && (
                                        <div class={`media-grid grid-${Math.min(attachments.length, 4)}`}>
                                            {attachments.slice(0, 4).map((media: any) => (
                                                <a href={media.url} class="media-item" data-src={media.url}  data-sub-html={media.description}>
                                                    <img src={media.preview_url || media.url} alt={media.description || ""} loading="lazy" />
                                                </a>
                                            ))}
                                        </div>
                                    )}
                                </div>
                            </article>
                        )
                    })
                )
            }
		</div>
        
		{totalPages > 1 && (
			<nav class='pagination' id='shuoshuo-pagination' aria-label='分页'>
                <div class='pagination-pages'>
					{Array.from({ length: totalPages }, (_, index) => {
						const pageNumber = index + 1;
						return (
							<a class='page-link' href={`?page=${pageNumber}`} data-page={pageNumber}>
								{pageNumber}
							</a>
						);
					})}
				</div>
			</nav>
		)}
	</div>

    <script is:inline src="/lightgallery/js/lightgallery.min.js"></script>
    <script is:inline>
        // Init LightGallery
        function initGallery() {
            const grids = document.querySelectorAll('.media-grid');
            grids.forEach(grid => {
                if (window.lightGallery) {
                    window.lightGallery(grid, {
                        selector: '.media-item',
                        speed: 500,
                        download: false
                    });
                }
            });
        }
        
        // Init immediately if ready
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initGallery);
        } else {
            initGallery();
        }
    </script>
    
	<script is:inline define:vars={{ pageSize, totalPages }}>
		(() => {
			const items = Array.from(document.querySelectorAll('#shuoshuo .feed-item'));
			const pagination = document.getElementById('shuoshuo-pagination');
			const pageLinks = Array.from(document.querySelectorAll('#shuoshuo-pagination a[data-page]'));

			if (!pagination || !items.length || totalPages <= 1) {
				if (pagination) pagination.style.display = 'none';
				return;
			}

			const params = new URLSearchParams(window.location.search);
			const initialPage = Math.min(totalPages, Math.max(1, Number(params.get('page')) || 1));
			const clampPage = (page) => Math.min(totalPages, Math.max(1, page));

			function renderPage(page) {
				const currentPage = clampPage(page);
				const start = (currentPage - 1) * pageSize;
				const end = start + pageSize;

				items.forEach((item, index) => {
					const visible = index >= start && index < end;
					item.style.display = visible ? '' : 'none';
				});

				pageLinks.forEach((link) => {
					const linkPage = Number(link.dataset.page);
					link.classList.toggle('active', linkPage === currentPage);
				});

				params.set('page', String(currentPage));
				const nextUrl = `${window.location.pathname}?${params.toString()}${window.location.hash}`;
				window.history.replaceState({}, '', nextUrl);
                
                if (window.scrollY > 100) {
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                }
			}

			renderPage(initialPage);

			pageLinks.forEach((link) => {
				link.addEventListener('click', (event) => {
					event.preventDefault();
					const targetPage = Number(link.dataset.page);
					if (!Number.isFinite(targetPage)) return;
					renderPage(targetPage);
				});
			});
		})();
	</script>

	<style>
        .gossip-page {
            max-width: 700px;
            margin: 0 auto;
            padding-bottom: var(--space-lg);
        }

        .terminal-head {
            display: grid;
            grid-template-columns: 1fr auto;
            align-items: center;
            column-gap: var(--space-sm);
            margin-bottom: 6px;
            padding: 4px 0;
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
            font-size: 0.72rem;
            letter-spacing: 0.06em;
            color: var(--gray-color);
            border-bottom: 1px dashed color-mix(in oklab, var(--gray-color) 32%, transparent);
            text-transform: lowercase;
        }

        .terminal-file {
            color: color-mix(in oklab, var(--heading-color) 86%, var(--gray-color));
        }

        .terminal-count {
            opacity: 0.78;
        }

        .feed-container {
            display: grid;
            gap: var(--space-sm);
        }

        .feed-item {
            display: block;
            padding: 0;
        }

        .feed-card {
            padding: var(--space-sm) var(--space-md);
            margin: 0;
            border: 1px solid color-mix(in oklab, var(--gray-color) 10%, transparent);
            border-radius: 0;
            background: color-mix(in oklab, var(--content-bg) 82%, transparent);
            transition: border-color 0.2s, background-color 0.2s;
        }

        .feed-item:hover .feed-card {
            border-color: color-mix(in oklab, var(--gray-color) 16%, transparent);
            background: color-mix(in oklab, var(--content-bg) 88%, transparent);
        }

        .entry-meta {
            display: flex;
            align-items: center;
            gap: 0;
            margin-bottom: 7px;
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
            font-size: 0.66rem;
            line-height: 1.1;
            color: var(--gray-color);
            letter-spacing: 0.015em;
            font-variant-numeric: tabular-nums;
        }

        .entry-date {
            color: var(--heading-color);
            font-weight: 500;
            letter-spacing: 0.04em;
            min-width: 104px;
        }

        .entry-date::before { content: "["; opacity: 0.72; margin-right: 1px; }
        .entry-date::after { content: "]"; opacity: 0.72; margin-left: 1px; }

        .card-time {
            opacity: 0.86;
            min-width: 36px;
        }

        .draft-indicator {
            color: color-mix(in oklab, var(--color-warning) 74%, var(--text-color));
            font-size: 0.62rem;
            letter-spacing: 0.04em;
            text-transform: lowercase;
            margin-left: 7px;
        }

        .card-body {
            color: var(--text-color);
            font-size: 0.82rem;
            line-height: 1.42;
            letter-spacing: 0;
        }

        .card-body :global(p) {
            margin: 0.16rem 0;
        }

        .card-body :global(p:first-child) {
            margin-top: 0;
        }

        .card-body :global(p:last-child) {
            margin-bottom: 0;
        }

        .card-body :global(strong) {
            color: var(--heading-color);
            font-weight: 600;
        }

        .card-body :global(a) {
            text-underline-offset: 0.14em;
            text-decoration-thickness: 0.05em;
        }

        .card-body :global(img) {
            max-width: 100%;
            margin-top: 6px;
            opacity: 0.92;
        }

        .card-body :global(blockquote) {
            margin: 0.12rem 0;
            padding-left: 0.36rem;
            border-left: 1px solid color-mix(in oklab, var(--gray-color) 38%, transparent);
            color: var(--gray-color);
            font-size: 0.78rem;
            line-height: 1.36;
        }

		.pagination {
			display: flex;
			justify-content: center;
			margin-top: var(--space-sm);
		}

		.page-link {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			min-width: 30px;
            height: 30px;
			padding: 0 5px;
			margin: 0 1px;
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
            font-size: 0.72rem;
			color: var(--gray-color);
			text-decoration: none;
            border: 1px solid color-mix(in oklab, var(--gray-color) 18%, transparent);
            background: color-mix(in oklab, var(--content-bg) 78%, transparent);
		}

		.page-link:hover {
            color: var(--heading-color);
            border-color: color-mix(in oklab, var(--gray-color) 26%, transparent);
            background: color-mix(in oklab, var(--content-bg) 84%, transparent);
		}

		.page-link.active {
            color: var(--heading-color);
            border-color: color-mix(in oklab, var(--gray-color) 26%, transparent);
            background: transparent;
            position: relative;
        }

        .page-link.active::before {
            content: "[";
            margin-right: 1px;
        }

        .page-link.active::after {
            content: "]";
            margin-left: 1px;
		}

        .page-link:focus-visible {
            outline: 2px solid var(--accent-color);
            outline-offset: 1px;
        }

        @media (max-width: 720px) {
            .gossip-page {
                padding-bottom: var(--space-md);
            }

            .terminal-head {
                font-size: 0.64rem;
                margin-bottom: 4px;
            }

            .feed-item {
                padding: 0;
            }

            .feed-card {
                padding: var(--space-xs) var(--space-sm);
                border-radius: 0;
            }

            .card-body {
                font-size: 0.78rem;
                line-height: 1.34;
            }

            .entry-meta {
                margin-bottom: 4px;
                font-size: 0.62rem;
            }

            .entry-date {
                min-width: 86px;
            }

        }
	</style>
</Base>
