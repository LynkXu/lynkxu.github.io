---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SearchModal from '../components/SearchModal.astro';
import Background from '../components/Background.astro';
import type { ImageMetadata } from 'astro';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
    fullWidth?: boolean;
    hideHeader?: boolean;
    hideFooter?: boolean;
    useCard?: boolean; // 新增：是否使用卡片布局
    className?: string; // 新增：传递给卡片的 class
	readingSurface?: boolean;
	hideUtilities?: boolean;
	hideBackground?: boolean;
}

const {
	title,
	description,
	image,
	fullWidth = false,
	hideHeader = false,
	hideFooter = false,
	useCard = true,
	className = '',
	readingSurface = false,
	hideUtilities = false,
	hideBackground = false,
} = Astro.props;

const bodyClass = [
	fullWidth ? 'full-width' : '',
	readingSurface ? 'reading-surface' : '',
].filter(Boolean).join(' ');

const showBackground = !hideBackground && !readingSurface;
const showUtilities = !hideUtilities && !readingSurface;

---

<!doctype html>
<html lang='zh-CN'>
	<head>
		<BaseHead title={title} description={description} image={image} />
		<slot name='head' />
	</head>
	<body class={bodyClass}>
		{showBackground && <Background />}
        
        {
            useCard ? (
                <div class={`global-layout-card ${className}`}>
                    {!hideHeader && <Header />}
                    <main>
                        <slot />
                    </main>
                    {!hideFooter && <Footer />}
                </div>
            ) : readingSurface ? (
                <div class={className}>
                    <slot />
                </div>
            ) : (
                <div class={`global-layout-transparent ${className}`}>
                    {!hideHeader && <Header />}
                    <main>
                        <slot />
                    </main>
                    {!hideFooter && <Footer />}
                </div>
            )
        }
		
		<SearchModal />

		{showUtilities && <div class="utility-fab-cluster" role="group" aria-label="站点工具">
			<button
				id="search-fab"
				class="utility-fab search-fab"
				type="button"
				aria-label="搜索文章"
				aria-keyshortcuts="Meta+K Control+K"
				title="搜索 ⌘K"
			>
				<svg viewBox="0 0 24 24" width="18" height="18" focusable="false" aria-hidden="true">
					<path d="M10.5 3a7.5 7.5 0 0 1 5.93 12.1l3.74 3.73a1 1 0 0 1-1.42 1.42l-3.73-3.74A7.5 7.5 0 1 1 10.5 3Zm0 2a5.5 5.5 0 1 0 0 11 5.5 5.5 0 0 0 0-11Z"></path>
				</svg>
			</button>

			<button
				id="theme-toggle-fab"
				class="utility-fab theme-toggle-fab"
				type="button"
				aria-label="Toggle dark mode"
				aria-pressed="false"
			>
				<span class="theme-toggle-icon theme-toggle-icon--moon" aria-hidden="true">
					<svg viewBox="0 0 24 24" width="18" height="18" focusable="false" aria-hidden="true">
						<path d="M21 14.5a8.5 8.5 0 0 1-11.5-11A9 9 0 1 0 21 14.5Z"></path>
					</svg>
				</span>
				<span class="theme-toggle-icon theme-toggle-icon--sun" aria-hidden="true">
					<svg viewBox="0 0 24 24" width="18" height="18" focusable="false" aria-hidden="true">
						<path d="M12 18a6 6 0 1 0 0-12 6 6 0 0 0 0 12Zm0-16 1 2h-2l1-2Zm0 20-1-2h2l-1 2ZM2 13l2-1v2l-2-1Zm20-1 2 1-2 1v-2ZM4.22 19.78l1.42-1.42 1.41 1.41-1.41 1.42-1.42-1.41Zm14.14-14.14 1.42-1.42 1.41 1.41-1.41 1.42-1.42-1.41ZM4.22 4.22 5.64 5.64 4.22 7.05 2.81 5.64 4.22 4.22Zm14.14 14.14 1.42 1.42-1.42 1.41-1.41-1.41 1.41-1.42Z"></path>
					</svg>
				</span>
			</button>
		</div>}

		<script is:inline>
			(function () {
				function getPreferredTheme() {
					return window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
				}

				function getTheme() {
					var attr = document.documentElement.getAttribute('data-theme');
					if (attr === 'light' || attr === 'dark') return attr;
					try {
						var stored = localStorage.getItem('theme');
						if (stored === 'light' || stored === 'dark') return stored;
					} catch (e) {
						// ignore
					}
					return getPreferredTheme();
				}

				function updateFab() {
					var btn = document.getElementById('theme-toggle-fab');
					if (!btn) return;
					var theme = getTheme();
					var isDark = theme === 'dark';
					btn.setAttribute('aria-pressed', String(isDark));
					btn.setAttribute('aria-label', isDark ? 'Switch to light mode' : 'Switch to dark mode');
					btn.setAttribute('title', isDark ? 'Light mode' : 'Dark mode');
				}

				function setTheme(nextTheme) {
					document.documentElement.setAttribute('data-theme', nextTheme);
					document.documentElement.style.colorScheme = nextTheme;
					try {
						localStorage.setItem('theme', nextTheme);
					} catch (e) {
						// ignore
					}
					updateFab();
				}

				function initSearchFab() {
					var btn = document.getElementById('search-fab');
					if (!btn) return;
					btn.addEventListener('click', function () {
						if (window.openSearchModal) window.openSearchModal();
					});
				}

				function initFab() {
					var btn = document.getElementById('theme-toggle-fab');
					if (!btn) return;
					updateFab();
					btn.addEventListener('click', function () {
						var current = getTheme();
						setTheme(current === 'dark' ? 'light' : 'dark');
					});
				}

				function init() {
					initFab();
					initSearchFab();
				}

				if (document.readyState === 'loading') {
					document.addEventListener('DOMContentLoaded', init);
				} else {
					init();
				}
			})();
		</script>
	</body>
</html>
