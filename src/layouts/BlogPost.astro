---
import type { CollectionEntry } from 'astro:content';
import MagazineShell from './MagazineShell.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Toc from '../components/Toc.astro';
import NavButton from '../components/NavButton.astro';
import Changelog from '../components/Changelog.astro';
import LikeButton from '../components/LikeButton.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	postId?: string;
	showTOC?: boolean; // 是否显示目录，默认 true
	tocMinLevel?: number; // 目录最小层级，默认 2 (h2)
	tocMaxLevel?: number; // 目录最大层级，默认 3 (h3)
	readingTime?: number; // 阅读时间（分钟）
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	tags,
	categories,
	draft,
	changelog,
	postId,
	showTOC = true,
	tocMinLevel = 2,
	tocMaxLevel = 3,
	readingTime,
} = Astro.props;

const isDev = import.meta.env.DEV;
const primaryKind = categories?.[0] ?? tags?.[0] ?? 'essay';
const hasPostMeta = Boolean(updatedDate || (isDev && draft));
---

<MagazineShell title={title} description={description || ''} className="blog-post-layout" showProfileCard={false}>
	<!-- LightGallery CSS (本地) -->
	<link rel='stylesheet' href='/lightgallery/css/lightgallery.min.css' slot='head' />

	<style is:global>
		/* 文章结束标识 */
		.post-tail {
			display: flex;
			flex-direction: column;
			gap: clamp(1.25rem, 3vw, 1.5rem);
			margin: auto 0 clamp(0.5rem, 1.5vw, 0.75rem);
			padding-top: clamp(2rem, 4.5vw, 2.5rem);
		}

		.post-end {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 1rem;
			margin: 0;
			padding: 0.15rem 0 0;
		}

		.post-tail .changelog {
			margin: 0 !important;
		}

		.post-end-mark {
			display: flex;
			align-items: center;
			justify-content: center;
		}

		.post-end-text {
			flex-shrink: 0;
			color: var(--faint-color);
			font-family: var(--meta-font);
			font-size: 0.75rem;
			letter-spacing: 0.06em;
			text-transform: uppercase;
			white-space: nowrap;
		}

		/* Code Block Wrapper */
		.code-wrapper {
			position: relative;
			margin: var(--space-md) 0;
			border-radius: var(--paper-card-radius);
			background:
				linear-gradient(color-mix(in oklab, var(--rule-color) 9%, transparent) 1px, transparent 1px),
				color-mix(in oklab, var(--code-background-color) 54%, var(--paper-card-bg));
			background-size: 100% 1.65rem, auto;
			box-shadow: var(--paper-card-shadow);
			border: 1px solid var(--paper-card-border);
			overflow: hidden;
		}

		:root[data-theme="dark"] .code-wrapper {
			background: color-mix(in oklab, var(--code-background-color) 68%, var(--content-bg));
			border-color: color-mix(in oklab, var(--rule-color) 52%, transparent);
		}

		/* Header - Immersive Style */
		.code-header {
			position: absolute;
			top: 0;
			left: 0;
			width: 100%;
			height: 1.8rem;
			display: flex;
			align-items: center;
			justify-content: space-between;
			padding: 0 var(--space-md);
			background: transparent;
			z-index: 10;
			pointer-events: none;
		}

		.code-header > * {
			pointer-events: auto;
		}

		.mac-buttons {
			display: flex;
			gap: 6px;
		}

		.mac-button {
			width: 8px;
			height: 8px;
			border-radius: 0;
			background-color: var(--faint-color);
			opacity: 0.5;
		}

		.code-lang {
			font-size: 0.75rem;
			color: var(--faint-color);
			font-family: var(--code-font);
			text-transform: none;
			font-weight: var(--weight-medium);
			position: absolute;
			left: 50%;
			transform: translateX(-50%);
			user-select: none;
		}

		.blog-post-layout {
			--blog-shell-width: 1160px;
			--blog-shell-sidebar-width: 21rem;
		}

		.blog-main-column {
			display: flex;
			flex-direction: column;
			gap: clamp(var(--space-sm), 1.6vw, var(--space-md));
			min-width: 0;
		}

		.post-sidebar-stack {
			display: flex;
			flex-direction: column;
			gap: clamp(var(--space-md), 2vw, var(--space-lg));
		}

		.entry-sheet {
			--measure-readable: 72ch;
			--post-inline-padding: clamp(var(--space-md), 2vw, var(--space-lg));
			--post-rail-width: calc(var(--measure-readable) + var(--post-inline-padding) + var(--post-inline-padding));
			--post-content-width: var(--post-rail-width);
			display: flex;
			flex-direction: column;
			border: 1px solid var(--paper-card-border-soft);
			border-radius: var(--paper-card-radius);
			background: var(--paper-card-bg);
			box-shadow: var(--paper-card-shadow);
			overflow: hidden;
			margin-bottom: 0;
		}

		.post-header-card {
			--post-inline-padding: clamp(var(--space-md), 2vw, var(--space-lg));
			--post-rail-width: calc(72ch + var(--post-inline-padding) + var(--post-inline-padding));
			padding: clamp(1.1rem, 2.4vw, 1.45rem) 0;
			background: color-mix(in oklab, var(--paper-card-bg) 92%, var(--paper-field-bg));
			box-shadow: none;
		}

		.post-header {
			display: flex;
			flex-direction: column;
			margin: 0;
			padding: 0;
			border: none;
			border-radius: 0;
			background: transparent;
		}

		.post-flow {
			width: 100%;
			max-width: var(--post-rail-width);
			margin-left: auto;
			margin-right: auto;
			padding-left: var(--post-inline-padding);
			padding-right: var(--post-inline-padding);
		}

		.post-header-inner {
			display: flex;
			flex-direction: column;
			gap: 0.62rem;
		}

		.post-meta-bar {
			display: flex;
			flex-wrap: wrap;
			align-items: center;
			gap: 0.28rem;
			font-family: var(--field-font);
			font-size: 0.78rem;
			color: var(--gray-color);
			letter-spacing: 0.01em;
		}

		.post-meta-sep {
			color: var(--faint-color);
		}

		.post-kind {
			display: inline-flex;
			align-items: center;
			padding: 0.2em 0.55em;
			background: color-mix(in oklab, var(--accent-soft-bg) 55%, var(--paper-card-bg));
			border: 1px solid color-mix(in oklab, var(--accent-color) 10%, var(--paper-card-border-soft));
			border-radius: 3px;
			font-size: 0.72rem;
			font-weight: var(--weight-medium);
			color: color-mix(in oklab, var(--accent-color) 45%, var(--gray-color));
			letter-spacing: 0.01em;
			line-height: 1.3;
		}

		.post-header .post-title {
			margin: 0;
			font-family: var(--display-font);
			font-size: clamp(1.82rem, 3.5vw, 2.42rem);
			font-weight: var(--weight-display);
			line-height: 1.08;
			letter-spacing: 0;
			color: var(--heading-color);
		}

		.post-description {
			margin: 0;
			color: color-mix(in oklab, var(--gray-color) 58%, var(--text-color));
			font-family: var(--ui-font);
			font-size: 0.98rem;
			font-weight: var(--weight-medium);
			line-height: 1.68;
		}

		/* Copy Button */
		.copy-btn {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			background: transparent;
			border: none;
			color: var(--gray-color);
			cursor: pointer;
			padding: 4px;
			border-radius: 0;
			transition: all 0.2s;
			opacity: 0.0;
		}

		.code-wrapper:hover .copy-btn {
			opacity: 0.7;
		}

		.copy-btn:hover {
			background: rgba(0, 0, 0, 0.05);
			color: var(--text-color);
			opacity: 1 !important;
		}

		.copy-btn.copied {
			color: #4caf50;
			opacity: 1 !important;
		}

		:root[data-theme="dark"] .copy-btn:hover {
			background: rgba(255, 255, 255, 0.1);
		}

		.code-wrapper pre {
			margin: 0 !important;
			border-radius: 0 !important;
			padding: 1.8rem var(--space-md) var(--space-sm) var(--space-md) !important;
			background: transparent !important;
		}

		.blog-main-column .post-content {
			width: 100%;
			max-width: var(--post-rail-width);
			margin-left: auto;
			margin-right: auto;
			padding: clamp(1rem, 2.4vw, 1.25rem) var(--post-inline-padding) clamp(1.2rem, 3vw, 1.55rem);
		}

		.blog-main-column .post-content > :first-child {
			margin-top: 0;
		}

		.blog-main-column .post-content > :last-child {
			margin-bottom: 0;
		}

		.post-tail {
			position: relative;
			padding: clamp(1.8rem, 3.8vw, 2.35rem) 0 clamp(0.7rem, 1.4vw, 0.9rem);
			background: color-mix(in oklab, var(--content-bg) 74%, var(--paper-field-bg));
		}

		.post-tail::before {
			content: "";
			position: absolute;
			top: clamp(0.85rem, 1.8vw, 1.08rem);
			left: 50%;
			width: min(14rem, 36%);
			height: 1px;
			transform: translateX(-50%);
			background: linear-gradient(
				90deg,
				transparent 0%,
				color-mix(in oklab, var(--paper-card-border-soft) 72%, transparent) 50%,
				transparent 100%
			);
		}

		.post-tail-inner {
			display: flex;
			flex-direction: column;
			gap: clamp(1.35rem, 3.2vw, 1.75rem);
		}

		.post-tail-inner > .history-fold.changelog {
			margin-left: auto !important;
			margin-right: auto !important;
			width: min(100%, 28rem);
			box-shadow: none;
			background: color-mix(in oklab, var(--paper-card-bg) 94%, var(--paper-field-bg));
		}

		/* Sidebar cards */
		.sidebar-toc-card {
			max-height: calc(100vh - 9rem);
			overflow-y: auto;
		}

		/* 去掉 Toc 组件自带的卡片层，只保留 sidebar-toc-card 一层 */
		.sidebar-toc-card .toc-container {
			background: none !important;
			border: none !important;
			box-shadow: none !important;
			border-radius: 0 !important;
			padding: 0 !important;
		}

		.sidebar-toc-card .toc-header {
			margin: 0 0 1.1rem;
			color: var(--blog-section-label-color);
			font-family: var(--ui-font);
			font-size: 0.9rem;
			font-weight: var(--weight-medium);
			letter-spacing: 0.035em;
			line-height: 1.1;
			text-transform: uppercase;
		}

		.sidebar-toc-card .toc-header::after {
			content: "";
			display: block;
			width: 2.35rem;
			height: 1px;
			margin-top: 0.42rem;
			border-radius: 999px;
			background: currentColor;
		}

		.sidebar-toc-card .toc-list {
			list-style: none;
			margin: 0;
			padding: 0;
			display: flex;
			flex-direction: column;
			gap: 0.15rem;
		}

		.sidebar-toc-card .toc-list .toc-list {
			margin-left: 0.6rem;
			padding-left: 0.4rem;
			border-left: 1px solid var(--paper-card-border-soft);
			margin-top: 0.15rem;
			gap: 0.1rem;
		}

		.sidebar-toc-card .toc-link {
			display: block;
			padding: 0.2rem 0.35rem;
				font-family: var(--ui-font);
				font-size: 0.86rem;
				font-weight: var(--weight-medium);
				line-height: 1.45;
				color: color-mix(in oklab, var(--text-color) 84%, var(--gray-color));
			text-decoration: none;
			border-radius: 3px;
			transition: color 0.15s ease, background 0.15s ease;
			word-break: break-word;
		}

		.sidebar-toc-card .toc-link:hover {
			color: var(--heading-color);
			background: color-mix(in oklab, var(--accent-soft-bg) 45%, transparent);
		}

			.sidebar-toc-card .toc-link.active {
				color: color-mix(in oklab, var(--accent-color) 72%, var(--heading-color));
				font-weight: var(--weight-semibold);
				background: none;
			}

			@media (max-width: 1023px) {
				.sidebar-toc-card {
					display: none;
				}
			}

		@media (max-width: 720px) {
				.entry-sheet {
					--post-inline-padding: var(--space-md);
					border-radius: 0;
					border-left: none;
					border-right: none;
				}

				.post-header-card {
					--post-inline-padding: var(--space-md);
					border-right: 0;
					border-left: 0;
					border-radius: 0;
				}

			.post-header .post-title {
				max-width: var(--post-content-width);
			}
		}
	</style>

	<div slot="sidebar-extra" class="post-sidebar-stack">
		{showTOC && (
			<div class="magazine-rail-card sidebar-toc-card">
				<Toc minLevel={tocMinLevel} maxLevel={tocMaxLevel} title='On this page' />
			</div>
		)}
	</div>

	<div class="blog-main-column">
		<article class="post-header-card magazine-panel">
			<header class='post-header'>
				<div class="post-flow post-header-inner">
					<div class='post-meta-bar'>
						<span class='post-kind'>{primaryKind}</span>
						<span class='post-meta-sep'>·</span>
						<FormattedDate date={pubDate} />
						{readingTime && (
							<>
								<span class='post-meta-sep'>·</span>
								<span>{readingTime} min read</span>
							</>
						)}
						{hasPostMeta && (
							<>
								<span class='post-meta-sep'>·</span>
								{updatedDate && (
									<span>Updated <FormattedDate date={updatedDate} /></span>
								)}
								{isDev && draft && <span class="draft-badge" aria-label="Draft">Draft</span>}
							</>
						)}
					</div>

					<h1 class='post-title' transition:name={postId ? `post-title-${postId}` : undefined}>{title}</h1>

					{description && <p class='post-description'>{description}</p>}
				</div>
			</header>
		</article>

		<article class="entry-sheet">
			<!-- 主内容区 -->
			<div class='post-content content' id='lightgallery'>
				<slot />
			</div>

			<div class="post-tail">
				<div class="post-flow post-tail-inner">
					<!-- 文章结束标识和点赞 -->
					<div class='post-end' aria-hidden="true">
						<div class="post-end-mark">
							<span class="post-end-text">End of entry</span>
						</div>
						<LikeButton id={postId || Astro.url.pathname} type="post" />
					</div>

					{changelog && changelog.length > 0 && (
						<Changelog entries={changelog} />
					)}
				</div>
			</div>
		</article>

		<!-- 导航按钮 -->
		<NavButton showBackToTop={true} />
	</div>

	<!-- LightGallery JS (本地) -->
	<script is:inline src='/lightgallery/js/lightgallery.min.js' defer></script>

	<!-- 初始化 LightGallery -->
	<script is:inline>
		(function() {
			let lgInstance = null;
			let lgInitialized = false;

			function initLightGallery() {
				if (lgInitialized) return;
				lgInitialized = true;

				if (lgInstance) {
					try { lgInstance.destroy(true); } catch (e) {}
					lgInstance = null;
				}

				const postContent = document.querySelector('.post-content');
				if (postContent) {
					const images = postContent.querySelectorAll('img');
					images.forEach(function (img) {
						const src = img.src;
						if (img.parentElement.tagName === 'A') return;
						const link = document.createElement('a');
						link.href = src;
						link.className = 'no-link';
						link.setAttribute('data-sub-html', img.alt || '');
						img.parentNode.insertBefore(link, img);
						link.appendChild(img);
					});

					const container = document.getElementById('lightgallery');
					if (container && typeof window !== 'undefined' && 'lightGallery' in window) {
						lgInstance = window.lightGallery(container, {
							selector: 'a[href$=".jpg"], a[href$=".jpeg"], a[href$=".png"], a[href$=".gif"], a[href$=".webp"]',
							mode: 'lg-fade',
							cssEasing: 'ease',
							speed: 600,
							hideBarsDelay: 2000,
							controls: true,
							download: true,
							counter: true,
							thumbnail: true,
						});
					}
				}
			}

			function onReady() {
				if (typeof window.lightGallery === 'function') {
					initLightGallery();
				} else {
					// LightGallery not loaded yet, wait briefly
					setTimeout(onReady, 100);
				}
			}

			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', onReady);
			} else {
				onReady();
			}
			document.addEventListener('astro:page-load', onReady);
			document.addEventListener('astro:before-preparation', function () {
				lgInitialized = false;
				if (lgInstance) {
					try { lgInstance.destroy(true); } catch (e) {}
					lgInstance = null;
				}
			});
		})();
	</script>

	<script is:inline>
		(function() {
			function addCopyButtons() {
				const codeBlocks = document.querySelectorAll('pre:not(.code-block-added)');
				codeBlocks.forEach((block) => {
					block.classList.add('code-block-added');
					const wrapper = document.createElement('div');
					wrapper.className = 'code-wrapper';
					if (block.parentNode) {
						block.parentNode.insertBefore(wrapper, block);
						wrapper.appendChild(block);
					}
					const header = document.createElement('div');
					header.className = 'code-header';
					const macButtons = document.createElement('div');
					macButtons.className = 'mac-buttons';
					['close', 'minimize', 'maximize'].forEach(type => {
						const btn = document.createElement('div');
						btn.className = `mac-button ${type}`;
						macButtons.appendChild(btn);
					});
					const code = block.querySelector('code');
					let lang = '';
					if (block.dataset.language) {
						lang = block.dataset.language;
					} else if (code) {
						const classList = code.className.split(' ');
						const langClass = classList.find(c => c.startsWith('language-'));
						if (langClass) lang = langClass.replace('language-', '');
					}
					const langLabel = document.createElement('span');
					langLabel.className = 'code-lang';
					langLabel.textContent = lang;
					const copyBtn = document.createElement('button');
					copyBtn.className = 'copy-btn';
					copyBtn.setAttribute('aria-label', 'Copy');
					copyBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>';
					copyBtn.addEventListener('click', async () => {
						try {
							if (code) {
								const text = code.innerText;
								await navigator.clipboard.writeText(text);
								copyBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>';
								copyBtn.classList.add('copied');
								setTimeout(() => {
									copyBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>';
									copyBtn.classList.remove('copied');
								}, 2000);
							}
						} catch (err) {
							console.error('Copy failed:', err);
						}
					});
					header.appendChild(macButtons);
					header.appendChild(langLabel);
					header.appendChild(copyBtn);
					wrapper.insertBefore(header, block);
				});
			}

			function onReady() { addCopyButtons(); }
			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', onReady);
			} else { onReady(); }
			document.addEventListener('astro:page-load', onReady);
		})();
	</script>

		<script is:inline>
			(function () {
				// Skip if no link-card placeholders exist
				if (!document.querySelector('.post-content')) return;

				const LS_KEY = 'linkcard:cache';
				const REQUESTS_KEY = 'linkcard:requests';
				const RATE_WINDOW = 60000;
				const RATE_MAX = 10;
				const CACHE_TTL = 7 * 24 * 60 * 60 * 1000;

				function getRequests() {
					try {
						const raw = localStorage.getItem(REQUESTS_KEY);
						if (!raw) return [];
						const data = JSON.parse(raw);
						if (!Array.isArray(data)) return [];
						const now = Date.now();
						return data.filter(ts => now - ts < RATE_WINDOW);
					} catch (e) { return []; }
				}

				function pushRequest() {
					const reqs = getRequests();
					reqs.push(Date.now());
					try { localStorage.setItem(REQUESTS_KEY, JSON.stringify(reqs)); } catch (e) {}
					return reqs;
				}

				function canRequest() { return getRequests().length < RATE_MAX; }

				function getCache(url) {
					try {
						const raw = localStorage.getItem(LS_KEY);
						if (!raw) return null;
						const cache = JSON.parse(raw);
						if (!cache || typeof cache !== 'object') return null;
						const entry = cache[url];
						if (!entry) return null;
						if (Date.now() - (entry._ts || 0) > CACHE_TTL) return null;
						return entry;
					} catch (e) { return null; }
				}

				function setCache(url, data) {
					try {
						const raw = localStorage.getItem(LS_KEY);
						const cache = raw ? JSON.parse(raw) : {};
						cache[url] = { ...data, _ts: Date.now() };
						localStorage.setItem(LS_KEY, JSON.stringify(cache));
					} catch (e) {}
				}

				async function fetchMeta(url) {
					const cached = getCache(url);
					if (cached) return cached;
					if (!canRequest()) return null;
					pushRequest();

					try {
						const controller = new AbortController();
						const timeout = setTimeout(() => controller.abort(), 5000);
						const res = await fetch(
							`https://api.microlink.io/?url=${encodeURIComponent(url)}`,
							{ signal: controller.signal }
						);
						clearTimeout(timeout);
						if (!res.ok) return null;
						const json = await res.json();
						if (!json.data) return null;
						const { title, description, image, logo } = json.data;
						const result = {
							title: title || '',
							description: description || '',
							image: image?.url || '',
							logo: logo?.url || '',
						};
						setCache(url, result);
						return result;
					} catch (e) { return null; }
				}

				function renderCard(el, url, meta) {
					const style = el.dataset.style || 'default';
					const hostname = (() => { try { return new URL(url).hostname; } catch (e) { return url; } })();

					if (!meta || !meta.title) return;

					let html = `<a href="${url}" target="_blank" rel="noopener noreferrer" class="link-card__content">`;

					if (style === 'cover' && meta.image) {
						html += `<div class="link-card__image-wrapper"><img src="${meta.image}" alt="" loading="lazy" decoding="async" onerror="this.style.display='none'" /></div>`;
					} else if (style !== 'minimal' && meta.image) {
						html += `<div class="link-card__image-wrapper"><img src="${meta.image}" alt="" loading="lazy" decoding="async" onerror="this.style.display='none'" /></div>`;
					}

					html += `<div class="link-card__body"><h3>${meta.title}</h3>`;
					if (meta.description && style !== 'minimal') {
						html += `<p>${meta.description}</p>`;
					}
					html += `<span class="link-card__host">${hostname}</span></div></a>`;
					el.innerHTML = html;
					el.classList.add('link-card--ready');
				}

				function scanAndConvert() {
					const contentEl = document.querySelector('.post-content');
					if (!contentEl) return;
					const paragraphs = contentEl.querySelectorAll('p');
					paragraphs.forEach(p => {
						const text = p.textContent.trim();
						const match = text.match(/^::link-card\{url="([^"]+)"(?:\s*,\s*style="([^"]+)")?\}$/);
						if (match) {
							const url = match[1];
							const style = match[2] || '';
							const styleClass = style ? `link-card--${style}` : '';
							p.outerHTML = '<div class="link-card ' + styleClass + '" data-url="' + url + '"' + (style ? ' data-style="' + style + '"' : '') + '><a href="' + url + '" target="_blank" rel="noopener noreferrer" class="link-card__fallback">' + url + '</a></div>';
						}
					});
				}

				async function initCards() {
					scanAndConvert();
					const cards = document.querySelectorAll('.link-card[data-url]');
					if (cards.length === 0) return;
					for (const el of cards) {
						const url = el.getAttribute('data-url');
						if (!url) continue;
						const cached = getCache(url);
						if (cached && cached.title) {
							renderCard(el, url, cached);
							continue;
						}
						const meta = await fetchMeta(url);
						if (meta) renderCard(el, url, meta);
					}
				}

				if (document.readyState === 'loading') {
					document.addEventListener('DOMContentLoaded', initCards);
				} else { initCards(); }
				document.addEventListener('astro:page-load', initCards);
			})();
		</script>
