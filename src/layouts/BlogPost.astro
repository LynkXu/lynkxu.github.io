---
import type { CollectionEntry } from 'astro:content';
import ReadingShell from './ReadingShell.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Toc from '../components/Toc.astro';
import NavButton from '../components/NavButton.astro';
import Changelog from '../components/Changelog.astro';
import LikeButton from '../components/LikeButton.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	postId?: string;
	showTOC?: boolean;
	tocMinLevel?: number;
	tocMaxLevel?: number;
	readingTime?: number;
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	tags,
	categories,
	draft,
	changelog,
	postId,
	showTOC = true,
	tocMinLevel = 2,
	tocMaxLevel = 3,
	readingTime,
} = Astro.props;

const isDev = import.meta.env.DEV;
const topicLabels = tags?.length
	? tags
	: categories?.length
		? categories
		: [];
const topicLinksEnabled = Boolean(tags?.length);
---

<ReadingShell title={title} description={description || ''}>
	<link rel="stylesheet" href="/lightgallery/css/lightgallery.min.css" slot="head" />

	<article class="r-article">
		<header class="r-article__header">
			<h1 class="r-page-title" transition:name={postId ? `post-title-${postId}` : undefined}>{title}</h1>

			<div class="r-meta">
				<span><FormattedDate date={pubDate} /></span>
				{topicLabels.map((label) => (
					topicLinksEnabled ? (
						<a href={`/tags/${label}/`}>{label}</a>
					) : (
						<span>{label}</span>
					)
				))}
				{readingTime && <span>{readingTime} min</span>}
				{updatedDate && (
					<span>更新于 <FormattedDate date={updatedDate} /></span>
				)}
				{isDev && draft && <span>草稿</span>}
			</div>

			{description && <p class="r-article__desc">{description}</p>}
		</header>

		{showTOC && (
			<details class="r-toc">
				<summary>目录</summary>
				<Toc minLevel={tocMinLevel} maxLevel={tocMaxLevel} title="本页目录" />
			</details>
		)}

		<div class="r-prose post-content content" id="lightgallery">
			<slot />
		</div>

		<footer class="r-article__tail">
			<div class="r-article__end" aria-hidden="true">·</div>
			<LikeButton id={postId || Astro.url.pathname} type="post" />
			{changelog && changelog.length > 0 && <Changelog entries={changelog} />}
		</footer>

		<NavButton showBackToTop={true} />
	</article>

	<style is:global>
		body.reading-surface .r-article__desc {
			margin: 0 0 var(--r-space-lg);
			color: var(--r-ink-soft);
			font-size: var(--r-text-sm);
			line-height: 1.65;
		}

		body.reading-surface .r-toc {
			margin: 0 0 var(--r-space-lg);
			font-family: var(--r-font-ui);
			font-size: var(--r-text-xs);
			color: var(--r-ink-soft);
		}

		body.reading-surface .r-toc summary {
			cursor: pointer;
			color: var(--r-ink-faint);
			list-style: none;
		}

		body.reading-surface .r-toc summary::-webkit-details-marker {
			display: none;
		}

		body.reading-surface .r-toc .toc-container {
			margin-top: 0.65rem;
			border: 0;
			background: transparent;
			box-shadow: none;
			padding: 0;
		}

		body.reading-surface .r-toc .toc-toggle {
			display: none;
		}

		body.reading-surface .r-toc .toc {
			display: block !important;
		}

		body.reading-surface .r-toc .toc a {
			color: var(--r-ink-soft);
			text-decoration: none;
			font-size: var(--r-text-xs);
			line-height: 1.55;
		}

		body.reading-surface .r-toc .toc a:hover {
			color: var(--r-ink);
		}

		body.reading-surface .r-article__tail {
			margin-top: var(--r-space-xl);
			padding-top: var(--r-space-lg);
			border-top: 1px solid var(--r-rule);
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: var(--r-space-md);
		}

		body.reading-surface .r-article__end {
			color: var(--r-ink-faint);
			letter-spacing: 0.2em;
		}

		body.reading-surface .code-wrapper {
			position: relative;
			margin: 1.25rem 0;
			border-radius: 4px;
			background: var(--r-code-bg);
			overflow: hidden;
		}

		body.reading-surface .code-header {
			position: absolute;
			top: 0;
			right: 0;
			display: flex;
			align-items: center;
			gap: 0.5rem;
			padding: 0.35rem 0.55rem;
			z-index: 2;
		}

		body.reading-surface .code-lang {
			font-family: var(--r-font-code);
			font-size: 0.7rem;
			color: var(--r-ink-faint);
		}

		body.reading-surface .copy-btn {
			background: transparent;
			border: 0;
			color: var(--r-ink-faint);
			cursor: pointer;
			padding: 2px;
			opacity: 0.55;
		}

		body.reading-surface .code-wrapper:hover .copy-btn,
		body.reading-surface .copy-btn:focus-visible {
			opacity: 1;
		}

		body.reading-surface .code-wrapper pre {
			margin: 0 !important;
			padding: 1.5rem 1rem 1rem !important;
			background: transparent !important;
			border-radius: 0 !important;
		}

		body.reading-surface .nav-buttons-group {
			position: fixed;
			right: 1rem;
			bottom: 1.25rem;
			z-index: 20;
		}

		body.reading-surface .nav-button {
			width: 2.25rem;
			height: 2.25rem;
			border-radius: 999px;
			border: 1px solid var(--r-rule);
			background: var(--r-bg);
			color: var(--r-ink-soft);
			display: inline-flex;
			align-items: center;
			justify-content: center;
			cursor: pointer;
			box-shadow: none;
		}

		body.reading-surface .nav-button:hover {
			color: var(--r-ink);
		}

		body.reading-surface .link-card {
			margin: 1.25rem 0;
			border: 1px solid var(--r-rule);
			border-radius: 4px;
			overflow: hidden;
		}

		body.reading-surface .link-card a {
			text-decoration: none;
			color: inherit;
		}

		body.reading-surface .link-card__body {
			padding: 0.85rem 1rem;
		}

		body.reading-surface .link-card__body h3 {
			margin: 0 0 0.35rem;
			font-size: 1rem;
		}

		body.reading-surface .link-card__body p {
			margin: 0 0 0.35rem;
			font-size: var(--r-text-sm);
			color: var(--r-ink-soft);
		}

		body.reading-surface .link-card__host {
			font-family: var(--r-font-ui);
			font-size: var(--r-text-xs);
			color: var(--r-ink-faint);
		}

		body.reading-surface .changelog {
			width: 100%;
			font-family: var(--r-font-ui);
			font-size: var(--r-text-xs);
			color: var(--r-ink-soft);
		}
	</style>

	<script is:inline src="/lightgallery/js/lightgallery.min.js" defer></script>

	<script is:inline>
		(function () {
			let lgInstance = null;
			let lgInitialized = false;

			function initLightGallery() {
				if (lgInitialized) return;
				lgInitialized = true;

				if (lgInstance) {
					try { lgInstance.destroy(true); } catch (e) {}
					lgInstance = null;
				}

				const postContent = document.querySelector('.post-content');
				if (postContent) {
					const images = postContent.querySelectorAll('img');
					images.forEach(function (img) {
						const src = img.src;
						if (img.parentElement.tagName === 'A') return;
						const link = document.createElement('a');
						link.href = src;
						link.className = 'no-link';
						link.setAttribute('data-sub-html', img.alt || '');
						img.parentNode.insertBefore(link, img);
						link.appendChild(img);
					});

					const container = document.getElementById('lightgallery');
					if (container && typeof window !== 'undefined' && 'lightGallery' in window) {
						lgInstance = window.lightGallery(container, {
							selector: 'a[href$=".jpg"], a[href$=".jpeg"], a[href$=".png"], a[href$=".gif"], a[href$=".webp"]',
							mode: 'lg-fade',
							cssEasing: 'ease',
							speed: 600,
							hideBarsDelay: 2000,
							controls: true,
							download: true,
							counter: true,
							thumbnail: true,
						});
					}
				}
			}

			function onReady() {
				if (typeof window.lightGallery === 'function') {
					initLightGallery();
				} else {
					setTimeout(onReady, 100);
				}
			}

			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', onReady);
			} else {
				onReady();
			}
			document.addEventListener('astro:page-load', onReady);
			document.addEventListener('astro:before-preparation', function () {
				lgInitialized = false;
				if (lgInstance) {
					try { lgInstance.destroy(true); } catch (e) {}
					lgInstance = null;
				}
			});
		})();
	</script>

	<script is:inline>
		(function () {
			function addCopyButtons() {
				const codeBlocks = document.querySelectorAll('pre:not(.code-block-added)');
				codeBlocks.forEach((block) => {
					block.classList.add('code-block-added');
					const wrapper = document.createElement('div');
					wrapper.className = 'code-wrapper';
					if (block.parentNode) {
						block.parentNode.insertBefore(wrapper, block);
						wrapper.appendChild(block);
					}
					const header = document.createElement('div');
					header.className = 'code-header';
					const code = block.querySelector('code');
					let lang = '';
					if (block.dataset.language) {
						lang = block.dataset.language;
					} else if (code) {
						const classList = code.className.split(' ');
						const langClass = classList.find((c) => c.startsWith('language-'));
						if (langClass) lang = langClass.replace('language-', '');
					}
					const langLabel = document.createElement('span');
					langLabel.className = 'code-lang';
					langLabel.textContent = lang;
					const copyBtn = document.createElement('button');
					copyBtn.className = 'copy-btn';
					copyBtn.setAttribute('aria-label', 'Copy');
					copyBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>';
					copyBtn.addEventListener('click', async () => {
						try {
							if (code) {
								const text = code.innerText;
								await navigator.clipboard.writeText(text);
								copyBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>';
								copyBtn.classList.add('copied');
								setTimeout(() => {
									copyBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>';
									copyBtn.classList.remove('copied');
								}, 2000);
							}
						} catch (err) {
							console.error('Copy failed:', err);
						}
					});
					header.appendChild(langLabel);
					header.appendChild(copyBtn);
					wrapper.insertBefore(header, block);
				});
			}

			function onReady() { addCopyButtons(); }
			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', onReady);
			} else { onReady(); }
			document.addEventListener('astro:page-load', onReady);
		})();
	</script>

	<script is:inline>
		(function () {
			if (!document.querySelector('.post-content')) return;

			const LS_KEY = 'linkcard:cache';
			const REQUESTS_KEY = 'linkcard:requests';
			const RATE_WINDOW = 60000;
			const RATE_MAX = 10;
			const CACHE_TTL = 7 * 24 * 60 * 60 * 1000;

			function getRequests() {
				try {
					const raw = localStorage.getItem(REQUESTS_KEY);
					if (!raw) return [];
					const data = JSON.parse(raw);
					if (!Array.isArray(data)) return [];
					const now = Date.now();
					return data.filter((ts) => now - ts < RATE_WINDOW);
				} catch (e) { return []; }
			}

			function pushRequest() {
				const reqs = getRequests();
				reqs.push(Date.now());
				try { localStorage.setItem(REQUESTS_KEY, JSON.stringify(reqs)); } catch (e) {}
				return reqs;
			}

			function canRequest() { return getRequests().length < RATE_MAX; }

			function getCache(url) {
				try {
					const raw = localStorage.getItem(LS_KEY);
					if (!raw) return null;
					const cache = JSON.parse(raw);
					if (!cache || typeof cache !== 'object') return null;
					const entry = cache[url];
					if (!entry) return null;
					if (Date.now() - (entry._ts || 0) > CACHE_TTL) return null;
					return entry;
				} catch (e) { return null; }
			}

			function setCache(url, data) {
				try {
					const raw = localStorage.getItem(LS_KEY);
					const cache = raw ? JSON.parse(raw) : {};
					cache[url] = { ...data, _ts: Date.now() };
					localStorage.setItem(LS_KEY, JSON.stringify(cache));
				} catch (e) {}
			}

			async function fetchMeta(url) {
				const cached = getCache(url);
				if (cached) return cached;
				if (!canRequest()) return null;
				pushRequest();

				try {
					const controller = new AbortController();
					const timeout = setTimeout(() => controller.abort(), 5000);
					const res = await fetch(
						`https://api.microlink.io/?url=${encodeURIComponent(url)}`,
						{ signal: controller.signal }
					);
					clearTimeout(timeout);
					if (!res.ok) return null;
					const json = await res.json();
					if (!json.data) return null;
					const { title, description, image } = json.data;
					const result = {
						title: title || '',
						description: description || '',
						image: image?.url || '',
					};
					setCache(url, result);
					return result;
				} catch (e) { return null; }
			}

			function renderCard(el, url, meta) {
				const style = el.dataset.style || 'default';
				const hostname = (() => { try { return new URL(url).hostname; } catch (e) { return url; } })();
				if (!meta || !meta.title) return;

				let html = `<a href="${url}" target="_blank" rel="noopener noreferrer" class="link-card__content">`;
				if (style === 'cover' && meta.image) {
					html += `<div class="link-card__image-wrapper"><img src="${meta.image}" alt="" loading="lazy" decoding="async" onerror="this.style.display='none'" /></div>`;
				} else if (style !== 'minimal' && meta.image) {
					html += `<div class="link-card__image-wrapper"><img src="${meta.image}" alt="" loading="lazy" decoding="async" onerror="this.style.display='none'" /></div>`;
				}
				html += `<div class="link-card__body"><h3>${meta.title}</h3>`;
				if (meta.description && style !== 'minimal') {
					html += `<p>${meta.description}</p>`;
				}
				html += `<span class="link-card__host">${hostname}</span></div></a>`;
				el.innerHTML = html;
				el.classList.add('link-card--ready');
			}

			function scanAndConvert() {
				const contentEl = document.querySelector('.post-content');
				if (!contentEl) return;
				const paragraphs = contentEl.querySelectorAll('p');
				paragraphs.forEach((p) => {
					const text = p.textContent.trim();
					const match = text.match(/^::link-card\{url="([^"]+)"(?:\s*,\s*style="([^"]+)")?\}$/);
					if (match) {
						const url = match[1];
						const style = match[2] || '';
						const styleClass = style ? `link-card--${style}` : '';
						p.outerHTML = '<div class="link-card ' + styleClass + '" data-url="' + url + '"' + (style ? ' data-style="' + style + '"' : '') + '><a href="' + url + '" target="_blank" rel="noopener noreferrer" class="link-card__fallback">' + url + '</a></div>';
					}
				});
			}

			async function initCards() {
				scanAndConvert();
				const cards = document.querySelectorAll('.link-card[data-url]');
				if (cards.length === 0) return;
				for (const el of cards) {
					const url = el.getAttribute('data-url');
					if (!url) continue;
					const cached = getCache(url);
					if (cached && cached.title) {
						renderCard(el, url, cached);
						continue;
					}
					const meta = await fetchMeta(url);
					if (meta) renderCard(el, url, meta);
				}
			}

			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', initCards);
			} else { initCards(); }
			document.addEventListener('astro:page-load', initCards);
		})();
	</script>
</ReadingShell>
