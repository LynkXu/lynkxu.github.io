---
import type { CollectionEntry } from 'astro:content';
import MagazineShell from './MagazineShell.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Toc from '../components/Toc.astro';
import NavButton from '../components/NavButton.astro';
import Changelog from '../components/Changelog.astro';
import LikeButton from '../components/LikeButton.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	postId?: string;
	showTOC?: boolean; // 是否显示目录，默认 true
	tocMinLevel?: number; // 目录最小层级，默认 2 (h2)
	tocMaxLevel?: number; // 目录最大层级，默认 3 (h3)
	readingTime?: number; // 阅读时间（分钟）
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	tags,
	categories,
	draft,
	changelog,
	postId,
	showTOC = true,
	tocMinLevel = 2,
	tocMaxLevel = 3,
	readingTime,
} = Astro.props;

const isDev = import.meta.env.DEV;
const topicLabels = tags?.length
	? tags
	: categories?.length
		? categories
		: ['essay'];
const topicLinksEnabled = Boolean(tags?.length);
const hasPostMeta = Boolean(updatedDate || (isDev && draft));
---

<MagazineShell title={title} description={description || ''} className="blog-post-layout" showProfileCard={false}>
	<!-- LightGallery CSS (本地) -->
	<link rel='stylesheet' href='/lightgallery/css/lightgallery.min.css' slot='head' />

	<style is:global>
		/* 文章结束标识 */
		.post-tail {
			display: flex;
			flex-direction: column;
			gap: clamp(1.25rem, 3vw, 1.5rem);
			margin: auto 0 clamp(0.5rem, 1.5vw, 0.75rem);
			padding-top: clamp(2rem, 4.5vw, 2.5rem);
		}

		.post-end {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 1rem;
			margin: 0;
			padding: 0.15rem 0 0;
		}

		.post-tail .changelog {
			margin: 0 !important;
		}

		.post-end-mark {
			display: flex;
			align-items: center;
			justify-content: center;
		}

		.post-end-text {
			flex-shrink: 0;
			color: var(--faint-color);
			font-family: var(--meta-font);
			font-size: 0.75rem;
			letter-spacing: 0.02em;
			white-space: nowrap;
		}

		/* Code Block: quiet inset panel */
		.code-wrapper {
			position: relative;
			margin: var(--space-md) 0;
			border-radius: calc(var(--paper-card-radius) - 4px);
			background: color-mix(in oklab, var(--code-background-color) 92%, var(--content-bg));
			border: 1px solid var(--paper-card-border-soft);
			box-shadow: inset 0 1px 0 color-mix(in oklab, var(--paper-card-border-soft) 55%, transparent);
			overflow: hidden;
		}

		:root[data-theme="dark"] .code-wrapper {
			background: color-mix(in oklab, var(--code-background-color) 78%, var(--content-bg));
			border-color: color-mix(in oklab, var(--rule-color) 48%, transparent);
		}

		.code-header {
			display: flex;
			align-items: center;
			justify-content: space-between;
			gap: 0.75rem;
			min-height: 1.75rem;
			padding: 0.35rem var(--space-md);
			border-bottom: 1px solid var(--paper-card-border-soft);
			background: color-mix(in oklab, var(--paper-field-bg) 55%, transparent);
		}

		.code-lang {
			font-size: 0.72rem;
			color: var(--faint-color);
			font-family: var(--code-font);
			font-weight: var(--weight-medium);
			letter-spacing: 0;
			text-transform: none;
			user-select: none;
		}

		.blog-main-column {
			display: flex;
			flex-direction: column;
			/* 标题到正文的主间距：无分割线时由单一 gap 承担，避免多层叠加发空 */
			gap: clamp(1.2rem, 2.7vw, 1.85rem);
			min-width: 0;
		}

		.post-sidebar-stack {
			display: flex;
			flex-direction: column;
			gap: clamp(var(--space-md), 2vw, var(--space-lg));
		}

		.entry-sheet {
			/* 与墨轨读区同宽，避免 70ch + 主栏 1fr 双重收窄 */
			--measure-readable: var(--blog-content-max, 44rem);
			--post-inline-padding: 0;
			--post-content-width: var(--measure-readable);
			display: flex;
			flex-direction: column;
			width: 100%;
			border: 0;
			border-radius: 0;
			background: transparent;
			box-shadow: none;
			overflow: visible;
			margin-bottom: 0;
		}

		.post-header-card {
			--post-inline-padding: clamp(var(--space-md), 2vw, var(--space-lg));
			padding: 0;
			border: 0;
			border-radius: 0;
			background: transparent;
			box-shadow: none;
			overflow: visible;
		}

		.post-header {
			display: flex;
			flex-direction: column;
			margin: 0;
			padding: 0;
			border: none;
			border-radius: 0;
			background: transparent;
		}

		.post-flow {
			width: 100%;
			max-width: none;
			margin-left: 0;
			margin-right: 0;
			padding-left: 0;
			padding-right: 0;
		}

		.post-header-inner {
			display: flex;
			flex-direction: column;
			/* 标题 → 元信息：稍紧，让元信息成为标题下的注解 */
			gap: 0.68rem;
		}

		.post-meta-bar {
			display: flex;
			flex-wrap: wrap;
			align-items: center;
			gap: 0.35rem;
			font-family: var(--ui-font);
			font-size: 0.74rem;
			font-weight: 500;
			color: var(--gray-color);
			letter-spacing: 0;
		}

		.post-meta-sep {
			color: var(--faint-color);
		}

		.post-kind-group {
			display: inline-flex;
			flex-wrap: wrap;
			align-items: center;
			column-gap: 0.28rem;
			row-gap: 0.12rem;
		}

		.post-kind-sep {
			color: var(--faint-color);
			font-weight: var(--weight-regular);
		}

		.post-kind {
			display: inline;
			padding: 0;
			background: none;
			border: 0;
			border-radius: 0;
			font-size: inherit;
			font-weight: 500;
			color: var(--gray-color);
			letter-spacing: 0;
			line-height: 1.3;
			text-decoration: none;
		}

		a.post-kind {
			color: var(--gray-color);
			transition: color 0.2s ease;
		}

		a.post-kind:hover,
		a.post-kind:focus-visible {
			color: var(--accent-color);
			border-bottom-color: transparent;
		}

		.post-header .post-title {
			margin: 0;
			font-family: var(--display-font);
			font-size: clamp(1.75rem, 3.4vw, 2.35rem);
			font-weight: 500;
			line-height: 1.18;
			letter-spacing: -0.02em;
			color: var(--heading-color);
			text-wrap: balance;
		}

		.post-description {
			margin: 0;
			max-width: 58ch;
			color: color-mix(in oklab, var(--gray-color) 78%, var(--faint-color));
			font-family: var(--reading-font);
			font-size: 0.95rem;
			font-weight: 400;
			line-height: 1.7;
			letter-spacing: 0.01em;
		}

		.copy-btn {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			background: transparent;
			border: none;
			color: var(--faint-color);
			cursor: pointer;
			padding: 2px;
			border-radius: 0;
			opacity: 0.65;
			transition: color 0.2s ease, opacity 0.2s ease;
		}

		.copy-btn:hover {
			color: var(--text-color);
			opacity: 1;
		}

		.copy-btn.copied {
			color: var(--accent-color);
			opacity: 1;
		}

		.code-wrapper pre {
			margin: 0 !important;
			border-radius: 0 !important;
			padding: var(--space-sm) var(--space-md) !important;
			background: transparent !important;
			font-size: 0.78rem;
			line-height: 1.56;
			overflow-x: auto;
		}

		.code-wrapper pre code {
			font-size: inherit;
			line-height: inherit;
		}

		.blog-post-layout .blog-main-column .post-content {
			--reader-inline-pad: 0;
			width: 100%;
			max-width: none;
			box-sizing: border-box;
			margin-left: 0;
			margin-right: 0;
			padding: 0 0 clamp(0.95rem, 2.4vw, 1.45rem);
			border: 0;
			background: transparent;
			color: var(--text-color);
			font-family: var(--reading-font);
			font-size: 0.98rem;
			font-weight: 400;
			line-height: 1.78;
			letter-spacing: 0.01em;
			overflow-wrap: break-word;
			text-wrap: pretty;
		}

		:root[data-theme="dark"] .blog-post-layout .blog-main-column .post-content {
			background: transparent;
			color: color-mix(in oklab, var(--text-color) 92%, var(--heading-color));
		}

		.blog-main-column .post-content > :first-child {
			margin-top: 0;
		}

		.blog-main-column .post-content > :last-child {
			margin-bottom: 0;
		}

		/* 覆盖 style.scss 中同选择器的间距，只在此处定义一次 */
		.blog-post-layout .blog-main-column .post-content > :where(h2, h3, h4) {
			margin-top: 1.75em;
			margin-bottom: 0.55em;
			font-family: var(--display-font);
			font-weight: 500;
			letter-spacing: -0.01em;
			color: var(--heading-color);
		}

		.blog-post-layout .blog-main-column .post-content > h2 {
			font-size: clamp(1.2rem, 1.7vw, 1.34rem);
			line-height: 1.28;
		}

		.blog-post-layout .blog-main-column .post-content > h3 {
			margin-top: 1.45em;
			font-size: clamp(1.06rem, 1.35vw, 1.16rem);
			line-height: 1.32;
			color: color-mix(in oklab, var(--heading-color) 92%, var(--gray-color));
		}

		.blog-post-layout .blog-main-column .post-content > h4 {
			margin-top: 1.25em;
			font-family: var(--ui-font);
			font-size: 0.95rem;
			font-weight: 500;
			line-height: 1.4;
			color: color-mix(in oklab, var(--heading-color) 86%, var(--gray-color));
		}

		.blog-post-layout .blog-main-column .post-content > :where(h2, h3, h4):first-child {
			margin-top: 0;
		}

		.blog-post-layout .blog-main-column .post-content > p {
			margin-top: 0;
			margin-bottom: 0.7em;
			font-weight: var(--weight-regular);
			letter-spacing: 0;
		}

		.blog-post-layout .blog-main-column .post-content > :where(ul, ol) {
			margin-top: 0.5em;
			margin-bottom: 0.7em;
			font-weight: var(--weight-regular);
		}

		.blog-post-layout .blog-main-column .post-content li + li {
			margin-top: 0.18em;
		}

		.post-tail {
			position: relative;
			padding: clamp(2.15rem, 5vw, 3.2rem) 0 0;
			background: transparent;
		}

		.post-tail::before {
			content: none;
		}

		.post-tail-inner {
			display: flex;
			flex-direction: column;
			gap: clamp(1.35rem, 3.2vw, 1.75rem);
		}

		.post-tail-inner > .history-fold.changelog {
			margin-left: auto !important;
			margin-right: auto !important;
			width: min(100%, 28rem);
			box-shadow: none;
			background: color-mix(in oklab, var(--paper-card-bg) 94%, var(--paper-field-bg));
		}

		.post-end {
			align-items: flex-start;
		}

		.post-end-text {
			color: color-mix(in oklab, var(--faint-color) 82%, transparent);
			font-size: 0.66rem;
			letter-spacing: 0.055em;
		}

		/* Sidebar cards */
		.sidebar-toc-card {
			max-height: calc(100vh - 4rem);
			overflow-y: auto;
		}

		/* 去掉 Toc 组件自带的卡片层，只保留 sidebar-toc-card 一层 */
		.sidebar-toc-card .toc-container {
			background: none !important;
			border: none !important;
			box-shadow: none !important;
			border-radius: 0 !important;
			padding: 0 !important;
		}

		.sidebar-toc-card .toc-toggle {
			display: flex;
			align-items: center;
			gap: 0.5rem;
			width: 100%;
			margin: 0 0 0.8rem;
			padding: 0;
			border: 0;
			background: transparent;
			color: var(--gray-color);
			font-family: var(--ui-font);
			font-size: 0.78rem;
			font-weight: 520;
			letter-spacing: 0;
			line-height: 1.3;
			text-transform: none;
			text-align: left;
			cursor: pointer;
			transition: color 0.15s ease;
		}

		.sidebar-toc-card .toc-toggle:hover,
		.sidebar-toc-card .toc-toggle:focus-visible {
			color: var(--heading-color);
		}

		.sidebar-toc-card .toc-toggle__count {
			flex: 1 1 auto;
			min-width: 0;
			color: var(--faint-color);
			font-weight: var(--weight-regular);
			font-variant-numeric: tabular-nums;
			overflow: hidden;
			text-overflow: ellipsis;
			white-space: nowrap;
		}

		.sidebar-toc-card .toc-toggle__chevron {
			flex: 0 0 auto;
			display: inline-block;
			opacity: 0.65;
			transition: transform 0.2s ease;
		}

		.sidebar-toc-card .toc-toggle__chevron::before {
			content: "⌄";
		}

		.sidebar-toc-card .toc-container[data-expanded="true"] .toc-toggle__chevron {
			transform: rotate(180deg);
		}

		/* 目录默认展开；标题栏仍可点击收起 */
		.sidebar-toc-card .toc {
			max-height: 60vh;
			opacity: 1;
			overflow-y: auto;
			pointer-events: auto;
			transition: max-height 0.28s ease, opacity 0.2s ease;
		}

		.sidebar-toc-card .toc-container:not([data-expanded="true"]) .toc {
			max-height: 0;
			opacity: 0;
			overflow: hidden;
			pointer-events: none;
		}

		@media (prefers-reduced-motion: reduce) {
			.sidebar-toc-card .toc,
			.sidebar-toc-card .toc-toggle__chevron {
				transition: none;
			}
		}

		.sidebar-toc-card .toc-list {
			list-style: none;
			margin: 0;
			padding: 0;
			display: flex;
			flex-direction: column;
			gap: 0.15rem;
		}

		.sidebar-toc-card .toc-list .toc-list {
			margin-left: 0.6rem;
			padding-left: 0.4rem;
			border-left: 1px solid var(--paper-card-border-soft);
			margin-top: 0.15rem;
			gap: 0.1rem;
		}

		.sidebar-toc-card .toc-link {
			display: block;
			padding: 0.28rem 0;
			font-family: var(--ui-font);
			font-size: 0.76rem;
			font-weight: 500;
			line-height: 1.45;
			color: var(--gray-color);
			text-decoration: none;
			border-radius: 0;
			border-left: 2px solid transparent;
			padding-left: 0.55rem;
			transition: color 0.15s ease, border-color 0.15s ease;
			word-break: break-word;
		}

		.sidebar-toc-card .toc-link:hover {
			color: var(--heading-color);
			background: transparent;
		}

		.sidebar-toc-card .toc-link.active {
			color: var(--heading-color);
			font-weight: 520;
			background: transparent;
			border-left-color: color-mix(in oklab, var(--accent-color) 55%, var(--paper-card-border));
		}

		:root[data-theme="dark"] .sidebar-toc-card .toc-link.active {
			color: var(--heading-color);
		}

			@media (max-width: 1023px) {
				.sidebar-toc-card {
					display: none;
				}
			}

		@media (max-width: 720px) {
				.entry-sheet {
					--post-inline-padding: var(--space-md);
					border-radius: 0;
					border-left: none;
					border-right: none;
				}

				.post-header-card {
					--post-inline-padding: var(--space-md);
					border-right: 0;
					border-left: 0;
					border-radius: 0;
				}

			.post-header .post-title {
				max-width: var(--post-content-width);
			}

			.blog-main-column {
				gap: clamp(1.05rem, 4.2vw, 1.45rem);
			}

			.blog-post-layout .blog-main-column .post-content {
				max-width: 100%;
				padding-inline: 0.66rem;
				font-size: var(--text-md);
				line-height: var(--lh-body);
			}
		}
	</style>

	<div slot="sidebar-extra" class="post-sidebar-stack">
		{showTOC && (
			<div class="magazine-rail-card sidebar-toc-card">
				<Toc minLevel={tocMinLevel} maxLevel={tocMaxLevel} title='本页目录' />
			</div>
		)}
	</div>

	<div class="blog-main-column">
		<article class="post-header-card magazine-panel">
			<header class='post-header'>
				<div class="post-flow post-header-inner">
					<h1 class='post-title' transition:name={postId ? `post-title-${postId}` : undefined}>{title}</h1>

					<div class='post-meta-bar'>
						<span class='post-kind-group'>
							{topicLabels.map((label, index) => (
								<>
									{index > 0 && <span class='post-kind-sep' aria-hidden='true'>/</span>}
									{topicLinksEnabled ? (
										<a class='post-kind' href={`/tags/${label}/`}>{label}</a>
									) : (
										<span class='post-kind'>{label}</span>
									)}
								</>
							))}
						</span>
						<span class='post-meta-sep'>·</span>
						<FormattedDate date={pubDate} />
						{readingTime && (
							<>
								<span class='post-meta-sep'>·</span>
								<span>{readingTime} 分钟</span>
							</>
						)}
						{hasPostMeta && (
							<>
								<span class='post-meta-sep'>·</span>
								{updatedDate && (
									<span>更新于 <FormattedDate date={updatedDate} /></span>
								)}
								{isDev && draft && <span class="draft-badge" aria-label="草稿">草稿</span>}
							</>
						)}
					</div>

					{description && <p class='post-description'>{description}</p>}
				</div>
			</header>
		</article>

		<article class="entry-sheet">
			<!-- 主内容区 -->
			<div class='post-content content' id='lightgallery'>
				<slot />
			</div>

			<div class="post-tail">
				<div class="post-flow post-tail-inner">
					<!-- 文章结束标识和点赞 -->
					<div class='post-end' aria-hidden="true">
						<div class="post-end-mark">
							<span class="post-end-text">全文完</span>
						</div>
						<LikeButton id={postId || Astro.url.pathname} type="post" />
					</div>

					{changelog && changelog.length > 0 && (
						<Changelog entries={changelog} />
					)}
				</div>
			</div>
		</article>

		<!-- 导航按钮 -->
		<NavButton showBackToTop={true} />
	</div>

	<!-- LightGallery JS (本地) -->
	<script is:inline src='/lightgallery/js/lightgallery.min.js' defer></script>

	<!-- 初始化 LightGallery -->
	<script is:inline>
		(function() {
			let lgInstance = null;
			let lgInitialized = false;

			function initLightGallery() {
				if (lgInitialized) return;
				lgInitialized = true;

				if (lgInstance) {
					try { lgInstance.destroy(true); } catch (e) {}
					lgInstance = null;
				}

				const postContent = document.querySelector('.post-content');
				if (postContent) {
					const images = postContent.querySelectorAll('img');
					images.forEach(function (img) {
						const src = img.src;
						if (img.parentElement.tagName === 'A') return;
						const link = document.createElement('a');
						link.href = src;
						link.className = 'no-link';
						link.setAttribute('data-sub-html', img.alt || '');
						img.parentNode.insertBefore(link, img);
						link.appendChild(img);
					});

					const container = document.getElementById('lightgallery');
					if (container && typeof window !== 'undefined' && 'lightGallery' in window) {
						lgInstance = window.lightGallery(container, {
							selector: 'a[href$=".jpg"], a[href$=".jpeg"], a[href$=".png"], a[href$=".gif"], a[href$=".webp"]',
							mode: 'lg-fade',
							cssEasing: 'ease',
							speed: 600,
							hideBarsDelay: 2000,
							controls: true,
							download: true,
							counter: true,
							thumbnail: true,
						});
					}
				}
			}

			function onReady() {
				if (typeof window.lightGallery === 'function') {
					initLightGallery();
				} else {
					// LightGallery not loaded yet, wait briefly
					setTimeout(onReady, 100);
				}
			}

			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', onReady);
			} else {
				onReady();
			}
			document.addEventListener('astro:page-load', onReady);
			document.addEventListener('astro:before-preparation', function () {
				lgInitialized = false;
				if (lgInstance) {
					try { lgInstance.destroy(true); } catch (e) {}
					lgInstance = null;
				}
			});
		})();
	</script>

	<script is:inline>
		(function() {
			function addCopyButtons() {
				const codeBlocks = document.querySelectorAll('pre:not(.code-block-added)');
				codeBlocks.forEach((block) => {
					block.classList.add('code-block-added');
					const wrapper = document.createElement('div');
					wrapper.className = 'code-wrapper';
					if (block.parentNode) {
						block.parentNode.insertBefore(wrapper, block);
						wrapper.appendChild(block);
					}
					const header = document.createElement('div');
					header.className = 'code-header';
					const code = block.querySelector('code');
					let lang = '';
					if (block.dataset.language) {
						lang = block.dataset.language;
					} else if (code) {
						const classList = code.className.split(' ');
						const langClass = classList.find(c => c.startsWith('language-'));
						if (langClass) lang = langClass.replace('language-', '');
					}
					const langLabel = document.createElement('span');
					langLabel.className = 'code-lang';
					langLabel.textContent = lang || 'code';
					const copyBtn = document.createElement('button');
					copyBtn.className = 'copy-btn';
					copyBtn.setAttribute('aria-label', 'Copy');
					copyBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>';
					copyBtn.addEventListener('click', async () => {
						try {
							if (code) {
								const text = code.innerText;
								await navigator.clipboard.writeText(text);
								copyBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>';
								copyBtn.classList.add('copied');
								setTimeout(() => {
									copyBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>';
									copyBtn.classList.remove('copied');
								}, 2000);
							}
						} catch (err) {
							console.error('Copy failed:', err);
						}
					});
					header.appendChild(langLabel);
					header.appendChild(copyBtn);
					wrapper.insertBefore(header, block);
				});
			}

			function onReady() { addCopyButtons(); }
			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', onReady);
			} else { onReady(); }
			document.addEventListener('astro:page-load', onReady);
		})();
	</script>

		<script is:inline>
			(function () {
				// Skip if no link-card placeholders exist
				if (!document.querySelector('.post-content')) return;

				const LS_KEY = 'linkcard:cache';
				const REQUESTS_KEY = 'linkcard:requests';
				const RATE_WINDOW = 60000;
				const RATE_MAX = 10;
				const CACHE_TTL = 7 * 24 * 60 * 60 * 1000;

				function getRequests() {
					try {
						const raw = localStorage.getItem(REQUESTS_KEY);
						if (!raw) return [];
						const data = JSON.parse(raw);
						if (!Array.isArray(data)) return [];
						const now = Date.now();
						return data.filter(ts => now - ts < RATE_WINDOW);
					} catch (e) { return []; }
				}

				function pushRequest() {
					const reqs = getRequests();
					reqs.push(Date.now());
					try { localStorage.setItem(REQUESTS_KEY, JSON.stringify(reqs)); } catch (e) {}
					return reqs;
				}

				function canRequest() { return getRequests().length < RATE_MAX; }

				function getCache(url) {
					try {
						const raw = localStorage.getItem(LS_KEY);
						if (!raw) return null;
						const cache = JSON.parse(raw);
						if (!cache || typeof cache !== 'object') return null;
						const entry = cache[url];
						if (!entry) return null;
						if (Date.now() - (entry._ts || 0) > CACHE_TTL) return null;
						return entry;
					} catch (e) { return null; }
				}

				function setCache(url, data) {
					try {
						const raw = localStorage.getItem(LS_KEY);
						const cache = raw ? JSON.parse(raw) : {};
						cache[url] = { ...data, _ts: Date.now() };
						localStorage.setItem(LS_KEY, JSON.stringify(cache));
					} catch (e) {}
				}

				async function fetchMeta(url) {
					const cached = getCache(url);
					if (cached) return cached;
					if (!canRequest()) return null;
					pushRequest();

					try {
						const controller = new AbortController();
						const timeout = setTimeout(() => controller.abort(), 5000);
						const res = await fetch(
							`https://api.microlink.io/?url=${encodeURIComponent(url)}`,
							{ signal: controller.signal }
						);
						clearTimeout(timeout);
						if (!res.ok) return null;
						const json = await res.json();
						if (!json.data) return null;
						const { title, description, image } = json.data;
						const result = {
							title: title || '',
							description: description || '',
							image: image?.url || '',
						};
						setCache(url, result);
						return result;
					} catch (e) { return null; }
				}

				function renderCard(el, url, meta) {
					const style = el.dataset.style || 'default';
					const hostname = (() => { try { return new URL(url).hostname; } catch (e) { return url; } })();

					if (!meta || !meta.title) return;

					let html = `<a href="${url}" target="_blank" rel="noopener noreferrer" class="link-card__content">`;

					if (style === 'cover' && meta.image) {
						html += `<div class="link-card__image-wrapper"><img src="${meta.image}" alt="" loading="lazy" decoding="async" onerror="this.style.display='none'" /></div>`;
					} else if (style !== 'minimal' && meta.image) {
						html += `<div class="link-card__image-wrapper"><img src="${meta.image}" alt="" loading="lazy" decoding="async" onerror="this.style.display='none'" /></div>`;
					}

					html += `<div class="link-card__body"><h3>${meta.title}</h3>`;
					if (meta.description && style !== 'minimal') {
						html += `<p>${meta.description}</p>`;
					}
					html += `<span class="link-card__host">${hostname}</span></div></a>`;
					el.innerHTML = html;
					el.classList.add('link-card--ready');
				}

				function scanAndConvert() {
					const contentEl = document.querySelector('.post-content');
					if (!contentEl) return;
					const paragraphs = contentEl.querySelectorAll('p');
					paragraphs.forEach(p => {
						const text = p.textContent.trim();
						const match = text.match(/^::link-card\{url="([^"]+)"(?:\s*,\s*style="([^"]+)")?\}$/);
						if (match) {
							const url = match[1];
							const style = match[2] || '';
							const styleClass = style ? `link-card--${style}` : '';
							p.outerHTML = '<div class="link-card ' + styleClass + '" data-url="' + url + '"' + (style ? ' data-style="' + style + '"' : '') + '><a href="' + url + '" target="_blank" rel="noopener noreferrer" class="link-card__fallback">' + url + '</a></div>';
						}
					});
				}

				async function initCards() {
					scanAndConvert();
					const cards = document.querySelectorAll('.link-card[data-url]');
					if (cards.length === 0) return;
					for (const el of cards) {
						const url = el.getAttribute('data-url');
						if (!url) continue;
						const cached = getCache(url);
						if (cached && cached.title) {
							renderCard(el, url, cached);
							continue;
						}
						const meta = await fetchMeta(url);
						if (meta) renderCard(el, url, meta);
					}
				}

				if (document.readyState === 'loading') {
					document.addEventListener('DOMContentLoaded', initCards);
				} else { initCards(); }
				document.addEventListener('astro:page-load', initCards);
			})();
		</script>
</MagazineShell>
