---
import type { CollectionEntry } from 'astro:content';
import MagazineShell from './MagazineShell.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Toc from '../components/Toc.astro';
import NavButton from '../components/NavButton.astro';
import Changelog from '../components/Changelog.astro';
import LikeButton from '../components/LikeButton.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	postId?: string;
	showTOC?: boolean; // 是否显示目录，默认 true
	tocMinLevel?: number; // 目录最小层级，默认 2 (h2)
	tocMaxLevel?: number; // 目录最大层级，默认 3 (h3)
	readingTime?: number; // 阅读时间（分钟）
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	tags,
	categories,
	draft,
	changelog,
	postId,
	showTOC = true,
	tocMinLevel = 2,
	tocMaxLevel = 3,
	readingTime,
} = Astro.props;

const isDev = import.meta.env.DEV;
const primaryKind = categories?.[0] ?? tags?.[0] ?? 'essay';
const hasPostMeta = Boolean(updatedDate || (isDev && draft));
---

<MagazineShell title={title} description={description || ''} className="blog-post-layout">
	<!-- LightGallery CSS (本地) -->
	<link rel='stylesheet' href='/lightgallery/css/lightgallery.min.css' slot='head' />

	<style is:global>
		/* 文章结束标识 */
		.post-tail {
			display: flex;
			flex-direction: column;
			gap: clamp(1.25rem, 3vw, 1.5rem);
			margin: auto 0 clamp(0.5rem, 1.5vw, 0.75rem);
			padding-top: clamp(2rem, 4.5vw, 2.5rem);
		}

		.post-end {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 1.25rem;
			margin: 0;
			padding: 0.6rem 0 0.2rem;
		}

		.post-tail .changelog {
			margin: 0 !important;
		}

		.post-end-mark {
			display: flex;
			align-items: center;
			gap: 0.75rem;
			width: 100%;
			max-width: 16rem;
		}

		.post-end-line {
			flex: 1;
			height: 1px;
			background: linear-gradient(
				90deg,
				transparent 0%,
				color-mix(in oklab, var(--paper-card-border-soft) 80%, transparent) 50%,
				transparent 100%
			);
		}

		.post-end-text {
			flex-shrink: 0;
			color: var(--gray-color);
			opacity: 0.5;
			font-family: var(--meta-font);
			font-size: 0.75rem;
			letter-spacing: 0.06em;
			text-transform: uppercase;
			white-space: nowrap;
		}

		/* Code Block Wrapper */
		.code-wrapper {
			position: relative;
			margin: var(--space-md) 0;
			border-radius: var(--paper-card-radius);
			background:
				linear-gradient(color-mix(in oklab, var(--rule-color) 9%, transparent) 1px, transparent 1px),
				color-mix(in oklab, var(--code-background-color) 54%, var(--paper-card-bg));
			background-size: 100% 1.65rem, auto;
			box-shadow: var(--paper-card-shadow);
			border: 1px solid var(--paper-card-border);
			overflow: hidden;
		}

		:root[data-theme="dark"] .code-wrapper {
			background: color-mix(in oklab, var(--code-background-color) 68%, var(--content-bg));
			border-color: color-mix(in oklab, var(--rule-color) 52%, transparent);
		}

		/* Header - Immersive Style */
		.code-header {
			position: absolute;
			top: 0;
			left: 0;
			width: 100%;
			height: 1.8rem;
			display: flex;
			align-items: center;
			justify-content: space-between;
			padding: 0 var(--space-md);
			background: transparent;
			z-index: 10;
			pointer-events: none;
		}

		.code-header > * {
			pointer-events: auto;
		}

		.mac-buttons {
			display: flex;
			gap: 6px;
		}

		.mac-button {
			width: 8px;
			height: 8px;
			border-radius: 0;
			background-color: var(--gray-color);
			opacity: 0.25;
		}

		.code-lang {
			font-size: 0.75rem;
			color: var(--gray-color);
			font-family: var(--field-font, "Lilex", ui-monospace, monospace);
			text-transform: none;
			font-weight: 500;
			position: absolute;
			left: 50%;
			transform: translateX(-50%);
			opacity: 0.42;
			user-select: none;
		}

		.entry-sheet {
			--measure-readable: 76ch;
			--post-inline-padding: clamp(0.8rem, 2.2vw, 1.05rem);
			--post-rail-width: calc(var(--measure-readable) + var(--post-inline-padding) + var(--post-inline-padding));
			--post-content-width: var(--post-rail-width);
			display: flex;
			flex-direction: column;
			border: 1px solid var(--paper-card-border-soft);
			border-radius: var(--paper-card-radius);
			background: var(--paper-card-bg);
			box-shadow: var(--paper-card-shadow);
			overflow: hidden;
			margin-bottom: 0;
		}

		.post-header {
			display: flex;
			flex-direction: column;
			margin: 0;
			padding: clamp(1.3rem, 3.2vw, 1.7rem) 0 clamp(1.1rem, 2.8vw, 1.4rem);
			border: none;
			border-bottom: 1px solid var(--paper-card-border-soft);
			border-radius: 0;
			background:
				linear-gradient(180deg, color-mix(in oklab, var(--accent-soft-bg) 22%, var(--paper-card-bg)) 0%, var(--paper-card-bg) 100%);
		}

		.post-flow {
			width: 100%;
			max-width: var(--post-rail-width);
			margin-left: auto;
			margin-right: auto;
			padding-left: var(--post-inline-padding);
			padding-right: var(--post-inline-padding);
		}

		.post-header-inner {
			display: flex;
			flex-direction: column;
			gap: 0.85rem;
		}

		.post-meta-bar {
			display: flex;
			flex-wrap: wrap;
			align-items: center;
			gap: 0.28rem;
			font-family: var(--field-font);
			font-size: 0.78rem;
			color: var(--gray-color);
			letter-spacing: 0.01em;
		}

		.post-meta-sep {
			opacity: 0.35;
		}

		.post-kind {
			display: inline-flex;
			align-items: center;
			padding: 0.2em 0.55em;
			background: color-mix(in oklab, var(--accent-soft-bg) 55%, var(--paper-card-bg));
			border: 1px solid color-mix(in oklab, var(--accent-color) 10%, var(--paper-card-border-soft));
			border-radius: 3px;
			font-size: 0.72rem;
			font-weight: 500;
			color: color-mix(in oklab, var(--accent-color) 45%, var(--gray-color));
			letter-spacing: 0.01em;
			line-height: 1.3;
		}

		.post-header .post-title {
			margin: 0;
			font-family: var(--serif-font);
			font-size: clamp(1.72rem, 3.6vw, 2.55rem);
			font-weight: 500;
			line-height: 1.14;
			letter-spacing: -0.022em;
			color: var(--panel-title-color);
		}

		.post-description {
			margin: 0;
			color: color-mix(in oklab, var(--gray-color) 72%, var(--text-color));
			font-size: 0.95rem;
			line-height: 1.72;
		}

		/* Copy Button */
		.copy-btn {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			background: transparent;
			border: none;
			color: var(--gray-color);
			cursor: pointer;
			padding: 4px;
			border-radius: 0;
			transition: all 0.2s;
			opacity: 0.0;
		}

		.code-wrapper:hover .copy-btn {
			opacity: 0.7;
		}

		.copy-btn:hover {
			background: rgba(0, 0, 0, 0.05);
			color: var(--text-color);
			opacity: 1 !important;
		}

		.copy-btn.copied {
			color: #4caf50;
			opacity: 1 !important;
		}

		:root[data-theme="dark"] .copy-btn:hover {
			background: rgba(255, 255, 255, 0.1);
		}

		.code-wrapper pre {
			margin: 0 !important;
			border-radius: 0 !important;
			padding: 1.8rem var(--space-md) var(--space-sm) var(--space-md) !important;
			background: transparent !important;
		}

		.blog-main-column .post-content {
			width: 100%;
			max-width: var(--post-rail-width);
			margin-left: auto;
			margin-right: auto;
			padding: clamp(1.2rem, 3vw, 1.55rem) var(--post-inline-padding) clamp(1.5rem, 3.5vw, 2rem);
		}

		.blog-main-column .post-content > :first-child {
			margin-top: 0;
		}

		.blog-main-column .post-content > :last-child {
			margin-bottom: 0;
		}

		.post-tail {
			position: relative;
			padding: clamp(1.7rem, 3.8vw, 2.1rem) 0 clamp(0.8rem, 1.6vw, 1rem);
			border-top: 1px solid color-mix(in oklab, var(--paper-card-border-soft) 72%, transparent);
			background: color-mix(in oklab, var(--content-bg) 74%, var(--paper-field-bg));
		}

		.post-tail-inner {
			display: flex;
			flex-direction: column;
			gap: clamp(1.25rem, 3vw, 1.5rem);
		}

		.post-tail-inner > .history-fold.changelog {
			margin-left: auto !important;
			margin-right: auto !important;
		}

		/* Sidebar TOC card */
		.sidebar-toc-card {
			margin-top: 0.85rem;
			padding: 0.85rem 0.75rem;
			border: 1px solid var(--paper-card-border-soft);
			border-radius: var(--paper-card-radius);
			background: var(--paper-card-bg);
			box-shadow: var(--paper-card-shadow);
			max-height: calc(100vh - 420px);
			overflow-y: auto;
			animation: fade-up 0.5s ease-out 0.15s both;
		}

		/* 去掉 Toc 组件自带的卡片层，只保留 sidebar-toc-card 一层 */
		.sidebar-toc-card .toc-container {
			background: none !important;
			border: none !important;
			box-shadow: none !important;
			border-radius: 0 !important;
			padding: 0 !important;
		}

		.sidebar-toc-card .toc-header {
			font-family: var(--serif-font);
			font-size: 0.78rem;
			font-weight: 500;
			color: var(--panel-title-color);
			margin-bottom: 0.5rem;
			padding-bottom: 0.4rem;
			border-bottom: 1px solid var(--paper-card-border-soft);
			letter-spacing: 0.02em;
		}

		.sidebar-toc-card .toc-list {
			list-style: none;
			margin: 0;
			padding: 0;
			display: flex;
			flex-direction: column;
			gap: 0.15rem;
		}

		.sidebar-toc-card .toc-list .toc-list {
			margin-left: 0.6rem;
			padding-left: 0.4rem;
			border-left: 1px solid color-mix(in oklab, var(--paper-card-border-soft) 60%, transparent);
			margin-top: 0.15rem;
			gap: 0.1rem;
		}

		.sidebar-toc-card .toc-link {
			display: block;
			padding: 0.2rem 0.35rem;
			font-size: 0.72rem;
			line-height: 1.45;
			color: color-mix(in oklab, var(--text-color) 72%, var(--gray-color));
			text-decoration: none;
			border-radius: 3px;
			transition: color 0.15s ease, background 0.15s ease;
			word-break: break-word;
		}

		.sidebar-toc-card .toc-link:hover {
			color: var(--heading-color);
			background: color-mix(in oklab, var(--accent-soft-bg) 45%, transparent);
		}

		.sidebar-toc-card .toc-link.active {
			color: var(--heading-color);
			font-weight: 500;
			background: color-mix(in oklab, var(--accent-soft-bg) 65%, transparent);
		}

		@media (max-width: 1023px) {
			.sidebar-toc-card {
				display: none;
			}
		}

		@media (max-width: 720px) {
			.entry-sheet {
				--post-inline-padding: 0.95rem;
				border-radius: 0;
				border-left: none;
				border-right: none;
			}

			.post-header .post-title {
				max-width: var(--post-content-width);
			}
		}
	</style>

	{showTOC && (
		<div slot="sidebar-extra" class="sidebar-toc-card">
			<Toc minLevel={tocMinLevel} maxLevel={tocMaxLevel} title='目录' />
		</div>
	)}

	<div class="blog-main-column">
		<article class="entry-sheet">
			<header class='post-header'>
				<div class="post-flow post-header-inner">
					<div class='post-meta-bar'>
						<span class='post-kind'>{primaryKind}</span>
						<span class='post-meta-sep'>·</span>
						<FormattedDate date={pubDate} />
						{readingTime && (
							<>
								<span class='post-meta-sep'>·</span>
								<span>{readingTime} min read</span>
							</>
						)}
						{hasPostMeta && (
							<>
								<span class='post-meta-sep'>·</span>
								{updatedDate && (
									<span>Updated <FormattedDate date={updatedDate} /></span>
								)}
								{isDev && draft && <span class="draft-badge" aria-label="Draft">Draft</span>}
							</>
						)}
					</div>

					<h1 class='post-title' transition:name={postId ? `post-title-${postId}` : undefined}>{title}</h1>

					{description && <p class='post-description'>{description}</p>}
				</div>
			</header>

			<!-- 主内容区 -->
			<div class='post-content content' id='lightgallery'>
				<slot />
			</div>

			<div class="post-tail">
				<div class="post-flow post-tail-inner">
					{changelog && changelog.length > 0 && (
						<Changelog entries={changelog} />
					)}

					<!-- 文章结束标识和点赞 -->
					<div class='post-end' aria-hidden="true">
						<div class="post-end-mark">
							<span class="post-end-line" aria-hidden="true"></span>
							<span class="post-end-text">End of entry</span>
							<span class="post-end-line" aria-hidden="true"></span>
						</div>
						<LikeButton id={postId || Astro.url.pathname} type="post" />
					</div>
				</div>
			</div>
		</article>

		<!-- 导航按钮 -->
		<NavButton showBackToTop={true} />
	</div>

	<!-- LightGallery JS (本地) -->
	<script is:inline src='/lightgallery/js/lightgallery.min.js'></script>

	<!-- 初始化 LightGallery -->
	<script is:inline>
		let lgInstance = null;

		function initLightGallery() {
			if (lgInstance) {
				try {
					lgInstance.destroy(true);
				} catch (e) {}
				lgInstance = null;
			}

			const postContent = document.querySelector('.post-content');
			if (postContent) {
				const images = postContent.querySelectorAll('img');
				images.forEach(function (img) {
					const src = img.src;
					if (img.parentElement.tagName === 'A') {
						return;
					}
					const link = document.createElement('a');
					link.href = src;
					link.className = 'no-link';
					link.setAttribute('data-sub-html', img.alt || '');
					img.parentNode.insertBefore(link, img);
					link.appendChild(img);
				});

			const container = document.getElementById('lightgallery');
			if (container && typeof window !== 'undefined' && 'lightGallery' in window) {
				// @ts-ignore
				lgInstance = window.lightGallery(container, {
						selector: 'a[href$=".jpg"], a[href$=".jpeg"], a[href$=".png"], a[href$=".gif"], a[href$=".webp"]',
						mode: 'lg-fade',
						cssEasing: 'ease',
						speed: 600,
						hideBarsDelay: 2000,
						controls: true,
						download: true,
						counter: true,
						thumbnail: true,
					});
				}
			}
		}

		document.addEventListener('DOMContentLoaded', initLightGallery);
		document.addEventListener('astro:page-load', initLightGallery);
		document.addEventListener('astro:before-preparation', function () {
			if (lgInstance) {
				try {
					lgInstance.destroy(true);
				} catch (e) {}
				lgInstance = null;
			}
		});
	</script>

	<script is:inline>
		function addCopyButtons() {
			const codeBlocks = document.querySelectorAll('pre:not(.code-block-added)');
			codeBlocks.forEach((block) => {
				block.classList.add('code-block-added');
				const wrapper = document.createElement('div');
				wrapper.className = 'code-wrapper';
				if (block.parentNode) {
					block.parentNode.insertBefore(wrapper, block);
					wrapper.appendChild(block);
				}
				const header = document.createElement('div');
				header.className = 'code-header';
				const macButtons = document.createElement('div');
				macButtons.className = 'mac-buttons';
				['close', 'minimize', 'maximize'].forEach(type => {
					const btn = document.createElement('div');
					btn.className = `mac-button ${type}`;
					macButtons.appendChild(btn);
				});
				const code = block.querySelector('code');
				let lang = '';
				if (block.dataset.language) {
					lang = block.dataset.language;
				} else if (code) {
					const classList = code.className.split(' ');
					const langClass = classList.find(c => c.startsWith('language-'));
					if (langClass) {
						lang = langClass.replace('language-', '');
					}
				}
				const langLabel = document.createElement('span');
				langLabel.className = 'code-lang';
				langLabel.textContent = lang;
				const copyBtn = document.createElement('button');
				copyBtn.className = 'copy-btn';
				copyBtn.setAttribute('aria-label', 'Copy');
				copyBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>';
				copyBtn.addEventListener('click', async () => {
					try {
						if (code) {
							const text = code.innerText;
							await navigator.clipboard.writeText(text);
							copyBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>';
							copyBtn.classList.add('copied');
							setTimeout(() => {
								copyBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>';
								copyBtn.classList.remove('copied');
							}, 2000);
						}
					} catch (err) {
						console.error('Copy failed:', err);
					}
				});
				header.appendChild(macButtons);
				header.appendChild(langLabel);
				header.appendChild(copyBtn);
				wrapper.insertBefore(header, block);
			});
		}

		window.addEventListener('DOMContentLoaded', function () {
			addCopyButtons();
		});
		document.addEventListener('astro:page-load', function () {
			addCopyButtons();
		});
	</script>
</MagazineShell>
