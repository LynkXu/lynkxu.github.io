---
import Base from './Base.astro';
import { getCollection } from 'astro:content';
import { filterDrafts } from '../utils/drafts';

interface Props {
	title: string;
	description: string;
	className?: string;
	showProfileCard?: boolean;
	shellLabel?: string;
}

const {
	title,
	description,
	className = '',
	showProfileCard = true,
	shellLabel = 'Blog',
} = Astro.props;

const currentPath = Astro.url.pathname;
const allPosts = filterDrafts(await getCollection('blog')).filter((post) => !post.id.startsWith('en/'));

const tagsMap = new Map<string, number>();
allPosts.forEach((post) => {
	(post.data.tags || []).forEach((tag) => {
		tagsMap.set(tag, (tagsMap.get(tag) || 0) + 1);
	});
});

const sortedTags = Array.from(tagsMap.entries()).sort((a, b) => b[1] - a[1]);

const navItems = [
	{ href: '/blog', label: 'Archive' },
	{ href: '/shuoshuo', label: 'Memos' },
	{ href: '/message', label: 'Leaves' },
	{ href: '/about', label: 'About' },
	{ href: '/index.xml', label: 'RSS' },
];

function isActive(href: string) {
	if (href === '/index.xml') return false;
	if (href === '/') return currentPath === '/';
	return currentPath === href || currentPath.startsWith(href + '/');
}

const hasSidebarExtra = Astro.slots.has('sidebar-extra');
const shouldRenderRail = showProfileCard || hasSidebarExtra;
---

<Base
	title={title}
	description={description}
	className={`blog-surface-layout ${className}`}
	hideHeader={true}
>
	<slot name="head" slot="head" />

	<header class="magazine-topbar">
		<a href="/" class="magazine-brand" aria-label="LynkXu / Blog">
			<span class="magazine-brand__name">LynkXu</span>
			<span class="magazine-brand__slash">/</span>
			<span class="magazine-brand__label">{shellLabel}</span>
		</a>

		<nav class="magazine-nav" aria-label="Primary navigation">
			{navItems.map((item) => (
				<a
					href={item.href}
					class:list={['magazine-nav__link', { active: isActive(item.href) }]}
					aria-current={isActive(item.href) ? 'page' : undefined}
				>
					{item.label}
				</a>
			))}
		</nav>

		<button
			class="magazine-search"
			type="button"
			aria-label="Search articles"
			onclick="window.openSearchModal && window.openSearchModal()"
		>
			<svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<circle cx="11" cy="11" r="7"></circle>
				<path d="m20 20-3.5-3.5"></path>
			</svg>
			<span>Search</span>
			<kbd>⌘K</kbd>
		</button>
	</header>

	<div class:list={['magazine-shell', { 'magazine-shell--no-rail': !shouldRenderRail }]}>
		<main class="magazine-main">
			<slot />
		</main>

		{shouldRenderRail && (
			<aside class="magazine-rail" aria-label="Page context">
				{showProfileCard && (
					<div class="profile-card">
						<a href="/" class="profile-avatar-link" aria-label="回到首页">
							<img src="/ava4.png" alt="" class="profile-avatar" loading="eager" width="72" height="72" />
						</a>
						<div class="profile-info">
							<h2 class="profile-name">LynkXu</h2>
							<p class="profile-bio">细节控 / APP 体验家 / Web3 爱好 / AI 依赖</p>
						</div>
						<div class="profile-stats" aria-label="Blog statistics">
							<div class="stat-item">
								<span class="stat-num">{allPosts.length}</span>
								<span class="stat-label">Entries</span>
							</div>
							<div class="stat-sep" aria-hidden="true">·</div>
							<div class="stat-item">
								<span class="stat-num">{sortedTags.length}</span>
								<span class="stat-label">Topics</span>
							</div>
							<div class="stat-sep" aria-hidden="true">·</div>
							<div class="stat-item">
								<span class="stat-num">2021</span>
								<span class="stat-label">Since</span>
							</div>
						</div>
					</div>
				)}
				<slot name="sidebar-extra" />
			</aside>
		)}
	</div>
</Base>

<style is:global>
	.blog-surface-layout {
		--blog-shell-width: 1160px;
		--blog-shell-sidebar-width: 18.5rem;
		--blog-shell-gap: clamp(1.35rem, 2.5vw, 2rem);
		--blog-card-gap: clamp(1.2rem, 2.4vw, 1.6rem);
		--blog-section-label-color: color-mix(in oklab, var(--accent-color) 78%, var(--heading-color));
		font-family: var(--ui-font);
	}

	.blog-surface-layout.global-layout-card {
		width: 100%;
		max-width: none;
		min-height: 100vh;
		margin: 0;
		padding: 0 0 var(--space-xl);
		border: 0;
		border-radius: 0;
		background: var(--page-bg);
		box-shadow: none;
	}

	.blog-surface-layout > main {
		width: 100%;
	}

	body:has(.blog-surface-layout) {
		overflow-x: clip;
	}

	.blog-surface-layout .sr-only {
		font-size: 0;
		line-height: 0;
	}

	.magazine-topbar {
		display: grid;
		grid-template-columns: minmax(12rem, 1fr) auto minmax(12rem, 1fr);
		align-items: center;
		gap: clamp(var(--space-md), 2vw, var(--space-xl));
		width: 100%;
		min-height: 4.9rem;
		margin: 0;
		padding: 0 clamp(var(--space-lg), 4.6vw, var(--space-3xl));
		border-bottom: 1px solid var(--paper-card-border-soft);
		background: color-mix(in oklab, var(--content-bg) 86%, var(--page-bg));
	}

	.global-layout-card .magazine-topbar {
		margin-bottom: 0;
	}

	.magazine-brand {
		display: inline-flex;
		align-items: baseline;
		gap: 0.28rem;
		justify-self: start;
		width: fit-content;
		border: 0 !important;
		background: none !important;
		color: var(--heading-color);
		font-family: var(--ui-font);
		font-size: clamp(1.22rem, 2vw, 1.5rem);
		font-weight: var(--weight-bold);
		letter-spacing: 0;
		line-height: 1;
		text-decoration: none;
	}

	.magazine-brand__name {
		color: color-mix(in oklab, var(--accent-color) 78%, var(--heading-color));
	}

	.magazine-brand__slash {
		color: color-mix(in oklab, var(--heading-color) 74%, var(--gray-color));
	}

	.magazine-brand__label {
		color: var(--heading-color);
	}

	.magazine-nav {
		display: flex;
		align-items: stretch;
		justify-content: center;
		gap: clamp(1.35rem, 3vw, 2.35rem);
		height: 100%;
	}

	.magazine-nav__link {
		position: relative;
		display: inline-flex;
		align-items: center;
		border: 0 !important;
		background: none !important;
		color: var(--heading-color);
		font-family: var(--ui-font);
		font-size: 0.92rem;
		font-weight: var(--weight-medium);
		line-height: 1;
		text-decoration: none;
		transition: color 0.18s ease;
	}

	.magazine-nav__link::before {
		content: none !important;
	}

	.magazine-nav__link::after {
		content: "";
		position: absolute;
		left: 0;
		right: 0;
		bottom: 0;
		height: 3px;
		border-radius: 999px 999px 0 0;
		background: var(--accent-color);
		opacity: 0;
		transform: scaleX(0.65);
		transition: opacity 0.18s ease, transform 0.18s ease;
	}

	.magazine-nav__link:hover,
	.magazine-nav__link.active {
		color: color-mix(in oklab, var(--accent-color) 55%, var(--heading-color));
	}

	.magazine-nav__link.active::after {
		opacity: 1;
		transform: scaleX(1);
	}

	.magazine-search {
		display: inline-flex;
		align-items: center;
		justify-self: end;
		gap: 0.55rem;
		min-width: 9.5rem;
		height: 2.35rem;
		padding: 0 0.9rem;
		border: 1px solid var(--paper-card-border-soft);
		border-radius: 999px;
		background: var(--paper-card-bg);
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: 0.88rem;
		line-height: 1;
		box-shadow: none;
		cursor: pointer;
		transition: border-color 0.18s ease, color 0.18s ease, background 0.18s ease;
	}

	.magazine-search:hover {
		border-color: var(--paper-hover-border);
		background: var(--paper-hover-bg);
		color: var(--heading-color);
	}

	.magazine-search svg {
		flex: 0 0 auto;
	}

	.magazine-search kbd {
		margin-left: auto;
		border: 0;
		background: transparent;
		color: var(--faint-color);
		font-family: var(--ui-font);
		font-size: 0.78rem;
	}

	.magazine-shell {
		display: grid;
		grid-template-columns: minmax(0, 1fr) var(--blog-shell-sidebar-width);
		gap: var(--blog-shell-gap);
		width: min(var(--blog-shell-width), calc(100% - 2 * var(--page-inline)));
		margin: 0 auto;
		padding: clamp(1.6rem, 3.6vw, 2.4rem) 0 clamp(2.8rem, 5vw, 4rem);
	}

	.magazine-shell--no-rail {
		grid-template-columns: minmax(0, 1fr);
	}

	.magazine-main {
		display: flex;
		flex-direction: column;
		gap: var(--blog-card-gap, var(--space-lg));
		min-width: 0;
	}

	.magazine-rail {
		position: sticky;
		top: var(--space-lg);
		display: flex;
		flex-direction: column;
		gap: clamp(var(--space-md), 2vw, var(--space-lg));
		align-self: start;
		min-width: 0;
	}

	.magazine-panel,
	.magazine-rail-card,
	.profile-card {
		border: 1px solid var(--paper-card-border-soft);
		border-radius: var(--paper-card-radius);
		background: var(--paper-card-bg);
		box-shadow: var(--paper-card-shadow);
	}

	.magazine-panel {
		padding: clamp(1.35rem, 2.8vw, 1.9rem);
	}

	.magazine-rail-card {
		padding: clamp(1.1rem, 2.1vw, 1.4rem);
	}

	.magazine-section-label {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.42rem;
		width: fit-content;
		margin: 0;
		color: var(--blog-section-label-color);
		font-family: var(--ui-font);
		font-size: 0.86rem;
		font-weight: var(--weight-bold);
		letter-spacing: 0.045em;
		line-height: 1.1;
		text-transform: uppercase;
	}

	.magazine-section-label::after {
		content: "";
		width: 2.75rem;
		height: 2px;
		border-radius: 999px;
		background: currentColor;
	}

	.magazine-muted {
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: 0.9rem;
		line-height: 1.65;
	}

	.magazine-chip {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 1.65rem;
		padding: 0.22rem 0.72rem;
		border: 0;
		border-radius: 5px;
		background: color-mix(in oklab, var(--accent-soft-bg) 54%, var(--paper-field-bg));
		color: color-mix(in oklab, var(--accent-color) 65%, var(--heading-color));
		font-family: var(--ui-font);
		font-size: 0.76rem;
		font-weight: var(--weight-semibold);
		line-height: 1;
		text-decoration: none;
	}

	.profile-card {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.9rem;
		padding: clamp(1.25rem, 2.4vw, 1.55rem);
		text-align: center;
	}

	.profile-avatar-link {
		display: block;
		border: 0 !important;
		background: none !important;
		line-height: 0;
		border-radius: 50%;
	}

	.profile-avatar-link:hover {
		transform: none;
	}

	.profile-avatar {
		width: 72px;
		height: 72px;
		border-radius: 50%;
		object-fit: cover;
		border: 2px solid color-mix(in oklab, var(--paper-card-border-soft) 60%, transparent);
		background: var(--paper-field-bg);
		transition: border-color 0.2s ease, transform 0.2s ease;
	}

	.profile-avatar-link:hover .profile-avatar {
		border-color: color-mix(in oklab, var(--accent-color) 30%, var(--paper-card-border-soft));
		transform: scale(1.04);
	}

	.profile-info {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
	}

	.profile-name {
		margin: 0;
		color: var(--heading-color);
		font-family: var(--ui-font);
		font-size: 1.2rem;
		font-weight: var(--weight-bold);
		line-height: 1.2;
	}

	.profile-bio {
		margin: 0;
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: 0.78rem;
		line-height: 1.55;
	}

	.profile-stats {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.36rem;
		width: 100%;
		padding-top: 0.8rem;
		border-top: 1px solid var(--paper-card-border-soft);
	}

	.stat-item {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.15rem;
	}

	.stat-num {
		color: color-mix(in oklab, var(--accent-color) 70%, var(--heading-color));
		font-family: var(--ui-font);
		font-size: 0.96rem;
		font-weight: var(--weight-bold);
		font-variant-numeric: tabular-nums;
		line-height: 1;
	}

	.stat-label {
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: 0.62rem;
		letter-spacing: 0.01em;
	}

	.stat-sep {
		color: var(--faint-color);
		font-size: 0.75rem;
	}

	@keyframes fade-up {
		from {
			opacity: 0;
			transform: translateY(12px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.magazine-main > *,
	.magazine-rail > * {
		animation: fade-up 0.48s ease-out both;
	}

	.magazine-rail > :nth-child(2) {
		animation-delay: 0.07s;
	}

	.magazine-rail > :nth-child(3) {
		animation-delay: 0.14s;
	}

	@media (max-width: 1023px) {
		.magazine-topbar {
			grid-template-columns: 1fr auto;
			row-gap: 0.85rem;
			min-height: 0;
			padding-top: 1rem;
			padding-bottom: 0.9rem;
		}

		.magazine-brand {
			grid-column: 1;
		}

		.magazine-search {
			grid-column: 2;
			min-width: 0;
		}

		.magazine-nav {
			grid-column: 1 / -1;
			justify-content: flex-start;
			gap: 1rem;
			height: auto;
			overflow-x: auto;
			padding-bottom: 0.1rem;
			flex-wrap: nowrap;
		}

		.magazine-nav__link {
			min-height: 2rem;
			flex: 0 0 auto;
			font-size: 0.84rem;
			white-space: nowrap;
		}

		.magazine-shell {
			grid-template-columns: 1fr;
			width: min(var(--content-width), calc(100% - 2 * var(--page-inline)));
		}

		.magazine-rail {
			position: static;
			order: 2;
		}

		.profile-card {
			flex-direction: row;
			align-items: center;
			text-align: left;
		}

		.profile-avatar {
			width: 56px;
			height: 56px;
		}

		.profile-info {
			flex: 1;
			min-width: 0;
		}

		.profile-stats {
			width: auto;
			padding-top: 0;
			border-top: 0;
		}
	}

	@media (max-width: 640px) {
		.magazine-topbar {
			padding-right: var(--page-inline);
			padding-left: var(--page-inline);
		}

		.magazine-search {
			width: 2.35rem;
			padding: 0;
			justify-content: center;
		}

		.magazine-search span,
		.magazine-search kbd {
			display: none;
		}

		.magazine-shell {
			width: 100%;
			padding-top: var(--space-lg);
		}

		.magazine-nav {
			gap: 0.78rem;
		}

		.magazine-nav__link {
			font-size: 0.72rem;
		}

		.magazine-panel,
		.magazine-rail-card {
			border-right: 0;
			border-left: 0;
			border-radius: 0;
		}

		.profile-card {
			margin: 0 var(--page-inline);
			flex-direction: column;
			text-align: center;
		}

		.profile-stats {
			justify-content: center;
			width: 100%;
			padding-top: 0.72rem;
			border-top: 1px solid var(--paper-card-border-soft);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.magazine-main > *,
		.magazine-rail > *,
		.profile-avatar {
			animation: none;
			transition: none;
		}
	}
</style>
