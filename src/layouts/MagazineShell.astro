---
import Base from './Base.astro';
import Footer from '../components/Footer.astro';
import { AVATAR_IMAGE } from '../consts';

interface Props {
	title: string;
	description: string;
	className?: string;
	showProfileCard?: boolean;
}

const {
	title,
	description,
	className = '',
	showProfileCard = false,
} = Astro.props;

const currentPath = Astro.url.pathname;

const navItems = [
	{ href: '/', label: '首页' },
	{ href: '/blog', label: '归档' },
	{ href: '/shuoshuo', label: '碎语' },
	{ href: '/message', label: '留言' },
	{ href: '/about', label: '关于' },
];

const secondaryNavItems = [
	{ href: '/photography', label: '摄影' },
	{ href: '/media', label: '书影音' },
	{ href: '/travel', label: '旅行' },
	{ href: '/sports', label: '运动' },
	{ href: '/tools', label: '工具' },
];

const socialItems = [
	{ href: 'https://github.com/LynkXu', label: 'GitHub' },
	{ href: 'https://x.com/lynk_xv', label: 'X' },
	{ href: 'https://www.instagram.com/link_xl', label: 'Instagram' },
];

function normalizePath(path: string) {
	return path.endsWith('/') && path !== '/' ? path.slice(0, -1) : path;
}

function isActive(href: string) {
	const current = normalizePath(currentPath);
	const target = normalizePath(href);
	if (target === '/') return current === '/';
	return current === target || current.startsWith(`${target}/`);
}

const hasSidebarExtra = Astro.slots.has('sidebar-extra');
const shouldRenderRail = showProfileCard || hasSidebarExtra;
---

<Base
	title={title}
	description={description}
	className={`blog-surface-layout ${className}`}
	hideHeader={true}
	hideFooter={true}
>
	<slot name="head" slot="head" />

	<div class="ledger-shell">
		<aside class="ledger-sidebar" aria-label="站点导航">
			<div class="ledger-sidebar__inner">
				<a href="/" class="ledger-brand" aria-label="LynkXu 首页">
					<img src={AVATAR_IMAGE.src} srcset={AVATAR_IMAGE.srcset} sizes="44px" alt="" class="ledger-brand__avatar" width="44" height="44" loading="eager" />
					<span class="ledger-brand__stack">
						<span class="ledger-brand__kicker">Personal notes</span>
						<span class="ledger-brand__name">LynkXu</span>
					</span>
				</a>

				<div class="ledger-nav-group ledger-nav-group--primary">
					<nav class="ledger-nav ledger-nav--primary" aria-label="主导航">
						{navItems.map((item) => (
							<a
								href={item.href}
								class:list={['ledger-nav__link', { active: isActive(item.href) }]}
								aria-current={isActive(item.href) ? 'page' : undefined}
							>
								<span class="ledger-nav__text">{item.label}</span>
							</a>
						))}
					</nav>
				</div>

				<button
					class="ledger-search"
					type="button"
					aria-label="搜索文章"
					aria-keyshortcuts="Meta+K Control+K"
					onclick="window.openSearchModal && window.openSearchModal()"
				>
					<span>搜索</span>
					<kbd>⌘K</kbd>
				</button>

				<details class="ledger-collections">
					<summary class="ledger-group-label ledger-collections__summary">
						<span>专题</span>
					</summary>
					<nav class="ledger-nav ledger-nav--secondary" aria-label="专题页面">
						{secondaryNavItems.map((item) => (
							<a
								href={item.href}
								class:list={['ledger-nav__link', { active: isActive(item.href) }]}
								aria-current={isActive(item.href) ? 'page' : undefined}
							>
								<span class="ledger-nav__text">{item.label}</span>
							</a>
						))}
					</nav>
				</details>

				<nav class="ledger-social" aria-label="社交与订阅链接">
					<span class="ledger-group-label">别处</span>
					<div class="ledger-social__links">
						{socialItems.map((item) => (
							<a href={item.href} target="_blank" rel="noopener noreferrer">
								{item.label}
							</a>
						))}
						<a href="/index.xml" class="ledger-rss">RSS</a>
					</div>
				</nav>
			</div>
		</aside>

		<main class="ledger-main">
			<slot />
			<Footer />
		</main>

		{/* 始终保留右栏占位，避免首页无侧栏时主栏被拉宽、切换页面时跳动 */}
		<aside class="ledger-context" aria-label="Page context" data-empty={!shouldRenderRail || undefined}>
			{showProfileCard && (
				<section class="ledger-context-card profile-card">
					<a href="/" class="profile-avatar-link" aria-label="回到首页">
						<img src={AVATAR_IMAGE.src} srcset={AVATAR_IMAGE.srcset} sizes="56px" alt="" class="profile-avatar" loading="eager" width="56" height="56" />
					</a>
					<div class="profile-info">
						<h2 class="profile-name">LynkXu</h2>
						<p class="profile-bio">个人笔记与长文。</p>
					</div>
				</section>
			)}
			<slot name="sidebar-extra" />
		</aside>
	</div>
</Base>

<style is:global>
	/*
	 * 方案 B′ · 墨轨 Ink Rail
	 * 保留两/三栏网格，但用「全高色墨侧轨 + 浅纸阅读席」彻底换气质。
	 * 刻意避开：灰阶 Notion、玻璃胶囊、铜光晕、奶油+陶土默认。
	 */
	html:has(.blog-surface-layout),
	.blog-surface-layout {
		/* Spectral 只扛大标题；正文用系统黑体，避免衬线在屏幕上发虚 */
		--display-font: "Spectral", "Songti SC", "Source Han Serif CN", "Noto Serif SC", "SimSun", serif;
		--serif-font: var(--display-font);
		--ui-font: "Sora", "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", "Noto Sans SC", sans-serif;
		--reading-font: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", "Noto Sans SC", "Sora", sans-serif;
		--meta-font: var(--ui-font);
		--field-font: var(--ui-font);

		/* 阅读席：冷雾纸，不是纯白 */
		--page-bg: oklch(0.955 0.014 230);
		--background-color: var(--page-bg);
		--content-bg: oklch(0.982 0.006 230);
		--desk-bg: var(--content-bg);

		/* 墨轨：深青墨，与主栏强对比 */
		--rail-bg: oklch(0.26 0.045 245);
		--rail-ink: oklch(0.93 0.012 230);
		--rail-muted: oklch(0.72 0.02 230);
		--rail-faint: oklch(0.58 0.018 230);
		--rail-line: oklch(0.93 0.012 230 / 0.14);
		--rail-active: oklch(0.82 0.09 175);

		--heading-color: oklch(0.21 0.026 245);
		--panel-title-color: oklch(0.27 0.022 245);
		--text-color: oklch(0.3 0.018 245);
		--gray-color: oklch(0.45 0.016 245);
		--faint-color: oklch(0.56 0.012 245);

		/* 强调：青绿铜锈，只用于链接与激活 */
		--accent-color: oklch(0.48 0.09 175);
		--link-color: oklch(0.42 0.085 175);
		--ink-accent: var(--accent-color);
		--ink-line: color-mix(in oklab, var(--accent-color) 30%, transparent);
		--ink-wash: color-mix(in oklab, var(--accent-color) 6%, var(--content-bg));
		--accent-soft-bg: color-mix(in oklab, var(--accent-color) 8%, var(--content-bg));
		--accent-soft-border: color-mix(in oklab, var(--accent-color) 24%, transparent);

		--rule-color: oklch(0.3 0.03 245 / 0.14);
		--paper-card-bg: var(--content-bg);
		--paper-card-bg-soft: color-mix(in oklab, var(--content-bg) 90%, var(--page-bg));
		--paper-card-border: oklch(0.3 0.03 245 / 0.12);
		--paper-card-border-soft: oklch(0.3 0.03 245 / 0.08);
		--paper-card-shadow: none;
		--paper-card-radius: 2px;
		--paper-field-bg: oklch(0.35 0.025 245 / 0.04);
		--paper-hover-bg: color-mix(in oklab, var(--accent-color) 7%, var(--content-bg));
		--paper-hover-border: color-mix(in oklab, var(--accent-color) 28%, transparent);
		--paper-accent-mark: var(--accent-color);
		--code-background-color: oklch(0.935 0.012 230);
		--selection-bg: color-mix(in oklab, var(--accent-color) 24%, white);
		--selection-color: oklch(0.2 0.03 245);

		--blog-shell-width: 1280px;
		/* 全屏墨轨：左轨作建筑立面，读区+右栏成组贴轨，右侧自然页边 */
		--blog-sidebar-width: 16rem;
		--blog-content-max: 44rem;
		--blog-context-width: 12.75rem;
		/* 左轨↔读区、读区↔右栏共用同一 gutter，2/3 栏对称 */
		--blog-shell-gap: clamp(var(--space-xl), 3vw, var(--space-2xl));
		--measure-readable: var(--blog-content-max);
	}

	.blog-surface-layout {
		font-family: var(--ui-font);
		isolation: isolate;
		font-synthesis: none;
		text-rendering: optimizeLegibility;
	}

	/* 浅底正文用亚像素抗锯齿更利；墨轨深底保持灰度抗锯齿 */
	.blog-surface-layout .ledger-main {
		-webkit-font-smoothing: auto;
		-moz-osx-font-smoothing: auto;
	}

	.blog-surface-layout .ledger-sidebar {
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
	}

	@media (prefers-color-scheme: dark) {
		:root:not([data-theme]):has(.blog-surface-layout),
		:root:not([data-theme]) .blog-surface-layout {
			--page-bg: oklch(0.16 0.02 245);
			--background-color: var(--page-bg);
			--content-bg: oklch(0.19 0.018 245);
			--desk-bg: var(--content-bg);
			--rail-bg: oklch(0.12 0.03 245);
			--rail-ink: oklch(0.92 0.014 90);
			--rail-muted: oklch(0.68 0.02 90);
			--rail-faint: oklch(0.52 0.016 90);
			--rail-line: oklch(0.92 0.014 90 / 0.12);
			--rail-active: oklch(0.78 0.1 175);
			--heading-color: oklch(0.94 0.014 90);
			--panel-title-color: oklch(0.88 0.012 90);
			--text-color: oklch(0.84 0.012 90);
			--gray-color: oklch(0.68 0.012 90);
			--faint-color: oklch(0.55 0.01 90);
			--accent-color: oklch(0.76 0.09 175);
			--link-color: oklch(0.8 0.08 175);
			--ink-accent: var(--accent-color);
			--ink-line: color-mix(in oklab, var(--accent-color) 34%, transparent);
			--ink-wash: color-mix(in oklab, var(--accent-color) 10%, var(--content-bg));
			--accent-soft-bg: color-mix(in oklab, var(--accent-color) 12%, var(--content-bg));
			--accent-soft-border: color-mix(in oklab, var(--accent-color) 28%, transparent);
			--rule-color: oklch(0.92 0.014 90 / 0.12);
			--paper-card-border: oklch(0.92 0.014 90 / 0.1);
			--paper-card-border-soft: oklch(0.92 0.014 90 / 0.07);
			--paper-field-bg: oklch(0.92 0.014 90 / 0.04);
			--paper-hover-bg: color-mix(in oklab, var(--accent-color) 10%, var(--content-bg));
			--code-background-color: oklch(0.15 0.018 245);
			--selection-bg: color-mix(in oklab, var(--accent-color) 30%, black);
			--selection-color: oklch(0.96 0.012 90);
		}
	}

	:root[data-theme="dark"]:has(.blog-surface-layout),
	:root[data-theme="dark"] .blog-surface-layout {
		--page-bg: oklch(0.16 0.02 245);
		--background-color: var(--page-bg);
		--content-bg: oklch(0.19 0.018 245);
		--desk-bg: var(--content-bg);
		--rail-bg: oklch(0.12 0.03 245);
		--rail-ink: oklch(0.92 0.014 90);
		--rail-muted: oklch(0.68 0.02 90);
		--rail-faint: oklch(0.52 0.016 90);
		--rail-line: oklch(0.92 0.014 90 / 0.12);
		--rail-active: oklch(0.78 0.1 175);
		--heading-color: oklch(0.94 0.014 90);
		--panel-title-color: oklch(0.88 0.012 90);
		--text-color: oklch(0.84 0.012 90);
		--gray-color: oklch(0.68 0.012 90);
		--faint-color: oklch(0.55 0.01 90);
		--accent-color: oklch(0.76 0.09 175);
		--link-color: oklch(0.8 0.08 175);
		--ink-accent: var(--accent-color);
		--ink-line: color-mix(in oklab, var(--accent-color) 34%, transparent);
		--ink-wash: color-mix(in oklab, var(--accent-color) 10%, var(--content-bg));
		--accent-soft-bg: color-mix(in oklab, var(--accent-color) 12%, var(--content-bg));
		--accent-soft-border: color-mix(in oklab, var(--accent-color) 28%, transparent);
		--rule-color: oklch(0.92 0.014 90 / 0.12);
		--paper-card-border: oklch(0.92 0.014 90 / 0.1);
		--paper-card-border-soft: oklch(0.92 0.014 90 / 0.07);
		--paper-field-bg: oklch(0.92 0.014 90 / 0.04);
		--paper-hover-bg: color-mix(in oklab, var(--accent-color) 10%, var(--content-bg));
		--code-background-color: oklch(0.15 0.018 245);
		--selection-bg: color-mix(in oklab, var(--accent-color) 30%, black);
		--selection-color: oklch(0.96 0.012 90);
	}

	.blog-surface-layout.global-layout-card {
		width: 100%;
		max-width: none;
		min-height: 100vh;
		margin: 0;
		padding: 0;
		border: 0;
		border-radius: 0;
		background: transparent;
		box-shadow: none;
	}

	body:has(.blog-surface-layout) {
		background: var(--page-bg);
		overflow-x: clip;
	}

	body:has(.blog-surface-layout)::before,
	body:has(.blog-surface-layout)::after {
		content: none;
	}

	body:has(.blog-surface-layout) #background-canvas {
		display: none;
	}

	.blog-surface-layout > main {
		width: 100%;
	}

	/* 桌面：墨轨 | 读区 | 右栏
	   不定居中、不拉 1fr 空列；右栏恒占位，余下视口即页边 */
	.ledger-shell {
		display: grid;
		grid-template-columns:
			var(--blog-sidebar-width)
			minmax(0, var(--blog-content-max))
			var(--blog-context-width);
		column-gap: var(--blog-shell-gap);
		row-gap: 0;
		width: 100%;
		max-width: none;
		margin: 0;
		padding: 0 clamp(1.25rem, 3vw, 2.5rem) 0 0;
		justify-content: start;
		min-height: 100vh;
	}

	.ledger-sidebar,
	.ledger-context {
		min-width: 0;
	}

	.ledger-sidebar {
		display: flex;
		flex-direction: column;
		align-self: stretch;
		background:
			linear-gradient(165deg, color-mix(in oklab, var(--rail-active) 14%, var(--rail-bg)), var(--rail-bg) 46%);
		color: var(--rail-ink);
	}

	.ledger-sidebar__inner {
		position: sticky;
		top: 0;
		display: flex;
		align-self: start;
		flex-direction: column;
		gap: 1.35rem;
		width: 100%;
		min-height: 100vh;
		padding: clamp(1.8rem, 4vw, 2.6rem) clamp(1.1rem, 2vw, 1.45rem) 2rem;
		border: 0;
		background: transparent;
		color: var(--rail-ink);
		box-sizing: border-box;
	}

	.ledger-brand {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.85rem;
		width: 100%;
		margin: 0;
		padding: 0 0 1.15rem;
		border: 0;
		border-bottom: 1px solid var(--rail-line) !important;
		background: none !important;
		color: var(--rail-ink);
		text-decoration: none;
	}

	.ledger-brand__avatar {
		width: 44px;
		height: 44px;
		border-radius: 4px;
		object-fit: cover;
		filter: saturate(0.92);
	}

	.ledger-brand__stack {
		display: flex;
		flex-direction: column;
		gap: 0.28rem;
	}

	.ledger-brand__kicker {
		color: var(--rail-faint);
		font-family: var(--ui-font);
		font-size: 0.68rem;
		font-weight: 500;
		letter-spacing: 0.08em;
		line-height: 1;
		text-transform: uppercase;
	}

	.ledger-brand__name {
		font-family: var(--display-font);
		font-size: 1.55rem;
		font-weight: 500;
		line-height: 1;
		letter-spacing: -0.02em;
	}

	.ledger-nav-group {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
	}

	.ledger-collections {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	.ledger-collections__summary {
		display: grid;
		grid-template-columns: auto auto;
		justify-content: start;
		align-items: center;
		gap: 0.45rem;
		width: fit-content;
		min-height: 1.8rem;
		color: var(--rail-faint);
		cursor: pointer;
		list-style: none;
		user-select: none;
	}

	.ledger-collections__summary::-webkit-details-marker {
		display: none;
	}

	.ledger-collections__summary::after {
		content: "+";
		color: var(--rail-faint);
		font-family: var(--ui-font);
		font-size: 0.75rem;
		line-height: 1;
	}

	.ledger-collections[open] .ledger-collections__summary::after {
		content: "–";
	}

	.ledger-collections__summary:hover {
		color: var(--rail-ink);
	}

	.ledger-group-label {
		color: var(--rail-faint);
		font-family: var(--ui-font);
		font-size: 0.68rem;
		font-weight: 500;
		letter-spacing: 0.06em;
		line-height: 1.2;
		text-transform: uppercase;
	}

	.ledger-nav {
		display: flex;
		flex-direction: column;
		gap: 0.1rem;
	}

	.ledger-nav__link {
		display: flex;
		align-items: baseline;
		gap: 0.55rem;
		min-height: 2rem;
		padding: 0.2rem 0;
		border: 0 !important;
		border-radius: 0;
		background: none !important;
		color: var(--rail-muted);
		font-size: 0.95rem;
		font-weight: 400;
		line-height: 1.2;
		text-decoration: none;
		transition: color 0.18s ease;
	}

	.ledger-nav--secondary .ledger-nav__link {
		min-height: 1.75rem;
		color: var(--rail-faint);
		font-size: 0.84rem;
	}

	.ledger-nav__text {
		min-width: 0;
	}

	.ledger-nav__link.active {
		color: var(--rail-ink);
		font-weight: 500;
	}

	.ledger-nav__link.active .ledger-nav__text::before {
		content: "";
		display: inline-block;
		width: 0.45rem;
		height: 0.45rem;
		margin-right: 0.55rem;
		border-radius: 1px;
		background: var(--rail-active);
		transform: translateY(-0.05em);
	}

	.ledger-nav__link:hover {
		color: var(--rail-ink);
	}

	.ledger-search {
		display: inline-flex;
		align-items: center;
		justify-content: space-between;
		gap: 0.65rem;
		width: 100%;
		min-height: 2.25rem;
		padding: 0 0.7rem;
		border: 1px solid var(--rail-line);
		border-radius: 2px;
		background: color-mix(in oklab, black 18%, transparent);
		color: var(--rail-muted);
		font: inherit;
		font-size: 0.78rem;
		font-weight: 400;
		text-align: left;
		cursor: pointer;
		transition: color 0.18s ease, border-color 0.18s ease, background 0.18s ease;
	}

	.ledger-search kbd {
		color: var(--rail-faint);
		font-family: var(--code-font);
		font-size: 0.66rem;
	}

	.ledger-search:hover,
	.ledger-search:focus-visible {
		color: var(--rail-ink);
		border-color: color-mix(in oklab, var(--rail-active) 45%, var(--rail-line));
		background: color-mix(in oklab, var(--rail-active) 12%, transparent);
	}

	.ledger-social {
		display: flex;
		flex-direction: column;
		gap: 0.55rem;
		margin-top: 0.35rem;
		padding-top: 1rem;
		border-top: 1px solid var(--rail-line);
	}

	.ledger-social__links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.35rem 0.85rem;
	}

	.ledger-social a {
		border: 0 !important;
		background: none !important;
		color: var(--rail-faint);
		font-size: 0.74rem;
		font-weight: 400;
		line-height: 1.3;
		text-decoration: none;
	}

	.ledger-social a:hover {
		color: var(--rail-active);
	}

	.ledger-main {
		display: flex;
		flex-direction: column;
		gap: clamp(1.6rem, 3.5vw, 2.4rem);
		min-height: 0;
		min-width: 0;
