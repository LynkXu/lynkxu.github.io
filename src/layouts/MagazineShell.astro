---
import Base from './Base.astro';
import Footer from '../components/Footer.astro';
import { AVATAR_IMAGE } from '../consts';

interface Props {
	title: string;
	description: string;
	className?: string;
	showProfileCard?: boolean;
}

const {
	title,
	description,
	className = '',
	showProfileCard = false,
} = Astro.props;

const currentPath = Astro.url.pathname;

const navItems = [
	{ href: '/', label: '首页' },
	{ href: '/blog', label: '归档' },
	{ href: '/shuoshuo', label: '碎语' },
	{ href: '/message', label: '留言' },
	{ href: '/about', label: '关于' },
];

const secondaryNavItems = [
	{ href: '/photography', label: '摄影' },
	{ href: '/media', label: '书影音' },
	{ href: '/travel', label: '旅行' },
	{ href: '/sports', label: '运动' },
	{ href: '/tools', label: '工具' },
];

const socialItems = [
	{ href: 'https://x.com/lynk_xv', label: 'X' },
	{ href: 'https://www.instagram.com/link_xl', label: 'Instagram' },
];

function normalizePath(path: string) {
	return path.endsWith('/') && path !== '/' ? path.slice(0, -1) : path;
}

function isActive(href: string) {
	const current = normalizePath(currentPath);
	const target = normalizePath(href);
	if (target === '/') return current === '/';
	return current === target || current.startsWith(`${target}/`);
}

const hasSidebarExtra = Astro.slots.has('sidebar-extra');
const shouldRenderRail = showProfileCard || hasSidebarExtra;
---

<Base
	title={title}
	description={description}
	className={`blog-surface-layout ${className}`}
	hideHeader={true}
	hideFooter={true}
>
	<slot name="head" slot="head" />

	<div class="ledger-shell">
		<aside class="ledger-sidebar" aria-label="站点导航">
			<div class="ledger-sidebar__inner">
				<a href="/" class="ledger-brand" aria-label="LynkXu 首页">
					<span class="ledger-brand__wordmark">LynkXu's Blog</span>
					<!-- <span class="ledger-brand__tag" aria-hidden="true">Est. 2020</span> -->
				</a>

				<div class="ledger-nav-group ledger-nav-group--primary">
					<nav class="ledger-nav ledger-nav--primary" aria-label="主导航">
						{navItems.map((item) => (
							<a
								href={item.href}
								class:list={['ledger-nav__link', { active: isActive(item.href) }]}
								aria-current={isActive(item.href) ? 'page' : undefined}
							>
								<span class="ledger-nav__marker" aria-hidden="true"></span>
								<span class="ledger-nav__text">{item.label}</span>
							</a>
						))}
					</nav>
				</div>

				<details class="ledger-collections">
					<summary class="ledger-group-label ledger-collections__summary">
						<span>专题</span>
					</summary>
					<nav class="ledger-nav ledger-nav--secondary" aria-label="专题页面">
						{secondaryNavItems.map((item) => (
							<a
								href={item.href}
								class:list={['ledger-nav__link', { active: isActive(item.href) }]}
								aria-current={isActive(item.href) ? 'page' : undefined}
							>
								<span class="ledger-nav__marker" aria-hidden="true"></span>
								<span class="ledger-nav__text">{item.label}</span>
							</a>
						))}
					</nav>
				</details>

				<div class="ledger-meta">
					<nav class="ledger-social" aria-label="社交与订阅链接">
						<span class="ledger-meta__label">社交</span>
						<span class="ledger-meta__value ledger-social__links">
							{socialItems.map((item) => (
								<a href={item.href} target="_blank" rel="noopener noreferrer">
									{item.label}
								</a>
							))}
						</span>
						<span class="ledger-meta__label">订阅</span>
						<span class="ledger-meta__value ledger-social__links">
							<a href="/index.xml" class="ledger-rss">RSS</a>
						</span>
					</nav>
				</div>
			</div>
		</aside>

		<main class="ledger-main">
			<slot />
			<Footer />
		</main>

		{/* 始终保留右栏占位，避免首页无侧栏时主栏被拉宽、切换页面时左右跳动 */}
		<aside class="ledger-context" aria-label="Page context" data-empty={!shouldRenderRail || undefined}>
			{showProfileCard && (
				<section class="ledger-context-card profile-card">
					<a href="/" class="profile-avatar-link" aria-label="回到首页">
						<img src={AVATAR_IMAGE.src} srcset={AVATAR_IMAGE.srcset} sizes="56px" alt="" class="profile-avatar" loading="eager" width="56" height="56" />
					</a>
					<div class="profile-info">
						<h2 class="profile-name">LynkXu</h2>
						<p class="profile-bio">个人笔记与长文。</p>
					</div>
				</section>
			)}
			<slot name="sidebar-extra" />
		</aside>
	</div>
</Base>

<style is:global>
	/* Dispatch / Postcard — stone canvas + lifted paper sheet */
	.blog-surface-layout {
		--page-bg: oklch(0.935 0.012 100);
		--background-color: oklch(0.935 0.012 100);
		--content-bg: oklch(0.992 0.004 95);
		--sheet-bg: oklch(0.992 0.004 95);
		--sheet-edge: oklch(0.32 0.022 95 / 0.22);
		--sheet-shadow:
			0 1px 0 oklch(0.32 0.02 95 / 0.04),
			0 10px 28px oklch(0.32 0.02 95 / 0.07);
		--heading-color: oklch(0.22 0.02 95);
		--panel-title-color: oklch(0.28 0.016 95);
		--text-color: oklch(0.32 0.015 95);
		--gray-color: oklch(0.46 0.012 95);
		--faint-color: oklch(0.58 0.01 95);
		--accent-color: oklch(0.4 0.045 205);
		--link-color: oklch(0.36 0.05 205);
		--rule-color: oklch(0.32 0.02 95 / 0.16);
		--paper-dot: oklch(0.32 0.02 95 / 0.055);
		--paper-rule: oklch(0.4 0.045 205 / 0.07);
		--paper-card-bg: var(--sheet-bg);
		--paper-card-bg-soft: color-mix(in oklab, var(--sheet-bg) 88%, var(--page-bg));
		--paper-card-border: var(--sheet-edge);
		--paper-card-border-soft: oklch(0.32 0.02 95 / 0.12);
		--paper-card-shadow: var(--sheet-shadow);
		--paper-card-radius: 2px;
		--paper-field-bg: oklch(0.32 0.02 95 / 0.03);
		--paper-hover-bg: oklch(0.4 0.045 205 / 0.045);
		--paper-hover-border: oklch(0.4 0.045 205 / 0.32);
		/* === Blog shell layout tokens (single source of truth) ===
		   Change widths here only. Consumers should use var(--blog-*) without local fallbacks. */
		--blog-sidebar-width: 10.75rem;
		--blog-content-max: 48rem;
		--blog-context-width: 12.75rem;
		--blog-shell-gap: clamp(1.6rem, 2.8vw, 2.35rem);
		/* 左右栏首行与中间纸页首行对齐：1px 边框 + 常见 sheet 上内边距 */
		--ledger-rail-inset-top: calc(1px + clamp(1.1rem, 2.4vw, 1.45rem));
		/* Shell tracks the three columns + gaps, with a little breathing room */
		--blog-shell-width: calc(
			var(--blog-sidebar-width) + var(--blog-content-max) + var(--blog-context-width)
			+ 2 * 2.35rem + 2rem
		);
		--measure-readable: var(--blog-content-max);
		font-family: var(--ui-font);
		color: var(--text-color);
	}

	@media (prefers-color-scheme: dark) {
		:root:not([data-theme]) .blog-surface-layout {
			--page-bg: oklch(0.155 0.02 150);
			--background-color: oklch(0.155 0.02 150);
			--content-bg: oklch(0.205 0.016 148);
			--sheet-bg: oklch(0.215 0.014 145);
			--sheet-edge: oklch(0.9 0.012 95 / 0.16);
			--sheet-shadow:
				0 1px 0 oklch(0 0 0 / 0.2),
				0 14px 36px oklch(0 0 0 / 0.28);
			--heading-color: oklch(0.94 0.01 95);
			--panel-title-color: oklch(0.88 0.012 95);
			--text-color: oklch(0.85 0.012 95);
			--gray-color: oklch(0.66 0.014 145);
			--faint-color: oklch(0.52 0.014 145);
			--accent-color: oklch(0.74 0.042 165);
			--link-color: oklch(0.8 0.044 165);
			--rule-color: oklch(0.9 0.012 95 / 0.14);
			--paper-dot: oklch(0.9 0.012 95 / 0.06);
			--paper-rule: oklch(0.74 0.042 165 / 0.1);
			--paper-card-border: var(--sheet-edge);
			--paper-card-border-soft: oklch(0.9 0.012 95 / 0.1);
			--paper-field-bg: oklch(0.9 0.012 95 / 0.035);
			--paper-hover-bg: oklch(0.74 0.042 165 / 0.08);
			--paper-hover-border: oklch(0.74 0.042 165 / 0.3);
		}
	}

	:root[data-theme="dark"] .blog-surface-layout {
		--page-bg: oklch(0.155 0.02 150);
		--background-color: oklch(0.155 0.02 150);
		--content-bg: oklch(0.205 0.016 148);
		--sheet-bg: oklch(0.215 0.014 145);
		--sheet-edge: oklch(0.9 0.012 95 / 0.16);
		--sheet-shadow:
			0 1px 0 oklch(0 0 0 / 0.2),
			0 14px 36px oklch(0 0 0 / 0.28);
		--heading-color: oklch(0.94 0.01 95);
		--panel-title-color: oklch(0.88 0.012 95);
		--text-color: oklch(0.85 0.012 95);
		--gray-color: oklch(0.66 0.014 145);
		--faint-color: oklch(0.52 0.014 145);
		--accent-color: oklch(0.74 0.042 165);
		--link-color: oklch(0.8 0.044 165);
		--rule-color: oklch(0.9 0.012 95 / 0.14);
		--paper-dot: oklch(0.9 0.012 95 / 0.06);
		--paper-rule: oklch(0.74 0.042 165 / 0.1);
		--paper-card-border: var(--sheet-edge);
		--paper-card-border-soft: oklch(0.9 0.012 95 / 0.1);
		--paper-field-bg: oklch(0.9 0.012 95 / 0.035);
		--paper-hover-bg: oklch(0.74 0.042 165 / 0.08);
		--paper-hover-border: oklch(0.74 0.042 165 / 0.3);
	}

	.blog-surface-layout.global-layout-card {
		width: 100%;
		max-width: none;
		min-height: 100vh;
		margin: 0;
		padding: 0;
		border: 0;
		border-radius: 0;
		background: var(--page-bg);
		box-shadow: none;
	}

	body:has(.blog-surface-layout) {
		background: var(--page-bg);
		overflow-x: clip;
	}

	body:has(.blog-surface-layout) #background-canvas {
		display: none;
	}

	.blog-surface-layout > main {
		width: 100%;
	}

	/* 三栏始终同宽同起点；中间列封顶。justify center 避免外壳余量堆在右侧造成整页偏左 */
	.ledger-shell {
		display: grid;
		grid-template-columns:
			var(--blog-sidebar-width)
			minmax(0, var(--blog-content-max))
			var(--blog-context-width);
		column-gap: var(--blog-shell-gap);
		row-gap: var(--blog-shell-gap);
		width: min(var(--blog-shell-width), calc(100% - clamp(2rem, 5vw, 4.5rem)));
		margin: 0 auto;
		padding: clamp(2rem, 5vw, 4rem) 0 clamp(3rem, 8vw, 6rem);
		justify-content: center;
	}

	.ledger-sidebar,
	.ledger-context {
		min-width: 0;
	}

	.ledger-sidebar__inner {
		position: sticky;
		top: clamp(1.25rem, 3vw, 2rem);
		display: flex;
		align-self: start;
		flex-direction: column;
		gap: clamp(1.15rem, 2.4vh, 1.55rem);
		padding: var(--ledger-rail-inset-top) 0.2rem 0.5rem 0.7rem;
		border-right: 0;
		background: transparent;
	}

	.ledger-brand {
		display: flex;
		flex-direction: column;
		gap: 0.34rem;
		width: 100%;
		margin-bottom: 0.1rem;
		padding: 0 0 clamp(0.95rem, 1.8vh, 1.2rem);
		border: 0;
		border-bottom: 1px solid color-mix(in oklab, var(--rule-color) 55%, transparent) !important;
		background: none !important;
		color: var(--heading-color);
		text-decoration: none;
	}

	.ledger-brand__wordmark {
		font-family: var(--display-font);
		font-size: 1.42rem;
		font-weight: 600;
		line-height: 1;
		letter-spacing: -0.02em;
		color: var(--heading-color);
	}

	.ledger-brand__tag {
		font-family: var(--field-font);
		font-size: 0.58rem;
		font-weight: var(--weight-medium);
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: var(--faint-color);
	}

	.ledger-nav-group {
		display: flex;
		flex-direction: column;
		gap: 0;
	}

	.ledger-collections {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		padding-top: 0.15rem;
	}

	.ledger-collections__summary {
		display: grid;
		grid-template-columns: auto auto;
		justify-content: start;
		align-items: center;
		gap: 0.55rem;
		width: fit-content;
		min-height: 2.25rem;
		cursor: pointer;
		list-style: none;
		user-select: none;
	}

	.ledger-collections__summary::-webkit-details-marker {
		display: none;
	}

	.ledger-collections__summary::after {
		content: "›";
		color: var(--faint-color);
		font-family: var(--field-font);
		font-size: 0.82rem;
		line-height: 1;
		transform: rotate(0deg);
		transition: transform 0.18s ease;
	}

	.ledger-collections[open] .ledger-collections__summary::after {
		transform: rotate(90deg);
	}

	.ledger-collections__summary:hover {
		color: var(--gray-color);
	}

	.ledger-group-label {
		color: var(--faint-color);
		font-family: var(--field-font);
		font-size: 0.62rem;
		font-weight: var(--weight-medium);
		letter-spacing: 0.1em;
		text-transform: uppercase;
		line-height: 1;
	}

	/* Spine index: a vertical ink rule the destinations hang off of. */
	.ledger-nav {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 0.04rem;
	}

	.ledger-nav::before {
		content: "";
		position: absolute;
		left: 0;
		top: 0.22rem;
		bottom: 0.22rem;
		width: 1px;
		background: var(--rule-color);
	}

	.ledger-nav--secondary::before {
		background: color-mix(in oklab, var(--rule-color) 70%, transparent);
	}

	.ledger-nav__link {
		position: relative;
		display: flex;
		align-items: center;
		min-height: 1.95rem;
		padding-left: 0.95rem;
		border: 0 !important;
		background: none !important;
		color: var(--gray-color);
		font-size: 0.78rem;
		font-weight: var(--weight-regular);
		line-height: 1.2;
		text-decoration: none;
		transition: color 0.16s ease;
	}

	.ledger-nav--primary .ledger-nav__link {
		color: color-mix(in oklab, var(--gray-color) 70%, var(--heading-color));
		font-size: 0.82rem;
	}

	.ledger-nav--secondary .ledger-nav__link {
		min-height: 1.7rem;
		color: color-mix(in oklab, var(--gray-color) 90%, var(--heading-color));
		font-size: 0.75rem;
	}

	.ledger-nav__text {
		min-width: 0;
	}

	/* Tick sits on the spine and marks "you are here". Opacity/scale only — no reflow. */
	.ledger-nav__marker {
		position: absolute;
		left: -0.5px;
		top: 50%;
		width: 2px;
		height: 0.9rem;
		background: var(--accent-color);
		opacity: 0;
		transform: translateY(-50%) scaleY(0.35);
		transform-origin: center;
		transition: opacity 0.16s ease, transform 0.16s ease;
	}

	.ledger-nav__link:hover {
		color: var(--heading-color);
	}

	.ledger-nav__link:hover .ledger-nav__marker {
		opacity: 0.45;
		transform: translateY(-50%) scaleY(1);
	}

	.ledger-nav__link.active {
		color: color-mix(in oklab, var(--accent-color) 40%, var(--heading-color));
		font-weight: var(--weight-medium);
	}

	.ledger-nav__link.active .ledger-nav__marker {
		opacity: 1;
		transform: translateY(-50%) scaleY(1);
	}

	/* Meta footer: social / subscribe as one two-column ledger table. */
	.ledger-meta {
		display: flex;
		flex-direction: column;
		gap: 0.08rem;
		margin-top: 0.15rem;
		padding-top: clamp(0.85rem, 1.6vh, 1.1rem);
		border-top: 1px dashed color-mix(in oklab, var(--rule-color) 75%, transparent);
		--meta-label-col: 2.6rem;
	}

	.ledger-social {
		display: grid;
		grid-template-columns: var(--meta-label-col) minmax(0, 1fr);
		column-gap: 0.7rem;
		row-gap: 0.5rem;
		align-items: baseline;
	}

	.ledger-meta__label {
		color: var(--faint-color);
		font-family: var(--field-font);
		font-size: 0.62rem;
		font-weight: var(--weight-medium);
		letter-spacing: 0.06em;
		line-height: 1.2;
		white-space: nowrap;
	}

	.ledger-meta__value {
		min-width: 0;
	}

	.ledger-social__links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.28rem 0.72rem;
	}

	.ledger-social a {
		border: 0 !important;
		background: none !important;
		color: color-mix(in oklab, var(--gray-color) 88%, var(--heading-color));
		font-size: 0.7rem;
		line-height: 1.3;
		text-decoration: none;
		transition: color 0.16s ease;
	}

	.ledger-social a:hover {
		color: var(--heading-color);
	}

	.ledger-main {
		display: flex;
		flex-direction: column;
		gap: clamp(1.8rem, 4vw, 3rem);
		width: 100%;
		min-height: calc(100vh - clamp(3.5rem, 7vw, 5rem));
		min-width: 0;
	}

	/* 主内容纸页默认吃满中间栏，避免各页再写不同 max-width */
	.ledger-main > .postcard-sheet,
	.ledger-main > section {
		width: 100%;
		max-width: 100%;
		box-sizing: border-box;
	}

	.blog-surface-layout .ledger-main > footer {
		margin-top: auto;
	}

	.ledger-context {
		position: sticky;
		top: clamp(1.25rem, 3vw, 2rem);
		display: flex;
		flex-direction: column;
		gap: 1.6rem;
		align-self: start;
		min-height: 0;
		padding-top: var(--ledger-rail-inset-top);
		padding-left: clamp(0.75rem, 1.6vw, 1.1rem);
		border-left: 0;
		font-size: 0.78rem;
	}

	.ledger-context[data-empty] {
		/* 占位保列宽，不渲染可见内容 */
		visibility: hidden;
		pointer-events: none;
	}

	.ledger-context .magazine-section-label {
		font-family: var(--field-font);
		font-size: 0.6rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--faint-color);
	}

	.magazine-panel,
	.magazine-rail-card,
	.ledger-context-card,
	.profile-card {
		border: 0;
		border-radius: 0;
		background: transparent;
		box-shadow: none;
	}

	.magazine-panel,
	.magazine-rail-card {
		padding: 0;
	}

	.magazine-section-label {
		display: block;
		width: fit-content;
		margin: 0;
		color: var(--gray-color);
		font-size: 0.72rem;
		font-weight: var(--weight-medium);
		letter-spacing: 0.02em;
		line-height: 1.2;
	}

	.magazine-section-label::after {
		content: none;
	}

	.magazine-chip {
		display: inline-flex;
		align-items: center;
		min-height: 1.35rem;
		padding: 0;
		border: 0 !important;
		border-radius: 0;
		background: transparent !important;
		color: var(--gray-color);
		font-size: 0.72rem;
		font-weight: var(--weight-regular);
		line-height: 1;
		text-decoration: none;
	}

	.magazine-chip::before {
		content: "#";
		opacity: 0.55;
	}

	.magazine-chip:hover {
		color: var(--accent-color);
	}

	/* Form-field metadata (dispatch / postcard signature) */
	.dispatch-field {
		display: inline-flex;
		align-items: baseline;
		gap: 0.4rem;
		min-width: 0;
		font-family: var(--field-font);
		font-size: 0.7rem;
		line-height: 1.3;
		color: var(--gray-color);
	}

	.dispatch-field__label {
		flex: 0 0 auto;
		color: var(--faint-color);
		font-size: 0.62rem;
		font-weight: var(--weight-medium);
		letter-spacing: 0.06em;
		text-transform: uppercase;
	}

	.dispatch-field__value {
		min-width: 0;
		color: color-mix(in oklab, var(--heading-color) 72%, var(--gray-color));
		font-variant-numeric: tabular-nums;
	}

	.dispatch-fields {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: 0.35rem 1.1rem;
	}

