---
import Base from './Base.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';
import { filterDrafts } from '../utils/drafts';

interface Props {
	title: string;
	description: string;
	className?: string;
	showProfileCard?: boolean;
}

const {
	title,
	description,
	className = '',
	showProfileCard = false,
} = Astro.props;

const currentPath = Astro.url.pathname;
const allPosts = filterDrafts(await getCollection('blog')).filter((post) => !post.id.startsWith('en/'));
const oldestPost = allPosts.reduce<Date | undefined>((oldest, post) => {
	if (!oldest || post.data.pubDate < oldest) return post.data.pubDate;
	return oldest;
}, undefined);

const tagsMap = new Map<string, number>();
allPosts.forEach((post) => {
	(post.data.tags || []).forEach((tag) => {
		tagsMap.set(tag, (tagsMap.get(tag) || 0) + 1);
	});
});

const navItems = [
	{ href: '/', label: '首页' },
	{ href: '/blog', label: '归档' },
	{ href: '/shuoshuo', label: '碎语' },
	{ href: '/message', label: '留言' },
	{ href: '/about', label: '关于' },
];

const secondaryNavItems = [
	{ href: '/photography', label: '摄影' },
	{ href: '/media', label: '书影音' },
	{ href: '/travel', label: '旅行' },
	{ href: '/sports', label: '运动' },
	{ href: '/tools', label: '工具' },
];

const socialItems = [
	{ href: 'https://github.com/LynkXu', label: 'GitHub' },
	{ href: 'https://x.com/lynk_xv', label: 'X' },
	{ href: 'https://www.instagram.com/link_xl', label: 'Instagram' },
];

function normalizePath(path: string) {
	return path.endsWith('/') && path !== '/' ? path.slice(0, -1) : path;
}

function isActive(href: string) {
	const current = normalizePath(currentPath);
	const target = normalizePath(href);
	if (target === '/') return current === '/';
	return current === target || current.startsWith(`${target}/`);
}

const hasSidebarExtra = Astro.slots.has('sidebar-extra');
const shouldRenderRail = showProfileCard || hasSidebarExtra;
const sinceYear = oldestPost?.getFullYear() ?? new Date().getFullYear();
---

<Base
	title={title}
	description={description}
	className={`blog-surface-layout ${className}`}
	hideHeader={true}
	hideFooter={true}
>
	<slot name="head" slot="head" />

	<div class:list={['ledger-shell', { 'ledger-shell--no-context': !shouldRenderRail }]}>
		<aside class="ledger-sidebar" aria-label="站点导航">
			<div class="ledger-sidebar__inner">
				<a href="/" class="ledger-brand" aria-label="LynkXu 首页">
					<img src="/ava4.png" alt="" class="ledger-brand__avatar" width="40" height="40" loading="eager" />
					<span class="ledger-brand__name">LynkXu</span>
				</a>

				<div class="ledger-nav-group ledger-nav-group--primary">
					<nav class="ledger-nav ledger-nav--primary" aria-label="主导航">
						{navItems.map((item) => (
							<a
								href={item.href}
								class:list={['ledger-nav__link', { active: isActive(item.href) }]}
								aria-current={isActive(item.href) ? 'page' : undefined}
							>
								{item.label}
							</a>
						))}
					</nav>
				</div>

				<details class="ledger-collections">
					<summary class="ledger-group-label ledger-collections__summary">专题</summary>
					<nav class="ledger-nav ledger-nav--secondary" aria-label="专题页面">
						{secondaryNavItems.map((item) => (
							<a
								href={item.href}
								class:list={['ledger-nav__link', { active: isActive(item.href) }]}
								aria-current={isActive(item.href) ? 'page' : undefined}
							>
								{item.label}
							</a>
						))}
					</nav>
				</details>

				<nav class="ledger-social" aria-label="社交链接">
					<span class="ledger-group-label">社交</span>
					<div class="ledger-social__links">
						{socialItems.map((item) => (
							<a href={item.href} target="_blank" rel="noopener noreferrer">
								{item.label}
							</a>
						))}
					</div>
				</nav>

				<div class="ledger-sidebar__bottom">
					<!-- <div class="ledger-sidebar__meta-group">
						<span class="ledger-group-label">统计</span>
						<div class="ledger-sidebar__meta" aria-label="博客统计">
							<span>{allPosts.length} 篇</span>
							<span>{tagsMap.size} 个话题</span>
							<span>始于 {sinceYear}</span>
						</div>
					</div> -->

					<div class="ledger-sidebar__actions">
						<button
							class="ledger-search"
							type="button"
							aria-label="搜索文章"
							onclick="window.openSearchModal && window.openSearchModal()"
						>
							<span>搜索</span>
							<kbd>⌘K</kbd>
						</button>
						<a href="/index.xml" class="ledger-rss">RSS</a>
					</div>
				</div>
			</div>
		</aside>

		<main class="ledger-main">
			<slot />
			<Footer />
		</main>

		{shouldRenderRail && (
			<aside class="ledger-context" aria-label="Page context">
				{showProfileCard && (
					<section class="ledger-context-card profile-card">
						<a href="/" class="profile-avatar-link" aria-label="回到首页">
							<img src="/ava4.png" alt="" class="profile-avatar" loading="eager" width="56" height="56" />
						</a>
						<div class="profile-info">
							<h2 class="profile-name">LynkXu</h2>
							<p class="profile-bio">个人笔记与长文。</p>
						</div>
					</section>
				)}
				<slot name="sidebar-extra" />
			</aside>
		)}
	</div>
</Base>

<style is:global>
	.blog-surface-layout {
		--page-bg: #fbfaf9;
		--background-color: #fbfaf9;
		--content-bg: #fbfaf9;
		--heading-color: #242321;
		--panel-title-color: #302f2b;
		--text-color: #36342f;
		--gray-color: #5f5c55;
		--faint-color: #8a867c;
		--accent-color: #3f6f5a;
		--link-color: #315f4d;
		--rule-color: rgba(36, 35, 33, 0.16);
		--paper-card-bg: transparent;
		--paper-card-bg-soft: transparent;
		--paper-card-border: rgba(36, 35, 33, 0.18);
		--paper-card-border-soft: rgba(36, 35, 33, 0.13);
		--paper-card-shadow: none;
		--paper-card-radius: 0;
		--paper-field-bg: rgba(36, 35, 33, 0.035);
		--paper-hover-bg: rgba(63, 111, 90, 0.055);
		--paper-hover-border: rgba(63, 111, 90, 0.28);
		--blog-shell-width: 1280px;
		--blog-sidebar-width: 12.5rem;
		--blog-context-width: 14rem;
		--blog-shell-gap: clamp(2rem, 3.5vw, 2.8rem);
		--blog-section-label-color: var(--gray-color);
		font-family: var(--ui-font);
	}

	@media (prefers-color-scheme: dark) {
		:root:not([data-theme]) .blog-surface-layout {
			--page-bg: #151514;
			--background-color: #151514;
			--content-bg: #151514;
			--heading-color: #f1eee6;
			--panel-title-color: #e8e4da;
			--text-color: #d8d3c8;
			--gray-color: #b4aea2;
			--faint-color: #8a847a;
			--accent-color: #82a890;
			--link-color: #9ab9a4;
			--rule-color: rgba(241, 238, 230, 0.16);
			--paper-card-border: rgba(241, 238, 230, 0.17);
			--paper-card-border-soft: rgba(241, 238, 230, 0.12);
			--paper-field-bg: rgba(241, 238, 230, 0.045);
			--paper-hover-bg: rgba(130, 168, 144, 0.08);
			--paper-hover-border: rgba(130, 168, 144, 0.3);
		}
	}

	:root[data-theme="dark"] .blog-surface-layout {
		--page-bg: #151514;
		--background-color: #151514;
		--content-bg: #151514;
		--heading-color: #f1eee6;
		--panel-title-color: #e8e4da;
		--text-color: #d8d3c8;
		--gray-color: #b4aea2;
		--faint-color: #8a847a;
		--accent-color: #82a890;
		--link-color: #9ab9a4;
		--rule-color: rgba(241, 238, 230, 0.16);
		--paper-card-border: rgba(241, 238, 230, 0.17);
		--paper-card-border-soft: rgba(241, 238, 230, 0.12);
		--paper-field-bg: rgba(241, 238, 230, 0.045);
		--paper-hover-bg: rgba(130, 168, 144, 0.08);
		--paper-hover-border: rgba(130, 168, 144, 0.3);
	}

	.blog-surface-layout.global-layout-card {
		width: 100%;
		max-width: none;
		min-height: 100vh;
		margin: 0;
		padding: 0;
		border: 0;
		border-radius: 0;
		background: var(--page-bg);
		box-shadow: none;
	}

	body:has(.blog-surface-layout) {
		background: var(--page-bg);
		overflow-x: clip;
	}

	body:has(.blog-surface-layout) #background-canvas {
		display: none;
	}

	.blog-surface-layout > main {
		width: 100%;
	}

	.ledger-shell {
		display: grid;
		grid-template-columns: var(--blog-sidebar-width) minmax(0, 1fr) var(--blog-context-width);
		gap: var(--blog-shell-gap);
		width: min(var(--blog-shell-width), calc(100% - clamp(2rem, 6vw, 5.5rem)));
		margin: 0 auto;
		padding: clamp(2rem, 5vw, 4rem) 0 clamp(3rem, 8vw, 6rem);
	}

	.ledger-shell--no-context {
		grid-template-columns: var(--blog-sidebar-width) minmax(0, 1fr);
	}

	.ledger-sidebar,
	.ledger-context {
		min-width: 0;
	}

	.ledger-sidebar__inner {
		position: sticky;
		top: clamp(1.25rem, 3vw, 2rem);
		display: flex;
		min-height: calc(100vh - clamp(3.5rem, 7vw, 5rem));
		flex-direction: column;
		gap: clamp(1.15rem, 2.3vh, 1.55rem);
		padding: 0 clamp(1rem, 2vw, 1.35rem) 0 0;
		border-right: 1px solid var(--paper-card-border-soft);
	}

	.ledger-brand {
		display: flex;
		flex-direction: row;
		align-items: center;
		gap: 0.75rem;
		width: 100%;
		margin-bottom: clamp(0.05rem, 0.6vh, 0.35rem);
		padding-bottom: clamp(1rem, 1.6vh, 1.2rem);
		border: 0;
		border-bottom: 1px solid var(--paper-card-border-soft) !important;
		background: none !important;
		color: var(--heading-color);
		text-decoration: none;
	}

	.ledger-brand__avatar {
		width: 44px;
		height: 44px;
		border-radius: 50%;
		object-fit: cover;
	}

	.ledger-brand__name {
		font-size: 1.3rem;
		font-weight: var(--weight-semibold);
		line-height: 1;
		letter-spacing: 0;
	}

	.ledger-nav-group {
		display: flex;
		flex-direction: column;
		gap: 0.56rem;
	}

	.ledger-nav-group--secondary {
		padding-top: clamp(0.18rem, 0.8vh, 0.5rem);
		border-top: 0;
	}

	.ledger-collections {
		display: flex;
		flex-direction: column;
		gap: 0.56rem;
		padding-top: clamp(0.18rem, 0.8vh, 0.5rem);
	}

	.ledger-collections__summary {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: 100%;
		cursor: pointer;
		list-style: none;
		user-select: none;
	}

	.ledger-collections__summary::-webkit-details-marker {
		display: none;
	}

	.ledger-collections__summary::after {
		content: "+";
		color: var(--faint-color);
		font-family: var(--field-font);
		font-size: 0.72rem;
		line-height: 1;
	}

	.ledger-collections[open] .ledger-collections__summary::after {
		content: "−";
	}

	.ledger-collections__summary:hover {
		color: var(--gray-color);
	}

	.ledger-group-label {
		display: block;
		width: fit-content;
		color: var(--faint-color);
		font-family: var(--field-font);
		font-size: 0.68rem;
		font-weight: var(--weight-regular);
		letter-spacing: 0.02em;
		line-height: 1;
	}

	.ledger-nav {
		display: flex;
		flex-direction: column;
		gap: 0.08rem;
	}

	.ledger-nav--secondary {
		gap: 0.06rem;
	}

	.ledger-nav__link {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		min-height: 1.82rem;
		border: 0 !important;
		background: none !important;
		color: var(--gray-color);
		font-size: 0.84rem;
		font-weight: var(--weight-regular);
		line-height: 1.2;
		text-decoration: none;
		transition: color 0.16s ease, padding-left 0.16s ease;
	}

	.ledger-nav--primary .ledger-nav__link {
		color: color-mix(in oklab, var(--gray-color) 72%, var(--heading-color));
		font-size: 0.86rem;
	}

	.ledger-nav--secondary .ledger-nav__link {
		min-height: 1.64rem;
		color: color-mix(in oklab, var(--gray-color) 88%, var(--heading-color));
		font-size: 0.8rem;
	}

	.ledger-nav__link:hover {
		color: var(--heading-color);
	}

	.ledger-nav__link.active {
		color: color-mix(in oklab, var(--accent-color) 36%, var(--heading-color));
		font-weight: var(--weight-medium);
	}

	.ledger-nav__link:hover {
		padding-left: 0.18rem;
	}

	.ledger-nav__link.active::after {
		content: "";
		width: 0.26rem;
		height: 0.26rem;
		margin-left: 0.75rem;
		border-radius: 50%;
		background: var(--accent-color);
	}

	.ledger-sidebar__bottom {
		display: flex;
		flex-direction: column;
		gap: clamp(0.82rem, 1.5vh, 1rem);
		margin-top: auto;
		padding-top: 0;
		border-top: 0;
	}

	.ledger-sidebar__meta-group {
		display: flex;
		flex-direction: column;
		gap: 0.42rem;
	}

	.ledger-sidebar__meta {
		display: flex;
		flex-direction: column;
		gap: 0.18rem;
		color: var(--faint-color);
		font-size: 0.68rem;
		line-height: 1.45;
		font-variant-numeric: tabular-nums;
	}

	.ledger-sidebar__actions {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 0.45rem;
		align-items: center;
		padding-top: 0.12rem;
	}

	.ledger-search,
	.ledger-rss {
		display: inline-flex;
		align-items: center;
		min-height: 2rem;
		border: 0;
		border-bottom: 1px solid var(--paper-card-border-soft);
		background: transparent;
		color: var(--gray-color);
		font: inherit;
		font-size: 0.72rem;
		text-decoration: none;
	}

	.ledger-search {
		justify-content: space-between;
		gap: 0.5rem;
		width: 100%;
		padding: 0 0.45rem 0 0;
		cursor: pointer;
	}

	.ledger-search kbd {
		color: var(--faint-color);
		font: inherit;
		font-size: 0.68rem;
	}

	.ledger-rss {
		justify-content: center;
		padding: 0 0 0 0.45rem;
	}

	.ledger-search:hover,
	.ledger-rss:hover {
		border-color: var(--paper-hover-border);
		color: var(--heading-color);
	}

	.ledger-social {
		display: flex;
		flex-direction: column;
		gap: 0.46rem;
		padding-top: clamp(0.15rem, 0.7vh, 0.45rem);
		border-top: 0;
	}

	.ledger-social__links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.28rem 0.72rem;
	}

	.ledger-social a {
		border: 0 !important;
		background: none !important;
		color: var(--faint-color);
		font-size: 0.65rem;
		line-height: 1.3;
		text-decoration: none;
	}

	.ledger-social a:hover {
		color: var(--heading-color);
	}

	.ledger-main {
		display: flex;
		flex-direction: column;
		gap: clamp(1.8rem, 4vw, 3rem);
		min-height: calc(100vh - clamp(3.5rem, 7vw, 5rem));
		min-width: 0;
	}

	.blog-surface-layout .ledger-main > footer {
		margin-top: auto;
	}

	.ledger-context {
		position: sticky;
		top: clamp(1.25rem, 3vw, 2rem);
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		align-self: start;
		padding-left: clamp(1rem, 2vw, 1.35rem);
		border-left: 1px solid var(--paper-card-border-soft);
	}

	.magazine-panel,
	.magazine-rail-card,
	.ledger-context-card,
	.profile-card {
		border: 0;
		border-radius: 0;
		background: transparent;
		box-shadow: none;
	}

	.magazine-panel,
	.magazine-rail-card {
		padding: 0;
	}

	.magazine-section-label {
		display: block;
		width: fit-content;
		margin: 0;
		color: var(--gray-color);
		font-size: 0.72rem;
		font-weight: var(--weight-medium);
		letter-spacing: 0.02em;
		line-height: 1.2;
	}

	.magazine-section-label::after {
		content: none;
	}

	.magazine-chip {
		display: inline-flex;
		align-items: center;
		min-height: 1.35rem;
		padding: 0;
		border: 0 !important;
		border-radius: 0;
		background: transparent !important;
		color: var(--gray-color);
		font-size: 0.72rem;
		font-weight: var(--weight-regular);
		line-height: 1;
		text-decoration: none;
	}

	.magazine-chip::before {
		content: "#";
		opacity: 0.55;
	}

	.magazine-chip:hover {
		color: var(--accent-color);
	}

	.profile-card {
		display: grid;
		grid-template-columns: 3.5rem minmax(0, 1fr);
		gap: 0.8rem;
		align-items: center;
	}

	.profile-avatar-link {
		display: block;
		border: 0 !important;
		background: none !important;
		line-height: 0;
	}

	.profile-avatar {
		width: 56px;
		height: 56px;
		border-radius: 50%;
		object-fit: cover;
	}

	.profile-name {
		margin: 0;
		color: var(--heading-color);
		font-size: 0.96rem;
		font-weight: var(--weight-medium);
		line-height: 1.2;
	}

	.profile-bio {
		margin: 0.24rem 0 0;
		color: var(--gray-color);
		font-size: 0.76rem;
		line-height: 1.5;
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	@media (max-width: 1100px) {
		.ledger-shell,
		.ledger-shell--no-context {
			grid-template-columns: 1fr;
			gap: clamp(1.5rem, 4vw, 2.4rem);
			width: min(44rem, calc(100% - 2rem));
			padding-top: 1.2rem;
		}

		.ledger-sidebar__inner {
			position: static;
			min-height: 0;
			gap: 0.9rem;
			padding-right: 0;
			padding-bottom: 1rem;
			border-right: 0;
			border-bottom: 1px solid var(--paper-card-border-soft);
		}

		.ledger-brand {
			flex-direction: row;
			align-items: center;
			gap: 0.65rem;
			margin-bottom: 0;
			padding-bottom: 0.95rem;
		}

		.ledger-nav {
			flex-direction: row;
			flex-wrap: wrap;
			gap: 0.35rem 0.9rem;
		}

		.ledger-nav-group {
			gap: 0.42rem;
		}

		.ledger-nav-group--secondary {
			padding-top: 0.78rem;
		}

		.ledger-collections {
			padding-top: 0.78rem;
		}

		.ledger-collections .ledger-nav {
			padding-top: 0.35rem;
		}

		.ledger-sidebar__meta {
			flex-direction: row;
			flex-wrap: wrap;
			gap: 0.4rem 0.9rem;
		}

		.ledger-sidebar__bottom {
			gap: 0.72rem;
			margin-top: 0;
			padding-top: 0.82rem;
		}

		.ledger-sidebar__actions {
			grid-template-columns: minmax(8rem, 13rem) auto;
			justify-content: start;
		}

		.ledger-social {
			gap: 0.32rem 0.9rem;
			padding-top: 0;
		}

		.ledger-main {
			min-height: 0;
		}

		.blog-surface-layout .ledger-main > footer {
			margin-top: clamp(0.6rem, 2vw, 1.2rem);
		}

		.ledger-context {
			position: static;
			padding-left: 0;
			border-left: 0;
			padding-top: 1.2rem;
			border-top: 1px solid var(--paper-card-border-soft);
		}
	}

	@media (max-width: 640px) {
		.ledger-shell,
		.ledger-shell--no-context {
			width: min(100% - 1.1rem, 40rem);
			padding-top: 0.9rem;
			padding-bottom: 3rem;
		}

		.ledger-brand__name {
			font-size: 1.22rem;
		}

		.ledger-nav__link {
