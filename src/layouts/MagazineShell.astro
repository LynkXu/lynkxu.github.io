---
import Base from './Base.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
	description: string;
	className?: string;
	showProfileCard?: boolean;
}

const {
	title,
	description,
	className = '',
	showProfileCard = false,
} = Astro.props;

const currentPath = Astro.url.pathname;

const navItems = [
	{ href: '/blog', label: '归档' },
	{ href: '/shuoshuo', label: '碎语' },
	{ href: '/message', label: '留言' },
	{ href: '/about', label: '关于' },
];

const secondaryNavItems = [
	{ href: '/photography', label: '摄影' },
	{ href: '/media', label: '书影音' },
	{ href: '/travel', label: '旅行' },
	{ href: '/sports', label: '运动' },
	{ href: '/tools', label: '工具' },
];

function normalizePath(path: string) {
	return path.endsWith('/') && path !== '/' ? path.slice(0, -1) : path;
}

function isActive(href: string) {
	const current = normalizePath(currentPath);
	const target = normalizePath(href);
	if (target === '/') return current === '/';
	return current === target || current.startsWith(`${target}/`);
}

const hasSidebarExtra = Astro.slots.has('sidebar-extra');
const shouldRenderRail = showProfileCard || hasSidebarExtra;
const isSecondaryRoute = secondaryNavItems.some((item) => isActive(item.href));
const isHome = normalizePath(currentPath) === '/';
---

<Base
	title={title}
	description={description}
	className={`blog-surface-layout ${className}`}
	hideHeader={true}
	hideFooter={true}
>
	<slot name="head" slot="head" />

	<div class:list={['ledger-shell', { 'ledger-shell--no-context': !shouldRenderRail }]}>
		<aside class="ledger-sidebar" aria-label="站点导航">
			<div class="ledger-sidebar__inner">
				<a
					href="/"
					class:list={['ledger-brand', { active: isHome }]}
					aria-label="LynkXu 首页"
					aria-current={isHome ? 'page' : undefined}
				>
					<img src="/ava4.png" alt="" class="ledger-brand__avatar" width="28" height="28" loading="eager" />
					<span class="ledger-brand__name">LynkXu</span>
				</a>

				<div class="ledger-nav-group ledger-nav-group--primary">
					<nav class="ledger-nav ledger-nav--primary" aria-label="主导航">
						{navItems.map((item) => (
							<a
								href={item.href}
								class:list={['ledger-nav__link', { active: isActive(item.href) }]}
								aria-current={isActive(item.href) ? 'page' : undefined}
							>
								{item.label}
							</a>
						))}
					</nav>
				</div>

				<details class="ledger-collections" open={isSecondaryRoute || undefined}>
					<summary class="ledger-group-label ledger-collections__summary">专题</summary>
					<nav class="ledger-nav ledger-nav--secondary" aria-label="专题页面">
						{secondaryNavItems.map((item) => (
							<a
								href={item.href}
								class:list={['ledger-nav__link', { active: isActive(item.href) }]}
								aria-current={isActive(item.href) ? 'page' : undefined}
							>
								{item.label}
							</a>
						))}
					</nav>
				</details>

				<div class="ledger-sidebar__actions">
					<button
						class="ledger-search"
						type="button"
						aria-label="搜索文章"
						onclick="window.openSearchModal && window.openSearchModal()"
					>
						<span>搜索</span>
						<kbd>⌘K</kbd>
					</button>
					<a href="/index.xml" class="ledger-rss">RSS</a>
				</div>
			</div>
		</aside>

		<main class="ledger-main">
			<slot />
			<Footer />
		</main>

		{shouldRenderRail && (
			<aside class="ledger-context" aria-label="Page context">
				{showProfileCard && (
					<section class="ledger-context-card profile-card">
						<a href="/" class="profile-avatar-link" aria-label="回到首页">
							<img src="/ava4.png" alt="" class="profile-avatar" loading="eager" width="56" height="56" />
						</a>
						<div class="profile-info">
							<h2 class="profile-name">LynkXu</h2>
							<p class="profile-bio">个人笔记与长文。</p>
						</div>
					</section>
				)}
				<slot name="sidebar-extra" />
			</aside>
		)}
	</div>
</Base>

<style is:global>
	.blog-surface-layout {
		--page-bg: #fbfaf9;
		--background-color: #fbfaf9;
		--content-bg: #fbfaf9;
		--heading-color: #242321;
		--panel-title-color: #302f2b;
		--text-color: #36342f;
		--gray-color: #5f5c55;
		--faint-color: #8a867c;
		--accent-color: #3f6f5a;
		--link-color: #315f4d;
		--rule-color: rgba(36, 35, 33, 0.16);
		--paper-card-bg: transparent;
		--paper-card-bg-soft: transparent;
		--paper-card-border: rgba(36, 35, 33, 0.18);
		--paper-card-border-soft: rgba(36, 35, 33, 0.13);
		--paper-card-shadow: none;
		--paper-card-radius: 0;
		--paper-field-bg: rgba(36, 35, 33, 0.035);
		--paper-hover-bg: rgba(63, 111, 90, 0.055);
		--paper-hover-border: rgba(63, 111, 90, 0.28);
		--blog-shell-width: 1280px;
		--blog-sidebar-width: 12.5rem;
		--blog-context-width: 14rem;
		--blog-shell-gap: clamp(2rem, 3.5vw, 2.8rem);
		--blog-section-label-color: var(--gray-color);
		font-family: var(--ui-font);
	}

	@media (prefers-color-scheme: dark) {
		:root:not([data-theme]) .blog-surface-layout {
			--page-bg: #151514;
			--background-color: #151514;
			--content-bg: #151514;
			--heading-color: #f1eee6;
			--panel-title-color: #e8e4da;
			--text-color: #d8d3c8;
			--gray-color: #b4aea2;
			--faint-color: #8a847a;
			--accent-color: #82a890;
			--link-color: #9ab9a4;
			--rule-color: rgba(241, 238, 230, 0.16);
			--paper-card-border: rgba(241, 238, 230, 0.17);
			--paper-card-border-soft: rgba(241, 238, 230, 0.12);
			--paper-field-bg: rgba(241, 238, 230, 0.045);
			--paper-hover-bg: rgba(130, 168, 144, 0.08);
			--paper-hover-border: rgba(130, 168, 144, 0.3);
		}
	}

	:root[data-theme="dark"] .blog-surface-layout {
		--page-bg: #151514;
		--background-color: #151514;
		--content-bg: #151514;
		--heading-color: #f1eee6;
		--panel-title-color: #e8e4da;
		--text-color: #d8d3c8;
		--gray-color: #b4aea2;
		--faint-color: #8a847a;
		--accent-color: #82a890;
		--link-color: #9ab9a4;
		--rule-color: rgba(241, 238, 230, 0.16);
		--paper-card-border: rgba(241, 238, 230, 0.17);
		--paper-card-border-soft: rgba(241, 238, 230, 0.12);
		--paper-field-bg: rgba(241, 238, 230, 0.045);
		--paper-hover-bg: rgba(130, 168, 144, 0.08);
		--paper-hover-border: rgba(130, 168, 144, 0.3);
	}

	.blog-surface-layout.global-layout-card {
		width: 100%;
		max-width: none;
		min-height: 100vh;
		margin: 0;
		padding: 0;
		border: 0;
		border-radius: 0;
		background: var(--page-bg);
		box-shadow: none;
	}

	body:has(.blog-surface-layout) {
		background: var(--page-bg);
		overflow-x: clip;
	}

	body:has(.blog-surface-layout) #background-canvas {
		display: none;
	}

	.blog-surface-layout > main {
		width: 100%;
	}

	.ledger-shell {
		display: grid;
		grid-template-columns: var(--blog-sidebar-width) minmax(0, 1fr) var(--blog-context-width);
		gap: var(--blog-shell-gap);
		width: min(var(--blog-shell-width), calc(100% - clamp(2rem, 6vw, 5.5rem)));
		margin: 0 auto;
		padding: clamp(2rem, 5vw, 4rem) 0 clamp(3rem, 8vw, 6rem);
	}

	.ledger-shell--no-context {
		grid-template-columns: var(--blog-sidebar-width) minmax(0, 1fr);
	}

	.ledger-sidebar,
	.ledger-context {
		min-width: 0;
	}

	.ledger-sidebar__inner {
		position: sticky;
		top: clamp(1.25rem, 3vw, 2rem);
		display: flex;
		flex-direction: column;
		align-self: start;
		width: 100%;
		gap: clamp(1.1rem, 2.2vh, 1.45rem);
		padding: 0 clamp(1rem, 2vw, 1.35rem) 0.35rem 0;
		border-right: 1px solid var(--paper-card-border-soft);
	}

	.ledger-brand {
		display: flex;
		flex-direction: row;
		align-items: center;
		gap: 0.55rem;
		width: 100%;
		margin-bottom: 0;
		padding-bottom: clamp(0.85rem, 1.5vh, 1.05rem);
		border: 0;
		border-bottom: 1px solid var(--paper-card-border-soft) !important;
		background: none !important;
		color: var(--heading-color);
		text-decoration: none;
	}

	.ledger-brand__avatar {
		width: 28px;
		height: 28px;
		border-radius: 50%;
		object-fit: cover;
	}

	.ledger-brand__name {
		font-size: 1rem;
		font-weight: var(--weight-semibold);
		line-height: 1;
		letter-spacing: 0;
	}

	.ledger-brand.active .ledger-brand__name {
		color: var(--heading-color);
	}

	.ledger-nav-group {
		display: flex;
		flex-direction: column;
		gap: 0.56rem;
	}

	.ledger-nav-group--secondary {
		padding-top: clamp(0.18rem, 0.8vh, 0.5rem);
		border-top: 0;
	}

	.ledger-collections {
		display: flex;
		flex-direction: column;
		gap: 0.56rem;
		padding-top: clamp(0.28rem, 1vh, 0.55rem);
	}

	.ledger-collections__summary {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: 100%;
		cursor: pointer;
		list-style: none;
		user-select: none;
	}

	.ledger-collections__summary::-webkit-details-marker {
		display: none;
	}

	.ledger-collections__summary::after {
		content: "+";
		color: var(--faint-color);
		font-family: var(--field-font);
		font-size: 0.72rem;
		line-height: 1;
	}

	.ledger-collections[open] .ledger-collections__summary::after {
		content: "−";
	}

	.ledger-collections__summary:hover {
		color: var(--gray-color);
	}

	.ledger-group-label {
		display: block;
		width: fit-content;
		color: var(--faint-color);
		font-family: var(--field-font);
		font-size: 0.68rem;
		font-weight: var(--weight-regular);
		letter-spacing: 0.02em;
		line-height: 1;
	}

	.ledger-nav {
		display: flex;
		flex-direction: column;
		gap: 0.14rem;
	}

	.ledger-nav--secondary {
		gap: 0.1rem;
	}

	.ledger-nav__link {
		position: relative;
		display: flex;
		align-items: center;
		min-height: 1.95rem;
		padding-left: 0.55rem;
		border: 0 !important;
		background: none !important;
		color: var(--gray-color);
		font-size: 0.84rem;
		font-weight: var(--weight-regular);
		line-height: 1.2;
		text-decoration: none;
		transition: color 0.16s ease, transform 0.16s ease;
	}

	.ledger-nav--primary .ledger-nav__link {
		color: color-mix(in oklab, var(--gray-color) 72%, var(--heading-color));
		font-size: 0.86rem;
	}

	.ledger-nav--secondary .ledger-nav__link {
		min-height: 1.64rem;
		color: color-mix(in oklab, var(--gray-color) 88%, var(--heading-color));
		font-size: 0.8rem;
	}

	.ledger-nav__link:hover {
		color: var(--heading-color);
		transform: translateX(2px);
	}

	.ledger-nav__link.active {
		color: var(--heading-color);
		font-weight: var(--weight-medium);
	}

	.ledger-nav__link.active::before {
		content: "";
		position: absolute;
		top: 0;
		bottom: 0;
		left: 0;
		width: 1px;
		height: 0.9em;
		margin-block: auto;
		background: var(--accent-color);
	}

	.ledger-sidebar__actions {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 0.45rem;
		align-items: center;
		margin-top: 0.35rem;
		padding-top: 0.75rem;
		border-top: 1px solid var(--paper-card-border-soft);
	}

	.ledger-search,
	.ledger-rss {
		display: inline-flex;
		align-items: center;
		min-height: 2rem;
		border: 0;
		border-bottom: 1px solid var(--paper-card-border-soft);
		background: transparent;
		color: var(--gray-color);
		font: inherit;
		font-size: 0.72rem;
		text-decoration: none;
	}

	.ledger-search {
		justify-content: space-between;
		gap: 0.5rem;
		width: 100%;
		padding: 0 0.45rem 0 0;
		cursor: pointer;
	}

	.ledger-search kbd {
		color: var(--faint-color);
		font: inherit;
		font-size: 0.68rem;
	}

	.ledger-rss {
		justify-content: center;
		padding: 0 0 0 0.45rem;
	}

	.ledger-search:hover,
	.ledger-rss:hover {
		border-color: var(--paper-hover-border);
		color: var(--heading-color);
	}

	@media (prefers-reduced-motion: reduce) {
		.ledger-nav__link {
			transition: none;
		}

		.ledger-nav__link:hover {
			transform: none;
		}
	}

	.ledger-main {
		display: flex;
		flex-direction: column;
		gap: clamp(1.8rem, 4vw, 3rem);
		min-height: calc(100vh - clamp(3.5rem, 7vw, 5rem));
		min-width: 0;
	}

	.blog-surface-layout .ledger-main > footer {
		margin-top: auto;
	}

	.ledger-context {
		position: sticky;
		top: clamp(1.25rem, 3vw, 2rem);
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		align-self: start;
		padding-left: clamp(1rem, 2vw, 1.35rem);
		border-left: 1px solid var(--paper-card-border-soft);
	}

	.magazine-panel,
	.magazine-rail-card,
	.ledger-context-card,
	.profile-card {
		border: 0;
		border-radius: 0;
		background: transparent;
		box-shadow: none;
	}

	.magazine-panel,
	.magazine-rail-card {
		padding: 0;
	}

	.magazine-section-label {
		display: block;
		width: fit-content;
		margin: 0;
		color: var(--gray-color);
		font-size: 0.72rem;
		font-weight: var(--weight-medium);
		letter-spacing: 0.02em;
		line-height: 1.2;
	}

	.magazine-section-label::after {
		content: none;
	}

	.magazine-chip {
		display: inline-flex;
		align-items: center;
		min-height: 1.35rem;
		padding: 0;
		border: 0 !important;
		border-radius: 0;
		background: transparent !important;
		color: var(--gray-color);
		font-size: 0.72rem;
		font-weight: var(--weight-regular);
		line-height: 1;
		text-decoration: none;
	}

	.magazine-chip::before {
		content: "#";
		opacity: 0.55;
	}

	.magazine-chip:hover {
		color: var(--accent-color);
	}

	.profile-card {
		display: grid;
		grid-template-columns: 3.5rem minmax(0, 1fr);
		gap: 0.8rem;
		align-items: center;
	}

	.profile-avatar-link {
		display: block;
		border: 0 !important;
		background: none !important;
		line-height: 0;
	}

	.profile-avatar {
		width: 56px;
		height: 56px;
		border-radius: 50%;
		object-fit: cover;
	}

	.profile-name {
		margin: 0;
		color: var(--heading-color);
		font-size: 0.96rem;
		font-weight: var(--weight-medium);
		line-height: 1.2;
	}

	.profile-bio {
		margin: 0.24rem 0 0;
		color: var(--gray-color);
		font-size: 0.76rem;
		line-height: 1.5;
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	@media (max-width: 1100px) {
		.ledger-shell,
		.ledger-shell--no-context {
			grid-template-columns: 1fr;
			gap: clamp(1.2rem, 3.5vw, 1.8rem);
			width: min(44rem, calc(100% - 2rem));
			padding-top: 1rem;
		}

		.ledger-sidebar__inner {
			position: static;
			gap: 0.65rem;
			padding-right: 0;
			padding-bottom: 0.8rem;
			border-right: 0;
			border-bottom: 1px solid var(--paper-card-border-soft);
		}

		.ledger-brand {
			gap: 0.5rem;
			padding-bottom: 0.55rem;
		}

		.ledger-nav--primary {
			flex-direction: row;
			flex-wrap: wrap;
			gap: 0.2rem 0.85rem;
		}

		.ledger-nav--primary .ledger-nav__link {
			min-height: 1.5rem;
			padding-left: 0;
			font-size: 0.8rem;
		}

		.ledger-nav--primary .ledger-nav__link.active::before {
			top: auto;
			right: 0;
			bottom: 0;
			left: 0;
			width: auto;
			height: 1px;
		}

		.ledger-nav--primary .ledger-nav__link:hover {
			transform: none;
		}

		.ledger-collections {
			gap: 0.35rem;
			padding-top: 0.15rem;
		}

		.ledger-collections .ledger-nav {
			flex-direction: row;
			flex-wrap: wrap;
			gap: 0.2rem 0.75rem;
			padding-top: 0.2rem;
		}

		.ledger-nav--secondary .ledger-nav__link {
			min-height: 1.4rem;
			padding-left: 0;
			font-size: 0.76rem;
		}

		.ledger-nav--secondary .ledger-nav__link.active::before {
			top: auto;
			right: 0;
			bottom: 0;
			left: 0;
			width: auto;
			height: 1px;
		}

		.ledger-nav--secondary .ledger-nav__link:hover {
			transform: none;
		}

		.ledger-sidebar__actions {
			grid-template-columns: minmax(7rem, 11rem) auto;
			justify-content: start;
			margin-top: 0;
			padding-top: 0.35rem;
			border-top: 0;
		}

		.ledger-search,
		.ledger-rss {
			min-height: 1.65rem;
			font-size: 0.68rem;
		}

		.ledger-main {
			min-height: 0;
		}

		.blog-surface-layout .ledger-main > footer {
			margin-top: clamp(0.6rem, 2vw, 1.2rem);
		}

		.ledger-context {
			position: static;
			padding-left: 0;
			border-left: 0;
			padding-top: 1.2rem;
			border-top: 1px solid var(--paper-card-border-soft);
		}
	}

	@media (max-width: 640px) {
		.ledger-shell,
		.ledger-shell--no-context {
			width: min(100% - 1.1rem, 40rem);
			padding-top: 0.85rem;
			padding-bottom: 3rem;
		}

		.ledger-brand__name {
			font-size: 0.96rem;
		}

		.ledger-nav--primary .ledger-nav__link {
			font-size: 0.78rem;
		}

		.ledger-search kbd {
			display: none;
		}

		.ledger-sidebar__actions {
			grid-template-columns: auto auto;
			gap: 0.85rem;
		}
	}
</style>
