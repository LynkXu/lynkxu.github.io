---
import Base from './Base.astro';

interface Props {
	title: string;
	description: string;
	className?: string;
}

const { title, description, className = '' } = Astro.props;
const currentPath = Astro.url.pathname;

const navSections = [
	{
		title: 'Writing',
		items: [
			{ href: '/blog', label: 'Archive', note: 'Entries' },
			{ href: '/tags', label: 'Topics', note: 'Themes' },
			{ href: '/shuoshuo', label: 'Memos', note: 'Notes' },
			{ href: '/message', label: 'Leaves', note: 'Messages' },
			{ href: '/about', label: 'About', note: 'Colophon' },
		],
	},
	{
		title: 'Elsewhere',
		items: [
			{ href: '/photography', label: 'Photography', note: 'Frames' },
			{ href: '/media', label: 'Media', note: 'Books' },
			{ href: '/travel', label: 'Travel', note: 'Places' },
			{ href: '/sports', label: 'Sports', note: 'Records' },
			{ href: '/tools', label: 'Tools', note: 'Utilities' },
			{ href: '/copyright', label: 'Copyright', note: 'License' },
		],
	},
];

function isActive(href: string) {
	if (href === '/') return currentPath === '/';
	return currentPath === href || currentPath.startsWith(href + '/');
}
---

<Base title={title} description={description} className={`blog-surface-layout ${className}`}>
	<slot name="head" slot="head" />
	<div class="magazine-shell">
		<main class="magazine-main">
			<slot />
		</main>

		<aside class="site-index" aria-label="Site index">
			<div class="site-index__inner">
				<a href="/" class="site-index__signature" aria-label="回到首页">
					<span class="site-index__avatar-wrap">
						<img src="/ava4.png" alt="" class="site-index__avatar" loading="eager" width="32" height="32" />
					</span>
					<span class="site-index__identity">
						<span class="site-index__kicker">LynkXu</span>
					</span>
				</a>

				<nav class="site-index__nav" aria-labelledby="site-index-title">
					<h2 id="site-index-title" class="site-index__section-title">Index</h2>
					{navSections.map((section) => (
						<div class="site-index__group">
							<h3 class="site-index__group-title">{section.title}</h3>
							<div class="site-index__links">
								{section.items.map((item) => (
									<a
										href={item.href}
										class:list={['site-index__link', { active: isActive(item.href) }]}
										aria-current={isActive(item.href) ? 'page' : undefined}
									>
										<span>{item.label}</span>
										<small>{item.note}</small>
									</a>
								))}
							</div>
						</div>
					))}
				</nav>

				<slot name="sidebar-extra" />
			</div>
		</aside>
	</div>
</Base>

<style is:global>
	.blog-surface-layout {
		--blog-shell-main-width: 760px;
		--blog-shell-sidebar-width: 13.25rem;
		--blog-shell-gap: clamp(var(--space-lg), 3.4vw, var(--space-2xl));
		--blog-shell-width: calc(
			var(--blog-shell-main-width) + var(--blog-shell-sidebar-width) + var(--blog-shell-gap)
		);
		--site-index-rule: color-mix(in oklab, var(--paper-card-border-soft) 58%, transparent);
		--site-index-quiet: color-mix(in oklab, var(--gray-color) 78%, var(--paper-bg));
	}

	.magazine-shell {
		display: grid;
		grid-template-columns: minmax(0, var(--blog-shell-main-width)) var(--blog-shell-sidebar-width);
		gap: var(--blog-shell-gap);
		justify-content: center;
		width: min(var(--blog-shell-width), 100%);
		margin: 0 auto;
		padding: clamp(0.5rem, 1.4vw, 0.85rem) 0 clamp(2.5rem, 5vw, 3.5rem);
	}

	.magazine-main {
		display: flex;
		flex-direction: column;
		gap: var(--blog-card-gap);
		min-width: 0;
	}

	.site-index {
		position: sticky;
		top: 2rem;
		align-self: start;
		box-sizing: border-box;
		color: var(--text-color);
	}

	.site-index__inner {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		padding-left: 0.95rem;
		border-left: 1px solid var(--site-index-rule);
		animation: fade-up 0.6s ease-out both;
	}

	.site-index__signature {
		display: grid;
		grid-template-columns: 2.25rem minmax(0, 1fr);
		align-items: center;
		gap: 0.62rem;
		min-width: 0;
		color: inherit;
		text-decoration: none;
		border: none !important;
		background: none !important;
	}

	.site-index__signature:hover {
		transform: none;
	}

	.site-index__avatar-wrap {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.25rem;
		height: 2.25rem;
		border: 1px solid transparent;
		border-radius: 3px;
		background:
			linear-gradient(var(--paper-card-bg), var(--paper-card-bg)) padding-box,
			linear-gradient(
				135deg,
				color-mix(in oklab, var(--accent-color) 24%, var(--paper-card-border-soft)),
				color-mix(in oklab, var(--paper-card-border-soft) 78%, transparent)
			) border-box;
	}

	.site-index__avatar {
		width: 1.88rem;
		height: 1.88rem;
		border-radius: 2px;
		object-fit: cover;
		filter: saturate(0.84);
		transition: filter 0.2s ease;
	}

	.site-index__signature:hover .site-index__avatar {
		filter: saturate(1);
	}

	.site-index__identity {
		display: flex;
		flex-direction: column;
		min-width: 0;
	}

	.site-index__kicker {
		color: var(--heading-color);
		font-family: var(--serif-font);
		font-size: 0.9rem;
		font-weight: 500;
		line-height: 1.2;
	}

	.site-index__nav,
	.site-index__section {
		display: flex;
		flex-direction: column;
		gap: 0.62rem;
	}

	.site-index__section-title {
		margin: 0;
		color: var(--site-index-quiet);
		font-family: var(--field-font);
		font-size: 0.62rem;
		font-weight: 600;
		letter-spacing: 0.06em;
		line-height: 1.3;
		text-transform: uppercase;
	}

	.site-index__group {
		display: flex;
		flex-direction: column;
		gap: 0.24rem;
	}

	.site-index__group + .site-index__group {
		margin-top: 0.34rem;
		padding-top: 0.72rem;
		border-top: 1px solid color-mix(in oklab, var(--paper-card-border-soft) 38%, transparent);
	}

	.site-index__group-title {
		margin: 0;
		color: var(--site-index-quiet);
		font-family: var(--field-font);
		font-size: 0.5rem;
		font-weight: 400;
		letter-spacing: 0.035em;
		line-height: 1.3;
		opacity: 0.52;
	}

	.site-index__links {
		display: flex;
		flex-direction: column;
		gap: 0;
		border-top: 1px solid var(--site-index-rule);
	}

	.site-index__link {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		align-items: baseline;
		gap: 0.7rem;
		min-height: 1.92rem;
		padding: 0.31rem 0;
		color: color-mix(in oklab, var(--text-color) 72%, var(--gray-color));
		font-family: var(--field-font);
		font-size: 0.76rem;
		font-weight: 400;
		line-height: 1.35;
		text-decoration: none;
		border-bottom: 1px solid color-mix(in oklab, var(--paper-card-border-soft) 34%, transparent) !important;
		background: none !important;
		transition: color 0.18s ease, padding-left 0.18s ease;
	}

	.site-index__link small {
		color: var(--site-index-quiet);
		font-size: 0.5rem;
		font-weight: 400;
		letter-spacing: 0.02em;
		line-height: 1.2;
		opacity: 0.5;
	}

	.site-index__link:hover {
		padding-left: 0.18rem;
		color: color-mix(in oklab, var(--accent-color) 38%, var(--heading-color));
	}

	.site-index__link.active {
		color: var(--heading-color);
		font-weight: 500;
	}

	.site-index__link.active small {
		color: var(--site-index-quiet);
		opacity: 0.56;
	}

	@keyframes fade-up {
		from {
			opacity: 0;
			transform: translateY(12px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (max-width: 1023px) {
		.magazine-shell {
			grid-template-columns: 1fr;
			gap: 1.5rem;
			padding-top: 0.8rem;
		}

		.magazine-main,
		.site-index {
			width: min(100%, var(--content-width));
			justify-self: center;
		}

		.site-index {
			position: static;
			order: 1;
		}

		.site-index__inner {
			gap: 0.7rem;
			padding: 0.78rem 0 0;
			border-top: 1px solid var(--site-index-rule);
			border-left: none;
		}

		.site-index__nav {
			display: none;
		}
	}

	@media (max-width: 768px) {
		.magazine-shell {
			width: 100%;
		}

		.site-index__avatar-wrap {
			width: 2rem;
			height: 2rem;
		}

		.site-index__avatar {
			width: 1.68rem;
			height: 1.68rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.site-index__inner {
			animation: none;
		}
	}

	@media (min-width: 1024px) {
		.blog-surface-layout:has(.magazine-shell) > header nav.section-nav {
			display: none;
		}

		.blog-surface-layout:has(.magazine-shell) > header .title {
			display: none;
		}
	}
</style>
