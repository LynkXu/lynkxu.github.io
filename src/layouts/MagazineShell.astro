---
import Base from './Base.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';
import { filterDrafts } from '../utils/drafts';

interface Props {
	title: string;
	description: string;
	className?: string;
	showProfileCard?: boolean;
	shellLabel?: string;
}

const {
	title,
	description,
	className = '',
	showProfileCard = false,
	shellLabel = 'Index',
} = Astro.props;

const currentPath = Astro.url.pathname;
const allPosts = filterDrafts(await getCollection('blog')).filter((post) => !post.id.startsWith('en/'));
const oldestPost = allPosts.reduce<Date | undefined>((oldest, post) => {
	if (!oldest || post.data.pubDate < oldest) return post.data.pubDate;
	return oldest;
}, undefined);

const tagsMap = new Map<string, number>();
allPosts.forEach((post) => {
	(post.data.tags || []).forEach((tag) => {
		tagsMap.set(tag, (tagsMap.get(tag) || 0) + 1);
	});
});

const navItems = [
	{ href: '/', label: 'Home' },
	{ href: '/blog', label: 'Archive' },
	{ href: '/tags', label: 'Tags' },
	{ href: '/shuoshuo', label: 'Memos' },
	{ href: '/message', label: 'Leaves' },
	{ href: '/about', label: 'About' },
];

const secondaryNavItems = [
	{ href: '/photography', label: 'Photography' },
	{ href: '/media', label: 'Media' },
	{ href: '/travel', label: 'Travel' },
	{ href: '/sports', label: 'Sports' },
	{ href: '/tools', label: 'Tools' },
];

function normalizePath(path: string) {
	return path.endsWith('/') && path !== '/' ? path.slice(0, -1) : path;
}

function isActive(href: string) {
	const current = normalizePath(currentPath);
	const target = normalizePath(href);
	if (target === '/') return current === '/';
	return current === target || current.startsWith(`${target}/`);
}

const hasSidebarExtra = Astro.slots.has('sidebar-extra');
const shouldRenderRail = showProfileCard || hasSidebarExtra;
const sinceYear = oldestPost?.getFullYear() ?? new Date().getFullYear();
---

<Base
	title={title}
	description={description}
	className={`blog-surface-layout ${className}`}
	hideHeader={true}
	hideFooter={true}
>
	<slot name="head" slot="head" />

	<div class:list={['ledger-shell', { 'ledger-shell--no-context': !shouldRenderRail }]}>
		<aside class="ledger-sidebar" aria-label="Site navigation">
			<div class="ledger-sidebar__inner">
				<a href="/" class="ledger-brand" aria-label="LynkXu home">
					<span class="ledger-brand__name">LynkXu</span>
					<span class="ledger-brand__label">{shellLabel}</span>
				</a>

				<nav class="ledger-nav" aria-label="Primary navigation">
					{navItems.map((item) => (
						<a
							href={item.href}
							class:list={['ledger-nav__link', { active: isActive(item.href) }]}
							aria-current={isActive(item.href) ? 'page' : undefined}
						>
							{item.label}
						</a>
					))}
				</nav>

				<nav class="ledger-nav ledger-nav--secondary" aria-label="Second level pages">
					{secondaryNavItems.map((item) => (
						<a
							href={item.href}
							class:list={['ledger-nav__link', { active: isActive(item.href) }]}
							aria-current={isActive(item.href) ? 'page' : undefined}
						>
							{item.label}
						</a>
					))}
				</nav>

				<div class="ledger-sidebar__meta" aria-label="Blog statistics">
					<span>{allPosts.length} entries</span>
					<span>{tagsMap.size} topics</span>
					<span>since {sinceYear}</span>
				</div>

				<div class="ledger-sidebar__actions">
					<button
						class="ledger-search"
						type="button"
						aria-label="Search articles"
						onclick="window.openSearchModal && window.openSearchModal()"
					>
						<span>Search</span>
						<kbd>⌘K</kbd>
					</button>
					<a href="/index.xml" class="ledger-rss">RSS</a>
				</div>
			</div>
		</aside>

		<main class="ledger-main">
			<slot />
			<Footer />
		</main>

		{shouldRenderRail && (
			<aside class="ledger-context" aria-label="Page context">
				{showProfileCard && (
					<section class="ledger-context-card profile-card">
						<a href="/" class="profile-avatar-link" aria-label="回到首页">
							<img src="/ava4.png" alt="" class="profile-avatar" loading="eager" width="56" height="56" />
						</a>
						<div class="profile-info">
							<h2 class="profile-name">LynkXu</h2>
							<p class="profile-bio">Personal notes and long-form writing.</p>
						</div>
					</section>
				)}
				<slot name="sidebar-extra" />
			</aside>
		)}
	</div>
</Base>

<style is:global>
	.blog-surface-layout {
		--page-bg: #fbfaf7;
		--background-color: #fbfaf7;
		--content-bg: #fbfaf7;
		--heading-color: #242321;
		--panel-title-color: #302f2b;
		--text-color: #36342f;
		--gray-color: #706d66;
		--faint-color: #9b978d;
		--accent-color: #3f6f5a;
		--link-color: #315f4d;
		--rule-color: rgba(36, 35, 33, 0.16);
		--paper-card-bg: transparent;
		--paper-card-bg-soft: transparent;
		--paper-card-border: rgba(36, 35, 33, 0.18);
		--paper-card-border-soft: rgba(36, 35, 33, 0.13);
		--paper-card-shadow: none;
		--paper-card-radius: 0;
		--paper-field-bg: rgba(36, 35, 33, 0.035);
		--paper-hover-bg: rgba(63, 111, 90, 0.055);
		--paper-hover-border: rgba(63, 111, 90, 0.28);
		--blog-shell-width: 1168px;
		--blog-sidebar-width: 12.5rem;
		--blog-context-width: 14.25rem;
		--blog-shell-gap: clamp(2.1rem, 4vw, 3.35rem);
		--blog-section-label-color: var(--gray-color);
		font-family: var(--ui-font);
	}

	@media (prefers-color-scheme: dark) {
		:root:not([data-theme]) .blog-surface-layout {
			--page-bg: #151514;
			--background-color: #151514;
			--content-bg: #151514;
			--heading-color: #f1eee6;
			--panel-title-color: #e8e4da;
			--text-color: #d8d3c8;
			--gray-color: #a6a096;
			--faint-color: #777168;
			--accent-color: #82a890;
			--link-color: #9ab9a4;
			--rule-color: rgba(241, 238, 230, 0.16);
			--paper-card-border: rgba(241, 238, 230, 0.17);
			--paper-card-border-soft: rgba(241, 238, 230, 0.12);
			--paper-field-bg: rgba(241, 238, 230, 0.045);
			--paper-hover-bg: rgba(130, 168, 144, 0.08);
			--paper-hover-border: rgba(130, 168, 144, 0.3);
		}
	}

	:root[data-theme="dark"] .blog-surface-layout {
		--page-bg: #151514;
		--background-color: #151514;
		--content-bg: #151514;
		--heading-color: #f1eee6;
		--panel-title-color: #e8e4da;
		--text-color: #d8d3c8;
		--gray-color: #a6a096;
		--faint-color: #777168;
		--accent-color: #82a890;
		--link-color: #9ab9a4;
		--rule-color: rgba(241, 238, 230, 0.16);
		--paper-card-border: rgba(241, 238, 230, 0.17);
		--paper-card-border-soft: rgba(241, 238, 230, 0.12);
		--paper-field-bg: rgba(241, 238, 230, 0.045);
		--paper-hover-bg: rgba(130, 168, 144, 0.08);
		--paper-hover-border: rgba(130, 168, 144, 0.3);
	}

	.blog-surface-layout.global-layout-card {
		width: 100%;
		max-width: none;
		min-height: 100vh;
		margin: 0;
		padding: 0;
		border: 0;
		border-radius: 0;
		background: var(--page-bg);
		box-shadow: none;
	}

	body:has(.blog-surface-layout) {
		background: var(--page-bg);
		overflow-x: clip;
	}

	body:has(.blog-surface-layout) #background-canvas {
		display: none;
	}

	.blog-surface-layout > main {
		width: 100%;
	}

	.ledger-shell {
		display: grid;
		grid-template-columns: var(--blog-sidebar-width) minmax(0, 1fr) var(--blog-context-width);
		gap: var(--blog-shell-gap);
		width: min(var(--blog-shell-width), calc(100% - clamp(2rem, 6vw, 5.5rem)));
		margin: 0 auto;
		padding: clamp(2rem, 5vw, 4rem) 0 clamp(3rem, 8vw, 6rem);
	}

	.ledger-shell--no-context {
		grid-template-columns: var(--blog-sidebar-width) minmax(0, 1fr);
	}

	.ledger-sidebar,
	.ledger-context {
		min-width: 0;
	}

	.ledger-sidebar__inner {
		position: sticky;
		top: clamp(1.25rem, 3vw, 2rem);
		display: flex;
		min-height: calc(100vh - clamp(2.5rem, 6vw, 4rem));
		flex-direction: column;
		gap: 1.1rem;
		padding: 0 clamp(1rem, 2vw, 1.35rem) 0 0;
		border-right: 1px solid var(--paper-card-border-soft);
	}

	.ledger-brand {
		display: flex;
		flex-direction: column;
		gap: 0.22rem;
		width: fit-content;
		margin-bottom: 0.35rem;
		border: 0 !important;
		background: none !important;
		color: var(--heading-color);
		text-decoration: none;
	}

	.ledger-brand__name {
		font-size: 1.28rem;
		font-weight: var(--weight-semibold);
		line-height: 1;
		letter-spacing: 0;
	}

	.ledger-brand__label {
		color: var(--gray-color);
		font-size: 0.68rem;
		font-weight: var(--weight-regular);
		line-height: 1.2;
	}

	.ledger-nav {
		display: flex;
		flex-direction: column;
		gap: 0.08rem;
	}

	.ledger-nav--secondary {
		margin-top: 0.55rem;
		padding-top: 0.9rem;
		border-top: 1px solid var(--paper-card-border-soft);
	}

	.ledger-nav__link {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		min-height: 1.82rem;
		border: 0 !important;
		background: none !important;
		color: var(--gray-color);
		font-size: 0.84rem;
		font-weight: var(--weight-regular);
		line-height: 1.2;
		text-decoration: none;
		transition: color 0.16s ease, padding-left 0.16s ease;
	}

	.ledger-nav__link:hover,
	.ledger-nav__link.active {
		color: var(--heading-color);
	}

	.ledger-nav__link:hover {
		padding-left: 0.18rem;
	}

	.ledger-nav__link.active::after {
		content: "";
		width: 0.28rem;
		height: 0.28rem;
		margin-left: 0.75rem;
		border-radius: 50%;
		background: var(--accent-color);
	}

	.ledger-sidebar__meta {
		display: flex;
		flex-direction: column;
		gap: 0.18rem;
		margin-top: auto;
		color: var(--faint-color);
		font-size: 0.68rem;
		line-height: 1.45;
		font-variant-numeric: tabular-nums;
	}

	.ledger-sidebar__actions {
		display: grid;
		grid-template-columns: 1fr auto;
		gap: 0.45rem;
		align-items: center;
	}

	.ledger-search,
	.ledger-rss {
		display: inline-flex;
		align-items: center;
		min-height: 2rem;
		border: 0;
		border-bottom: 1px solid var(--paper-card-border-soft);
		background: transparent;
		color: var(--gray-color);
		font: inherit;
		font-size: 0.72rem;
		text-decoration: none;
	}

	.ledger-search {
		justify-content: space-between;
		gap: 0.5rem;
		width: 100%;
		padding: 0 0.45rem 0 0;
		cursor: pointer;
	}

	.ledger-search kbd {
		color: var(--faint-color);
		font: inherit;
		font-size: 0.68rem;
	}

	.ledger-rss {
		justify-content: center;
		padding: 0 0 0 0.45rem;
	}

	.ledger-search:hover,
	.ledger-rss:hover {
		border-color: var(--paper-hover-border);
		color: var(--heading-color);
	}

	.ledger-main {
		display: flex;
		flex-direction: column;
		gap: clamp(1.8rem, 4vw, 3rem);
		min-width: 0;
	}

	.ledger-main > footer {
		margin-top: clamp(0.6rem, 2vw, 1.2rem);
	}

	.ledger-context {
		position: sticky;
		top: clamp(1.25rem, 3vw, 2rem);
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		align-self: start;
		padding-left: clamp(1rem, 2vw, 1.35rem);
		border-left: 1px solid var(--paper-card-border-soft);
	}

	.magazine-panel,
	.magazine-rail-card,
	.ledger-context-card,
	.profile-card {
		border: 0;
		border-radius: 0;
		background: transparent;
		box-shadow: none;
	}

	.magazine-panel,
	.magazine-rail-card {
		padding: 0;
	}

	.magazine-section-label {
		display: block;
		width: fit-content;
		margin: 0;
		color: var(--gray-color);
		font-size: 0.72rem;
		font-weight: var(--weight-medium);
		letter-spacing: 0.04em;
		line-height: 1.2;
		text-transform: uppercase;
	}

	.magazine-section-label::after {
		content: none;
	}

	.magazine-chip {
		display: inline-flex;
		align-items: center;
		min-height: 1.35rem;
		padding: 0;
		border: 0 !important;
		border-radius: 0;
		background: transparent !important;
		color: var(--gray-color);
		font-size: 0.72rem;
		font-weight: var(--weight-regular);
		line-height: 1;
		text-decoration: none;
	}

	.magazine-chip::before {
		content: "#";
		opacity: 0.55;
	}

	.magazine-chip:hover {
		color: var(--accent-color);
	}

	.profile-card {
		display: grid;
		grid-template-columns: 3.5rem minmax(0, 1fr);
		gap: 0.8rem;
		align-items: center;
	}

	.profile-avatar-link {
		display: block;
		border: 0 !important;
		background: none !important;
		line-height: 0;
	}

	.profile-avatar {
		width: 56px;
		height: 56px;
		border-radius: 50%;
		object-fit: cover;
	}

	.profile-name {
		margin: 0;
		color: var(--heading-color);
		font-size: 0.96rem;
		font-weight: var(--weight-medium);
		line-height: 1.2;
	}

	.profile-bio {
		margin: 0.24rem 0 0;
		color: var(--gray-color);
		font-size: 0.76rem;
		line-height: 1.5;
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	@media (max-width: 1100px) {
		.ledger-shell,
		.ledger-shell--no-context {
			grid-template-columns: 1fr;
			gap: clamp(1.5rem, 4vw, 2.4rem);
			width: min(44rem, calc(100% - 2rem));
			padding-top: 1.2rem;
		}

		.ledger-sidebar__inner {
			position: static;
			min-height: 0;
			gap: 0.85rem;
			padding-right: 0;
			padding-bottom: 1rem;
			border-right: 0;
			border-bottom: 1px solid var(--paper-card-border-soft);
		}

		.ledger-brand {
			flex-direction: row;
			align-items: baseline;
			gap: 0.65rem;
		}

		.ledger-nav {
			flex-direction: row;
			flex-wrap: wrap;
			gap: 0.35rem 0.9rem;
		}

		.ledger-nav--secondary {
			margin-top: 0;
			padding-top: 0;
			border-top: 0;
		}

		.ledger-sidebar__meta {
			flex-direction: row;
			flex-wrap: wrap;
			gap: 0.4rem 0.9rem;
			margin-top: 0;
		}

		.ledger-sidebar__actions {
			grid-template-columns: minmax(8rem, 13rem) auto;
			justify-content: start;
		}

		.ledger-context {
			position: static;
			padding-left: 0;
			border-left: 0;
			padding-top: 1.2rem;
			border-top: 1px solid var(--paper-card-border-soft);
		}
	}

	@media (max-width: 640px) {
		.ledger-shell,
		.ledger-shell--no-context {
			width: min(100% - 1.1rem, 40rem);
			padding-top: 0.9rem;
			padding-bottom: 3rem;
		}

		.ledger-brand__name {
			font-size: 1.22rem;
		}

		.ledger-nav__link {
			min-height: 1.45rem;
			font-size: 0.78rem;
		}

		.ledger-sidebar__actions {
			grid-template-columns: 1fr auto;
		}
	}
</style>
