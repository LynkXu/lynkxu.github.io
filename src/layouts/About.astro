---
import MagazineShell from './MagazineShell.astro';
import SponsorAbout from '../components/SponsorAbout.astro';

const { title } = Astro.props;
---

<MagazineShell title={title} description={title} showProfileCard={false}>
	<section class="about-profile magazine-panel" aria-labelledby="about-title">
		<p class="magazine-section-label">Profile</p>
		<h1 id="about-title">👋 Hi, I am Lynk</h1>
		<div class="about-profile__lead">
			<p>
				<span>一个偏乐观的悲观主义者。</span>
				<span>一个偏现实的理想主义者。</span>
				<span>一个想法很多，但却不善表达的人。</span>
			</p>
		</div>
		<div class="about-profile__rule" aria-hidden="true"></div>
		<p class="about-profile__note">
			我尝试在这里记下自己的所思所想，生活需要记录，记录是为了更好地生活。 很高兴你发现了这里，希望你喜欢我写的内容，也希望你能拥有愉快的一天。
		</p>
		<div class="about-profile__fragments" aria-label="Personal fragments">
			<div>
				<span>Input</span>
				<strong>数码产品 / APP 细节 / AI 工具</strong>
			</div>
			<div>
				<span>Pace</span>
				<strong>力量训练 / 马拉松 / 骑行 / 长时间散步</strong>
			</div>
			<div>
				<span>Temper</span>
				<strong>长期主义 / 混沌中立 / 慢热表达</strong>
			</div>
		</div>
		<div class="about-profile__sections" aria-label="About LynkXu's Blog">
			<section>
				<span>Writing</span>
				<h2>这里会写什么</h2>
				<p>长文、阶段性复盘、生活观察、工具体验、AI 学习，以及旅行和运动记录。内容不追热点，更像持续更新的个人索引。</p>
			</section>
			<section>
				<span>System</span>
				<h2>这个博客如何运转</h2>
				<p>以 Astro 为骨架，连接 Obsidian、Mastodon、NeoDB、Strava 等数据流，把分散在各处的记录汇总到一个长期维护的地方。</p>
			</section>
		</div>
	</section>

	<div slot="sidebar-extra" class="about-rail">
		<section class="magazine-rail-card about-now" aria-labelledby="about-now-title">
			<p id="about-now-title" class="magazine-section-label">Now</p>
			<dl class="about-now-list">
				<div>
					<dt>Base</dt>
					<dd>Shanghai</dd>
				</div>
				<div>
					<dt>Work</dt>
					<dd>Fullstack engineer</dd>
				</div>
			</dl>
		</section>

		<section class="magazine-rail-card about-support-card" aria-labelledby="about-support-title">
			<p id="about-support-title" class="magazine-section-label">Support</p>
			<!-- <h2>Sponsor <span>支持这个博客的长期维护。</span></h2> -->
			<SponsorAbout />
		</section>
	</div>
</MagazineShell>

<style is:global>
	.about-profile {
		display: grid;
		grid-template-columns: minmax(0, 0.82fr) minmax(18rem, 1fr);
		grid-template-areas:
			"label label"
			"title title"
			"lead lead"
			"note note"
			"fragments fragments"
			"rule rule"
			"sections sections";
		column-gap: clamp(1.4rem, 3vw, 2.4rem);
		row-gap: clamp(0.92rem, 1.8vw, 1.24rem);
		min-height: 0;
		padding: clamp(1.2rem, 2.35vw, 1.62rem);
	}

	.about-profile > .magazine-section-label {
		grid-area: label;
	}

	.about-profile h1 {
		grid-area: title;
		margin: 0;
		color: var(--heading-color);
		font-family: var(--ui-font);
		font-size: clamp(1.78rem, 3.4vw, 2.35rem);
		font-weight: var(--weight-bold);
		line-height: 1.15;
		letter-spacing: 0;
	}

	.about-profile__lead {
		grid-area: lead;
		margin-top: 0;
		max-width: 48rem;
		color: var(--text-color);
		font-family: var(--ui-font);
		font-size: clamp(0.98rem, 1.35vw, 1.08rem);
		font-weight: var(--weight-medium);
		line-height: 1.65;
	}

	.about-profile__lead p,
	.about-profile__note {
		margin: 0;
	}

	.about-profile__lead span {
		display: block;
	}

	.about-profile__rule {
		grid-area: rule;
		height: 1px;
		margin: 0.18rem 0 0;
		background: var(--paper-card-border-soft);
	}

	.about-profile__note {
		grid-area: note;
		max-width: 47rem;
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: 0.9rem;
		font-weight: var(--weight-regular);
		line-height: 1.72;
	}

	.about-profile__fragments {
		grid-area: fragments;
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: clamp(0.58rem, 1.35vw, 0.82rem);
		margin-top: 0.04rem;
	}

	.about-profile__fragments div {
		display: flex;
		min-width: 0;
		flex-direction: column;
		gap: 0.3rem;
		padding: 0.68rem 0.72rem;
		border: 1px solid color-mix(in oklab, var(--paper-card-border-soft) 68%, transparent);
		border-radius: var(--paper-card-radius);
		background: color-mix(in oklab, var(--paper-field-bg) 44%, transparent);
	}

	.about-profile__fragments span {
		color: var(--faint-color);
		font-family: var(--field-font);
		font-size: 0.63rem;
		font-weight: var(--weight-medium);
		line-height: 1;
		text-transform: uppercase;
	}

	.about-profile__fragments strong {
		color: color-mix(in oklab, var(--heading-color) 88%, var(--gray-color));
		font-family: var(--ui-font);
		font-size: 0.78rem;
		font-weight: var(--weight-regular);
		line-height: 1.48;
	}

	.about-profile__sections {
		grid-area: sections;
		display: grid;
		grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
		gap: clamp(1.1rem, 2vw, 1.45rem);
	}

	.about-profile__sections section {
		display: flex;
		min-width: 0;
		flex-direction: column;
		gap: 0.4rem;
		padding: 0;
	}

	.about-profile__sections span {
		color: var(--faint-color);
		font-family: var(--field-font);
		font-size: 0.64rem;
		font-weight: var(--weight-medium);
		line-height: 1;
		text-transform: uppercase;
	}

	.about-profile__sections h2 {
		margin: 0;
		color: var(--heading-color);
		font-family: var(--ui-font);
		font-size: 0.98rem;
		font-weight: var(--weight-medium);
		line-height: 1.35;
		letter-spacing: 0;
	}

	.about-profile__sections p {
		margin: 0;
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: 0.84rem;
		font-weight: var(--weight-regular);
		line-height: 1.65;
	}

	.about-rail {
		display: flex;
		flex-direction: column;
		gap: clamp(1.1rem, 2vw, 1.35rem);
	}

	.about-now,
	.about-support-card {
		display: flex;
		flex-direction: column;
		gap: 0.92rem;
	}

	.about-support-card h2 {
		margin: 0;
		color: var(--heading-color);
		font-family: var(--ui-font);
		font-size: 1.16rem;
		font-weight: var(--weight-medium);
		line-height: 1.15;
		letter-spacing: 0;
	}

	.about-now-list {
		display: flex;
		flex-direction: column;
		gap: 0;
		margin: 0;
		font-family: var(--ui-font);
	}

	.about-now-list div {
		display: grid;
		grid-template-columns: 4.5rem minmax(0, 1fr);
		gap: 0.85rem;
		padding: 0.64rem 0;
		border-top: 1px solid color-mix(in oklab, var(--paper-card-border-soft) 72%, transparent);
	}

	.about-now-list div:first-child {
		padding-top: 0;
		border-top: 0;
	}

	.about-now-list dt {
		color: var(--gray-color);
		font-size: 0.78rem;
		font-weight: var(--weight-medium);
		line-height: 1.45;
	}

	.about-now-list dd {
		margin: 0;
		color: var(--heading-color);
		font-size: 0.86rem;
		font-weight: var(--weight-medium);
		line-height: 1.45;
	}

	.about-support-card h2 {
		font-size: 1.08rem;
	}

	.about-support-card h2 span {
		display: block;
		margin-top: 0.35rem;
		color: var(--gray-color);
		font-size: 0.78rem;
		font-weight: var(--weight-regular);
		line-height: 1.55;
	}

	.about-support-card .sponsor-about {
		margin-top: 0;
	}

	@media (max-width: 860px) {
		.about-profile {
			grid-template-columns: 1fr;
			grid-template-areas:
				"label"
				"title"
				"lead"
				"note"
				"fragments"
				"rule"
				"sections";
		}

		.about-profile__note {
			max-width: none;
		}

		.about-profile__fragments {
			grid-template-columns: 1fr;
		}

		.about-profile__sections {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 680px) {
		.about-profile__lead span {
			display: inline;
		}
	}
</style>
