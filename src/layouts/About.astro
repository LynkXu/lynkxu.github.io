---
import MagazineShell from './MagazineShell.astro';
import SponsorAbout from '../components/SponsorAbout.astro';

const { title } = Astro.props;

const blogHistory = [
	{ date: '2026.01', text: '购买 lynkxu.com，自建主题，接入 Memos 等数据流'},
	{ date: '2025.06', text: '使用 Astro + Astro Theme Pure'},
	{ date: '2023.06', text: '使用 Gatsby + Breeze Theme'},
	{ date: '2020.09', text: '使用 GitHub Pages + Hexo' },
	{ date: '2018.09', text: '因域名备案问题博客暂停' },
	{ date: '2016.07', text: '购买 linkblog.com + wordpress 开始搭建博客' },
];

const contactLinks = [
	{ href: 'mailto:xulinxiao@live.com', label: 'Email', value: 'xulinxiao#live.com' },
	{ href: 'https://github.com/LynkXu', label: 'GitHub', value: '@LynkXu', external: true },
	// { href: 'https://x.com/lynkxu', label: 'X', value: '@lynkxu', external: true },
];
---

<MagazineShell title={title} description={title} showProfileCard={false}>
	<section class="about-profile magazine-panel" aria-labelledby="about-title">
		<p class="magazine-section-label">Profile</p>
		<h1 id="about-title">Hi, I am Lynk</h1>
		<div class="about-profile__lead">
			<p>
				<span>一个偏乐观的悲观主义者。</span>
				<span>一个偏现实的理想主义者。</span>
				<span>一个想法很多，但却不善表达的人。</span>
			</p>
		</div>
		<p class="about-profile__note">
			很高兴你发现了这里，希望你喜欢我写的内容，也希望你能拥有愉快的一天。
		</p>
		<div class="about-profile__fragments" aria-label="Personal fragments">
			<div>
				<span>Input</span>
				<strong>Web3 爱好 / APP 体验家 / AI 依赖</strong>
			</div>
			<div>
				<span>Pace</span>
				<strong>力量训练 / 马拉松 / 骑行 / 长时间散步</strong>
			</div>
			<div>
				<span>Temper</span>
				<strong>长期主义 / 混沌中立 / 生人勿近</strong>
			</div>
		</div>
		<div class="about-profile__sections" aria-label="About LynkXu's Blog">
			<section class="about-module about-module--contact">
				<div class="about-module__header">
					<span>Contact</span>
					<h2>联系我</h2>
				</div>
				<div class="about-module__links">
					{contactLinks.map((link) => (
						<a
							href={link.href}
							target={link.external ? '_blank' : undefined}
							rel={link.external ? 'noopener noreferrer' : undefined}
						>
							<span>{link.label}</span>
							<strong>{link.value}</strong>
						</a>
					))}
				</div>
			</section>

			<section class="about-module about-module--support">
				<div class="about-module__header">
					<span>Support</span>
					<h2>Sponsor</h2>
				</div>
				<SponsorAbout />
			</section>
		</div>
	</section>

	<div slot="sidebar-extra" class="about-rail">
		<section class="magazine-rail-card about-now" aria-labelledby="about-now-title">
			<p id="about-now-title" class="magazine-section-label">Now</p>
			<dl class="about-now-list">
				<div>
					<dt>Base</dt>
					<dd>Shanghai</dd>
				</div>
				<div>
					<dt>Work</dt>
					<dd>Fullstack Engineer</dd>
				</div>
			</dl>
		</section>

		<section class="magazine-rail-card about-history-card" aria-labelledby="about-history-title">
			<p id="about-history-title" class="magazine-section-label">Blog History</p>
			<ol class="about-history-list">
				{blogHistory.map((item) => (
					<li>
						<time>{item.date}</time>
						<span>{item.text}</span>
					</li>
				))}
			</ol>
		</section>
	</div>
</MagazineShell>

<style is:global>
	.about-profile {
		display: grid;
		grid-template-columns: minmax(0, 0.82fr) minmax(18rem, 1fr);
		grid-template-areas:
			"label label"
			"title title"
			"lead lead"
			"note note"
			"fragments fragments"
			"sections sections";
		column-gap: clamp(1.4rem, 3vw, 2.4rem);
		row-gap: clamp(0.92rem, 1.8vw, 1.24rem);
		min-height: 0;
		padding: clamp(1.2rem, 2.35vw, 1.62rem);
	}

	.about-profile > .magazine-section-label {
		grid-area: label;
	}

	.about-profile h1 {
		grid-area: title;
		margin: 0;
		color: var(--heading-color);
		font-family: var(--ui-font);
		font-size: clamp(1.78rem, 3.4vw, 2.35rem);
		font-weight: var(--weight-bold);
		line-height: 1.15;
		letter-spacing: 0;
	}

	.about-profile__lead {
		grid-area: lead;
		margin-top: 0;
		max-width: 48rem;
		color: var(--text-color);
		font-family: var(--ui-font);
		font-size: clamp(0.98rem, 1.35vw, 1.08rem);
		font-weight: var(--weight-medium);
		line-height: 1.65;
	}

	.about-profile__lead p,
	.about-profile__note {
		margin: 0;
	}

	.about-profile__lead span {
		display: block;
	}

	.about-profile__note {
		grid-area: note;
		max-width: 47rem;
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: 0.9rem;
		font-weight: var(--weight-regular);
		line-height: 1.72;
	}

	.about-profile__fragments {
		grid-area: fragments;
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: clamp(0.58rem, 1.35vw, 0.82rem);
		margin-top: 0.04rem;
	}

	.about-profile__fragments div {
		display: flex;
		min-width: 0;
		flex-direction: column;
		gap: 0.3rem;
		padding: 0.68rem 0.72rem;
		border: 1px solid color-mix(in oklab, var(--paper-card-border-soft) 68%, transparent);
		border-radius: var(--paper-card-radius);
		background: color-mix(in oklab, var(--paper-field-bg) 44%, transparent);
	}

	.about-profile__fragments span {
		color: var(--faint-color);
		font-family: var(--field-font);
		font-size: 0.63rem;
		font-weight: var(--weight-medium);
		line-height: 1;
		text-transform: uppercase;
	}

	.about-profile__fragments strong {
		color: color-mix(in oklab, var(--heading-color) 88%, var(--gray-color));
		font-family: var(--ui-font);
		font-size: 0.78rem;
		font-weight: var(--weight-regular);
		line-height: 1.48;
	}

	.about-profile__sections {
		grid-area: sections;
		display: grid;
		grid-template-columns: minmax(14rem, 0.86fr) minmax(18rem, 1.14fr);
		gap: clamp(1.2rem, 2.4vw, 1.7rem);
		align-items: start;
		margin-top: 1.2rem;
	}

	.about-module {
		display: flex;
		min-width: 0;
		flex-direction: column;
		gap: 0.72rem;
		padding: 0;
	}

	.about-module__header {
		display: flex;
		flex-direction: column;
		gap: 0.34rem;
	}

	.about-module__header span {
		color: var(--faint-color);
		font-family: var(--field-font);
		font-size: 0.64rem;
		font-weight: var(--weight-medium);
		line-height: 1;
		text-transform: uppercase;
	}

	.about-module__header h2 {
		margin: 0;
		color: var(--heading-color);
		font-family: var(--ui-font);
		font-size: 1rem;
		font-weight: var(--weight-medium);
		line-height: 1.35;
		letter-spacing: 0;
	}

	.about-module p {
		margin: 0;
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: 0.84rem;
		font-weight: var(--weight-regular);
		line-height: 1.65;
	}

	.about-module__links {
		display: flex;
		flex-direction: column;
		gap: 0.55rem;
		margin-top: 0.05rem;
	}

	.about-module__links a {
		display: grid;
		grid-template-columns: 4.2rem minmax(0, 1fr);
		gap: 0.85rem;
		align-items: center;
		min-height: 0;
		padding: 0.55rem 0;
		border: 0 !important;
		border-bottom: 1px solid var(--paper-card-border-soft) !important;
		border-radius: 0;
		background: transparent !important;
		color: inherit;
		font-family: var(--ui-font);
		text-decoration: none;
		transition: color 0.18s ease;
	}

	.about-module__links a:last-child {
		border-bottom: 0 !important;
	}

	.about-module__links span {
		color: var(--gray-color);
		font-size: 0.78rem;
		font-weight: var(--weight-medium);
		line-height: 1.45;
	}

	.about-module__links strong {
		min-width: 0;
		overflow: hidden;
		color: color-mix(in oklab, var(--accent-color) 78%, var(--heading-color));
		font-size: 0.84rem;
		font-weight: var(--weight-medium);
		line-height: 1.45;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.about-module__links a:hover strong {
		color: var(--heading-color);
	}

	.about-module__links a:hover {
		background: transparent !important;
	}

	.about-module--support .sponsor-about {
		margin: 0;
		gap: 0;
		padding: 0;
		border: 0;
		background: transparent;
	}

	.about-module--support .sponsor-fold {
		margin: 0;
		background: transparent;
		border: 0;
		border-bottom: 1px solid var(--paper-card-border-soft);
		border-radius: 0;
	}

	.about-module--support .sponsor-fold:last-child {
		border-bottom: 0;
	}

	.about-module--support .sponsor-fold summary {
		display: flex;
		align-items: center;
		min-height: 0;
		padding: 0.55rem 0;
		color: var(--text-color);
		font-weight: var(--weight-regular);
		background: transparent;
	}

	.about-module--support .sponsor-fold summary:hover {
		color: var(--heading-color);
		background: transparent;
	}

	.about-module--support .sponsor-grid,
	.about-module--support .crypto-list {
		animation: aboutSponsorReveal 0.18s ease-out;
	}

	@keyframes aboutSponsorReveal {
		from {
			opacity: 0;
			transform: translateY(-0.25rem);
		}

		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.about-rail {
		display: flex;
		flex-direction: column;
		gap: clamp(1.1rem, 2vw, 1.35rem);
	}

	.about-now,
	.about-history-card {
		display: flex;
		flex-direction: column;
		gap: 0.92rem;
	}

	.about-history-card h2,
	.about-support-card h2 {
		margin: 0;
		color: var(--heading-color);
		font-family: var(--ui-font);
		font-size: 1.16rem;
		font-weight: var(--weight-medium);
		line-height: 1.15;
		letter-spacing: 0;
	}

	.about-history-card h2 {
		font-size: 1rem;
	}

	.about-history-card p {
		margin: 0;
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: 0.8rem;
		font-weight: var(--weight-regular);
		line-height: 1.62;
	}

	.about-history-list {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 0;
		margin: 0;
		padding: 0 0 0 1.15rem;
		list-style: none;
		font-family: var(--ui-font);
	}

	.about-history-list::before {
		position: absolute;
		top: 0.35rem;
		bottom: 0.55rem;
		left: 0.2rem;
		width: 1px;
		background: var(--paper-card-border-soft);
		content: "";
	}

	.about-history-list li {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		padding: 0.58rem 0;
		border-top: 1px solid var(--paper-card-border-soft);
	}

	.about-history-list li:first-child {
		padding-top: 0;
		border-top: 0;
	}

	.about-history-list li::before {
		position: absolute;
		top: 0.72rem;
		left: -1.05rem;
		width: 0.28rem;
		height: 0.28rem;
		border-radius: 999px;
		background: color-mix(in oklab, var(--accent-color) 55%, var(--paper-card-border-soft));
		content: "";
	}

	.about-history-list li:first-child::before {
		top: 0.14rem;
	}

	.about-history-list time {
		color: var(--faint-color);
		font-size: 0.68rem;
		font-weight: var(--weight-medium);
		line-height: 1;
		letter-spacing: 0.02em;
	}

	.about-history-list span {
		color: var(--text-color);
		font-size: 0.8rem;
		font-weight: var(--weight-regular);
		line-height: 1.5;
	}

	.about-now-list {
		display: flex;
		flex-direction: column;
		gap: 0;
		margin: 0;
		font-family: var(--ui-font);
	}

	.about-now-list div {
		display: grid;
		grid-template-columns: 4.5rem minmax(0, 1fr);
		gap: 0.85rem;
		padding: 0.64rem 0;
		border-top: 1px solid color-mix(in oklab, var(--paper-card-border-soft) 72%, transparent);
	}

	.about-now-list div:first-child {
		padding-top: 0;
		border-top: 0;
	}

	.about-now-list dt {
		color: var(--gray-color);
		font-size: 0.78rem;
		font-weight: var(--weight-medium);
		line-height: 1.45;
	}

	.about-now-list dd {
		margin: 0;
		color: var(--heading-color);
		font-size: 0.86rem;
		font-weight: var(--weight-medium);
		line-height: 1.45;
	}

	.about-support-card h2 {
		font-size: 1.08rem;
	}

	.about-support-card h2 span {
		display: block;
		margin-top: 0.35rem;
		color: var(--gray-color);
		font-size: 0.78rem;
		font-weight: var(--weight-regular);
		line-height: 1.55;
	}

	.about-support-card .sponsor-about {
		margin-top: 0;
	}

	@media (max-width: 860px) {
		.about-profile {
			grid-template-columns: 1fr;
			grid-template-areas:
				"label"
				"title"
				"lead"
				"note"
				"fragments"
				"rule"
				"sections";
		}

		.about-profile__note {
			max-width: none;
		}

		.about-profile__fragments {
			grid-template-columns: 1fr;
		}

		.about-profile__sections {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 680px) {
		.about-profile__lead span {
			display: inline;
		}
	}
</style>

<style is:global>
	.about-profile {
		display: block;
		padding: 0;
	}

	.about-profile > .magazine-section-label {
		margin-bottom: 0.9rem;
		padding-bottom: 0.65rem;
		border-bottom: 1px solid var(--paper-card-border-soft);
	}

	.about-profile h1 {
		margin: 0 0 1.2rem;
		color: var(--heading-color);
		font-size: clamp(2rem, 5vw, 3.4rem);
		font-weight: var(--weight-semibold);
		line-height: 1.08;
	}

	.about-profile__lead {
		max-width: 42rem;
		color: var(--text-color);
		font-size: clamp(1rem, 1.45vw, 1.08rem);
		font-weight: var(--weight-regular);
		line-height: 1.85;
	}

	.about-profile__note {
		max-width: 42rem;
		margin-top: 1.2rem;
		color: var(--gray-color);
		font-size: 0.96rem;
		line-height: 1.82;
	}

	.about-profile__fragments {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0;
		max-width: 42rem;
		margin-top: clamp(1.4rem, 3vw, 2.2rem);
		border-top: 1px solid var(--paper-card-border-soft);
	}

	.about-profile__fragments div {
		display: grid;
		grid-template-columns: 5.5rem minmax(0, 1fr);
		gap: 1rem;
		padding: 0.72rem 0;
		border: 0;
		border-bottom: 1px solid var(--paper-card-border-soft);
		border-radius: 0;
		background: transparent;
	}

	.about-profile__fragments span {
		color: var(--gray-color);
		font-size: 0.72rem;
		font-weight: var(--weight-regular);
		text-transform: none;
	}

	.about-profile__fragments strong {
		color: var(--text-color);
		font-size: 0.9rem;
		font-weight: var(--weight-regular);
		line-height: 1.55;
	}

	.about-profile__sections {
		display: grid;
		grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
		gap: clamp(1.6rem, 4vw, 3rem);
		max-width: 46rem;
		margin-top: clamp(1.8rem, 4vw, 3rem);
		padding-top: clamp(1rem, 3vw, 1.6rem);
		border-top: 1px solid var(--paper-card-border-soft);
	}

	.about-module__header span {
		color: var(--gray-color);
		font-size: 0.72rem;
		font-weight: var(--weight-medium);
		letter-spacing: 0.04em;
	}

	.about-module__header h2 {
		font-size: 1rem;
		font-weight: var(--weight-medium);
	}

	.about-module__links a {
		min-height: 0;
		padding: 0.5rem 0;
		border: 0 !important;
		border-bottom: 1px solid var(--paper-card-border-soft) !important;
		border-radius: 0;
		background: transparent !important;
	}

	.about-module__links span,
	.about-module__links strong {
		font-weight: var(--weight-regular);
	}

	.about-module__links strong {
		color: var(--heading-color);
	}

	.about-module--support .sponsor-fold {
		border-radius: 0;
		background: transparent;
	}

	.about-module--support .sponsor-fold summary {
		min-height: 0;
		padding: 0.5rem 0;
		font-weight: var(--weight-regular);
	}

	.about-rail {
		gap: 1.5rem;
	}

	.about-now,
	.about-history-card {
		gap: 0.85rem;
	}

	.about-now-list div {
		grid-template-columns: 4.4rem minmax(0, 1fr);
		padding: 0.55rem 0;
		border-top: 1px solid var(--paper-card-border-soft);
	}

	.about-now-list dt,
	.about-now-list dd {
		font-size: 0.78rem;
		font-weight: var(--weight-regular);
	}

	.about-history-list {
		position: relative;
		gap: 0;
		padding-left: 1.15rem;
	}

	.about-history-list::before {
		position: absolute;
		top: 0.35rem;
		bottom: 0.55rem;
		left: 0.2rem;
		width: 1px;
		background: var(--paper-card-border-soft);
		content: "";
	}

	.about-history-list li {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
		padding: 0.58rem 0;
		border-top: 1px solid var(--paper-card-border-soft);
	}

	.about-history-list li:first-child {
		padding-top: 0;
		border-top: 0;
	}

	.about-history-list li::before {
		position: absolute;
		top: 0.72rem;
		left: -1.05rem;
		width: 0.28rem;
		height: 0.28rem;
		border-radius: 999px;
		background: color-mix(in oklab, var(--accent-color) 55%, var(--paper-card-border-soft));
		content: "";
	}

	.about-history-list li:first-child::before {
		top: 0.14rem;
	}

	.about-history-list time {
		color: var(--faint-color);
		font-size: 0.68rem;
		font-weight: var(--weight-medium);
		line-height: 1;
		letter-spacing: 0.02em;
	}

	.about-history-list span {
		color: var(--text-color);
		font-size: 0.8rem;
		font-weight: var(--weight-regular);
		line-height: 1.5;
	}

	@media (max-width: 760px) {
		.about-profile__sections {
			grid-template-columns: 1fr;
		}

		.about-profile__fragments div {
			grid-template-columns: 1fr;
			gap: 0.25rem;
		}
	}
</style>
