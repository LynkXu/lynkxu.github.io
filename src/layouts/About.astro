---
import MagazineShell from './MagazineShell.astro';
import SponsorAbout from '../components/SponsorAbout.astro';

const { title } = Astro.props;

const blogHistory = [
	{ date: '2026.01', text: '购买 lynkxu.com，自建主题，接入 Memos 等数据流'},
	{ date: '2025.06', text: '使用 Astro + Astro Theme Pure'},
	{ date: '2023.06', text: '使用 Gatsby + Breeze Theme'},
	{ date: '2020.09', text: '使用 GitHub Pages + Hexo' },
	{ date: '2018.09', text: '因域名备案问题博客暂停' },
	{ date: '2016.07', text: '购买 linkblog.com + wordpress 开始搭建博客' },
];

const contactLinks = [
	{ href: 'mailto:xulinxiao@live.com', label: 'Email', value: 'xulinxiao#live.com' },
	{ href: 'https://github.com/LynkXu', label: 'GitHub', value: '@LynkXu', external: true },
	// { href: 'https://x.com/lynkxu', label: 'X', value: '@lynkxu', external: true },
];
---

<MagazineShell title={title} description={title} showProfileCard={false}>
	<section class="about-profile magazine-panel" aria-labelledby="about-title">
		<p class="magazine-section-label">简介</p>
		<h1 id="about-title">Hi, I am Lynk</h1>
		<div class="about-profile__lead">
			<p>
				<span>一个偏乐观的悲观主义者。</span>
				<span>一个偏现实的理想主义者。</span>
				<span>一个想法很多，但却不善表达的人。</span>
			</p>
		</div>
		<p class="about-profile__note">
			很高兴你发现了这里，希望你喜欢我写的内容，也希望你能拥有愉快的一天。
		</p>
		<div class="about-profile__fragments" aria-label="个人片段">
			<div>
				<span>输入</span>
				<strong>Web3 爱好 / APP 体验家 / AI 依赖</strong>
			</div>
			<div>
				<span>节奏</span>
				<strong>力量训练 / 马拉松 / 骑行 / 散步</strong>
			</div>
			<div>
				<span>性情</span>
				<strong>长期主义 / 混沌中立 / 生人勿近</strong>
			</div>
		</div>
		<div class="about-profile__sections" aria-label="关于 LynkXu's Blog">
			<section class="about-module about-module--contact">
				<div class="about-module__header">
					<span>联系</span>
					<h2>联系我</h2>
				</div>
				<div class="about-module__links">
					{contactLinks.map((link) => (
						<a
							href={link.href}
							target={link.external ? '_blank' : undefined}
							rel={link.external ? 'noopener noreferrer' : undefined}
						>
							<span>{link.label}</span>
							<strong>{link.value}</strong>
						</a>
					))}
				</div>
			</section>

			<section class="about-module about-module--support">
				<div class="about-module__header">
					<span>支持</span>
					<h2>赞助</h2>
				</div>
				<SponsorAbout />
			</section>
		</div>
	</section>

	<div slot="sidebar-extra" class="about-rail">
		<section class="magazine-rail-card about-now" aria-labelledby="about-now-title">
			<p id="about-now-title" class="magazine-section-label">此刻</p>
			<dl class="about-now-list">
				<div>
					<dt>所在</dt>
					<dd>上海</dd>
				</div>
				<div>
					<dt>工作</dt>
					<dd>全栈工程师</dd>
				</div>
			</dl>
		</section>

		<section class="magazine-rail-card about-history-card" aria-labelledby="about-history-title">
			<p id="about-history-title" class="magazine-section-label">博客历程</p>
			<ol class="about-history-list">
				{blogHistory.map((item) => (
					<li>
						<time>{item.date}</time>
						<span>{item.text}</span>
					</li>
				))}
			</ol>
		</section>
	</div>
</MagazineShell>

<style is:global>
	.about-profile {
		display: block;
		padding: 0;
	}

	.about-profile > .magazine-section-label {
		margin-bottom: 0.75rem;
		padding-bottom: 0.55rem;
		border-bottom: 1px solid var(--paper-card-border-soft);
	}

	.about-profile h1 {
		margin: 0 0 0.9rem;
		color: var(--heading-color);
		font-family: var(--display-font);
		font-size: clamp(1.85rem, 4.2vw, 2.75rem);
		font-weight: var(--weight-semibold, 600);
		line-height: 1.12;
		letter-spacing: -0.01em;
	}

	.about-profile__lead {
		max-width: 42rem;
		color: var(--text-color);
		font-family: var(--reading-font, var(--serif-font));
		font-size: clamp(0.98rem, 1.35vw, 1.06rem);
		font-weight: var(--weight-regular);
		line-height: 1.82;
	}

	.about-profile__lead p,
	.about-profile__note {
		margin: 0;
	}

	.about-profile__lead span {
		display: block;
	}

	.about-profile__note {
		max-width: 42rem;
		margin-top: 0.85rem;
		color: var(--gray-color);
		font-family: var(--reading-font, var(--serif-font));
		font-size: 0.92rem;
		font-weight: var(--weight-regular);
		line-height: 1.78;
	}

	.about-profile__fragments {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0;
		max-width: 42rem;
		margin-top: clamp(1.1rem, 2.4vw, 1.6rem);
		border-top: 1px solid var(--paper-card-border-soft);
	}

	.about-profile__fragments div {
		display: grid;
		grid-template-columns: 5rem minmax(0, 1fr);
		gap: 0.85rem;
		padding: 0.62rem 0;
		border: 0;
		border-bottom: 1px solid var(--paper-card-border-soft);
		border-radius: 0;
		background: transparent;
	}

	.about-profile__fragments span {
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: 0.72rem;
		font-weight: var(--weight-regular);
		line-height: 1.45;
	}

	.about-profile__fragments strong {
		color: var(--text-color);
		font-family: var(--ui-font);
		font-size: 0.88rem;
		font-weight: var(--weight-regular);
		line-height: 1.55;
	}

	.about-profile__sections {
		display: grid;
		grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
		gap: clamp(1.4rem, 3.2vw, 2.4rem);
		max-width: 46rem;
		margin-top: clamp(1.3rem, 3vw, 2rem);
		padding-top: clamp(0.9rem, 2.2vw, 1.3rem);
		border-top: 1px solid var(--paper-card-border-soft);
	}

	.about-module {
		display: flex;
		min-width: 0;
		flex-direction: column;
		gap: 0.55rem;
		padding: 0;
	}

	.about-module__header {
		display: flex;
		flex-direction: column;
		gap: 0.28rem;
	}

	.about-module__header span {
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: 0.7rem;
		font-weight: var(--weight-medium);
		line-height: 1;
		letter-spacing: 0.04em;
	}

	.about-module__header h2 {
		margin: 0;
		color: var(--heading-color);
		font-family: var(--display-font);
		font-size: 1rem;
		font-weight: var(--weight-medium);
		line-height: 1.35;
		letter-spacing: 0;
	}

	.about-module__links {
		display: flex;
		flex-direction: column;
		gap: 0;
		margin-top: 0.1rem;
	}

	.about-module__links a {
		display: grid;
		grid-template-columns: 4.2rem minmax(0, 1fr);
		gap: 0.75rem;
		align-items: center;
		min-height: 0;
		padding: 0.5rem 0;
		border: 0 !important;
		border-bottom: 1px solid var(--paper-card-border-soft) !important;
		border-radius: 0;
		background: transparent !important;
		color: inherit;
		font-family: var(--ui-font);
		text-decoration: none;
		transition: color 0.18s ease;
	}

	.about-module__links a:last-child {
		border-bottom: 0 !important;
	}

	.about-module__links span {
		color: var(--gray-color);
		font-size: 0.76rem;
		font-weight: var(--weight-regular);
		line-height: 1.45;
	}

	.about-module__links strong {
		min-width: 0;
		overflow: hidden;
		color: var(--heading-color);
		font-size: 0.84rem;
		font-weight: var(--weight-regular);
		line-height: 1.45;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.about-module__links a:hover strong {
		color: var(--accent-color);
	}

	.about-module__links a:hover {
		background: transparent !important;
	}

	.about-module--support .sponsor-about {
		margin: 0;
		gap: 0;
		padding: 0;
		border: 0;
		background: transparent;
	}

	.about-module--support .sponsor-fold {
		margin: 0;
		background: transparent;
		border: 0;
		border-bottom: 1px solid var(--paper-card-border-soft);
		border-radius: 0;
	}

	.about-module--support .sponsor-fold:last-child {
		border-bottom: 0;
	}

	.about-module--support .sponsor-fold summary {
		display: flex;
		align-items: center;
		min-height: 0;
		padding: 0.5rem 0;
		color: var(--text-color);
		font-family: var(--ui-font);
		font-weight: var(--weight-regular);
		background: transparent;
	}

	.about-module--support .sponsor-fold summary:hover {
		color: var(--heading-color);
		background: transparent;
	}

	.about-rail {
		display: flex;
		flex-direction: column;
		gap: 1.35rem;
	}

	.about-now,
	.about-history-card {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.about-now-list {
		display: flex;
		flex-direction: column;
		gap: 0;
		margin: 0;
		font-family: var(--ui-font);
	}

	.about-now-list div {
		display: grid;
		grid-template-columns: 4.4rem minmax(0, 1fr);
		gap: 0.75rem;
		padding: 0.5rem 0;
		border-top: 1px solid var(--paper-card-border-soft);
	}

	.about-now-list div:first-child {
		padding-top: 0;
		border-top: 0;
	}

	.about-now-list dt {
		color: var(--gray-color);
		font-size: 0.76rem;
		font-weight: var(--weight-regular);
		line-height: 1.45;
	}

	.about-now-list dd {
		margin: 0;
		color: var(--heading-color);
		font-size: 0.84rem;
		font-weight: var(--weight-regular);
		line-height: 1.45;
	}

	.about-history-list {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 0;
		margin: 0;
		padding: 0 0 0 1.05rem;
		list-style: none;
		font-family: var(--ui-font);
	}

	.about-history-list::before {
		position: absolute;
		top: 0.3rem;
		bottom: 0.45rem;
		left: 0.18rem;
		width: 1px;
		background: var(--paper-card-border-soft);
		content: "";
	}

	.about-history-list li {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
		padding: 0.5rem 0;
		border-top: 1px solid var(--paper-card-border-soft);
	}

	.about-history-list li:first-child {
		padding-top: 0;
		border-top: 0;
	}

	.about-history-list li::before {
		position: absolute;
		top: 0.68rem;
		left: -0.96rem;
		width: 0.22rem;
		height: 0.22rem;
		border-radius: 50%;
		background: color-mix(in oklab, var(--accent-color) 45%, var(--paper-card-border-soft));
		content: "";
	}

	.about-history-list li:first-child::before {
		top: 0.12rem;
	}

	.about-history-list time {
		color: var(--faint-color);
		font-size: 0.66rem;
		font-weight: var(--weight-medium);
		line-height: 1;
		letter-spacing: 0.02em;
	}

	.about-history-list span {
		color: var(--text-color);
		font-size: 0.78rem;
		font-weight: var(--weight-regular);
		line-height: 1.5;
	}

	@media (max-width: 760px) {
		.about-profile__sections {
			grid-template-columns: 1fr;
		}

		.about-profile__fragments div {
			grid-template-columns: 1fr;
			gap: 0.2rem;
		}
	}

	@media (max-width: 680px) {
		.about-profile__lead span {
			display: inline;
		}
	}
</style>
