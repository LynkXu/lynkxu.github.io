---
import MagazineShell from './MagazineShell.astro';
import ListingFrame from '../components/ListingFrame.astro';

const { title } = Astro.props;
---

<MagazineShell title={title} description={title}>
	<ListingFrame
		eyebrow="Colophon"
		title="About"
		description="A small profile, a few notes, and some coordinates for this site."
		className="about-frame"
	>
		<div class="about-hero">
			<div class="about-hero__copy">
				<h2 class="about-hero__title">👋 Hi, I am Lynk</h2>
				<div class="about-hero__intro">
					<p class="about-hero__lines">
						<span>一个偏乐观的悲观主义者。</span>
						<span>一个偏现实的理想主义者。</span>
						<span>一个想法很多，但却不善表达的人。</span>
					</p>
					<p>
						我尝试在这里记下自己的所思所想，生活需要记录，记录是为了更好地生活。
						很高兴你发现了这里，希望你喜欢我写的内容，也希望你能拥有愉快的一天。
					</p>
				</div>
			</div>
			<dl class="about-hero__meta" aria-label="Profile summary">
				<div>
					<dt>Base</dt>
					<dd>Shanghai</dd>
				</div>
				<div>
					<dt>Work</dt>
					<dd>Fullstack Engineer</dd>
				</div>
				<div>
					<dt>Rhythm</dt>
					<dd>Training · Reading · Wandering</dd>
				</div>
			</dl>
		</div>
		<div class="about-sheet">
			<slot />
		</div>
	</ListingFrame>
</MagazineShell>

<style is:global>
	/* About hero */
	.about-hero {
		position: relative;
		display: grid;
		grid-template-columns: minmax(0, 1.35fr) minmax(13rem, 0.75fr);
		gap: clamp(0.9rem, 2.4vw, 1.35rem);
		align-items: end;
		border-bottom: 1px solid color-mix(in oklab, var(--paper-card-border-soft) 48%, transparent);
		padding: 0 0 clamp(0.88rem, 2vw, 1.12rem);
		animation: fade-up 0.5s ease-out both;
	}

	.about-hero__copy {
		max-width: none;
	}

	.about-hero__title {
		margin: 0;
		font-family: var(--serif-font);
		font-size: clamp(1.18rem, 1.9vw, 1.42rem);
		font-weight: 500;
		color: var(--heading-color);
		line-height: 1.26;
	}

	.about-hero__intro {
		margin: 0.42rem 0 0;
		font-size: 0.84rem;
		color: color-mix(in oklab, var(--text-color) 70%, var(--gray-color));
		line-height: 1.66;
	}

	.about-hero__intro p {
		margin: 0;
	}

	.about-hero__intro p + p {
		margin-top: 0.5rem;
		max-width: 72ch;
	}

	.about-hero__lines {
		display: flex;
		flex-direction: column;
		gap: 0.08rem;
	}

	.about-hero__meta {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0;
		margin: 0;
		padding: 0.54rem 0.68rem;
		border: 1px solid color-mix(in oklab, var(--paper-card-border-soft) 58%, transparent);
		border-radius: var(--paper-card-radius);
		background: color-mix(in oklab, var(--paper-field-bg) 54%, transparent);
	}

	.about-hero__meta div {
		min-width: 0;
		display: grid;
		grid-template-columns: 4rem minmax(0, 1fr);
		gap: 0.62rem;
		align-items: baseline;
		padding: 0.28rem 0;
		border-bottom: 1px solid color-mix(in oklab, var(--paper-card-border-soft) 34%, transparent);
	}

	.about-hero__meta div:last-child {
		border-bottom: none;
	}

	.about-hero__meta dt,
	.about-hero__meta dd {
		margin: 0;
	}

	.about-hero__meta dt {
		font-family: var(--field-font);
		font-size: 0.62rem;
		font-weight: 500;
		letter-spacing: 0.04em;
		color: color-mix(in oklab, var(--gray-color) 92%, var(--heading-color));
		line-height: 1.28;
	}

	.about-hero__meta dd {
		margin-top: 0;
		font-family: var(--serif-font);
		font-size: 0.82rem;
		font-weight: 400;
		color: color-mix(in oklab, var(--heading-color) 84%, var(--text-color));
		line-height: 1.28;
	}

	/* About sheet sits directly in magazine-main; let inner cards breathe */
	.about-sheet {
		display: flex;
		flex-direction: column;
		gap: clamp(0.78rem, 1.8vw, 1rem);
		padding-top: clamp(0.62rem, 1.5vw, 0.82rem);
		animation: fade-up 0.5s ease-out 0.08s both;
	}

	.about-sheet > :first-child {
		animation: fade-up 0.5s ease-out 0.14s both;
	}

	.about-sheet > :nth-child(2) {
		animation: fade-up 0.5s ease-out 0.2s both;
	}

	.about-sheet > :nth-child(3) {
		animation: fade-up 0.5s ease-out 0.26s both;
	}

	@media (prefers-reduced-motion: reduce) {
		.about-hero,
		.about-sheet,
		.about-sheet > * {
			animation: none;
		}
	}

	@media (max-width: 640px) {
		.about-hero {
			grid-template-columns: 1fr;
			align-items: stretch;
		}

		.about-hero__meta {
			grid-template-columns: 1fr;
		}

		.about-hero__meta dd {
			margin-top: 0.2rem;
		}
	}
</style>
