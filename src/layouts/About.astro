---
import MagazineShell from './MagazineShell.astro';
import SponsorAbout from '../components/SponsorAbout.astro';

const { title } = Astro.props;

const blogHistory = [
	{ date: '2026.01', text: '购买 lynkxu.com，自建主题，接入 Memos 等数据流'},
	{ date: '2025.06', text: '使用 Astro + Astro Theme Pure'},
	{ date: '2023.06', text: '使用 Gatsby + Breeze Theme'},
	{ date: '2020.09', text: '使用 GitHub Pages + Hexo' },
	{ date: '2018.09', text: '因域名备案问题博客暂停' },
	{ date: '2016.07', text: '购买 linkblog.com + wordpress 开始搭建博客' },
];

const contactLinks = [
	{ href: 'mailto:xulinxiao@live.com', label: 'Email', value: 'xulinxiao#live.com' },
	{ href: 'https://github.com/LynkXu', label: 'GitHub', value: '@LynkXu', external: true },
];
---

<MagazineShell title={title} description={title} showProfileCard={false}>
	<section class="about-profile postcard-sheet" aria-labelledby="about-title">
		<header class="about-profile__head">
			<p class="magazine-section-label">Profile</p>
			<h1 id="about-title">Hi, I am Lynk</h1>
		</header>
		<div class="about-profile__lead">
			<p>
				<span>一个偏乐观的悲观主义者。</span>
				<span>一个偏现实的理想主义者。</span>
				<span>一个想法很多，但却不善表达的人。</span>
			</p>
		</div>
		<p class="about-profile__note">
			很高兴你发现了这里，希望你喜欢我写的内容，也希望你能拥有愉快的一天。
		</p>
		<div class="about-profile__fragments" aria-label="个人片段">
			<div>
				<span class="dispatch-field__label">Input</span>
				<strong>Web3 爱好 / APP 体验 / AI 依赖</strong>
			</div>
			<div>
				<span class="dispatch-field__label">Pace</span>
				<strong>力量训练 / 马拉松 / 骑行 / 散步</strong>
			</div>
			<div>
				<span class="dispatch-field__label">Temper</span>
				<strong>长期主义 / 混沌中立 / 生人勿近</strong>
			</div>
		</div>
		<div class="about-profile__sections" aria-label="关于 LynkXu's Blog">
			<section class="about-module about-module--contact">
				<div class="about-module__header">
					<span class="dispatch-field__label">Contact</span>
					<h2>联系我</h2>
				</div>
				<div class="about-module__links">
					{contactLinks.map((link) => (
						<a
							href={link.href}
							target={link.external ? '_blank' : undefined}
							rel={link.external ? 'noopener noreferrer' : undefined}
						>
							<span class="dispatch-field__label">{link.label}</span>
							<strong>{link.value}</strong>
						</a>
					))}
				</div>
			</section>

			<section class="about-module about-module--support">
				<div class="about-module__header">
					<span class="dispatch-field__label">Support</span>
					<h2>赞助</h2>
				</div>
				<SponsorAbout />
			</section>
		</div>
	</section>

	<div slot="sidebar-extra" class="about-rail">
		<section class="magazine-rail-card about-now" aria-labelledby="about-now-title">
			<p id="about-now-title" class="magazine-section-label">Now</p>
			<dl class="about-now-list">
				<div>
					<dt class="dispatch-field__label">Place</dt>
					<dd>上海</dd>
				</div>
				<div>
					<dt class="dispatch-field__label">Work</dt>
					<dd>全栈工程师</dd>
				</div>
			</dl>
		</section>

		<section class="magazine-rail-card about-history-card" aria-labelledby="about-history-title">
			<p id="about-history-title" class="magazine-section-label">History</p>
			<ol class="about-history-list">
				{blogHistory.map((item) => (
					<li>
						<time class="dispatch-field__value">{item.date}</time>
						<span>{item.text}</span>
					</li>
				))}
			</ol>
		</section>
	</div>
</MagazineShell>

<style is:global>
	.about-profile {
		max-width: var(--blog-content-max, 46rem);
		padding: clamp(1.25rem, 2.8vw, 1.85rem);
	}

	.about-profile__head {
		display: flex;
		flex-direction: column;
		gap: 0.55rem;
		margin-bottom: 1.15rem;
		padding-bottom: 0.9rem;
		border-bottom: 1px solid var(--sheet-edge);
	}

	.about-profile__head .magazine-section-label {
		font-family: var(--field-font);
		font-size: 0.62rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--faint-color);
	}

	.about-profile h1 {
		margin: 0;
		color: var(--heading-color);
		font-family: var(--display-font);
		font-size: clamp(1.85rem, 3.6vw, 2.45rem);
		font-weight: 600;
		line-height: 1.12;
		letter-spacing: -0.02em;
	}

	.about-profile__lead {
		max-width: 100%;
		color: var(--text-color);
		font-family: var(--reading-font);
		font-size: clamp(0.98rem, 1.35vw, 1.08rem);
		font-weight: var(--weight-regular);
		line-height: 1.75;
	}

	.about-profile__lead p,
	.about-profile__note {
		margin: 0;
	}

	.about-profile__lead span {
		display: block;
	}

	.about-profile__note {
		max-width: 100%;
		margin-top: 0.95rem;
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: 0.9rem;
		line-height: 1.72;
	}

	.about-profile__fragments {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 0.65rem;
		margin-top: clamp(1.25rem, 2.8vw, 1.7rem);
		padding-top: clamp(1rem, 2.2vw, 1.3rem);
		border-top: 1px dashed color-mix(in oklab, var(--sheet-edge) 75%, transparent);
	}

	.about-profile__fragments div {
		display: flex;
		min-width: 0;
		flex-direction: column;
		gap: 0.35rem;
		padding: 0.65rem 0.7rem;
		border: 1px solid color-mix(in oklab, var(--sheet-edge) 70%, transparent);
		border-radius: var(--paper-card-radius);
		background: var(--paper-field-bg);
	}

	.about-profile__fragments strong {
		color: color-mix(in oklab, var(--heading-color) 88%, var(--gray-color));
		font-family: var(--ui-font);
		font-size: 0.78rem;
		font-weight: var(--weight-regular);
		line-height: 1.48;
	}

	.about-profile__sections {
		display: grid;
		grid-template-columns: minmax(14rem, 0.86fr) minmax(18rem, 1.14fr);
		gap: clamp(1.2rem, 2.4vw, 1.7rem);
		align-items: start;
		margin-top: 1.35rem;
		padding-top: 1.15rem;
		border-top: 1px solid var(--sheet-edge);
	}

	.about-module {
		display: flex;
		min-width: 0;
		flex-direction: column;
		gap: 0.72rem;
		padding: 0;
	}

	.about-module__header {
		display: flex;
		flex-direction: column;
		gap: 0.34rem;
	}

	.about-module__header h2 {
		margin: 0;
		color: var(--heading-color);
		font-family: var(--display-font);
		font-size: 1.05rem;
		font-weight: 500;
		line-height: 1.35;
		letter-spacing: -0.01em;
	}

	.about-module__links {
		display: flex;
		flex-direction: column;
		gap: 0;
		margin-top: 0.05rem;
	}

	.about-module__links a {
		display: grid;
		grid-template-columns: 4.2rem minmax(0, 1fr);
		gap: 0.85rem;
		align-items: baseline;
		min-height: 0;
		padding: 0.55rem 0;
		border: 0 !important;
		border-bottom: 1px solid var(--paper-card-border-soft) !important;
		border-radius: 0;
		background: transparent !important;
		color: inherit;
		font-family: var(--ui-font);
		text-decoration: none;
	}

	.about-module__links a:last-child {
		border-bottom: 0 !important;
	}

	.about-module__links strong {
		min-width: 0;
		overflow: hidden;
		color: color-mix(in oklab, var(--heading-color) 88%, var(--accent-color));
		font-size: 0.84rem;
		font-weight: var(--weight-medium);
		line-height: 1.45;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.about-module__links a:hover strong {
		color: var(--heading-color);
	}

	.about-module--support .sponsor-about {
		margin: 0;
		gap: 0;
		padding: 0;
		border: 0;
		background: transparent;
	}

	.about-module--support .sponsor-fold {
		margin: 0;
		background: transparent;
		border: 0;
		border-bottom: 1px solid var(--paper-card-border-soft);
		border-radius: 0;
	}

	.about-module--support .sponsor-fold:last-child {
		border-bottom: 0;
	}

	.about-module--support .sponsor-fold summary {
		display: flex;
		align-items: center;
		min-height: 0;
		padding: 0.55rem 0;
		color: var(--text-color);
		font-weight: var(--weight-regular);
		background: transparent;
	}

	.about-rail {
		display: flex;
		flex-direction: column;
		gap: clamp(1.35rem, 2.4vw, 1.75rem);
	}

	.about-now,
	.about-history-card {
		display: flex;
		flex-direction: column;
		gap: 0.85rem;
	}

	.about-history-list {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 0;
		margin: 0;
		padding: 0 0 0 1.05rem;
		list-style: none;
		font-family: var(--ui-font);
	}

	.about-history-list::before {
		position: absolute;
		top: 0.3rem;
		bottom: 0.45rem;
		left: 0.18rem;
		width: 1px;
		background: var(--paper-card-border-soft);
		content: "";
	}

	.about-history-list li {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
		padding: 0.5rem 0;
		border-top: 1px solid var(--paper-card-border-soft);
	}

	.about-history-list li:first-child {
		padding-top: 0;
		border-top: 0;
	}

	.about-history-list li::before {
		position: absolute;
		top: 0.68rem;
		left: -0.96rem;
		width: 0.22rem;
		height: 0.22rem;
		border-radius: 50%;
		background: color-mix(in oklab, var(--accent-color) 45%, var(--paper-card-border-soft));
		content: "";
	}

	.about-history-list li:first-child::before {
		top: 0.12rem;
	}

	.about-history-list time {
		color: var(--faint-color);
		font-family: var(--field-font);
		font-size: 0.66rem;
		font-weight: var(--weight-medium);
		line-height: 1;
		letter-spacing: 0.02em;
	}

	.about-history-list span {
		color: var(--text-color);
		font-size: 0.78rem;
		font-weight: var(--weight-regular);
		line-height: 1.5;
	}

	.about-now-list {
		display: flex;
		flex-direction: column;
		gap: 0;
		margin: 0;
		font-family: var(--ui-font);
	}

	.about-now-list div {
		display: grid;
		grid-template-columns: 4.2rem minmax(0, 1fr);
		gap: 0.75rem;
		align-items: baseline;
		padding: 0.55rem 0;
		border-top: 1px solid var(--paper-card-border-soft);
	}

	.about-now-list div:first-child {
		padding-top: 0;
		border-top: 0;
	}

	.about-now-list dd {
		margin: 0;
		color: var(--heading-color);
		font-size: 0.82rem;
		font-weight: var(--weight-medium);
		line-height: 1.45;
	}

	@media (max-width: 860px) {
		.about-profile__fragments {
			grid-template-columns: 1fr;
		}

		.about-profile__sections {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 680px) {
		.about-profile__lead span {
			display: inline;
		}
	}
</style>
