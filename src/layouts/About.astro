---
import Base from './Base.astro';
import TaxonomyHero from '../components/TaxonomyHero.astro';

const { title } = Astro.props;
---

<Base title={title} description={title} className="blog-surface-layout">
	<div class="content-limit-width about-index">
		<TaxonomyHero
			title="👋Hi, I am Lynk"
			description="有些话适合当面说，有些话适合走很远之后，再慢慢写下来。"
		/>

		<div class="about-sheet">
			<slot />
		</div>
	</div>
</Base>
