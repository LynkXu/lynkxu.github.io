---
import Base from './Base.astro';
import TaxonomyHero from '../components/TaxonomyHero.astro';

const { title } = Astro.props;
---

<Base title={title} description={title} className="blog-surface-layout">
	<div class="content-limit-width about-index">
		<TaxonomyHero
			eyebrow="About"
			title={title}
			description="Backend / full-stack in Shanghai — a notebook for work, tools, weather, and whatever keeps echoing."
		/>

		<div class="about-sheet">
			<slot />
		</div>
	</div>
</Base>
