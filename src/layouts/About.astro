---
import Base from './Base.astro';

const { title } = Astro.props;
---

<Base title={title} description={title} className="blog-surface-layout">
	<div class="content-limit-width about-index">
		<header class="about-intro">
			<h1 class="about-intro__title">{title}</h1>
			<p class="page-rail__meta">backend / full-stack · shanghai · b. 1998</p>
		</header>

		<div class="about-sheet">
			<slot />
		</div>
	</div>
</Base>
