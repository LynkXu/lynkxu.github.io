---
import MagazineShell from './MagazineShell.astro';
import SponsorAbout from '../components/SponsorAbout.astro';

const { title } = Astro.props;
---

<MagazineShell title={title} description={title} showProfileCard={false}>
	<section class="about-profile magazine-panel" aria-labelledby="about-title">
		<p class="magazine-section-label">Profile</p>
		<h1 id="about-title">Hi, I am Lynk</h1>
		<div class="about-profile__lead">
			<p>
				<span>一个偏乐观的悲观主义者。</span>
				<span>一个偏现实的理想主义者。</span>
				<span>一个想法很多，但却不善表达的人。</span>
			</p>
		</div>
		<div class="about-profile__rule" aria-hidden="true"></div>
		<p class="about-profile__note">
			我尝试在这里记下自己的所思所想，生活需要记录，记录是为了更好地生活。
			这个页面更像一张说明书：我是谁、我在做什么、以及这个博客如何被维护。
		</p>
		<div class="about-profile__facts">
			<slot />
		</div>
	</section>

	<div slot="sidebar-extra" class="about-rail">
		<section class="magazine-rail-card about-now" aria-labelledby="about-now-title">
			<p id="about-now-title" class="magazine-section-label">Now</p>
			<dl class="about-now-list">
				<div>
					<dt>Base</dt>
					<dd>Shanghai</dd>
				</div>
				<div>
					<dt>Work</dt>
					<dd>Fullstack engineer</dd>
				</div>
				<div>
					<dt>Writing</dt>
					<dd>AI, blog systems, life notes</dd>
				</div>
				<div>
					<dt>Sports</dt>
					<dd>Marathon / Fitness / Cycling</dd>
				</div>
			</dl>
		</section>

		<section class="magazine-rail-card about-colophon-card" aria-labelledby="about-colophon-title">
			<p id="about-colophon-title" class="magazine-section-label">Index</p>
			<nav class="about-link-list" aria-label="About page shortcuts">
				<a href="/blog">
					<strong>Archive</strong>
					<span>长文、记录和阶段性复盘</span>
				</a>
				<a href="/shuoshuo">
					<strong>Memos</strong>
					<span>短想法与 Mastodon 同步</span>
				</a>
				<a href="/sports">
					<strong>Sports</strong>
					<span>跑步、骑行和训练数据</span>
				</a>
			</nav>
		</section>

		<section class="magazine-rail-card about-support-card" aria-labelledby="about-support-title">
			<p id="about-support-title" class="magazine-section-label">Support</p>
			<h2>Sponsor <span>赞助入口保持低优先级，不打断关于页的叙事。</span></h2>
			<SponsorAbout />
		</section>
	</div>
</MagazineShell>

<style is:global>
	.about-profile {
		min-height: min(48rem, calc(100vh - 10rem));
	}

	.about-profile h1 {
		margin: clamp(1rem, 2vw, 1.35rem) 0 0;
		color: var(--heading-color);
		font-family: var(--ui-font);
		font-size: clamp(1.85rem, 4vw, 2.5rem);
		font-weight: var(--weight-bold);
		line-height: 1.15;
		letter-spacing: 0;
	}

	.about-profile__lead {
		margin-top: clamp(1.3rem, 3vw, 1.8rem);
		color: var(--text-color);
		font-family: var(--ui-font);
		font-size: clamp(1rem, 1.7vw, 1.18rem);
		font-weight: var(--weight-semibold);
		line-height: 1.85;
	}

	.about-profile__lead p,
	.about-profile__note {
		margin: 0;
	}

	.about-profile__lead span {
		display: block;
	}

	.about-profile__rule {
		height: 1px;
		margin: clamp(2.3rem, 5vw, 3.3rem) 0 clamp(1.7rem, 3.8vw, 2.4rem);
		background: var(--paper-card-border-soft);
	}

	.about-profile__note {
		max-width: 45rem;
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: 0.95rem;
		font-weight: var(--weight-regular);
		line-height: 1.85;
	}

	.about-profile__facts {
		margin-top: clamp(2.35rem, 6vw, 4.2rem);
	}

	.about-panels {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: clamp(var(--space-md), 2vw, var(--space-lg));
	}

	.about-panel {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr);
		gap: 1rem;
		align-items: start;
		min-height: 6rem;
		padding: clamp(1rem, 2.2vw, 1.35rem);
		border: 1px solid var(--paper-card-border-soft);
		border-radius: var(--paper-card-radius);
		background: color-mix(in oklab, var(--paper-field-bg) 54%, var(--paper-card-bg));
	}

	.about-panel__header {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.3rem;
		height: 2.3rem;
		border: 0;
		border-radius: 0;
		background: transparent;
		color: color-mix(in oklab, var(--accent-color) 62%, var(--heading-color));
	}

	.about-panel__header svg {
		width: 1rem;
		height: 1rem;
	}

	.about-facts {
		display: flex;
		flex-direction: column;
		gap: 0.34rem;
		margin: 0;
		padding: 0;
		list-style: none;
		font-family: var(--ui-font);
	}

	.about-facts li {
		margin: 0;
		color: var(--gray-color);
		font-size: 0.88rem;
		font-weight: var(--weight-regular);
		line-height: 1.55;
	}

	.about-facts li:first-child {
		color: var(--heading-color);
		font-size: 1rem;
		font-weight: var(--weight-semibold);
	}

	.about-rail {
		display: flex;
		flex-direction: column;
		gap: clamp(var(--space-md), 2vw, var(--space-lg));
	}

	.about-now,
	.about-colophon-card,
	.about-support-card {
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.about-support-card h2 {
		margin: 0;
		color: var(--heading-color);
		font-family: var(--ui-font);
		font-size: 1.16rem;
		font-weight: var(--weight-medium);
		line-height: 1.15;
		letter-spacing: 0;
	}

	.about-now-list {
		display: flex;
		flex-direction: column;
		gap: 0;
		margin: 0;
		font-family: var(--ui-font);
	}

	.about-now-list div {
		display: grid;
		grid-template-columns: 4.5rem minmax(0, 1fr);
		gap: 0.85rem;
		padding: 0.68rem 0;
		border-top: 1px solid color-mix(in oklab, var(--paper-card-border-soft) 72%, transparent);
	}

	.about-now-list div:first-child {
		padding-top: 0;
		border-top: 0;
	}

	.about-now-list dt {
		color: var(--gray-color);
		font-size: 0.78rem;
		font-weight: var(--weight-medium);
		line-height: 1.45;
	}

	.about-now-list dd {
		margin: 0;
		color: var(--heading-color);
		font-size: 0.86rem;
		font-weight: var(--weight-medium);
		line-height: 1.45;
	}

	.about-link-list {
		display: flex;
		flex-direction: column;
		gap: 0.12rem;
	}

	.about-link-list a {
		display: flex;
		flex-direction: column;
		gap: 0.18rem;
		padding: 0.62rem 0;
		border: 0 !important;
		border-top: 1px solid color-mix(in oklab, var(--paper-card-border-soft) 72%, transparent) !important;
		background: none !important;
		color: inherit;
		text-decoration: none;
	}

	.about-link-list a:first-child {
		padding-top: 0;
		border-top: 0 !important;
	}

	.about-link-list strong {
		color: var(--heading-color);
		font-family: var(--ui-font);
		font-size: 0.9rem;
		font-weight: var(--weight-medium);
		line-height: 1.35;
	}

	.about-link-list span {
		color: var(--gray-color);
		font-size: 0.78rem;
		font-weight: var(--weight-medium);
		line-height: 1.45;
	}

	.about-support-card h2 {
		font-size: 1.08rem;
	}

	.about-support-card h2 span {
		display: block;
		margin-top: 0.35rem;
		color: var(--gray-color);
		font-size: 0.86rem;
		font-weight: var(--weight-medium);
		line-height: 1.7;
	}

	.about-support-card .sponsor-about {
		margin-top: 0;
	}

	@media (max-width: 680px) {
		.about-panels {
			grid-template-columns: 1fr;
		}

		.about-panel {
			grid-template-columns: auto minmax(0, 1fr);
		}
	}
</style>
