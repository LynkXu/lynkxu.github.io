---
import Base from './Base.astro';

const { title } = Astro.props;
---

<Base
  title={title}
  description="运动记录"
  fullWidth={true}
  hideHeader={true}
  useCard={false}
  className="sports-page"
>
  <link rel="dns-prefetch" href="https://unpkg.com" slot="head" />
  <link rel="preconnect" href="https://unpkg.com" crossorigin="" slot="head" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" slot="head" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin="" slot="head" defer></script>
  <div class="sports-layout">
    <div class="content">
      <slot />
    </div>
  </div>

  <style>
    :global(body.full-width .global-layout-transparent.sports-page) {
      width: 100%;
      max-width: 100%;
      margin: 0;
      padding: 0;
    }

    .sports-layout {
      width: min(100% - clamp(2rem, 6vw, 6rem), 1400px);
      margin: 0 auto;
    }

    .content {
      min-width: 0;
    }

    @media (max-width: 680px) {
      .sports-layout {
        width: min(100% - 2rem, 1400px);
      }
    }
  </style>
</Base>
