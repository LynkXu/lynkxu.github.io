---
interface Props {
	eyebrow?: string;
	title: string;
	description?: string;
}

const {
	eyebrow,
	title,
	description,
} = Astro.props;
---

<section class='taxonomy-hero'>
	{eyebrow && <p class='taxonomy-hero__eyebrow'>{eyebrow}</p>}
	<h1 class='taxonomy-hero__title'>{title}</h1>
	{description && <p class='taxonomy-hero__description'>{description}</p>}
</section>

<style>
	.taxonomy-hero {
		display: flex;
		flex-direction: column;
		gap: 0.55rem;
		margin: 0;
		padding: 0;
		width: 100%;
	}

	.taxonomy-hero__eyebrow {
		margin: 0;
		color: var(--gray-color);
		font-family: var(--meta-font);
		font-size: 0.72rem;
		font-weight: 500;
		letter-spacing: 0.03em;
		text-transform: none;
	}

	.taxonomy-hero__title {
		margin: 0;
		color: var(--panel-title-color);
		font-family: var(--serif-font);
		font-size: clamp(1.8rem, 4.4vw, 2.55rem);
		font-weight: 500;
		line-height: 1.12;
		letter-spacing: 0;
	}

	.taxonomy-hero__description {
		max-width: 48rem;
		margin: 0;
		color: var(--gray-color);
		font-size: 0.94rem;
		line-height: 1.72;
	}
	
	@media (max-width: 640px) {
		.taxonomy-hero {
			gap: 0.55rem;
		}

		.taxonomy-hero__title {
			font-size: clamp(1.55rem, 8vw, 2rem);
			letter-spacing: 0;
		}

		.taxonomy-hero__description {
			font-size: 0.94rem;
		}
	}
</style>
