---
import { cn } from 'astro-pure/utils'

const { class: className, title } = Astro.props
---

<section class={cn('flex flex-col gap-y-4 md:flex-row md:gap-y-0 md:gap-x-8', className)}>
  <div class='text-xl font-semibold md:min-w-32 flex-shrink-0'>
    <h2 class='tracking-tight'>{title}</h2>
  </div>
  <div class='flex flex-1 flex-col gap-y-3'>
    <slot />
  </div>
</section>
