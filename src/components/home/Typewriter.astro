---
type Props = {
  words: string[]
  speed?: number
  pause?: number
  class?: string
}

const { words = [], speed = 110, pause = 1400, class: className } = Astro.props
const initialText = words[0] ?? ''
const id = `typewriter-${Math.random().toString(36).slice(2, 7)}`
---

<span id={id} class={`typewriter ${className ?? ''}`} aria-live='polite'>
  {initialText}
</span>

<script>
  const words = JSON.parse('{JSON.stringify(words)}')
  const speed = {speed}
  const pause = {pause}
  const el = document.getElementById('{id}')
  const media = window.matchMedia('(prefers-reduced-motion: reduce)')

  if (!el || media.matches || words.length <= 1) {
    if (el && words.length) el.textContent = words[0] ?? ''
  } else {
    let wordIndex = 0
    let charIndex = 0
    let deleting = false

    const tick = () => {
      const current = words[wordIndex] ?? ''
      const visible = current.slice(0, charIndex)
      el.textContent = visible

      if (!deleting && charIndex >= current.length) {
        deleting = true
        setTimeout(tick, pause)
        return
      }

      if (deleting && charIndex === 0) {
        deleting = false
        wordIndex = (wordIndex + 1) % words.length
      }

      charIndex += deleting ? -1 : 1
      const delay = deleting ? speed * 0.6 : speed
      setTimeout(tick, delay)
    }

    tick()
  }
</script>

<style>
  .typewriter {
    position: relative;
    display: inline-flex;
    align-items: center;
  }

  .typewriter::after {
    content: '';
    width: 0.6ch;
    height: 1em;
    margin-left: 0.1ch;
    background: currentColor;
    opacity: 0.7;
    border-radius: 2px;
    animation: caret-blink 1.1s steps(1) infinite;
  }

  @keyframes caret-blink {
    0%,
    60% {
      opacity: 0.75;
    }
    60%,
    100% {
      opacity: 0.2;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .typewriter::after {
      animation: none;
    }
  }
</style>

