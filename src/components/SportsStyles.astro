<style is:inline>
  /* Empty State */
    padding: 3rem 2rem;
    text-align: center;
    color: var(--gray-color);
    background: var(--code-background-color);
    border-radius: 12px;
    /* 增加边框可见度 */
    border: 1px dashed rgba(0,0,0,0.15);
  }
  
  :global([data-theme="dark"]) .empty-state {
     border-color: rgba(255,255,255,0.15);
  }

  /* Table */
  .tabs-content table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    margin: 1.5rem 0;
    font-size: 0.9rem;
  }
  
  .tabs-content th {
    text-align: left;
    padding: 1rem;
    border-bottom: 1px solid rgba(0,0,0,0.1);
    color: var(--gray-color);
    font-weight: 600;
    font-size: 0.8em;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  .tabs-content td {
    padding: 1rem;
    border-bottom: 1px solid rgba(0,0,0,0.06);
    color: var(--text-color);
    transition: background-color 0.2s;
  }
  
  .tabs-content tr:last-child td { border-bottom: none; }
  .tabs-content tbody tr:hover td { 
    background-color: var(--code-background-color); 
    color: var(--heading-color);
  }
  .tabs-content tbody tr td:first-child {
    border-top-left-radius: 8px;
    border-bottom-left-radius: 8px;
  }
  .tabs-content tbody tr td:last-child {
    border-top-right-radius: 8px;
    border-bottom-right-radius: 8px;
  }
  
  :global([data-theme="dark"]) .tabs-content th {
    border-bottom-color: rgba(255,255,255,0.1);
  }
  :global([data-theme="dark"]) .tabs-content td {
    border-bottom-color: rgba(255,255,255,0.06);
  }
</style>
