---
interface Props {
  url?: string;
}

const { url = '#' } = Astro.props;
---

<a href={url} target="_blank" rel="noopener noreferrer" class="strava-link" aria-label="Follow on Strava">
  <svg class="strava-icon" viewBox="0 0 24 24" fill="#fc4c02" xmlns="http://www.w3.org/2000/svg">
    <path d="M15.387 17.944l-2.089-4.116h-3.065L15.387 24l5.15-10.172h-3.066m-7.008-5.599l2.836 5.598h4.172L10.875 0 3.972 13.643h4.172"/>
  </svg>
  <span class="strava-text">Follow on Strava</span>
</a>

<style>
  .strava-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    text-decoration: none;
    color: var(--gray-color);
    font-size: 0.78rem;
    font-weight: 500;
    font-family: var(--ui-font, inherit);
    padding: 0.35rem 0.7rem;
    border-radius: 6px;
    border: 1px solid rgba(0, 0, 0, 0.07);
    background: transparent;
    transition: all 0.2s ease;
    line-height: 1;
    white-space: nowrap;
  }

  :global([data-theme="dark"]) .strava-link {
    border-color: rgba(255, 255, 255, 0.09);
    color: var(--gray-color);
  }

  .strava-link:hover {
    color: #fc4c02;
    border-color: rgba(252, 76, 2, 0.25);
    background: rgba(252, 76, 2, 0.04);
  }

  :global([data-theme="dark"]) .strava-link:hover {
    color: #ff7a3d;
    border-color: rgba(255, 122, 61, 0.3);
    background: rgba(255, 122, 61, 0.05);
  }

  .strava-icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  .strava-text {
    line-height: 1;
  }
</style>
