    box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--accent-color) 12%, transparent);
  }

  :global([data-theme="dark"]) .year-chip:hover {
    background: rgba(255, 255, 255, 0.05);
  }

  :global([data-theme="dark"]) .year-chip.active {
    background: color-mix(in oklab, var(--accent-soft-bg) 34%, rgba(255, 255, 255, 0.08));
    color: var(--heading-color);
  }

  /* Chart groups */
  .chart-group {
    display: none;
  }

  .chart-group.active {
    display: block;
    animation: fadeIn 0.35s ease-out;
  }

  .empty-chart {
    text-align: center;
    padding: 2rem 1rem;
    color: var(--gray-color);
    font-size: 0.85rem;
  }

  /* Viz tabs inside module header */
  .viz-tabs {
    display: flex;
    gap: 0;
  }

  .viz-tab {
    background: none;
    border: none;
    padding: 0.55rem 0.65rem;
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--gray-color);
    cursor: pointer;
    border-bottom: 1.5px solid transparent;
    margin-bottom: -1px;
    transition: all 0.2s ease;
    font-family: inherit;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .tab-icon {
    width: 13px;
    height: 13px;
    flex-shrink: 0;
    opacity: 0.55;
  }

  .viz-tab.active .tab-icon {
    opacity: 0.8;
  }

  .viz-tab:hover {
