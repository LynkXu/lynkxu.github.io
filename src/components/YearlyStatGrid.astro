---
import StatGrid from './StatGrid.astro';
import StatCard from './StatCard.astro';
import SportsBarChart from './SportsBarChart.astro';
import SportsLineChart from './SportsLineChart.astro';
import RaceMap from './RaceMap.astro';

interface Props {
  type: 'running' | 'cycling';
  stats: any;
  races?: any[];
}

const { type, stats, races = [] } = Astro.props;

const currentYear = new Date().getFullYear();
const availableYears = Object.keys(stats.years || {}).sort().reverse();
const yearTabs = [currentYear.toString(), ...availableYears.filter(y => y !== currentYear.toString())];

function toFixedTrim(n: number, digits: number) {
  const s = n.toFixed(digits);
  return s.replace(/\.0+$/, '').replace(/(\.\d*?)0+$/, '$1');
}

function avgKmPerCountText(distText: any, count: any) {
  const c = Number(count) || 0;
  const d = Number(distText) || 0;
  if (c <= 0) return '暂无记录';
  const avg = d / c;
  return `~${toFixedTrim(avg, 1)} km/次`;
}

function paceText(distKmText: any, timeHoursText: any) {
  const distKm = Number(distKmText) || 0;
  const timeHours = Number(timeHoursText) || 0;
  if (distKm <= 0 || timeHours <= 0) return '暂无记录';
  const totalSeconds = timeHours * 3600;
  const secPerKm = totalSeconds / distKm;
  let mm = Math.floor(secPerKm / 60);
  let ss = Math.round(secPerKm - mm * 60);
  if (ss === 60) {
    mm += 1;
    ss = 0;
  }
  const ssText = String(ss).padStart(2, '0');
  return `~${mm}'${ssText}''/km`;
}

function parseRaceTimeToSeconds(timeText: any) {
  const raw = String(timeText || '').trim();
  if (!raw) return null;
  const parts = raw.split(':').map((x) => Number.parseInt(x, 10));
  if (parts.some((x) => !Number.isFinite(x) || x < 0)) return null;
  if (parts.length === 3) return parts[0] * 3600 + parts[1] * 60 + parts[2];
  if (parts.length === 2) return parts[0] * 60 + parts[1];
  return null;
}

function getPbRaceByType(targetType: string) {
  let bestRace: any = null;
  let bestSeconds = Number.POSITIVE_INFINITY;

  for (const race of races) {
    const raceType = String(race?.type || '').trim();
    const raceStatus = String(race?.status || '').trim().toLowerCase();
    if (raceType !== targetType || raceStatus !== 'completed') continue;

    const sec = parseRaceTimeToSeconds(race?.time);
    if (sec == null || sec <= 0) continue;

    if (sec < bestSeconds) {
      bestSeconds = sec;
      bestRace = race;
    }
  }

  return bestRace;
}

function pbSubtext(race: any, fallback: string) {
  if (!race) return fallback;
  const pace = String(race?.pace || '').trim();
  const date = String(race?.date || '').trim();
  if (pace && date) return `${pace}/km @${date}`;
  if (pace) return `${pace}/km`;
  if (date) return `@${date}`;
  return fallback;
}

const halfPbRace = getPbRaceByType('半马');
const fullPbRace = getPbRaceByType('全马');

const halfMarathonCard = halfPbRace
  ? {
      ...stats.cards.halfMarathon,
      value: String(halfPbRace.time || '').trim() || stats.cards.halfMarathon.value,
      subtext: pbSubtext(halfPbRace, stats.cards.halfMarathon.subtext),
    }
  : stats.cards.halfMarathon;

const fullMarathonCard = fullPbRace
  ? {
      ...stats.cards.fullMarathon,
      value: String(fullPbRace.time || '').trim() || stats.cards.fullMarathon.value,
      subtext: pbSubtext(fullPbRace, stats.cards.fullMarathon.subtext),
    }
  : stats.cards.fullMarathon;

// --- Fixed stat cards: always show totals ---
const runningPaceSub = paceText(stats.cards.totalDistance.value, stats.cards.totalTime.value);
const importedDistanceKm = Number(stats.imported?.distanceKm) || 0;
const hasImportedAggregate = type === 'running' && importedDistanceKm > 0 && stats.imported?.hasMonthly === false;
const totalDistSub = type === 'running'
  ? hasImportedAggregate
    ? `${runningPaceSub} · 含导入${toFixedTrim(importedDistanceKm, 1)} km`
    : runningPaceSub
  : stats.cards.totalDistance.subtext;

const totalCountSub = type === 'cycling'
  ? avgKmPerCountText(stats.cards.totalDistance.value, stats.cards.totalCount?.value)
  : stats.cards.totalCount?.subtext;

// --- Monthly data grouped by year ---
const monthlyData = Array.isArray(stats.monthly) ? stats.monthly : [];
const monthlyGroups: Record<string, any[]> = { total: monthlyData };
yearTabs.forEach(year => {
  monthlyGroups[year] = monthlyData.filter((m: any) => m.month.startsWith(year));
});

const idPrefix = `stats-${type}`;
// Default to the most recent year that actually has monthly data
const initialYear = yearTabs.find(y => (monthlyGroups[y] || []).length > 0) || 'total';

const monthlyChartDataByYear: Record<string, any[]> = {};
const fullYearMonths = Array.from({ length: 12 }, (_, i) => String(i + 1).padStart(2, '0'));

function getMonthKey(monthText: any) {
  const text = String(monthText || '').trim();
  const yearMonth = text.match(/^\d{4}-(\d{1,2})(?:-\d{1,2})?$/);
  if (yearMonth) return yearMonth[1].padStart(2, '0');

  const monthOnly = text.match(/^(\d{1,2})(?:月)?$/);
  if (monthOnly) return monthOnly[1].padStart(2, '0');

  return text;
}

[...yearTabs, 'total'].forEach(year => {
  if (year === 'total') {
    const group = monthlyGroups[year] || [];
    monthlyChartDataByYear[year] = group.slice().reverse().map((m: any) => ({
      label: m.month,
      value: Number(m.distanceKm),
      displayValue: m.displayValue || `${m.distanceKm} km`
    }));
  } else {
    const group = monthlyGroups[year] || [];
    const map = new Map(group.map((m: any) => [getMonthKey(m.month), m]));
    monthlyChartDataByYear[year] = fullYearMonths.map(mm => {
      const m = map.get(mm);
      return {
        label: `${mm}月`,
        value: m ? Number(m.distanceKm) : 0,
        displayValue: m ? (m.displayValue || `${m.distanceKm} km`) : '0 km'
      };
    });
  }
});

// --- Races: all-time data for map, trend, and list ---
const sortedRaces = [...races].sort((a, b) => {
  return new Date(b.date).getTime() - new Date(a.date).getTime();
});

const hasAnyRaces = sortedRaces.length > 0;

const raceTrendDataTotal = sortedRaces
  .filter((r: any) => r.status === 'completed' && r.time)
  .sort((a: any, b: any) => new Date(a.date).getTime() - new Date(b.date).getTime())
  .map((r: any) => {
    const sec = parseRaceTimeToSeconds(r.time);
    return {
      label: r.date.slice(5),
      value: sec ? Math.round(sec / 60 * 10) / 10 : 0,
      displayValue: r.time
    };
  });
---

<!-- Fixed stat cards -->
<StatGrid>
  <StatCard
    label={stats.cards.totalDistance.label}
    value={stats.cards.totalDistance.value}
    unit={stats.cards.totalDistance.unit}
    subtext={totalDistSub}
  />
  <StatCard
    label={stats.cards.totalTime.label}
    value={stats.cards.totalTime.value}
    unit={stats.cards.totalTime.unit}
    subtext={stats.cards.totalTime.subtext}
  />

  {type === 'running' ? (
    <>
      <StatCard
        label={halfMarathonCard.label}
        value={halfMarathonCard.value}
        unit={halfMarathonCard.unit}
        subtext={halfMarathonCard.subtext}
      />
      <StatCard
        label={fullMarathonCard.label}
        value={fullMarathonCard.value}
        unit={fullMarathonCard.unit}
        subtext={fullMarathonCard.subtext}
      />
    </>
  ) : (
    <>
      <StatCard
        label={stats.cards.totalCount.label}
        value={stats.cards.totalCount.value}
        unit={stats.cards.totalCount.unit}
        subtext={totalCountSub}
      />
      <StatCard
        label={stats.cards.farthest.label}
        value={stats.cards.farthest.value}
        unit={stats.cards.farthest.unit}
        subtext={stats.cards.farthest.subtext}
      />
    </>
  )}
</StatGrid>

<!-- Modules stack -->
<div class="modules-stack" id={`${idPrefix}-modules`}>

  <!-- Monthly bar chart with year switcher -->
  {Object.values(monthlyChartDataByYear).some(arr => arr.length > 0) && (
    <div class="module-card monthly-card">
      <div class="module-header tabbed">
        <h4>
          <svg class="mod-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <rect x="1" y="9" width="3" height="6" rx="1"/>
            <rect x="6.5" y="5" width="3" height="10" rx="1"/>
            <rect x="12" y="1" width="3" height="14" rx="1"/>
          </svg>
          {type === 'running' ? '月度跑量' : '月度里程'}
        </h4>
        <div class="year-switcher-inline" id={`${idPrefix}-year-switcher`}>
          {yearTabs.map(y => (
            <button class={`year-chip ${y === initialYear ? 'active' : ''}`} data-year={y}>{y}</button>
          ))}
          <button class={`year-chip ${'total' === initialYear ? 'active' : ''}`} data-year="total">全部</button>
        </div>
      </div>
      <div class="module-body chart-dense monthly-chart-body">
        {[...yearTabs, 'total'].map(year => (
          <div
            class={`chart-group ${year === initialYear ? 'active' : ''}`}
            data-year={year}
          >
            {monthlyChartDataByYear[year]?.length > 0 ? (
              <SportsBarChart
                data={monthlyChartDataByYear[year]}
                id={`${idPrefix}-monthly-chart-${year}`}
              />
            ) : (
              <div class="empty-chart">{year === 'total' ? '暂无数据' : `${year}年暂无数据`}</div>
            )}
          </div>
        ))}
      </div>
    </div>
  )}

  {type === 'running' && hasAnyRaces && Object.values(monthlyChartDataByYear).some(arr => arr.length > 0) && (
    <div class="section-divider"></div>
  )}

  <!-- Running: Map + Race trend (all-time) -->
  {type === 'running' && hasAnyRaces && (
    <div class="module-card">
      <div class="module-header tabbed">
        <div class="viz-tabs" data-viz-tabs={`${idPrefix}-viz`}>
          <button class="viz-tab active" data-viz="map">
            <svg class="tab-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M8 14s-4-4.5-4-7a4 4 0 0 1 8 0c0 2.5-4 7-4 7z"/>
              <circle cx="8" cy="7" r="1.5"/>
            </svg>
            足迹
          </button>
          {raceTrendDataTotal.length >= 2 && (
            <button class="viz-tab" data-viz="trend">
              <svg class="tab-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="1 10 5 6 9 9 15 3"/>
              </svg>
              成绩趋势
            </button>
          )}
        </div>
      </div>
      <div class="module-body no-padding">
        <div class="viz-panels">
          <div class="viz-panel active" data-viz-panel="map">
            <RaceMap races={sortedRaces} id={`${idPrefix}-map`} />
          </div>
          {raceTrendDataTotal.length >= 2 && (
            <div class="viz-panel" data-viz-panel="trend">
              <SportsLineChart
                data={raceTrendDataTotal}
                unit="min"
                color="#e11d48"
                id={`${idPrefix}-race-chart`}
              />
            </div>
          )}
        </div>
      </div>
    </div>
  )}

  <!-- Compact race list (all-time) -->
  {type === 'running' && hasAnyRaces && (
    <div class="module-card">
      <div class="module-header">
        <h4>
          <svg class="mod-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 14l2-7"/>
            <path d="M12 14l-2-7"/>
            <circle cx="8" cy="3" r="2"/>
          </svg>
          比赛记录
        </h4>
      </div>
      <div class="module-body no-padding">
        <div class="race-table">
          <div class="race-thead">
            <span class="race-col date">日期</span>
            <span class="race-col type">类型</span>
            <span class="race-col name">赛事</span>
            <span class="race-col location">地点</span>
            <span class="race-col time">成绩</span>
            <span class="race-col pace">配速</span>
          </div>
          {sortedRaces.map((race: any) => (
            <div class={`race-row ${race.status}`}>
              <span class="race-col date">{race.date}</span>
              <span class="race-col type">
                <span class={`race-badge ${race.type === '全马' ? 'full' : 'half'}`}>{race.type}</span>
              </span>
              <span class="race-col name">
                {race.name}
                {race.note && <span class="race-note">{race.note}</span>}
              </span>
              <span class="race-col location">{race.location || '-'}</span>
              <span class="race-col time">{race.time || '-'}</span>
              <span class="race-col pace">{race.pace ? `${race.pace}/km` : '-'}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  )}

</div>

<script define:vars={{ idPrefix }}>
  // Year switcher: only controls the bar chart
  const yearSwitcher = document.getElementById(`${idPrefix}-year-switcher`);
  if (yearSwitcher) {
    const chips = yearSwitcher.querySelectorAll('.year-chip');
    const chartGroups = document.querySelectorAll(`#${idPrefix}-modules .chart-group`);

    chips.forEach(chip => {
      chip.addEventListener('click', () => {
        chips.forEach(c => c.classList.remove('active'));
        chip.classList.add('active');

        const year = chip.getAttribute('data-year');
        chartGroups.forEach(g => {
          if (g.getAttribute('data-year') === year) {
            g.classList.add('active');
          } else {
            g.classList.remove('active');
          }
        });
      });
    });
  }

  // Inner viz tabs (map / trend)
  const modules = document.getElementById(`${idPrefix}-modules`);
  if (modules) {
    modules.querySelectorAll('.viz-tabs').forEach(tabContainer => {
      const tabs = tabContainer.querySelectorAll('.viz-tab');
      const panels = tabContainer.closest('.module-card')?.querySelector('.viz-panels');
      if (!panels) return;
      const panelEls = panels.querySelectorAll('.viz-panel');

      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          const target = tab.getAttribute('data-viz');
          tabs.forEach(t => t.classList.remove('active'));
          tab.classList.add('active');
          panelEls.forEach(p => {
            if (p.getAttribute('data-viz-panel') === target) {
              p.classList.add('active');
            } else {
              p.classList.remove('active');
            }
          });
          setTimeout(() => {
            const mapPanel = panels.querySelector('.viz-panel[data-viz-panel="map"]');
            if (mapPanel && mapPanel.classList.contains('active')) {
              window.dispatchEvent(new Event('resize'));
            }
          }, 50);
        });
      });
    });
  }
</script>

<style>
  .modules-stack {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  /* Section divider between monthly chart and map */
  .section-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(0,0,0,0.04), transparent);
    margin: 0 1.25rem;
  }

  :global([data-theme="dark"]) .section-divider {
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.04), transparent);
  }

  /* Unified module card */
  .module-card {
    border: 1px solid var(--paper-card-border-soft);
    border-radius: 16px;
    overflow: hidden;
    background: color-mix(in oklab, var(--page-bg) 45%, var(--paper-card-bg));
    box-shadow: var(--paper-card-shadow);
  }

  :global([data-theme="dark"]) .module-card {
    border-color: var(--paper-card-border-soft);
    background: color-mix(in oklab, var(--page-bg) 18%, var(--paper-card-bg));
  }

  .module-header {
    padding: 0.85rem 1.25rem;
    border-bottom: 1px solid rgba(0,0,0,0.04);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    flex-wrap: wrap;
    min-height: 2.6rem;
  }

  .module-header h4 {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--heading-color);
    margin: 0;
    opacity: 0.8;
    letter-spacing: 0.01em;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .mod-icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    opacity: 0.55;
    color: var(--gray-color);
  }

  .module-header.tabbed {
    padding: 0 0 0 1rem;
    border-bottom: 1px solid rgba(0,0,0,0.04);
  }

  :global([data-theme="dark"]) .module-header,
  :global([data-theme="dark"]) .module-header.tabbed {
    border-bottom-color: rgba(255,255,255,0.05);
  }

  .module-body {
    padding: 1.25rem;
  }

  .module-body.no-padding {
    padding: 0;
  }

  .module-body :global(.bar-chart-box) {
    margin: 0;
  }

  .module-body.chart-dense {
    padding: 0.4rem 0.15rem 0.6rem;
  }

  .monthly-card {
    border-radius: 18px;
    background: var(--paper-card-bg);
  }

  :global([data-theme="dark"]) .monthly-card {
    background: var(--paper-card-bg);
  }

  .monthly-card .module-header.tabbed {
    padding: 0.42rem 0.8rem 0.42rem 1rem;
    background: var(--paper-card-bg);
    min-height: 2.35rem;
  }

  .monthly-card .module-header h4 {
    font-size: 0.82rem;
    opacity: 0.9;
  }

  .monthly-card .mod-icon {
    color: oklch(0.44 0.045 155);
    opacity: 0.62;
  }

  .monthly-chart-body {
    padding: 0;
  }

  /* Year switcher inside module header */
  .year-switcher-inline {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    padding: 0.12rem;
    border: 1px solid color-mix(in oklab, var(--paper-card-border-soft) 80%, transparent);
    border-radius: 999px;
    background: color-mix(in oklab, var(--paper-card-bg) 72%, transparent);
  }

  .year-chip {
    background: transparent;
    border: none;
    padding: 0.24rem 0.54rem;
    border-radius: 999px;
    font-size: 0.74rem;
    font-weight: 500;
    color: var(--gray-color);
    cursor: pointer;
