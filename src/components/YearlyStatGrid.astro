    display: block;
    animation: fadeIn 0.3s ease-out;
  }

  .viz-panel :global(.line-chart-wrapper) {
    margin: 0;
  }

  .viz-panel :global(.line-chart-title) {
    display: none;
  }

  /* Race Table */
  .race-table {
    display: flex;
    flex-direction: column;
    font-size: 0.82rem;
  }

  .race-thead {
    display: flex;
    align-items: center;
    padding: 0.55rem 1.5rem;
    gap: 0.75rem;
    border-bottom: 1px solid rgba(0,0,0,0.06);
    font-size: 0.68rem;
    font-weight: 500;
    color: var(--gray-color);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  :global([data-theme="dark"]) .race-thead {
    border-bottom-color: rgba(255,255,255,0.06);
  }

  .race-row {
    display: flex;
    align-items: center;
    padding: 0.7rem 1.5rem;
    gap: 0.75rem;
    border-bottom: 1px solid rgba(0,0,0,0.035);
    transition: background 0.15s ease;
  }

  .race-row.dnf,
  .race-row.retired {
    opacity: 0.5;
  }

  :global([data-theme="dark"]) .race-row {
    border-bottom-color: rgba(255,255,255,0.04);
  }

  .race-row:last-child {
    border-bottom: none;
  }

  .race-row:hover {
    background: rgba(0,0,0,0.015);
  }

  :global([data-theme="dark"]) .race-row:hover {
    background: rgba(255,255,255,0.015);
  }

  .race-col {
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .race-col.date {
    flex: 0 0 90px;
    color: var(--gray-color);
    font-variant-numeric: tabular-nums;
    font-size: 0.76rem;
  }

  .race-col.type {
    flex: 0 0 52px;
  }

  .race-col.name {
    flex: 1 1 auto;
    min-width: 60px;
    font-weight: 600;
    color: var(--heading-color);
