---
const today = new Date();
const currentYear = today.getFullYear();
---

<footer>
	<p class='copyright'>
		© 2020 – {currentYear} <a href='/'>LynkXu</a>
	</p>
	<p class='credit'>Powered by <a href='https://astro.build' target='_blank' rel='noopener noreferrer'>Astro</a>, Design by Lynk</p>
</footer>

<style>
	footer {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		align-items: end;
		gap: 1rem;
		width: min(var(--blog-shell-width, 68rem), calc(100% - clamp(2rem, 6vw, 5.5rem)));
		margin: 0 auto;
		padding: clamp(1.1rem, 2vw, 1.45rem) 0 clamp(2rem, 4vw, 3rem);
		border-top: 1px solid var(--paper-card-border-soft);
	}

	:global(body:has(.blog-surface-layout)) footer {
		grid-template-columns: minmax(0, 1fr) auto;
		width: 100%;
		margin-right: 0;
		margin-left: 0;
		margin-top: clamp(1.4rem, 4vw, 2.6rem);
		text-align: left;
	}

	:global(body:has(.blog-surface-layout)) footer::before {
		content: none !important;
	}

	:global(body:has(.blog-surface-layout) .ledger-main > footer > *) {
		grid-column: auto !important;
	}

	/* Fix for full-width layout pages */
	:global(body.full-width) footer {
		max-width: 1200px;
		margin: 0 auto;
		padding: var(--space-lg) var(--page-inline);
		box-sizing: border-box;
	}

	.copyright,
	.credit {
		margin: 0;
		color: var(--faint-color);
		font-family: var(--ui-font);
		font-size: 0.68rem;
		font-weight: 300;
		line-height: 1.5;
		letter-spacing: 0.01em;
		transition: color 0.2s ease;
	}

	.copyright a,
	.credit a {
		color: inherit;
		border-bottom: 0;
		text-decoration-line: underline;
		text-decoration-color: transparent;
		text-decoration-thickness: 1px;
		text-underline-offset: var(--link-underline-offset);
		transition: color 0.2s ease, text-decoration-color 0.2s ease;
	}

	.copyright a:hover,
	.credit a:hover {
		text-decoration-color: var(--link-underline-color);
	}

	footer:hover .copyright,
	footer:hover .credit {
		color: var(--gray-color);
	}

	@media (max-width: 480px) {
		footer {
			grid-template-columns: 1fr;
			align-items: start;
			gap: 0.4rem;
		}

		:global(body:has(.blog-surface-layout)) footer {
			grid-template-columns: 1fr;
		}
	}
</style>
