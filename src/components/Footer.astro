---
const today = new Date();
const currentYear = today.getFullYear();
---

<footer>
	<p class='copyright'>
		© 2020 – {currentYear} <a href='/'>LynkXu</a>
	</p>
	<p class='credit'>Powered by <a href='https://astro.build' target='_blank' rel='noopener noreferrer'>Astro</a>, Design by Lynk</p>
</footer>

<style>
	footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 0.5rem;
		padding: clamp(0.75rem, 1.5vw, 1rem) 0 clamp(1rem, 2vw, 1.4rem);
		width: 100%;
		border-top: 1px solid var(--paper-card-border-soft);
	}

	/* Fix for full-width layout pages */
	:global(body.full-width) footer {
		max-width: 1200px;
		margin: 0 auto;
		padding: var(--space-lg) var(--page-inline);
		box-sizing: border-box;
	}

	.copyright,
	.credit {
		margin: 0;
		color: var(--faint-color);
		font-family: var(--ui-font);
		font-size: 0.72rem;
		font-weight: 300;
		line-height: 1.5;
		letter-spacing: 0.01em;
		transition: color 0.2s ease;
	}

	.copyright a,
	.credit a {
		color: inherit;
		text-decoration: none;
		border-bottom: 1px solid transparent;
		transition: border-color 0.2s, color 0.2s;
	}

	.copyright a:hover,
	.credit a:hover {
		border-bottom-color: currentColor;
	}

	footer:hover .copyright,
	footer:hover .credit {
		color: var(--gray-color);
	}

	@media (max-width: 480px) {
		footer {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.4rem;
		}
	}
</style>
