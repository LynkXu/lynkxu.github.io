---
const today = new Date();
const currentYear = today.getFullYear();
---

<footer>
	<p class='copyright'>
		© 2020 – {currentYear} <a href='/'>LynkXu</a>
	</p>
	<div class='social-links'>
		<a href='https://github.com/lynkxu' target='_blank' rel='noopener noreferrer' aria-label='GitHub'>
			<svg xmlns='http://www.w3.org/2000/svg' width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4'/><path d='M9 18c-4.51 2-5-2-7-2'/></svg>
		</a>
		<a href='https://x.com/lynk_xv' target='_blank' rel='noopener noreferrer' aria-label='X'>
			<svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='currentColor'><path d='M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z'/></svg>
		</a>
	</div>
</footer>

<style>
	footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 0.5rem;
		padding: clamp(1.7rem, 3.4vw, 2.3rem) 0 clamp(1rem, 2vw, 1.4rem);
		width: 100%;
		border-top: 1px solid color-mix(in oklab, var(--paper-card-border-soft) 50%, transparent);
	}

	/* Fix for full-width layout pages */
	:global(body.full-width) footer {
		max-width: 1200px;
		margin: 0 auto;
		padding: var(--space-lg) var(--page-inline);
		box-sizing: border-box;
	}

	.copyright {
		margin: 0;
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: var(--text-sm);
		line-height: 1.5;
		opacity: 0.72;
	}

	.copyright a {
		color: var(--gray-color);
		text-decoration: none;
		border-bottom: 1px solid transparent;
		transition: border-color 0.2s;
	}

	.copyright a:hover {
		border-bottom-color: var(--gray-color);
	}

	.social-links {
		display: flex;
		align-items: center;
		gap: 0.6rem;
	}

	.social-links a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--gray-color);
		opacity: 0.55;
		transition: opacity 0.2s ease, color 0.2s ease;
	}

	.social-links a:hover {
		opacity: 1;
		color: var(--heading-color);
	}

	@media (max-width: 480px) {
		footer {
			flex-direction: column;
			align-items: flex-start;
			gap: 0.4rem;
		}
	}
</style>
