---
import changelogData from '../data/changelog.json';

interface ChangelogEntry {
	hash: string;
	message: string;
	date: string;
	fileCount: number;
}

const entries: ChangelogEntry[] = Array.isArray(changelogData) ? changelogData : [];
---

{
	entries.length > 0 ? (
		<ul class="changelog-list" role="list">
			{entries.map((entry) => (
				<li class="changelog-item">
					<time class="changelog-date" datetime={entry.date}>
						{entry.date.slice(5)}
					</time>
					<span class="changelog-message">{entry.message}</span>
				</li>
			))}
		</ul>
	) : (
		<p class="changelog-empty">暂无近期变更记录</p>
	)
}
