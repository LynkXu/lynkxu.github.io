---
import StatGrid from './StatGrid.astro';
import StatCard from './StatCard.astro';
import SportsBarChart from './SportsBarChart.astro';
import SportsLineChart from './SportsLineChart.astro';

interface Props {
  stats: any;
}

const { stats } = Astro.props;

function toFixedTrim(n: number, digits: number) {
  const s = n.toFixed(digits);
  return s.replace(/\.0+$/, '').replace(/(\.\d*?)0+$/, '$1');
}

function kgToTonneText(kg: any) {
  const value = Number(kg) || 0;
  return `${toFixedTrim(value / 1000, value >= 100000 ? 0 : 1)} t`;
}

function monthLabel(month: any) {
  const text = String(month || '');
  const match = text.match(/^(\d{4})-(\d{2})$/);
  return match ? `${match[1].slice(2)}.${match[2]}` : text;
}

const cards = stats?.cards || {};
const monthly = Array.isArray(stats?.monthly) ? stats.monthly : [];
const muscles = Array.isArray(stats?.muscles) ? stats.muscles : [];
const lifts = Array.isArray(stats?.lifts) ? stats.lifts : [];
const recentWorkouts = Array.isArray(stats?.recentWorkouts) ? stats.recentWorkouts : [];

const monthlyVolumeData = monthly.slice().reverse().map((row: any) => ({
  label: row.month,
  value: Math.round((Number(row.volumeKg) || 0) / 100) / 10,
  displayValue: kgToTonneText(row.volumeKg),
}));

const maxMuscleSets = Math.max(...muscles.map((row: any) => Number(row.sets) || 0), 1);
const featuredLift = lifts[0] || null;
const featuredLiftData = featuredLift
  ? featuredLift.history.map((row: any) => ({
      label: monthLabel(row.date?.slice(0, 7)),
      value: Number(row.estimated1rmKg) || 0,
      displayValue: `${toFixedTrim(Number(row.estimated1rmKg) || 0, 1)} kg`,
    }))
  : [];
---

<div class="strength-dashboard">
  <StatGrid>
    <StatCard
      label={cards.totalWorkouts?.label}
      value={cards.totalWorkouts?.value}
      unit={cards.totalWorkouts?.unit}
      subtext={cards.totalWorkouts?.subtext}
    />
    <StatCard
      label={cards.totalTime?.label}
      value={cards.totalTime?.value}
      unit={cards.totalTime?.unit}
      subtext={cards.totalTime?.subtext}
    />
    <StatCard
      label={cards.totalVolume?.label}
      value={cards.totalVolume?.value}
      unit={cards.totalVolume?.unit}
      subtext={cards.totalVolume?.subtext}
    />
    <StatCard
      label={cards.activeWeeks?.label}
      value={cards.activeWeeks?.value}
      unit={cards.activeWeeks?.unit}
      subtext={cards.activeWeeks?.subtext}
    />
  </StatGrid>

  <div class="modules-stack">
    <section class="module-card strength-monthly-card" aria-labelledby="strength-monthly-title">
      <div class="module-header">
        <h4 id="strength-monthly-title">
          <svg class="mod-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3 13V7" />
            <path d="M8 13V3" />
            <path d="M13 13V5" />
          </svg>
          月度训练量
        </h4>
        <span class="module-note">mock Hevy data</span>
      </div>
      <div class="module-body chart-dense">
        <SportsBarChart
          data={monthlyVolumeData}
          unit="t"
          id="strength-monthly-volume"
        />
      </div>
    </section>

    <div class="strength-grid">
      <section class="module-card" aria-labelledby="strength-distribution-title">
        <div class="module-header">
          <h4 id="strength-distribution-title">
            <svg class="mod-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M2 12c2-5 4-8 6-8s4 3 6 8" />
              <path d="M5 12h6" />
            </svg>
            肌群分布
          </h4>
        </div>
        <div class="module-body">
          <div class="muscle-list">
            {muscles.map((row: any) => {
              const sets = Number(row.sets) || 0;
              const width = Math.max(5, Math.round((sets / maxMuscleSets) * 100));
              return (
                <div class="muscle-row">
                  <div class="muscle-meta">
                    <span>{row.label}</span>
                    <strong>{sets} 组</strong>
                  </div>
                  <div class="muscle-track" aria-hidden="true">
                    <span style={`width: ${width}%`}></span>
                  </div>
                  <div class="muscle-volume">{kgToTonneText(row.volumeKg)}</div>
                </div>
              );
            })}
          </div>
        </div>
      </section>

      <section class="module-card" aria-labelledby="strength-lifts-title">
        <div class="module-header">
          <h4 id="strength-lifts-title">
            <svg class="mod-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M2 8h12" />
              <path d="M4 6v4" />
              <path d="M12 6v4" />
            </svg>
            重点动作
          </h4>
        </div>
        <div class="module-body lift-body">
          {featuredLift && featuredLiftData.length > 0 && (
            <div class="featured-lift">
              <div class="featured-lift__head">
                <div>
                  <span class="eyebrow">趋势</span>
                  <strong>{featuredLift.name}</strong>
                </div>
                <span>{featuredLift.bestSet}</span>
              </div>
              <SportsLineChart
                data={featuredLiftData}
                unit="kg"
                color="#0f766e"
                id="strength-featured-lift"
              />
            </div>
          )}
          <div class="lift-ledger">
            {lifts.map((lift: any) => (
              <div class="lift-row">
                <div>
                  <strong>{lift.name}</strong>
                  <span>{lift.subtext}</span>
                </div>
                <em>{lift.bestSet}</em>
              </div>
            ))}
          </div>
        </div>
      </section>
    </div>

    <section class="module-card" aria-labelledby="strength-workouts-title">
      <div class="module-header">
        <h4 id="strength-workouts-title">
          <svg class="mod-icon" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 2h8" />
            <path d="M5 2v12" />
            <path d="M11 2v12" />
            <path d="M3 6h10" />
          </svg>
          最近训练
        </h4>
      </div>
      <div class="module-body no-padding">
        <div class="workout-table">
          <div class="workout-thead">
            <span class="workout-col date">日期</span>
            <span class="workout-col title">训练</span>
            <span class="workout-col focus">重点</span>
            <span class="workout-col sets">组数</span>
            <span class="workout-col volume">训练量</span>
            <span class="workout-col time">时长</span>
          </div>
          {recentWorkouts.map((workout: any) => (
            <div class="workout-row">
              <span class="workout-col date">{workout.date}</span>
              <span class="workout-col title">
                {workout.title}
                <small>{workout.exerciseCount} 动作</small>
              </span>
              <span class="workout-col focus">{workout.focus}</span>
              <span class="workout-col sets">{workout.setCount} 组</span>
              <span class="workout-col volume">{kgToTonneText(workout.volumeKg)}</span>
              <span class="workout-col time">{workout.durationMin}m</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  </div>
</div>

<style>
  .strength-dashboard {
    --strength-accent: oklch(0.42 0.052 182);
    --strength-accent-soft: color-mix(in oklab, var(--strength-accent) 8%, transparent);
  }

  :global([data-theme="dark"]) .strength-dashboard {
    --strength-accent: oklch(0.72 0.054 182);
    --strength-accent-soft: color-mix(in oklab, var(--strength-accent) 13%, transparent);
  }

  .modules-stack {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .module-card {
    border: 1px solid var(--paper-card-border-soft);
    border-radius: 16px;
    overflow: hidden;
    background: color-mix(in oklab, var(--page-bg) 45%, var(--paper-card-bg));
    box-shadow: var(--paper-card-shadow);
  }

  :global([data-theme="dark"]) .module-card {
    background: color-mix(in oklab, var(--page-bg) 18%, var(--paper-card-bg));
  }

  .module-header {
    min-height: 2.6rem;
    padding: 0.85rem 1.25rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.04);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  :global([data-theme="dark"]) .module-header {
    border-bottom-color: rgba(255, 255, 255, 0.05);
  }

  .module-header h4 {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--heading-color);
    margin: 0;
    opacity: 0.86;
    letter-spacing: 0.01em;
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .module-note,
  .eyebrow {
    color: var(--gray-color);
    font-family: var(--ui-font, inherit);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.03em;
  }

  .mod-icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    color: var(--strength-accent);
    opacity: 0.66;
  }

  .module-body {
    padding: 1.25rem;
  }

  .module-body.no-padding {
    padding: 0;
  }

  .module-body.chart-dense {
    padding: 0.4rem 0.15rem 0.6rem;
  }

  .strength-monthly-card {
    background:
      linear-gradient(180deg, var(--strength-accent-soft), transparent 32%),
      var(--paper-card-bg);
  }

  .strength-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: 1.5rem;
  }

  .muscle-list {
    display: grid;
    gap: 0.85rem;
  }

  .muscle-row {
    display: grid;
    grid-template-columns: minmax(5.5rem, 0.7fr) minmax(7rem, 1fr) 4rem;
    gap: 0.75rem;
    align-items: center;
  }

  .muscle-meta {
    display: flex;
    justify-content: space-between;
    gap: 0.6rem;
    font-family: var(--ui-font, inherit);
    font-size: 0.78rem;
    color: var(--heading-color);
  }

  .muscle-meta strong {
    color: var(--gray-color);
    font-size: 0.72rem;
    font-weight: 500;
    font-variant-numeric: tabular-nums;
  }

  .muscle-track {
    height: 0.48rem;
    border-radius: 999px;
    background: color-mix(in oklab, var(--gray-color) 12%, transparent);
    overflow: hidden;
  }

  .muscle-track span {
    display: block;
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, color-mix(in oklab, var(--strength-accent) 64%, transparent), var(--strength-accent));
  }

  .muscle-volume {
    color: var(--gray-color);
    font-family: var(--ui-font, inherit);
    font-size: 0.72rem;
    font-variant-numeric: tabular-nums;
    text-align: right;
  }

  .lift-body {
    display: grid;
    gap: 1rem;
  }

  .featured-lift {
    border: 1px solid color-mix(in oklab, var(--paper-card-border-soft) 82%, transparent);
    border-radius: 12px;
    background: color-mix(in oklab, var(--paper-card-bg) 80%, transparent);
    padding: 0.85rem 0.85rem 0.4rem;
  }

  .featured-lift__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.25rem;
    font-family: var(--ui-font, inherit);
  }

  .featured-lift__head div {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  .featured-lift__head strong {
    color: var(--heading-color);
    font-size: 0.9rem;
  }

  .featured-lift__head span:last-child {
    color: var(--strength-accent);
    font-size: 0.78rem;
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }

  .featured-lift :global(.line-chart-wrapper) {
    margin: 0;
  }

  .featured-lift :global(.line-chart-title) {
    display: none;
  }

  .lift-ledger {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border-top: 1px solid rgba(0, 0, 0, 0.04);
  }

  :global([data-theme="dark"]) .lift-ledger {
    border-top-color: rgba(255, 255, 255, 0.05);
  }

  .lift-row {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.72rem 0.1rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.035);
    font-family: var(--ui-font, inherit);
  }

  .lift-row:nth-child(odd) {
    padding-right: 0.8rem;
  }

  .lift-row:nth-child(even) {
    padding-left: 0.8rem;
  }

  :global([data-theme="dark"]) .lift-row {
    border-bottom-color: rgba(255, 255, 255, 0.04);
  }

  .lift-row div {
    min-width: 0;
  }

  .lift-row strong,
  .lift-row span {
    display: block;
  }

  .lift-row strong {
    color: var(--heading-color);
    font-size: 0.82rem;
  }

  .lift-row span {
    color: var(--gray-color);
    font-size: 0.68rem;
    margin-top: 0.16rem;
  }

  .lift-row em {
    color: var(--gray-color);
    font-size: 0.76rem;
    font-style: normal;
    font-weight: 600;
    white-space: nowrap;
    font-variant-numeric: tabular-nums;
  }

  .workout-table {
    display: flex;
    flex-direction: column;
    font-family: var(--ui-font, inherit);
    font-size: 0.82rem;
  }

  .workout-thead,
  .workout-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .workout-thead {
    padding: 0.55rem 1.5rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    color: var(--gray-color);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.04em;
  }

  :global([data-theme="dark"]) .workout-thead {
    border-bottom-color: rgba(255, 255, 255, 0.06);
  }

  .workout-row {
    padding: 0.72rem 1.5rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.035);
    transition: background 0.15s ease;
  }

  .workout-row:last-child {
    border-bottom: none;
  }

  .workout-row:hover {
    background: rgba(0, 0, 0, 0.015);
  }

  :global([data-theme="dark"]) .workout-row {
    border-bottom-color: rgba(255, 255, 255, 0.04);
  }

  :global([data-theme="dark"]) .workout-row:hover {
    background: rgba(255, 255, 255, 0.015);
  }

  .workout-col {
    min-width: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .workout-col.date {
    flex: 0 0 92px;
    color: var(--gray-color);
    font-size: 0.76rem;
    font-variant-numeric: tabular-nums;
  }

  .workout-col.title {
    flex: 1 1 auto;
    color: var(--heading-color);
    font-weight: 650;
  }

  .workout-col.title small {
    color: var(--gray-color);
    font-size: 0.66rem;
    font-weight: 500;
    margin-left: 0.42rem;
  }

  .workout-col.focus {
    flex: 0 0 126px;
    color: var(--gray-color);
    font-size: 0.76rem;
  }

  .workout-col.sets,
  .workout-col.volume,
  .workout-col.time {
    flex: 0 0 72px;
    text-align: right;
    color: var(--gray-color);
    font-size: 0.76rem;
    font-variant-numeric: tabular-nums;
  }

  .workout-col.volume {
    color: var(--heading-color);
    font-weight: 700;
  }

  @media (prefers-reduced-motion: reduce) {
    .workout-row,
    .muscle-track span {
      transition: none;
    }
  }

  @media (max-width: 900px) {
    .strength-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .modules-stack,
    .strength-grid {
      gap: 1.25rem;
    }

    .module-header {
      padding: 0.6rem 0.85rem;
    }

    .module-body {
      padding: 0.85rem;
    }

    .module-body.chart-dense {
      padding: 0;
    }

    :global(.strength-dashboard .bar-chart-plot) {
      overflow-x: hidden;
    }

    :global(.strength-dashboard .bar-chart-svg) {
      min-width: 0;
    }

    .muscle-row {
      grid-template-columns: 1fr 4.2rem;
      gap: 0.45rem 0.75rem;
    }

    .muscle-track {
      grid-column: 1 / -1;
      order: 3;
    }

    .muscle-volume {
      font-size: 0.7rem;
    }

    .lift-ledger {
      grid-template-columns: 1fr;
    }

    .lift-row:nth-child(odd),
    .lift-row:nth-child(even) {
      padding-left: 0;
      padding-right: 0;
    }

    .workout-thead {
      display: none;
    }

    .workout-row {
      padding: 0.7rem 1rem;
      gap: 0.45rem 0.7rem;
      flex-wrap: wrap;
    }

    .workout-col.title {
      flex: 1 1 100%;
      order: -1;
      font-size: 0.86rem;
      text-align: left;
    }

    .workout-col.title small {
      display: inline;
    }

    .workout-col.date,
    .workout-col.focus,
    .workout-col.sets,
    .workout-col.volume,
    .workout-col.time {
      flex: 0 0 auto;
      text-align: left;
      font-size: 0.72rem;
    }
  }
</style>
