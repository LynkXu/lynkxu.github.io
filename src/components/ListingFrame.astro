---
interface Props {
	eyebrow?: string;
	title: string;
	description?: string;
	bodyWidth?: string;
	bodyAlign?: 'start' | 'center';
	className?: string;
}

const { eyebrow, title, description, bodyWidth, bodyAlign = 'start', className = '' } = Astro.props;
const frameStyleValue = [
	bodyWidth ? `--listing-frame-body-width: ${bodyWidth};` : '',
	bodyAlign === 'center' ? '--listing-frame-body-margin: auto;' : '',
].filter(Boolean).join(' ');
const frameStyle = frameStyleValue || undefined;
---

<section class:list={['listing-frame', className]} style={frameStyle} aria-labelledby="listing-frame-title">
	<header class="listing-frame__intro">
		{eyebrow && <p class="listing-frame__eyebrow">{eyebrow}</p>}
		<h1 id="listing-frame-title" class="listing-frame__title">{title}</h1>
		{description && <p class="listing-frame__description">{description}</p>}
	</header>

	<div class="listing-frame__body">
		<slot />
	</div>
</section>

<style>
	.listing-frame {
		--listing-frame-body-width: 100%;
		--listing-frame-body-margin: 0;
		display: flex;
		flex-direction: column;
		gap: clamp(0.78rem, 1.8vw, 1.08rem);
		width: 100%;
		min-width: 0;
		padding: 0 0 clamp(var(--space-2xl), 6vw, var(--space-4xl));
		animation: listing-frame-in 0.5s ease-out both;
	}

	.listing-frame__intro {
		display: flex;
		flex-direction: column;
		justify-content: flex-end;
		gap: 0.3rem;
		box-sizing: border-box;
		min-height: clamp(3.85rem, 6.2vw, 4.65rem);
		padding: 0 0 clamp(0.56rem, 1.2vw, 0.68rem);
		border-bottom: 1px solid color-mix(in oklab, var(--paper-card-border-soft) 48%, transparent);
	}

	.listing-frame__eyebrow,
	.listing-frame__title,
	.listing-frame__description {
		margin: 0;
	}

	.listing-frame__eyebrow {
		color: color-mix(in oklab, var(--gray-color) 78%, var(--heading-color));
		font-family: var(--field-font);
		font-size: 0.58rem;
		font-weight: 600;
		letter-spacing: 0.07em;
		line-height: 1.3;
		text-transform: uppercase;
	}

	.listing-frame__title {
		color: color-mix(in oklab, var(--heading-color) 90%, var(--gray-color));
		font-family: var(--serif-font);
		font-size: clamp(1.15rem, 2.05vw, 1.42rem);
		font-weight: 500;
		letter-spacing: -0.01em;
		line-height: 1.22;
		text-wrap: balance;
	}

	.listing-frame__description {
		max-width: 58ch;
		color: color-mix(in oklab, var(--text-color) 62%, var(--gray-color));
		font-size: 0.76rem;
		line-height: 1.62;
	}

	.listing-frame__body {
		width: min(100%, var(--listing-frame-body-width));
		margin-right: var(--listing-frame-body-margin);
		margin-left: var(--listing-frame-body-margin);
		min-width: 0;
	}

	@keyframes listing-frame-in {
		from {
			opacity: 0;
			transform: translateY(10px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (max-width: 720px) {
		.listing-frame {
			gap: var(--space-md);
			padding-top: 0;
		}

		.listing-frame__intro {
			min-height: 3.8rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.listing-frame {
			animation: none;
		}
	}
</style>
