---
import { Image } from 'astro:assets';

interface Props {
  title: string;
  cover: string;
  rating?: number; // 个人评分 (1-10)
  neodbRating?: number; // NeoDB 评分
  comment?: string;
  date: string;
  year?: string | number;
  link?: string;
  status?: string; // 'progress' or 'complete'
}

const { title, cover, rating, neodbRating, comment, date, year, link, status } = Astro.props;

// Convert 1-10 rating to 1-5 stars
const starCount = rating ? Math.round(rating / 2) : 0;
---

<a href={link} target="_blank" rel="noopener noreferrer" class="media-card no-underline">
    <div class="cover-wrapper">
        <img src={cover} alt={title} loading="lazy" onerror="this.src='/placeholder.png'"/>
        {status === 'progress' && <span class="badge-status">在看</span>}
    </div>
    <div class="info">
        <h3 class="title" title={title}>{title}</h3>
        <div class="meta">
            {starCount > 0 ? (
                <span class="stars" title={`个人评分: ${rating}/10`}>
                    {Array.from({ length: 5 }).map((_, i) => (
                        <span class={`star ${i < starCount ? 'filled' : ''}`}>★</span>
                    ))}
                </span>
            ) : neodbRating ? (
                <span class="neodb-rating">NeoDB {neodbRating}</span>
            ) : null}
            {year && year !== '未知' && <span class="year">{year}</span>}
        </div>
        {comment && <p class="comment" title={comment}>{comment}</p>}
    </div>
</a>

<style>
    .media-card {
        display: flex;
        flex-direction: column;
        text-decoration: none;
        color: inherit;
        overflow: hidden;
        position: relative;
        transition: transform 0.2s ease;
        border-bottom: none !important; /* 强制覆盖全局的 a 标签 border-bottom */
    }

    .media-card:hover {
        transform: translateY(-4px);
        border-bottom: none !important; /* 悬浮时也取消下划线 */
    }

    .media-card:focus-visible {
        outline: 2px solid rgba(66, 153, 225, 0.6);
        outline-offset: 4px;
        border-radius: 4px;
    }

    .cover-wrapper {
        position: relative;
        width: 100%;
        aspect-ratio: 2 / 3;
        background: rgba(0, 0, 0, 0.03);
        border-radius: 4px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
        transition: box-shadow 0.2s ease;
    }

    .media-card:hover .cover-wrapper {
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.08);
    }

    .cover-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        transition: transform 0.3s ease;
    }

    .media-card:hover .cover-wrapper img {
        transform: scale(1.03);
    }

    .badge-status {
        position: absolute;
        top: var(--space-xs);
        right: var(--space-xs);
        background: var(--heading-color);
        color: var(--content-bg);
        font-size: 0.65rem;
        font-weight: 500;
        padding: 2px var(--space-xs);
        border-radius: 4px;
        z-index: 2;
        letter-spacing: 0.05em;
    }

    .info {
        margin-top: var(--space-sm);
        width: 100%;
        display: flex;
        flex-direction: column;
        gap: var(--space-2xs);
    }

    .title {
        margin: 0;
        font-size: var(--text-sm);
        font-weight: 600;
        color: var(--heading-color);
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        transition: color 0.2s;
        border-bottom: none; /* 确保标题文字部分也没有下划线 */
    }

    .media-card:hover .title {
        color: var(--link-color);
    }

    .meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-size: var(--text-xs);
        color: var(--gray-color);
        line-height: 1;
    }

    .stars {
        display: inline-flex;
        gap: 1px;
    }

    .star {
        color: rgba(0, 0, 0, 0.15);
        font-size: var(--text-xs);
    }

    .star.filled {
        color: #f59e0b;
    }

    .neodb-rating {
        font-weight: 500;
    }

    .year {
        opacity: 0.8;
    }

    .comment {
        margin: var(--space-2xs) 0 0 0;
        font-size: var(--text-xs);
        color: var(--gray-color);
        line-height: 1.55;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        opacity: 0.8;
    }

    /* ── Dark mode ── */
    :global([data-theme='dark']) .cover-wrapper {
        background: rgba(255, 255, 255, 0.03);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
    }

    :global([data-theme='dark']) .media-card:hover .cover-wrapper {
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.4);
    }

    :global([data-theme='dark']) .star {
        color: rgba(255, 255, 255, 0.15);
    }
</style>
