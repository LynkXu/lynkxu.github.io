---
interface Props {
  details: {
    pubDate: Date;
    readingTime?: number;
  };
}

const { details } = Astro.props;
const traceOffset = Math.max(0, Math.min(18, (details.readingTime ?? 4) * 2));
---

<aside class="left-sidebar" aria-hidden="true">
    <div class="signal-totem" style={`--trace-offset: ${traceOffset}px;`}>
        <span class="trace trace--long"></span>
        <span class="trace trace--mid"></span>
        <span class="trace trace--short"></span>
        <span class="node node--square"></span>
        <span class="node node--dot"></span>
    </div>
</aside>

<style>
    .left-sidebar {
        display: none; /* Hidden on small screens by default */
    }

    @media (min-width: 1400px) {
        .left-sidebar {
            display: block;
            position: fixed;
            left: max(20px, calc((100vw - var(--width, 860px)) / 2 - 24px - 88px));
            bottom: 120px;
            width: 52px;
            height: 160px;
            z-index: 0;
            user-select: none;
            pointer-events: none;
        }
    }

    .signal-totem {
        position: relative;
        width: 100%;
        height: 100%;
        opacity: 0.78;
    }

    .trace,
    .node {
        position: absolute;
    }

    .trace {
        height: 1px;
        background: color-mix(in oklab, var(--gray-color) 14%, transparent);
    }

    .trace--long {
        right: 0;
        bottom: calc(16px + var(--trace-offset));
        width: 38px;
    }

    .trace--mid {
        left: 8px;
        bottom: calc(54px + var(--trace-offset));
        width: 22px;
    }

    .trace--short {
        left: 24px;
        bottom: calc(96px + var(--trace-offset));
        width: 12px;
        background: color-mix(in oklab, var(--accent-color) 16%, transparent);
    }

    .node--square {
        left: 18px;
        bottom: calc(46px + var(--trace-offset));
        width: 7px;
        height: 7px;
        border: 1px solid color-mix(in oklab, var(--accent-color) 26%, transparent);
        background: color-mix(in oklab, var(--accent-color) 8%, transparent);
    }

    .node--dot {
        right: 10px;
        bottom: calc(12px + var(--trace-offset));
        width: 4px;
        height: 4px;
        background: color-mix(in oklab, var(--gray-color) 28%, transparent);
    }

    .signal-totem::before,
    .signal-totem::after {
        content: "";
        position: absolute;
        width: 1px;
        background: linear-gradient(
            to bottom,
            color-mix(in oklab, var(--gray-color) 12%, transparent) 0%,
            transparent 100%
        );
    }

    .signal-totem::before {
        left: 34px;
        bottom: calc(22px + var(--trace-offset));
        height: 104px;
    }

    .signal-totem::after {
        left: 18px;
        bottom: calc(86px + var(--trace-offset));
        height: 26px;
        background: linear-gradient(
            to bottom,
            color-mix(in oklab, var(--accent-color) 14%, transparent) 0%,
            transparent 100%
        );
    }

    :root[data-theme="dark"] .trace {
        background: color-mix(in oklab, var(--text-color) 10%, transparent);
    }

    :root[data-theme="dark"] .trace--short,
    :root[data-theme="dark"] .signal-totem::after {
        background: color-mix(in oklab, var(--accent-color) 12%, transparent);
    }

    :root[data-theme="dark"] .node--square {
        border-color: color-mix(in oklab, var(--accent-color) 22%, transparent);
        background: color-mix(in oklab, var(--accent-color) 7%, transparent);
    }

    :root[data-theme="dark"] .node--dot {
        background: color-mix(in oklab, var(--text-color) 18%, transparent);
    }

    :root[data-theme="dark"] .signal-totem::before {
        background: linear-gradient(
            to bottom,
            color-mix(in oklab, var(--text-color) 9%, transparent) 0%,
            transparent 100%
        );
    }
</style>
