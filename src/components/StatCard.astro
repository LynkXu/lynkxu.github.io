---
const { label, value, unit, subtext, id } = Astro.props;
---

<div class="stat-card" id={id}>
  <div class="stat-label">{label}</div>
  <div class="stat-main">
    <span class="stat-value">{value}</span>
    {unit && <span class="stat-unit">{unit}</span>}
  </div>
  {subtext && <div class="stat-sub">{subtext}</div>}
</div>

<style>
  .stat-card {
    background: color-mix(in oklab, var(--page-bg) 45%, var(--paper-card-bg));
    padding: 1.5rem 1.75rem;
    border-radius: 16px;
    border: 1px solid var(--paper-card-border-soft);
    box-shadow: var(--paper-card-shadow);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }

  .stat-card:hover {
    transform: translateY(-2px);
    border-color: color-mix(in oklab, var(--accent-color) 10%, var(--paper-card-border-soft));
    box-shadow: 0 8px 24px -10px rgba(0, 0, 0, 0.1);
  }

  :global([data-theme="dark"]) .stat-card {
    border-color: var(--paper-card-border-soft);
    background: color-mix(in oklab, var(--page-bg) 18%, var(--paper-card-bg));
  }

  :global([data-theme="dark"]) .stat-card:hover {
    border-color: color-mix(in oklab, var(--accent-color) 14%, var(--paper-card-border-soft));
    box-shadow: 0 8px 24px -10px rgba(0, 0, 0, 0.4);
  }

  .stat-label {
    font-size: 0.72rem;
    color: var(--gray-color);
    margin-bottom: 0.55rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    opacity: 0.9;
  }

  .stat-main {
    display: flex;
    align-items: baseline;
    gap: 0.3rem;
  }

  .stat-value {
    font-size: clamp(1.45rem, 1.3rem + 1.1vw, 1.95rem);
    font-weight: 750;
    color: var(--heading-color);
    line-height: 1;
    font-family: var(--font-heading, inherit);
    letter-spacing: -0.03em;
    font-variant-numeric: tabular-nums;
  }

  .stat-unit {
    font-size: 0.85rem;
    color: var(--gray-color);
    font-weight: 500;
    transform: translateY(-0.02em);
  }

  .stat-sub {
    margin-top: 0.5rem;
    font-size: 0.8rem;
    color: var(--gray-color);
    opacity: 0.75;
    font-weight: 500;
    line-height: 1.45;
  }
</style>
