---
interface CategoryItem {
	name: string;
	count: number;
	href: string;
}

interface Props {
	categories: CategoryItem[];
	activeCategory?: string;
	label?: string;
}

const {
	categories,
	activeCategory,
	label = 'Category Index',
} = Astro.props;
---

{
	categories.length > 0 && (
		<section class='category-filter' aria-label={label}>
			<p class='filter-label'>{label}</p>
			<div class='filter-list'>
				{
					categories.map((item) => {
						const isActive = item.name === activeCategory;

						return (
							<a
								href={item.href}
								class:list={['filter-chip', { active: isActive }]}
								aria-current={isActive ? 'page' : undefined}
							>
								<span class='filter-chip__name'>{item.name}</span>
								<span class='filter-chip__count'>{item.count}</span>
							</a>
						);
					})
				}
			</div>
		</section>
	)
}

<style>
	.category-filter {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		margin: 0;
		padding-bottom: 0.82rem;
		border-bottom: 1px solid color-mix(in oklab, var(--paper-card-border-soft) 42%, transparent);
	}

	.filter-label {
		margin: 0;
		color: var(--gray-color);
		font-family: var(--meta-font);
		font-size: 0.56rem;
		font-weight: 600;
		letter-spacing: 0.07em;
		text-transform: uppercase;
	}

	.filter-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.42rem;
	}

	.filter-chip {
		display: inline-flex;
		align-items: center;
		gap: 0.38rem;
		min-height: 1.78rem;
		padding: 0.34rem 0.52rem;
		border-radius: 999px;
		border: 1px solid var(--paper-card-border-soft);
		background: color-mix(in oklab, var(--paper-field-bg) 68%, transparent);
		color: color-mix(in oklab, var(--text-color) 82%, var(--gray-color));
		font-family: var(--field-font, var(--ui-font));
		font-size: 0.68rem;
		line-height: 1.2;
		position: relative;
		overflow: hidden;
		transition: border-color 0.18s ease, background-color 0.18s ease, color 0.18s ease;
	}

	.filter-chip::before {
		content: none;
		position: absolute;
		left: 0;
		top: 0;
		bottom: 0;
		width: 1px;
		background: var(--ink-accent);
		opacity: 0;
		transition: opacity 0.18s ease;
	}

	.filter-chip:hover {
		color: color-mix(in oklab, var(--accent-color) 42%, var(--heading-color));
		background: color-mix(in oklab, var(--accent-soft-bg) 55%, var(--paper-field-bg));
		border-color: color-mix(in oklab, var(--accent-color) 16%, var(--paper-card-border-soft));
	}

	.filter-chip:hover::before,
	.filter-chip.active::before {
		opacity: 0;
	}

	.filter-chip.active {
		color: var(--heading-color);
		border-color: color-mix(in oklab, var(--accent-color) 14%, var(--paper-card-border-soft));
		background: color-mix(in oklab, var(--accent-soft-bg) 60%, var(--paper-field-bg));
	}

	.filter-chip__name {
		font-weight: 500;
		line-height: 1.3;
	}

	.filter-chip__count {
		color: var(--gray-color);
		font-size: 0.58rem;
		line-height: 1;
		font-variant-numeric: tabular-nums;
	}

	.filter-chip.active .filter-chip__count {
		color: color-mix(in oklab, var(--heading-color) 62%, var(--gray-color));
	}

	@media (max-width: 640px) {
		.category-filter {
			margin-top: 1rem;
		}

		.filter-list {
			gap: 0.38rem;
		}

		.filter-chip {
			padding: 0.34rem 0.52rem;
			font-size: 0.68rem;
		}
	}
</style>
