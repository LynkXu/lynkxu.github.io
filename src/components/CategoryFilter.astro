---
interface CategoryItem {
	name: string;
	count: number;
	href: string;
}

interface Props {
	categories: CategoryItem[];
	activeCategory?: string;
	label?: string;
}

const {
	categories,
	activeCategory,
	label = 'Category Index',
} = Astro.props;
---

{
	categories.length > 0 && (
		<section class='category-filter' aria-label={label}>
			<p class='filter-label'>{label}</p>
			<div class='filter-list'>
				{
					categories.map((item) => {
						const isActive = item.name === activeCategory;

						return (
							<a
								href={item.href}
								class:list={['filter-chip', { active: isActive }]}
								aria-current={isActive ? 'page' : undefined}
							>
								<span class='filter-chip__name'>{item.name}</span>
								<span class='filter-chip__count'>{item.count}</span>
							</a>
						);
					})
				}
			</div>
		</section>
	)
}

<style>
	.category-filter {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		margin: clamp(1.15rem, 3vw, 1.55rem) 0 0;
		padding: clamp(0.85rem, 2.2vw, 1rem);
		border: 1px solid var(--paper-card-border-soft);
		background: color-mix(in oklab, var(--paper-card-bg) 40%, transparent);
		border-radius: var(--paper-card-radius);
		position: relative;
	}

	.category-filter::before {
		content: "";
		position: absolute;
		top: -1px;
		left: -1px;
		width: 1.1rem;
		height: 1px;
		background: var(--ink-accent);
		opacity: 0.42;
	}

	.filter-label {
		margin: 0;
		color: var(--gray-color);
		font-family: var(--field-font);
		font-size: 0.68rem;
		font-weight: 500;
		letter-spacing: 0.11em;
		text-transform: uppercase;
		font-variant-numeric: tabular-nums;
	}

	.filter-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.42rem;
	}

	.filter-chip {
		display: inline-flex;
		align-items: center;
		gap: 0.38rem;
		min-height: 2rem;
		padding: 0.38rem 0.58rem;
		border-radius: var(--paper-card-radius);
		border: 1px solid var(--paper-card-border-soft);
		background: var(--paper-field-bg);
		color: color-mix(in oklab, var(--text-color) 82%, var(--gray-color));
		font-family: var(--field-font);
		font-size: 0.78rem;
		line-height: 1.2;
		border-bottom: 1px solid transparent;
		font-variant-numeric: tabular-nums;
		transition: border-color 0.18s ease, background-color 0.18s ease, color 0.18s ease;
	}

	.filter-chip:hover {
		color: color-mix(in oklab, var(--ink-accent) 44%, var(--heading-color));
		border-color: color-mix(in oklab, var(--ink-accent) 22%, var(--paper-card-border-soft));
		background: color-mix(in oklab, var(--ink-wash) 55%, var(--paper-field-bg));
		border-bottom-color: color-mix(in oklab, var(--ink-accent) 22%, var(--paper-card-border-soft));
	}

	.filter-chip.active {
		color: color-mix(in oklab, var(--ink-accent) 48%, var(--heading-color));
		border-color: color-mix(in oklab, var(--ink-accent) 30%, var(--paper-card-border-soft));
		background: color-mix(in oklab, var(--ink-wash) 72%, var(--paper-field-bg));
		box-shadow: none;
		border-bottom-color: color-mix(in oklab, var(--ink-accent) 30%, var(--paper-card-border-soft));
	}

	.filter-chip.active::before {
		content: "";
		width: 0.38rem;
		height: 0.38rem;
		border-radius: 0;
		background: currentColor;
		opacity: 0.7;
	}

	.filter-chip__name {
		font-weight: 500;
	}

	.filter-chip__count {
		color: var(--gray-color);
		font-size: 0.68rem;
		font-variant-numeric: tabular-nums;
	}

	.filter-chip.active .filter-chip__count {
		color: color-mix(in oklab, var(--heading-color) 62%, var(--gray-color));
	}

	@media (max-width: 640px) {
		.category-filter {
			margin-top: 1rem;
			padding: 0.8rem;
		}

		.filter-list {
			gap: 0.36rem;
		}

		.filter-chip {
			padding: 0.36rem 0.52rem;
			font-size: 0.76rem;
		}
	}
</style>
