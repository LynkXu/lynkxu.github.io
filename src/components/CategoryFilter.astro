---
interface CategoryItem {
	name: string;
	count: number;
	href: string;
}

interface Props {
	categories: CategoryItem[];
	activeCategory?: string;
	label?: string;
}

const {
	categories,
	activeCategory,
	label = '分类索引',
} = Astro.props;
---

{
	categories.length > 0 && (
		<section class='category-filter' aria-label={label}>
			<p class='filter-label'>{label}</p>
			<div class='filter-list'>
				{
					categories.map((item) => {
						const isActive = item.name === activeCategory;

						return (
							<a
								href={item.href}
								class:list={['filter-chip', { active: isActive }]}
								aria-current={isActive ? 'page' : undefined}
							>
								<span class='filter-chip__name'>{item.name}</span>
								<span class='filter-chip__count'>{item.count}</span>
							</a>
						);
					})
				}
			</div>
		</section>
	)
}

<style>
	.category-filter {
		display: flex;
		flex-direction: column;
		gap: 0.9rem;
		margin: 1.5rem 0 0;
	}

	.filter-label {
		margin: 0;
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: 0.74rem;
		font-weight: 600;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.filter-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem 0.65rem;
	}

	.filter-chip {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.48rem 0.8rem 0.52rem;
		border-radius: 999px;
		border: 1px solid color-mix(in oklab, var(--gray-color) 16%, transparent);
		background: color-mix(in oklab, var(--content-bg) 92%, var(--accent-soft-bg));
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: 0.9rem;
		line-height: 1;
		border-bottom: 1px solid transparent;
		transition: border-color 0.18s ease, background-color 0.18s ease, color 0.18s ease, transform 0.18s ease;
	}

	.filter-chip:hover {
		color: var(--heading-color);
		border-color: color-mix(in oklab, var(--accent-soft-border) 88%, var(--gray-color));
		background: color-mix(in oklab, var(--accent-soft-bg) 72%, var(--content-bg));
		border-bottom-color: color-mix(in oklab, var(--accent-soft-border) 88%, var(--gray-color));
		transform: translateY(-1px);
	}

	.filter-chip.active {
		color: var(--heading-color);
		border-color: color-mix(in oklab, var(--accent-soft-border) 94%, var(--heading-color));
		background: color-mix(in oklab, var(--accent-soft-bg) 88%, var(--content-bg));
		box-shadow: inset 0 0 0 1px color-mix(in oklab, var(--accent-soft-border) 45%, transparent);
		border-bottom-color: color-mix(in oklab, var(--accent-soft-border) 94%, var(--heading-color));
	}

	.filter-chip.active::before {
		content: "";
		width: 0.38rem;
		height: 0.38rem;
		border-radius: 999px;
		background: currentColor;
		opacity: 0.7;
	}

	.filter-chip__name {
		font-weight: 500;
	}

	.filter-chip__count {
		color: var(--gray-color);
		font-size: 0.76rem;
		font-variant-numeric: tabular-nums;
	}

	.filter-chip.active .filter-chip__count {
		color: color-mix(in oklab, var(--heading-color) 62%, var(--gray-color));
	}

	@media (max-width: 640px) {
		.category-filter {
			margin-top: 1.15rem;
		}

		.filter-list {
			gap: 0.6rem 0.55rem;
		}

		.filter-chip {
			padding: 0.46rem 0.72rem 0.5rem;
			font-size: 0.86rem;
		}
	}
</style>
