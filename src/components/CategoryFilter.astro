---
interface CategoryItem {
	name: string;
	count: number;
	href: string;
}

interface Props {
	categories: CategoryItem[];
	activeCategory?: string;
	label?: string;
}

const {
	categories,
	activeCategory,
	label = 'Category Index',
} = Astro.props;
---

{
	categories.length > 0 && (
		<section class='category-filter' aria-label={label}>
			<p class='filter-label'>{label}</p>
			<div class='filter-list'>
				{
					categories.map((item) => {
						const isActive = item.name === activeCategory;

						return (
							<a
								href={item.href}
								class:list={['filter-chip', { active: isActive }]}
								aria-current={isActive ? 'page' : undefined}
							>
								<span class='filter-chip__name'>{item.name}</span>
								<span class='filter-chip__count'>{item.count}</span>
							</a>
						);
					})
				}
			</div>
		</section>
	)
}

<style>
	.category-filter {
		display: flex;
		flex-direction: column;
		gap: 0.85rem;
		margin: clamp(1rem, 2.5vw, 1.25rem) 0 clamp(1.5rem, 3vw, 2rem);
	}

	.filter-label {
		margin: 0;
		color: var(--gray-color);
		font-family: var(--meta-font);
		font-size: 0.72rem;
		font-weight: 500;
		letter-spacing: 0.03em;
		text-transform: none;
	}

	.filter-list {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(10rem, 1fr));
		gap: var(--blog-card-gap, 0.75rem);
	}

	.filter-chip {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		align-items: center;
		column-gap: 0.7rem;
		row-gap: 0.2rem;
		min-height: 2.55rem;
		padding: 0.58rem 0.72rem;
		border-radius: var(--paper-card-radius);
		border: 1px solid var(--paper-card-border-soft);
		background: var(--paper-field-bg);
		color: color-mix(in oklab, var(--text-color) 82%, var(--gray-color));
		font-family: var(--field-font, var(--ui-font));
		font-size: 0.82rem;
		line-height: 1.2;
		position: relative;
		overflow: hidden;
		transition: border-color 0.18s ease, background-color 0.18s ease, color 0.18s ease;
	}

	.filter-chip::before {
		content: none;
		position: absolute;
		left: 0;
		top: 0;
		bottom: 0;
		width: 1px;
		background: var(--ink-accent);
		opacity: 0;
		transition: opacity 0.18s ease;
	}

	.filter-chip:hover {
		color: color-mix(in oklab, var(--accent-color) 42%, var(--heading-color));
		background: color-mix(in oklab, var(--accent-soft-bg) 55%, var(--paper-field-bg));
		border-color: color-mix(in oklab, var(--accent-color) 16%, var(--paper-card-border-soft));
	}

	.filter-chip:hover::before,
	.filter-chip.active::before {
		opacity: 0;
	}

	.filter-chip.active {
		color: var(--heading-color);
		border-color: color-mix(in oklab, var(--accent-color) 14%, var(--paper-card-border-soft));
		background: color-mix(in oklab, var(--accent-soft-bg) 60%, var(--paper-field-bg));
	}

	.filter-chip__name {
		font-weight: 500;
		line-height: 1.3;
	}

	.filter-chip__count {
		color: var(--gray-color);
		font-size: 0.74rem;
		line-height: 1;
		font-variant-numeric: tabular-nums;
	}

	.filter-chip.active .filter-chip__count {
		color: color-mix(in oklab, var(--heading-color) 62%, var(--gray-color));
	}

	@media (max-width: 640px) {
		.category-filter {
			margin-top: 1rem;
		}

		.filter-list {
			grid-template-columns: 1fr;
			gap: 0.62rem;
		}

		.filter-chip {
			padding: 0.58rem 0.72rem;
			font-size: 0.82rem;
		}
	}
</style>
