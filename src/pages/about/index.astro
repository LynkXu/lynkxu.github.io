---
import { Button, Collapse, Spoiler, Timeline } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import Substats from '@/components/about/Substats.astro'
import ToolSection from '@/components/about/ToolSection.astro'

const headings = [
  { depth: 2, slug: 'hobbies', text: 'Hobbies' },
  { depth: 2, slug: 'tools', text: 'Tools' },
  { depth: 2, slug: 'social-networks', text: 'Social Networks' },
  // { depth: 2, slug: 'gossips', text: 'Gossips' },
  { depth: 2, slug: 'about-blog', text: 'About Blog' }
]
---

<PageLayout title='About' {headings} highlightColor='#9B8AB4'>
  <p>Backend Developer</p>
  <ul>
    <li>📍 Living in <strong><a href='https://en.wikipedia.org/wiki/Shanghai' target='_blank'>Shanghai, China</a></strong></li>
    <li>💼 Working at <strong><a href='https://www.goatgroup.com/' target='_blank'>Goat Group</a></strong></li>
  </ul>
  <p>
    My motto: Stay hungry, Stay foolish. <Spoiler>这里可以夹私货，但是还没想好写什么！</Spoiler>
  </p>
  <Button title='Sponsor Me' class='w-fit' href='/projects#sponsorship' variant='ahead' />

  {/* general-talk */}
  <h2 id='hobbies'>Hobbies</h2>
  <ul>
    <li>💪 Fitness - Staying healthy and building strength</li>
    <li>🚴 Cycling - Exploring the city and enjoying the outdoors</li>
    <li>📷 Photography - Capturing moments and beautiful scenes</li>
    <li>💭 Daydreaming - Thinking about possibilities and future ideas</li>
  </ul>

  {/* tools */}
  <h2 id='tools'>Tools</h2>
  <p>Tools and technologies I use:</p>
  <ToolSection
    class='mb-5'
    title='Development'
    tools={[
      {
        name: 'VS Code',
        description: 'Primary IDE',
        href: 'https://code.visualstudio.com/',
        icon: import('@/assets/tools/vscode.svg?raw')
      }
    ]}
  />
  <ToolSection
    class='mb-5'
    title='Productivity'
    tools={[
      {
        name: 'Chrome',
        description: 'Browser',
        href: 'https://www.google.com/chrome/',
        icon: import('@/assets/tools/chrome.svg?raw')
      },
      {
        name: 'Notion',
        description: 'Note Taking',
        href: 'https://www.notion.so/',
        icon: import('@/assets/tools/notion.svg?raw')
      }
    ]}
  />

  {/* social-networks */}
  <h2 id='social-networks'>Social Networks</h2>
  <p>
    Feel free to connect with me on various platforms. I'm most active on GitHub where I share my projects and contributions.
  </p>
  <Substats
    stats={[
      {
        platform: 'GitHub',
        icon: 'github',
        link: 'https://github.com/lynkxu',
        text: 'followers',
        api: 'github/lynkxu'
      }
    ]}
  />

  <!-- {/* gossips */}
  <h2 id='gossips'>Gossips</h2>
  <Collapse title='Random Thoughts'>
    Life is a journey of continuous learning and exploration. Every challenge is an opportunity to grow, 
    and every project is a chance to create something meaningful. Stay curious, stay humble, and keep building!
  </Collapse> -->

  {/* about-blog */}
  <h2 id='about-blog'>About Blog</h2>
  <p>Website history:</p>
  <Timeline
    events={[
      {
        date: '2025-11-12',
        content:
          'Website created using <a href="https://astro.build/" target="_blank">Astro</a> and <a href="https://github.com/cworld1/astro-theme-pure" target="_blank">Astro Theme Pure</a>'
      }
    ]}
  />
</PageLayout>
