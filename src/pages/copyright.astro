---
import MagazineShell from '../layouts/MagazineShell.astro';

const rights = [
	{ label: '共享', desc: '你可以自由复制、分享本站内容' },
	{ label: '改编', desc: '你可以基于本站内容进行二次创作' },
	{ label: '署名', desc: '转载或改编时必须注明作者及来源' },
	{ label: '非商业', desc: '不得将内容用于商业用途' },
];
---

<MagazineShell title="Copyright" description="Copyright and license information for lynkxu.github.io.">
	<article class="copyright-page magazine-panel">
		<header class="copyright-page__header">
			<p class="magazine-section-label">许可</p>
			<h1 class="copyright-page__title">CC BY-NC 4.0</h1>
			<p class="copyright-page__lead">
				本站内容采用
				<a href="https://creativecommons.org/licenses/by-nc/4.0/" target="_blank" rel="noopener noreferrer">
					知识共享署名-非商业性使用 4.0 国际许可协议
				</a>
				进行许可。
			</p>
		</header>

		<section class="copyright-page__body" aria-labelledby="rights-title">
			<h2 id="rights-title" class="copyright-page__section-title">你可以做什么</h2>
			<dl class="copyright-page__rights">
				{rights.map((item) => (
					<div class="copyright-page__right">
						<dt>{item.label}</dt>
						<dd>{item.desc}</dd>
					</div>
				))}
			</dl>
		</section>

		<footer class="copyright-page__footer">
			<a href="https://creativecommons.org/licenses/by-nc/4.0/" target="_blank" rel="noopener noreferrer" class="copyright-page__link">
				查看完整协议
			</a>
			<p class="copyright-page__note">© 2020 – {new Date().getFullYear()} LynkXu. All rights reserved.</p>
		</footer>
	</article>
</MagazineShell>

<style>
	.copyright-page {
		padding: 0;
	}

	.copyright-page__header {
		margin-bottom: clamp(1.1rem, 2.6vw, 1.6rem);
		padding-bottom: 0.85rem;
		border-bottom: 1px solid var(--paper-card-border-soft);
	}

	.copyright-page__header .magazine-section-label {
		margin-bottom: 0.55rem;
	}

	.copyright-page__title {
		margin: 0 0 0.75rem;
		color: var(--heading-color);
		font-family: var(--display-font);
		font-size: clamp(1.55rem, 3.2vw, 2rem);
		font-weight: var(--weight-semibold, 600);
		line-height: 1.15;
		letter-spacing: -0.01em;
	}

	.copyright-page__lead {
		max-width: 42rem;
		margin: 0;
		color: var(--text-color);
		font-family: var(--reading-font, var(--serif-font));
		font-size: 0.94rem;
		line-height: 1.75;
	}

	.copyright-page__lead a {
		color: var(--heading-color);
		text-decoration: underline;
		text-decoration-thickness: 0.05em;
		text-underline-offset: 0.16em;
	}

	.copyright-page__lead a:hover {
		color: var(--accent-color);
	}

	.copyright-page__body {
		margin-bottom: clamp(1.1rem, 2.6vw, 1.6rem);
	}

	.copyright-page__section-title {
		margin: 0 0 0.55rem;
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: 0.72rem;
		font-weight: var(--weight-medium);
		letter-spacing: 0.04em;
		line-height: 1.2;
	}

	.copyright-page__rights {
		margin: 0;
		padding: 0;
		border-top: 1px solid var(--paper-card-border-soft);
	}

	.copyright-page__right {
		display: grid;
		grid-template-columns: 5rem minmax(0, 1fr);
		gap: 0.85rem;
		align-items: baseline;
		padding: 0.62rem 0;
		border-bottom: 1px solid var(--paper-card-border-soft);
	}

	.copyright-page__right dt {
		margin: 0;
		color: var(--heading-color);
		font-family: var(--ui-font);
		font-size: 0.84rem;
		font-weight: var(--weight-medium);
		line-height: 1.45;
	}

	.copyright-page__right dd {
		margin: 0;
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: 0.84rem;
		font-weight: var(--weight-regular);
		line-height: 1.55;
	}

	.copyright-page__footer {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 0.75rem 1.2rem;
		padding-top: 0.85rem;
		border-top: 1px solid var(--paper-card-border-soft);
	}

	.copyright-page__link {
		color: var(--heading-color);
		font-family: var(--ui-font);
		font-size: 0.8rem;
		font-weight: var(--weight-regular);
		text-decoration: underline;
		text-decoration-thickness: 0.05em;
		text-underline-offset: 0.18em;
	}

	.copyright-page__link:hover {
		color: var(--accent-color);
	}

	.copyright-page__note {
		margin: 0;
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: 0.72rem;
		line-height: 1.4;
	}

	@media (max-width: 640px) {
		.copyright-page__right {
			grid-template-columns: 1fr;
			gap: 0.2rem;
		}

		.copyright-page__footer {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>
