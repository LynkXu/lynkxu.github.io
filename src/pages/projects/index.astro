---
import { Button, Collapse, Icon } from 'astro-pure/user'
import PageLayout from '@/layouts/CommonPage.astro'
import ProjectSection from '@/components/projects/ProjectSection.astro'
import Sponsors from '@/components/projects/Sponsors.astro'
import Sponsorship from '@/components/projects/Sponsorship.astro'
import KeyIcon from '@/assets/icons/key.svg'
import wechat from '@/assets/wechat-qrcode.jpg'

const headings = [
  { depth: 2, slug: 'projects', text: 'Projects' },
  { depth: 2, slug: 'sponsorship', text: 'Sponsorship' }
]
---

<PageLayout title='Projects' {headings} view highlightColor='#8BB49B'>
  <p class='mb-2 flex items-center gap-2 text-xs font-medium uppercase tracking-wide text-muted-foreground'>
    <Icon name='activity' class='size-4' />
    GitHub Activity
  </p>
  <p class='mb-6'>
    <img
      src='https://ghchart.rshah.org/659eb9/lynkxu'
      alt='GitHub activity chart'
      loading='lazy'
      class='w-full max-w-3xl rounded-md border border-border/40 bg-card/70 p-2'
    />
  </p>

  <h2 id='projects'>Projects</h2>
  <p>My projects will be updated here as I continue building and learning. Stay tuned!</p>
  <!-- You can add your projects here using ProjectSection component
  <ProjectSection
    projects={[
      {
        name: 'Project Name',
        description: 'Project description',
        links: [
          { type: 'github', href: 'https://github.com/lynkxu/project-name' }
        ]
      }
    ]}
  />
  -->

  <!-- gpg signature -->
  <!-- Uncomment if you use GPG signatures
  <h2 id='gpg-signature'>GPG Signature</h2>
  <p>
    You can verify the authenticity of the files I signed by checking the GPG signature. My GPG key
    is <code>YOUR_KEY_ID</code>, and you can find it on the opengpg key servers.
  </p>
  <Button href='https://keys.openpgp.org/search?q=YOUR_KEY_ID' title='Checkout my key' target='_blank'>
    <KeyIcon class='size-5' slot='before' />
  </Button>
  -->

  <!-- sponsorship -->
  <h2 id='sponsorship'>Sponsorship</h2>
  <p>If you find my work valuable, you can support me through the following methods. Please leave a message after sponsoring!</p>
  <Sponsorship
    methods={[
      { name: 'WeChat', icon: 'wechat-pay', image: wechat }
      // { name: 'Alipay', icon: 'alipay', image: alipay }
    ]}
  />
  <p>Thanks to all sponsors for their support! 💖</p>
  <!-- Uncomment and update with real sponsors when you receive sponsorships
  <Sponsors
    progressMax={25}
    sponsors={[
      { name: 'Sponsor Name', platform: 'Wechat', amount: 50, date: '2025-11-12' }
    ]}
  />
  -->
</PageLayout>

<style>
  .sponsorship-card {
    & .sponsorship-card-img {
      opacity: 0.3;
      --un-blur: blur(4px);
      filter: var(--un-blur);
    }

    &:hover {
      & .sponsorship-card-icon {
        opacity: 0;
      }
      & .sponsorship-card-img {
        opacity: 1;
        --un-blur: blur(0);
      }
    }
  }
</style>
