---
import { getCollection } from 'astro:content';
import MagazineShell from '../../layouts/MagazineShell.astro';
import { SITE_DESCRIPTION } from '../../consts';
import { INCLUDE_DRAFTS, filterDrafts } from '../../utils/drafts';

const posts = filterDrafts(await getCollection('blog'))
	.filter((post) => !post.id.startsWith('en/'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const postsByYear: Record<number, typeof posts> = {};
posts.forEach((post) => {
	const year = post.data.pubDate.getFullYear();
	if (!postsByYear[year]) {
		postsByYear[year] = [];
	}
	postsByYear[year].push(post);
});

const years = Object.keys(postsByYear)
	.map(Number)
	.sort((a, b) => b - a);

function getArchiveDate(date: Date) {
	const month = String(date.getMonth() + 1).padStart(2, '0');
	const day = String(date.getDate()).padStart(2, '0');
	return `${month}.${day}`;
}
---

<MagazineShell title='Archive' description={SITE_DESCRIPTION}>
	<div class="archive-header">
		<h1 class="page-title">Archive</h1>
		<p class="page-meta">{posts.length} posts · by year</p>
	</div>

	<div class="archive-entries">
		{
			years.map((year) => (
				<section class="year-section" aria-labelledby={`archive-year-${year}`}>
					<h2 class="year-label" id={`archive-year-${year}`}>{year}</h2>
					<ul class="year-list">
						{postsByYear[year].map((post) => (
							<li class="year-item">
								<time class="year-date" datetime={post.data.pubDate.toISOString()}>
									{getArchiveDate(post.data.pubDate)}
								</time>
								<a
									href={`/blog/${post.data.slug ?? post.id}.html`}
									class="year-link"
									transition:name={`post-title-${post.id}`}
								>
									{post.data.title}
								</a>
								{INCLUDE_DRAFTS && post.data.draft && (
									<span class="draft-badge" aria-label="Draft">Draft</span>
								)}
							</li>
						))}
					</ul>
				</section>
			))
		}
	</div>
</MagazineShell>

<style>
	.archive-header {
		margin-bottom: 0.5rem;
	}

	.page-title {
		margin: 0;
		font-family: var(--serif-font);
		font-size: clamp(1.25rem, 2.2vw, 1.55rem);
		font-weight: 500;
		color: var(--heading-color);
		letter-spacing: -0.01em;
	}

	.page-meta {
		margin: 0.35rem 0 0;
		font-size: 0.82rem;
		color: var(--gray-color);
	}

	.archive-entries {
		display: flex;
		flex-direction: column;
		gap: 1.8rem;
	}

	.year-section {
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}

	.year-label {
		margin: 0;
		font-family: var(--field-font);
		font-size: 0.78rem;
		font-weight: 500;
		color: var(--gray-color);
		letter-spacing: 0.06em;
		text-transform: uppercase;
		padding-bottom: 0.4rem;
		border-bottom: 1px solid var(--paper-card-border-soft);
	}

	.year-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
	}

	.year-item {
		display: flex;
		align-items: baseline;
		gap: 0.85rem;
		padding: 0.55rem 0;
		border-bottom: 1px solid color-mix(in oklab, var(--paper-card-border-soft) 50%, transparent);
		transition: background 0.15s ease;
	}

	.year-item:last-child {
		border-bottom: none;
	}

	.year-item:hover {
		background: color-mix(in oklab, var(--accent-soft-bg) 30%, transparent);
	}

	.year-date {
		font-family: var(--field-font);
		font-size: 0.72rem;
		color: var(--gray-color);
		font-variant-numeric: tabular-nums;
		letter-spacing: 0.02em;
		flex-shrink: 0;
		min-width: 2.4rem;
	}

	.year-link {
		color: var(--heading-color);
		font-size: 0.94rem;
		font-weight: 500;
		letter-spacing: -0.005em;
		text-decoration: none;
		border-bottom: none !important;
		background: none !important;
		transition: color 0.2s ease;
		flex: 1;
	}

	.year-link:hover {
		color: color-mix(in oklab, var(--accent-color) 42%, var(--heading-color));
	}

	.draft-badge {
		font-family: var(--field-font);
		font-size: 0.65rem;
		font-weight: 500;
		color: color-mix(in oklab, var(--color-warning) 65%, var(--gray-color));
		letter-spacing: 0.02em;
		flex-shrink: 0;
	}

	@keyframes fade-up {
		from { opacity: 0; transform: translateY(10px); }
		to { opacity: 1; transform: translateY(0); }
	}

	.archive-header {
		animation: fade-up 0.5s ease-out both;
	}

	.year-section {
		animation: fade-up 0.5s ease-out both;
	}

	.year-section:nth-child(1) { animation-delay: 0.06s; }
	.year-section:nth-child(2) { animation-delay: 0.12s; }
	.year-section:nth-child(3) { animation-delay: 0.18s; }
	.year-section:nth-child(4) { animation-delay: 0.24s; }
	.year-section:nth-child(5) { animation-delay: 0.30s; }
	.year-section:nth-child(6) { animation-delay: 0.36s; }

	@media (prefers-reduced-motion: reduce) {
		.archive-header,
		.year-section {
			animation: none;
		}
	}
</style>
