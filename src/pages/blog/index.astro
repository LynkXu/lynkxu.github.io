---
import { getCollection } from 'astro:content';
import MagazineShell from '../../layouts/MagazineShell.astro';
import { SITE_DESCRIPTION } from '../../consts';
import { INCLUDE_DRAFTS, filterDrafts } from '../../utils/drafts';

const posts = filterDrafts(await getCollection('blog'))
	.filter((post) => !post.id.startsWith('en/'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const postsByYear: Record<number, typeof posts> = {};
posts.forEach((post) => {
	const year = post.data.pubDate.getFullYear();
	if (!postsByYear[year]) {
		postsByYear[year] = [];
	}
	postsByYear[year].push(post);
});

const years = Object.keys(postsByYear)
	.map(Number)
	.sort((a, b) => b - a);

const tagsMap = new Map<string, number>();
posts.forEach((post) => {
	(post.data.tags || []).forEach((tag) => {
		tagsMap.set(tag, (tagsMap.get(tag) || 0) + 1);
	});
});

const tags = Array.from(tagsMap.entries())
	.map(([name, count]) => ({ name, count, href: `/tags/${name}/` }))
	.sort((a, b) => b.count - a.count || a.name.localeCompare(b.name));

function getArchiveDate(date: Date) {
	const month = String(date.getMonth() + 1).padStart(2, '0');
	const day = String(date.getDate()).padStart(2, '0');
	return `${month}.${day}`;
}

function getPostHref(post: (typeof posts)[number]) {
	return `/blog/${post.data.slug ?? post.id}.html`;
}

---

<MagazineShell title='归档' description={SITE_DESCRIPTION} className="archive-layout" showProfileCard={false}>
	<section class="archive-board" aria-labelledby="archive-title">
		<header class="archive-board__header">
			<h1 id="archive-title" class="archive-board__title">归档</h1>
		</header>

		<div class="archive-ledger" role="list">
			{years.map((year) => (
				<section class="archive-year" aria-labelledby={`archive-year-${year}`} role="listitem">
					<h2 id={`archive-year-${year}`} class="archive-year__label">{year}</h2>
					<ul class="archive-year__posts">
						{postsByYear[year].map((post) => {
							const primaryTag = post.data.tags?.[0] || post.data.categories?.[0];
							return (
								<li class="archive-entry">
									<time class="archive-entry__date" datetime={post.data.pubDate.toISOString()}>
										{getArchiveDate(post.data.pubDate)}
									</time>
									<div class="archive-entry__main">
										<a
											href={getPostHref(post)}
											class="archive-entry__title"
											transition:name={`post-title-${post.id}`}
										>
											{post.data.title}
										</a>
									</div>
									<div class="archive-entry__meta">
										{primaryTag && (
											<a class="archive-entry__tag" href={`/tags/${primaryTag}/`}>{primaryTag}</a>
										)}
										{INCLUDE_DRAFTS && post.data.draft && (
											<span class="draft-badge" aria-label="草稿">草稿</span>
										)}
									</div>
								</li>
							)
						})}
					</ul>
				</section>
			))}
		</div>
	</section>

	<div slot="sidebar-extra" class="archive-rail">
		<section class="archive-rail-card" aria-labelledby="archive-tags-title">
			<p id="archive-tags-title" class="archive-rail-label">标签</p>
			<ul class="archive-tag-list">
				{tags.slice(0, 10).map((tag) => (
					<li>
						<a href={tag.href}>{tag.name}</a>
					</li>
				))}
			</ul>
			<div class="archive-summary" aria-label="归档概览">
				<span><strong>{posts.length}</strong> 篇</span>
				<span><strong>{tags.length}</strong> 个话题</span>
				<span>始于 {years[years.length - 1]}</span>
			</div>
			<p id="archive-index-title" class="archive-rail-label archive-index-label">年份</p>
			<nav class="archive-year-index" aria-label="按年份跳转">
				{years.map((year) => (
					<a href={`#archive-year-${year}`}>
						<strong>{year}</strong>
						<span>{postsByYear[year].length} 篇</span>
					</a>
				))}
			</nav>
		</section>
	</div>
</MagazineShell>

<style>
	:global(.archive-layout .ledger-main) {
		min-height: 0;
	}

	:global(.archive-layout .ledger-main > footer) {
		margin-top: clamp(2rem, 5vw, 3.5rem);
	}

	.archive-board {
		min-height: 0;
		width: 100%;
	}

	.archive-board__header {
		margin-bottom: clamp(0.85rem, 2vw, 1.15rem);
		padding-bottom: 0.7rem;
		border-bottom: 2px solid var(--heading-color);
	}

	.archive-board__title {
		margin: 0;
		color: var(--heading-color);
		font-family: var(--display-font);
		font-size: clamp(1.45rem, 2.6vw, 1.75rem);
		font-weight: 500;
		letter-spacing: -0.02em;
		line-height: 1.15;
	}

	.archive-ledger {
		display: flex;
		flex-direction: column;
		gap: clamp(0.85rem, 1.8vw, 1.25rem);
	}

	.archive-year {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
		min-width: 0;
	}

	.archive-year__label {
		margin: 0;
		padding: 0.2rem 0 0.15rem;
		color: var(--heading-color);
		font-family: var(--display-font);
		font-size: 1.05rem;
		font-weight: 500;
		letter-spacing: -0.01em;
		line-height: 1.2;
	}

	.archive-year__posts {
		display: flex;
		flex-direction: column;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.archive-entry {
		display: grid;
		grid-template-columns: 3.4rem minmax(0, 1fr) auto;
		align-items: baseline;
		gap: 0.55rem 0.85rem;
		min-width: 0;
		padding: 0.42rem 0;
		border-bottom: 1px solid var(--paper-card-border-soft);
	}

	.archive-entry:hover .archive-entry__title {
		color: var(--accent-color);
	}

	.archive-entry__date {
		display: block;
		color: var(--faint-color);
		font-family: var(--code-font, var(--ui-font));
		font-size: 0.7rem;
		font-weight: 400;
		font-variant-numeric: tabular-nums;
		line-height: 1.3;
		letter-spacing: 0.01em;
		text-align: left;
		white-space: nowrap;
	}

	.archive-entry__main {
		min-width: 0;
	}

	.archive-entry__title {
		display: block;
		border: 0 !important;
		background: none !important;
		color: var(--heading-color);
		font-family: var(--ui-font);
		font-size: 0.92rem;
		font-weight: 400;
		line-height: 1.35;
		text-decoration: none;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		transition: color 0.18s ease;
	}

	.archive-entry__meta {
		display: inline-flex;
		align-items: center;
		justify-content: flex-end;
		gap: 0.3rem;
		min-width: 0;
		align-self: baseline;
	}

	.archive-entry__tag {
		border: 0 !important;
		background: none !important;
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: 0.68rem;
		font-weight: 500;
		line-height: 1.3;
		text-decoration: none;
		white-space: nowrap;
		transition: color 0.18s ease;
	}

	.archive-entry__tag:hover {
		color: var(--accent-color);
	}

	.archive-rail {
		display: contents;
	}

	.archive-rail-card {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.archive-rail-label {
		margin: 0;
		color: var(--faint-color);
		font-family: var(--ui-font);
		font-size: 0.68rem;
		font-weight: 500;
		letter-spacing: 0.08em;
		line-height: 1.3;
		text-transform: uppercase;
	}

	.archive-tag-list {
		display: flex;
		flex-direction: column;
		gap: 0;
		margin: 0;
		padding: 0;
		list-style: none;
		border-top: 1px solid var(--paper-card-border-soft);
	}

	.archive-tag-list a {
		display: block;
		padding: 0.32rem 0;
		border: 0 !important;
		border-bottom: 1px solid var(--paper-card-border-soft);
		background: none !important;
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: 0.72rem;
		font-weight: 500;
		line-height: 1.3;
		text-decoration: none;
		transition: color 0.18s ease;
	}

	.archive-tag-list a:hover {
		color: var(--heading-color);
	}

	.archive-summary {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0;
		margin-top: 0.25rem;
		padding-top: 0;
		border-top: 1px solid var(--paper-card-border-soft);
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: 0.76rem;
		font-weight: var(--weight-regular);
		line-height: 1.25;
	}

	.archive-summary span {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		padding: 0.32rem 0;
		border-bottom: 1px solid var(--paper-card-border-soft);
	}

	.archive-summary strong {
		color: var(--heading-color);
		font-size: 0.82rem;
		font-weight: 500;
	}

	.archive-index-label {
		margin-top: 0.15rem;
	}

	.archive-year-index {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0;
		border-top: 1px solid var(--paper-card-border-soft);
	}

	.archive-year-index a {
		display: flex;
		align-items: baseline;
		gap: 0.42rem;
		width: 100%;
		padding: 0.32rem 0;
		border: 0 !important;
		border-bottom: 1px solid var(--paper-card-border-soft) !important;
		background: none !important;
		color: inherit;
		font-family: var(--ui-font);
		text-decoration: none;
	}

	.archive-year-index strong {
		color: var(--heading-color);
		font-size: 0.82rem;
		font-weight: 500;
		line-height: 1;
	}

	.archive-year-index span {
		color: var(--gray-color);
		font-size: 0.7rem;
		font-weight: var(--weight-regular);
		white-space: nowrap;
	}

	.draft-badge {
		font-family: var(--ui-font);
		font-size: 0.68rem;
		font-weight: var(--weight-medium);
		color: color-mix(in oklab, var(--color-warning) 68%, var(--gray-color));
	}

	@media (max-width: 760px) {
		.archive-year__label {
			padding-bottom: 0.3rem;
			border-bottom: 1px solid var(--paper-card-border-soft);
			font-size: 1rem;
		}

		.archive-entry {
			grid-template-columns: 3.2rem minmax(0, 1fr);
			gap: 0.35rem 0.7rem;
		}

		.archive-entry__title {
			white-space: normal;
		}

		.archive-entry__meta {
			grid-column: 2;
			justify-content: flex-start;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.archive-entry__title,
		.archive-entry__tag,
		.archive-tag-list a {
			transition: none;
		}
	}
</style>
