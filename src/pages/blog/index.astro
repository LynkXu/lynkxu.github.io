---
import { getCollection } from 'astro:content';
import MagazineShell from '../../layouts/MagazineShell.astro';
import { SITE_DESCRIPTION } from '../../consts';
import { INCLUDE_DRAFTS, filterDrafts } from '../../utils/drafts';

const posts = filterDrafts(await getCollection('blog'))
	.filter((post) => !post.id.startsWith('en/'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const postsByYear: Record<number, typeof posts> = {};
posts.forEach((post) => {
	const year = post.data.pubDate.getFullYear();
	if (!postsByYear[year]) {
		postsByYear[year] = [];
	}
	postsByYear[year].push(post);
});

const years = Object.keys(postsByYear)
	.map(Number)
	.sort((a, b) => b - a);

const tagsMap = new Map<string, number>();
posts.forEach((post) => {
	(post.data.tags || []).forEach((tag) => {
		tagsMap.set(tag, (tagsMap.get(tag) || 0) + 1);
	});
});

const tags = Array.from(tagsMap.entries())
	.map(([name, count]) => ({ name, count, href: `/tags/${name}/` }))
	.sort((a, b) => b.count - a.count || a.name.localeCompare(b.name));

function getArchiveDate(date: Date) {
	const month = String(date.getMonth() + 1).padStart(2, '0');
	const day = String(date.getDate()).padStart(2, '0');
	return `${month}.${day}`;
}

function getPostHref(post: (typeof posts)[number]) {
	return `/blog/${post.data.slug ?? post.id}.html`;
}

---

<MagazineShell title='Archive' description={SITE_DESCRIPTION} showProfileCard={false}>
	<section class="archive-board magazine-panel" aria-labelledby="archive-title">
		<header class="archive-board__header">
			<div>
				<p class="magazine-section-label">Articles</p>
				<h1 id="archive-title" class="sr-only">Archive</h1>
				<p class="archive-board__intro">{posts.length} entries, filed by year. Tags stay secondary.</p>
			</div>
		</header>

		<div class="archive-ledger" role="list">
			{years.map((year) => (
				<section class="archive-year" aria-labelledby={`archive-year-${year}`} role="listitem">
					<h2 id={`archive-year-${year}`} class="archive-year__label">{year}</h2>
					<ul class="archive-year__posts">
						{postsByYear[year].map((post) => {
							const primaryTag = post.data.tags?.[0] || post.data.categories?.[0];
							return (
								<li class="archive-entry">
									<time class="archive-entry__date" datetime={post.data.pubDate.toISOString()}>
										{getArchiveDate(post.data.pubDate)}
									</time>
									<div class="archive-entry__main">
										<a
											href={getPostHref(post)}
											class="archive-entry__title"
											transition:name={`post-title-${post.id}`}
										>
											{post.data.title}
										</a>
									</div>
									<div class="archive-entry__meta">
										{primaryTag && <a class="magazine-chip" href={`/tags/${primaryTag}/`}>{primaryTag}</a>}
										{INCLUDE_DRAFTS && post.data.draft && (
											<span class="draft-badge" aria-label="Draft">Draft</span>
										)}
									</div>
								</li>
							)
						})}
					</ul>
				</section>
			))}
		</div>
	</section>

	<div slot="sidebar-extra" class="archive-rail">
		<section class="magazine-rail-card archive-tags-card" aria-labelledby="archive-tags-title">
			<p id="archive-tags-title" class="magazine-section-label">Tags</p>
			<p class="magazine-muted">辅助筛选，不抢走文章列表的注意力。</p>
			<div class="archive-tag-cloud">
				{tags.slice(0, 10).map((tag) => (
					<a href={tag.href} class="archive-tag-chip">
						<span>{tag.name}</span>
					</a>
				))}
			</div>
			<div class="archive-total">
				<strong>{posts.length}</strong>
				<span>entries since {years[years.length - 1]}</span>
			</div>
			<p class="archive-topic-count">{tags.length} topics, listed by latest update</p>
		</section>

		<section class="magazine-rail-card archive-index-card" aria-labelledby="archive-index-title">
			<p id="archive-index-title" class="magazine-section-label">Quick Index</p>
			<nav class="archive-year-index" aria-label="Archive years">
				{years.map((year) => (
					<a href={`#archive-year-${year}`}>
						<strong>{year}</strong>
						<span>{postsByYear[year].length} {postsByYear[year].length === 1 ? 'entry' : 'entries'}</span>
					</a>
				))}
			</nav>
		</section>
	</div>
</MagazineShell>

<style>
	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	.archive-board {
		min-height: min(50rem, calc(100vh - 10rem));
	}

	.archive-board__header {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: var(--space-lg);
		margin-bottom: clamp(var(--space-md), 2.4vw, var(--space-lg));
	}

	.archive-board__intro {
		margin: 0.72rem 0 0;
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: 0.88rem;
		font-weight: var(--weight-regular);
		line-height: 1.5;
	}

	.archive-ledger {
		display: flex;
		flex-direction: column;
		gap: 0.62rem;
	}

	.archive-year {
		display: grid;
		grid-template-columns: 6.2rem minmax(0, 1fr);
		gap: clamp(var(--space-sm), 1.8vw, var(--space-lg));
	}

	.archive-year + .archive-year {
		margin-top: 0.32rem;
	}

	.archive-year__label {
		position: sticky;
		top: calc(var(--space-lg) + 5rem);
		align-self: start;
		margin: 0;
		color: color-mix(in oklab, var(--accent-color) 76%, var(--heading-color));
		font-family: var(--ui-font);
		font-size: clamp(1.55rem, 3vw, 1.9rem);
		font-weight: var(--weight-bold);
		letter-spacing: 0;
		line-height: 1;
	}

	.archive-year__posts {
		display: flex;
		flex-direction: column;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.archive-entry {
		display: grid;
		grid-template-columns: 4rem minmax(0, 1fr) minmax(4rem, auto);
		align-items: center;
		gap: clamp(var(--space-sm), 1.6vw, var(--space-md));
		min-width: 0;
		padding: 0.68rem 0;
		border-bottom: 1px solid color-mix(in oklab, var(--paper-card-border-soft) 64%, transparent);
	}

	.archive-entry:first-child {
		padding-top: 0;
	}

	.archive-entry__date {
		color: color-mix(in oklab, var(--accent-color) 72%, var(--heading-color));
		font-family: var(--ui-font);
		font-size: 0.9rem;
		font-weight: var(--weight-medium);
		font-variant-numeric: tabular-nums;
		line-height: 1.25;
		text-align: right;
	}

	.archive-entry__main {
		min-width: 0;
	}

	.archive-entry__title {
		display: inline;
		border: 0 !important;
		background: none !important;
		color: var(--heading-color);
		font-family: var(--ui-font);
		font-size: clamp(0.98rem, 1.38vw, 1.08rem);
		font-weight: var(--weight-semibold);
		line-height: 1.32;
		text-decoration: none;
		overflow-wrap: anywhere;
		transition: color 0.18s ease;
	}

	.archive-entry__title:hover {
		color: color-mix(in oklab, var(--accent-color) 50%, var(--heading-color));
	}

	.archive-entry__meta {
		display: inline-flex;
		align-items: center;
		justify-content: flex-end;
		gap: 0.45rem;
		min-width: 0;
	}

	.archive-rail {
		display: contents;
	}

	.archive-tags-card,
	.archive-index-card {
		display: flex;
		flex-direction: column;
		gap: 0.82rem;
	}

	.archive-tag-cloud {
		display: flex;
		flex-wrap: wrap;
		gap: 0.64rem;
		padding-top: 0.35rem;
	}

	.archive-tag-chip {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-width: 3.9rem;
		min-height: 1.75rem;
		padding: 0.25rem 0.72rem;
		border: 0 !important;
		border-radius: 5px;
		background: color-mix(in oklab, var(--paper-field-bg) 76%, var(--accent-soft-bg)) !important;
		color: var(--heading-color);
		font-family: var(--ui-font);
		font-size: 0.75rem;
		font-weight: var(--weight-medium);
		line-height: 1;
		text-decoration: none;
	}

	.archive-total {
		display: flex;
		align-items: baseline;
		gap: 0.5rem;
		margin-top: 0.45rem;
		padding-top: 1.1rem;
		border-top: 1px solid var(--paper-card-border-soft);
		color: var(--heading-color);
		font-family: var(--ui-font);
	}

	.archive-total strong {
		color: color-mix(in oklab, var(--accent-color) 72%, var(--heading-color));
		font-size: 1.95rem;
		font-weight: var(--weight-bold);
		line-height: 1;
	}

	.archive-total span {
		font-size: 0.92rem;
		font-weight: var(--weight-medium);
	}

	.archive-topic-count {
		margin: -0.35rem 0 0;
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: 0.82rem;
		font-weight: var(--weight-medium);
		line-height: 1.45;
	}

	.archive-year-index {
		display: flex;
		flex-direction: column;
		gap: 0.72rem;
	}

	.archive-year-index a {
		display: flex;
		align-items: baseline;
		gap: 1rem;
		width: fit-content;
		border: 0 !important;
		background: none !important;
		color: inherit;
		font-family: var(--ui-font);
		text-decoration: none;
	}

	.archive-year-index strong {
		color: color-mix(in oklab, var(--accent-color) 72%, var(--heading-color));
		font-size: 1.55rem;
		font-weight: var(--weight-bold);
		line-height: 1;
	}

	.archive-year-index span {
		color: var(--gray-color);
		font-size: 0.86rem;
		font-weight: var(--weight-medium);
	}

	.draft-badge {
		font-family: var(--ui-font);
		font-size: 0.68rem;
		font-weight: var(--weight-medium);
		color: color-mix(in oklab, var(--color-warning) 68%, var(--gray-color));
	}

	@media (max-width: 760px) {
		.archive-year {
			grid-template-columns: 1fr;
			gap: 0.65rem;
		}

		.archive-year__label {
			position: static;
			padding-bottom: 0.35rem;
			border-bottom: 1px solid var(--paper-card-border-soft);
			font-size: 1.38rem;
		}

		.archive-entry {
			grid-template-columns: 3.4rem minmax(0, 1fr);
			gap: var(--space-sm);
		}

		.archive-entry__meta {
			grid-column: 2;
			justify-content: flex-start;
		}

		.archive-entry__date {
			text-align: left;
		}
	}
</style>
