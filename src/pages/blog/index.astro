---
import { getCollection } from 'astro:content';
import MagazineShell from '../../layouts/MagazineShell.astro';
import ListingFrame from '../../components/ListingFrame.astro';
import { SITE_DESCRIPTION } from '../../consts';
import { INCLUDE_DRAFTS, filterDrafts } from '../../utils/drafts';

const posts = filterDrafts(await getCollection('blog'))
	.filter((post) => !post.id.startsWith('en/'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const postsByYear: Record<number, typeof posts> = {};
posts.forEach((post) => {
	const year = post.data.pubDate.getFullYear();
	if (!postsByYear[year]) {
		postsByYear[year] = [];
	}
	postsByYear[year].push(post);
});

const years = Object.keys(postsByYear)
	.map(Number)
	.sort((a, b) => b - a);

function getArchiveDate(date: Date) {
	const month = String(date.getMonth() + 1).padStart(2, '0');
	const day = String(date.getDate()).padStart(2, '0');
	return `${month}.${day}`;
}
---

<MagazineShell title='Archive' description={SITE_DESCRIPTION}>
	<ListingFrame
		eyebrow="Writing"
		title="Archive"
		description={`${posts.length} entries, filed by year.`}
	>
		<div class="archive-entries">
			{
				years.map((year) => (
					<section class="year-section" aria-labelledby={`archive-year-${year}`}>
						<h2 class="year-label" id={`archive-year-${year}`}>{year}</h2>
						<ul class="year-list">
							{postsByYear[year].map((post) => (
								<li class="year-item">
									<time class="year-date" datetime={post.data.pubDate.toISOString()}>
										{getArchiveDate(post.data.pubDate)}
									</time>
									<a
										href={`/blog/${post.data.slug ?? post.id}.html`}
										class="year-link"
										transition:name={`post-title-${post.id}`}
									>
										{post.data.title}
									</a>
									{INCLUDE_DRAFTS && post.data.draft && (
										<span class="draft-badge" aria-label="Draft">Draft</span>
									)}
								</li>
							))}
						</ul>
					</section>
				))
			}
		</div>
	</ListingFrame>
</MagazineShell>

<style>
	.archive-entries {
		display: flex;
		flex-direction: column;
		gap: 0.68rem;
	}

	.year-section {
		display: grid;
		grid-template-columns: 4.5rem minmax(0, 1fr);
		gap: clamp(0.78rem, 1.8vw, 1rem);
		padding: clamp(0.72rem, 1.85vw, 0.92rem) clamp(0.82rem, 2.1vw, 1.05rem);
		border: 1px solid var(--paper-card-border-soft);
		border-radius: var(--paper-card-radius);
		background: var(--paper-card-bg);
		box-shadow: 0 1px 2px rgba(15, 23, 42, 0.02);
		transition: background 0.2s ease, border-color 0.2s ease;
		animation: fade-up 0.5s ease-out both;
	}

	.year-section:hover {
		background: var(--paper-hover-bg);
		border-color: var(--paper-hover-border);
	}

	.year-label {
		margin: 0;
		font-family: var(--field-font);
		font-size: 0.78rem;
		font-weight: 500;
		color: color-mix(in oklab, var(--heading-color) 82%, var(--gray-color));
		letter-spacing: 0.04em;
		line-height: 1.4;
		padding-top: 0.12rem;
	}

	.year-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
	}

	.year-item {
		display: flex;
		align-items: baseline;
		gap: 0.78rem;
		padding: 0.36rem 0;
		border-bottom: 1px solid color-mix(in oklab, var(--paper-card-border-soft) 36%, transparent);
		transition: background 0.15s ease;
	}

	.year-item:last-child {
		border-bottom: none;
	}

	.year-item:hover {
		background: var(--paper-hover-bg);
	}

	.year-date {
		font-family: var(--field-font);
		font-size: 0.72rem;
		color: color-mix(in oklab, var(--gray-color) 82%, var(--paper-bg));
		font-variant-numeric: tabular-nums;
		letter-spacing: 0.02em;
		flex-shrink: 0;
		min-width: 2.4rem;
	}

	.year-link {
		color: var(--heading-color);
		font-size: 0.9rem;
		font-weight: 500;
		letter-spacing: -0.005em;
		text-decoration: none;
		border-bottom: none !important;
		background: none !important;
		transition: color 0.2s ease;
		flex: 1;
	}

	.year-link:hover {
		color: color-mix(in oklab, var(--accent-color) 42%, var(--heading-color));
	}

	.draft-badge {
		font-family: var(--field-font);
		font-size: 0.65rem;
		font-weight: 500;
		color: color-mix(in oklab, var(--color-warning) 65%, var(--gray-color));
		letter-spacing: 0.02em;
		flex-shrink: 0;
	}

	@keyframes fade-up {
		from { opacity: 0; transform: translateY(10px); }
		to { opacity: 1; transform: translateY(0); }
	}

	.year-section:nth-child(1) { animation-delay: 0.06s; }
	.year-section:nth-child(2) { animation-delay: 0.12s; }
	.year-section:nth-child(3) { animation-delay: 0.18s; }
	.year-section:nth-child(4) { animation-delay: 0.24s; }
	.year-section:nth-child(5) { animation-delay: 0.30s; }
	.year-section:nth-child(6) { animation-delay: 0.36s; }

	@media (max-width: 720px) {
		.year-section {
			grid-template-columns: 1fr;
			gap: 0.5rem;
			padding: var(--space-sm);
		}

		.year-label {
			font-size: 0.78rem;
			padding-bottom: 0.3rem;
			border-bottom: 1px solid var(--paper-card-border-soft);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.year-section {
			animation: none;
		}
	}
</style>
