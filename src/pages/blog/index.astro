---
import { getCollection } from 'astro:content';
import MagazineShell from '../../layouts/MagazineShell.astro';
import { SITE_DESCRIPTION } from '../../consts';
import { INCLUDE_DRAFTS, filterDrafts } from '../../utils/drafts';

const posts = filterDrafts(await getCollection('blog'))
	.filter((post) => !post.id.startsWith('en/'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const postsByYear: Record<number, typeof posts> = {};
posts.forEach((post) => {
	const year = post.data.pubDate.getFullYear();
	if (!postsByYear[year]) {
		postsByYear[year] = [];
	}
	postsByYear[year].push(post);
});

const years = Object.keys(postsByYear)
	.map(Number)
	.sort((a, b) => b - a);

function getArchiveDate(date: Date) {
	const month = String(date.getMonth() + 1).padStart(2, '0');
	const day = String(date.getDate()).padStart(2, '0');
	return `${month}.${day}`;
}

function getPostHref(post: (typeof posts)[number]) {
	return `/blog/${post.data.slug ?? post.id}.html`;
}
---

<MagazineShell title='归档' description={SITE_DESCRIPTION} className="archive-layout" showProfileCard={false}>
	<section class="archive-board postcard-sheet" aria-labelledby="archive-title">
		<header class="archive-board__header">
			<div>
				<p class="magazine-section-label">Archive</p>
				<h1 id="archive-title" class="archive-board__title">全部文章 · 年表</h1>
			</div>
		</header>

		<div class="archive-board__legend" aria-hidden="true">
			<span class="archive-board__legend-date">Date</span>
			<span class="archive-board__legend-title">Title</span>
			<span class="archive-board__legend-tag">Tag</span>
		</div>

		<div class="archive-ledger" role="list">
			{years.map((year) => (
				<section class="archive-year" aria-labelledby={`archive-year-${year}`} role="listitem">
					<h2 id={`archive-year-${year}`} class="archive-year__label">{year}</h2>
					<ul class="archive-year__posts">
						{postsByYear[year].map((post) => {
							const primaryTag = post.data.tags?.[0] || post.data.categories?.[0];
							return (
								<li class="archive-entry">
									<time class="archive-entry__date" datetime={post.data.pubDate.toISOString()}>
										{getArchiveDate(post.data.pubDate)}
									</time>
									<div class="archive-entry__main">
										<a
											href={getPostHref(post)}
											class="archive-entry__title"
											transition:name={`post-title-${post.id}`}
										>
											{post.data.title}
										</a>
									</div>
									<div class="archive-entry__meta">
										{primaryTag && (
											<a class="archive-entry__tag" href={`/tags/${primaryTag}/`}>{primaryTag}</a>
										)}
										{INCLUDE_DRAFTS && post.data.draft && (
											<span class="draft-badge" aria-label="草稿">草稿</span>
										)}
									</div>
								</li>
							);
						})}
					</ul>
				</section>
			))}
		</div>
	</section>
</MagazineShell>

<style>
	.archive-board {
		min-height: 0;
		width: 100%;
		max-width: 100%;
		padding: clamp(1rem, 2.2vw, 1.35rem);
	}

	.archive-board__header {
		display: block;
		margin-bottom: 0.7rem;
		padding: 0 0 0.65rem;
		border-bottom: 1px solid var(--sheet-edge);
	}

	.archive-board__header .magazine-section-label {
		margin: 0 0 0.3rem;
		font-family: var(--field-font);
		font-size: 0.62rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--faint-color);
	}

	.archive-board__title {
		margin: 0;
		font-family: var(--display-font);
		font-size: clamp(1.25rem, 2.2vw, 1.45rem);
		font-weight: 600;
		letter-spacing: -0.015em;
		line-height: 1.2;
		color: var(--heading-color);
	}

	.archive-board__legend {
		display: grid;
		grid-template-columns: 3.6rem minmax(0, 1fr) 3.6rem;
		gap: 0.55rem 0.85rem;
		margin-bottom: 0.1rem;
		padding: 0.1rem 0 0.4rem;
		border-bottom: 1px dashed color-mix(in oklab, var(--sheet-edge) 75%, transparent);
		color: var(--faint-color);
		font-family: var(--field-font);
		font-size: 0.58rem;
		font-weight: var(--weight-medium);
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.archive-board__legend-tag {
		text-align: right;
	}

	.archive-ledger {
		display: flex;
		flex-direction: column;
		gap: clamp(0.85rem, 2vw, 1.25rem);
	}

	.archive-year {
		display: flex;
		flex-direction: column;
		gap: 0.15rem;
		min-width: 0;
	}

	.archive-year__label {
		margin: 0;
		padding: 0.55rem 0 0.2rem;
		color: color-mix(in oklab, var(--accent-color) 35%, var(--heading-color));
		font-family: var(--display-font);
		font-size: clamp(1.05rem, 1.7vw, 1.2rem);
		font-weight: 600;
		letter-spacing: -0.02em;
		line-height: 1.1;
	}

	.archive-year__posts {
		display: flex;
		flex-direction: column;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.archive-entry {
		display: grid;
		grid-template-columns: 3.6rem minmax(0, 1fr) 3.6rem;
		align-items: baseline;
		gap: 0.55rem 0.85rem;
		min-width: 0;
		padding: 0.38rem 0;
		border-bottom: 1px solid color-mix(in oklab, var(--paper-card-border-soft) 70%, transparent);
	}

	.archive-entry__date {
		display: block;
		min-width: 0;
		color: var(--gray-color);
		font-family: var(--code-font);
		font-size: 0.74rem;
		font-weight: 500;
		font-variant-numeric: tabular-nums;
		line-height: 1.25;
		letter-spacing: 0.02em;
		white-space: nowrap;
	}

	.archive-entry__main {
		min-width: 0;
	}

	.archive-entry__title {
		display: inline;
		border: 0 !important;
		background: none !important;
		color: var(--heading-color);
		font-family: var(--display-font);
		font-size: clamp(0.9rem, 1.05vw, 0.98rem);
		font-weight: 500;
		line-height: 1.3;
		text-decoration: none;
		overflow-wrap: break-word;
		transition: color 0.18s ease;
	}

	.archive-entry__title:hover {
		color: var(--link-color);
	}

	.archive-entry__meta {
		display: flex;
		align-items: baseline;
		justify-content: flex-end;
		gap: 0.4rem;
		min-width: 0;
	}

	.archive-entry__tag {
		border: 0 !important;
		background: none !important;
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: 0.7rem;
		line-height: 1.25;
		text-align: right;
		text-decoration: none;
		white-space: nowrap;
	}

	.archive-entry__tag:hover {
		color: var(--link-color);
	}

	.draft-badge {
		font-family: var(--ui-font);
		font-size: 0.68rem;
		font-weight: 500;
		color: color-mix(in oklab, var(--color-warning) 68%, var(--gray-color));
		white-space: nowrap;
	}

	@media (max-width: 720px) {
		.archive-board__legend {
			display: none;
		}

		.archive-entry {
			grid-template-columns: 3.2rem minmax(0, 1fr);
			gap: 0.4rem 0.7rem;
			padding: 0.34rem 0;
		}

		.archive-entry__meta {
			grid-column: 2;
			justify-content: flex-start;
		}

		.archive-entry__date {
			min-width: 0;
		}
	}
</style>
