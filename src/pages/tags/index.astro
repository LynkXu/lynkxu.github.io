---
import { getCollection } from 'astro:content';
import MagazineShell from '../../layouts/MagazineShell.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { filterDrafts } from '../../utils/drafts';

const allPosts = filterDrafts(await getCollection('blog'))
	.filter((post) => !post.id.startsWith('en/'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const postsByTopic = new Map<string, typeof allPosts>();

allPosts.forEach((post) => {
	(post.data.tags || []).forEach((tag) => {
		const posts = postsByTopic.get(tag) || [];
		posts.push(post);
		postsByTopic.set(tag, posts);
	});
});

const topics = Array.from(postsByTopic.entries())
	.map(([name, posts]) => {
		const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
		return {
			name,
			posts: sortedPosts,
			count: sortedPosts.length,
			latest: sortedPosts[0],
			href: `/tags/${name}/`,
		};
	})
	.sort((a, b) => b.count - a.count || a.name.localeCompare(b.name));

function getTopicTier(count: number) {
	if (count >= 8) return 'large';
	if (count >= 4) return 'medium';
	return 'small';
}
---

<MagazineShell title='话题' description='浏览全部话题'>
	<section class="topics-wall" aria-labelledby="topics-title">
		<h1 id="topics-title" class="sr-only">话题</h1>

		<div class="topic-cloud" aria-label="话题索引">
			{topics.map((topic) => (
				<a
					href={topic.href}
					class={`topic-token topic-token--${getTopicTier(topic.count)}`}
				>
					<span class="topic-token__head">
						<strong>{topic.name}</strong>
						<small>{topic.count}</small>
					</span>
					{topic.latest && (
						<span class="topic-token__latest">
							<span>{topic.latest.data.title}</span>
							<time datetime={topic.latest.data.pubDate.toISOString()}>
								<FormattedDate date={topic.latest.data.pubDate} />
							</time>
						</span>
					)}
				</a>
			))}
		</div>
	</section>
</MagazineShell>

<style>
	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	.topics-wall {
		gap: 1rem;
		padding: 0;
		animation: none;
	}

	.topic-cloud {
		display: flex;
		flex-direction: column;
		gap: 0;
		border-top: 1px solid var(--paper-card-border-soft);
	}

	.topic-token,
	.topic-token--large,
	.topic-token--medium,
	.topic-token--small {
		display: grid;
		grid-template-columns: minmax(8rem, 0.4fr) minmax(0, 1fr);
		gap: clamp(1rem, 3vw, 2rem);
		min-height: 0;
		padding: 0.86rem 0;
		border: 0 !important;
		border-bottom: 1px solid var(--paper-card-border-soft) !important;
		border-radius: 0;
		background: transparent !important;
		box-shadow: none;
		animation: none;
	}

	.topic-token:hover {
		transform: none;
		border-color: var(--paper-card-border-soft) !important;
		background: transparent !important;
	}

	.topic-token__head {
		justify-content: flex-start;
		gap: 0.7rem;
	}

	.topic-token__head strong,
	.topic-token--large .topic-token__head strong {
		color: var(--heading-color);
		font-family: var(--ui-font);
		font-size: clamp(1rem, 1.8vw, 1.18rem);
		font-weight: var(--weight-medium);
		line-height: 1.35;
	}

	.topic-token:hover .topic-token__head strong {
		color: var(--accent-color);
	}

	.topic-token__head small {
		color: var(--gray-color);
		font-size: 0.72rem;
	}

	.topic-token__latest {
		align-content: center;
		max-width: none;
	}

	.topic-token__latest span {
		color: var(--text-color);
		font-size: 0.86rem;
		line-height: 1.45;
		white-space: normal;
	}

	.topic-token__latest time {
		color: var(--gray-color);
		font-size: 0.72rem;
	}

	@media (max-width: 640px) {
		.topic-token,
		.topic-token--large,
		.topic-token--medium,
		.topic-token--small {
			grid-template-columns: 1fr;
			gap: 0.38rem;
		}
	}
</style>
