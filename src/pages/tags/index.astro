---
import { getCollection } from 'astro:content';
import MagazineShell from '../../layouts/MagazineShell.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { filterDrafts } from '../../utils/drafts';

const allPosts = filterDrafts(await getCollection('blog'))
	.filter((post) => !post.id.startsWith('en/'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const postsByTopic = new Map<string, typeof allPosts>();

allPosts.forEach((post) => {
	(post.data.tags || []).forEach((tag) => {
		const posts = postsByTopic.get(tag) || [];
		posts.push(post);
		postsByTopic.set(tag, posts);
	});
});

const topics = Array.from(postsByTopic.entries())
	.map(([name, posts]) => {
		const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
		return {
			name,
			posts: sortedPosts,
			count: sortedPosts.length,
			latest: sortedPosts[0],
			href: `/tags/${name}/`,
		};
	})
	.sort((a, b) => b.count - a.count || a.name.localeCompare(b.name));
---

<MagazineShell title='话题' description='浏览全部话题'>
	<section class="topics-wall magazine-panel" aria-labelledby="topics-title">
		<header class="topics-wall__header">
			<p class="magazine-section-label">索引</p>
			<h1 id="topics-title">话题</h1>
		</header>

		<div class="topic-list" aria-label="话题索引">
			{topics.map((topic) => (
				<a href={topic.href} class="topic-row">
					<span class="topic-row__name">{topic.name}</span>
					<span class="topic-row__count">{topic.count}</span>
					{topic.latest && (
						<span class="topic-row__latest">
							<span>{topic.latest.data.title}</span>
							<time datetime={topic.latest.data.pubDate.toISOString()}>
								<FormattedDate date={topic.latest.data.pubDate} />
							</time>
						</span>
					)}
				</a>
			))}
		</div>
	</section>
</MagazineShell>

<style>
	.topics-wall {
		padding: 0;
	}

	.topics-wall__header {
		margin-bottom: clamp(0.9rem, 2.4vw, 1.35rem);
		padding-bottom: 0.65rem;
		border-bottom: 1px solid var(--paper-card-border-soft);
	}

	.topics-wall__header .magazine-section-label {
		margin-bottom: 0.55rem;
	}

	.topics-wall__header h1 {
		margin: 0;
		color: var(--heading-color);
		font-family: var(--display-font);
		font-size: clamp(1.55rem, 3.2vw, 2rem);
		font-weight: var(--weight-semibold, 600);
		line-height: 1.15;
		letter-spacing: -0.01em;
	}

	.topic-list {
		display: flex;
		flex-direction: column;
		border-top: 1px solid var(--paper-card-border-soft);
	}

	.topic-row {
		display: grid;
		grid-template-columns: minmax(7rem, 0.32fr) 2.4rem minmax(0, 1fr);
		gap: clamp(0.8rem, 2.4vw, 1.6rem);
		align-items: baseline;
		padding: 0.72rem 0;
		border: 0;
		border-bottom: 1px solid var(--paper-card-border-soft);
		border-radius: 0;
		background: transparent;
		color: inherit;
		text-decoration: none;
	}

	.topic-row:hover .topic-row__name {
		color: var(--accent-color);
	}

	.topic-row__name {
		color: var(--heading-color);
		font-family: var(--display-font);
		font-size: clamp(0.98rem, 1.5vw, 1.12rem);
		font-weight: var(--weight-medium);
		line-height: 1.35;
	}

	.topic-row__count {
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: 0.72rem;
		font-variant-numeric: tabular-nums;
		line-height: 1.35;
	}

	.topic-row__latest {
		display: grid;
		gap: 0.15rem;
		min-width: 0;
	}

	.topic-row__latest span {
		overflow: hidden;
		color: var(--text-color);
		font-family: var(--ui-font);
		font-size: 0.86rem;
		line-height: 1.45;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.topic-row__latest time {
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: 0.72rem;
		line-height: 1.3;
	}

	@media (max-width: 640px) {
		.topic-row {
			grid-template-columns: minmax(0, 1fr) auto;
			gap: 0.35rem 0.8rem;
		}

		.topic-row__latest {
			grid-column: 1 / -1;
		}
	}
</style>
