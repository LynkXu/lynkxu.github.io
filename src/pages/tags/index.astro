---
import { getCollection } from 'astro:content';
import MagazineShell from '../../layouts/MagazineShell.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { filterDrafts } from '../../utils/drafts';

const allPosts = filterDrafts(await getCollection('blog'))
	.filter((post) => !post.id.startsWith('en/'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const postsByTopic = new Map<string, typeof allPosts>();

allPosts.forEach((post) => {
	(post.data.tags || []).forEach((tag) => {
		const posts = postsByTopic.get(tag) || [];
		posts.push(post);
		postsByTopic.set(tag, posts);
	});
});

const topics = Array.from(postsByTopic.entries())
	.map(([name, posts]) => {
		const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
		return {
			name,
			posts: sortedPosts,
			count: sortedPosts.length,
			latest: sortedPosts[0],
			href: `/tags/${name}/`,
		};
	})
	.sort((a, b) => b.count - a.count || a.name.localeCompare(b.name));

function getTopicTier(count: number) {
	if (count >= 8) return 'large';
	if (count >= 4) return 'medium';
	return 'small';
}
---

<MagazineShell title='Topics' description='Browse all topics'>
	<section class="topics-wall" aria-labelledby="topics-title">
		<h1 id="topics-title" class="sr-only">Topics</h1>

		<div class="topic-cloud" aria-label="Topic index">
			{topics.map((topic, index) => (
				<a
					href={topic.href}
					class={`topic-token topic-token--${getTopicTier(topic.count)}`}
					style={`--topic-index: ${index};`}
				>
					<span class="topic-token__head">
						<strong>{topic.name}</strong>
						<small>{topic.count}</small>
					</span>
					{topic.latest && (
						<span class="topic-token__latest">
							<span>{topic.latest.data.title}</span>
							<time datetime={topic.latest.data.pubDate.toISOString()}>
								<FormattedDate date={topic.latest.data.pubDate} />
							</time>
						</span>
					)}
				</a>
			))}
		</div>
	</section>
</MagazineShell>

<style>
	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	.topics-wall {
		display: flex;
		flex-direction: column;
		gap: clamp(var(--space-sm), 2vw, var(--space-lg));
		padding: 0.1rem 0 clamp(var(--space-xl), 5vw, var(--space-3xl));
		animation: topic-wall-in 0.5s ease-out both;
	}

	.topic-cloud {
		display: grid;
		grid-template-columns: repeat(10, minmax(0, 1fr));
		gap: clamp(0.38rem, 1vw, 0.55rem);
	}

	.topic-token {
		--topic-pad: clamp(0.52rem, 1.25vw, 0.68rem);
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		gap: clamp(var(--space-xs), 1.5vw, var(--space-sm));
		min-height: 5.15rem;
		padding: var(--topic-pad);
		color: inherit;
		text-decoration: none;
		border: 1px solid var(--paper-card-border-soft) !important;
		border-radius: var(--paper-card-radius);
		background:
			linear-gradient(180deg, color-mix(in oklab, var(--accent-soft-bg) 18%, transparent), transparent 52%),
			var(--paper-card-bg) !important;
		box-shadow: var(--paper-card-shadow);
		animation: topic-token-in 0.48s ease-out both;
		animation-delay: calc(min(var(--topic-index), 8) * 34ms);
		transition:
			transform 0.25s cubic-bezier(0.2, 0.8, 0.2, 1),
			border-color 0.2s ease,
			background 0.2s ease;
	}

	.topic-token:hover {
		transform: translateY(-2px);
		border-color: color-mix(in oklab, var(--accent-color) 15%, var(--paper-card-border-soft)) !important;
		background:
			linear-gradient(180deg, color-mix(in oklab, var(--accent-soft-bg) 38%, transparent), transparent 58%),
			var(--paper-card-bg) !important;
	}

	.topic-token--large {
		grid-column: span 3;
		min-height: 6.45rem;
	}

	.topic-token--medium {
		grid-column: span 2;
	}

	.topic-token--small {
		grid-column: span 2;
		min-height: 4.85rem;
	}

	.topic-token__head {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: var(--space-sm);
	}

	.topic-token__head strong {
		color: var(--heading-color);
		font-family: var(--serif-font);
		font-size: clamp(0.98rem, 1.6vw, 1.16rem);
		font-weight: 500;
		line-height: 1.16;
		letter-spacing: 0;
		overflow-wrap: anywhere;
		transition: color 0.2s ease;
	}

	.topic-token--large .topic-token__head strong {
		font-size: clamp(1.2rem, 2.35vw, 1.55rem);
	}

	.topic-token:hover .topic-token__head strong {
		color: color-mix(in oklab, var(--accent-color) 40%, var(--heading-color));
	}

	.topic-token__head small {
		flex: 0 0 auto;
		color: var(--gray-color);
		font-family: var(--field-font);
		font-size: 0.66rem;
		line-height: 1;
		font-variant-numeric: tabular-nums;
	}

	.topic-token__latest {
		display: grid;
		gap: 0.12rem;
		max-width: 24rem;
	}

	.topic-token__latest span {
		color: color-mix(in oklab, var(--text-color) 78%, var(--gray-color));
		font-size: 0.72rem;
		line-height: 1.35;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.topic-token__latest time {
		color: var(--gray-color);
		font-family: var(--field-font);
		font-size: 0.58rem;
		line-height: 1.3;
		font-variant-numeric: tabular-nums;
	}

	@keyframes topic-wall-in {
		from {
			opacity: 0;
			transform: translateY(10px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@keyframes topic-token-in {
		from {
			opacity: 0;
			transform: translateY(10px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (max-width: 920px) {
		.topic-cloud {
			grid-template-columns: repeat(6, minmax(0, 1fr));
		}

		.topic-token--large,
		.topic-token--medium,
		.topic-token--small {
			grid-column: span 3;
		}

		.topic-token--large {
			min-height: 5.8rem;
		}

		.topic-token--medium,
		.topic-token--small {
			min-height: 5.2rem;
		}
	}

	@media (max-width: 560px) {
		.topic-cloud {
			grid-template-columns: 1fr;
		}

		.topic-token--large,
		.topic-token--medium,
		.topic-token--small {
			grid-column: span 1;
			min-height: 4.85rem;
		}

		.topic-token__head strong,
		.topic-token--large .topic-token__head strong {
			font-size: clamp(1.05rem, 5.8vw, 1.35rem);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.topics-wall,
		.topic-token {
			animation: none;
		}

		.topic-token {
			transition: none;
		}
	}
</style>
