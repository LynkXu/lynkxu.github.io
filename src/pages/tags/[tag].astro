---
import { getCollection } from 'astro:content';
import MagazineShell from '../../layouts/MagazineShell.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import CategoryFilter from '../../components/CategoryFilter.astro';
import { INCLUDE_DRAFTS, filterDrafts } from '../../utils/drafts';

export async function getStaticPaths() {
	const allPosts = filterDrafts(await getCollection('blog'));
	const tags = new Set();

	allPosts.forEach((post) => {
		if (post.data.tags) {
			post.data.tags.forEach((tag) => tags.add(tag));
		}
	});

	return Array.from(tags).map((tag) => {
		const tagString = String(tag);
		const filteredPosts = allPosts
			.filter((post) => post.data.tags && post.data.tags.includes(tagString))
			.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

		return {
			params: { tag: tagString },
			props: { posts: filteredPosts, tag: tagString },
		};
	});
}

const { posts, tag } = Astro.props;
const allPosts = filterDrafts(await getCollection('blog'));
const tagsMap = new Map<string, number>();

allPosts.forEach((post) => {
	(post.data.tags || []).forEach((item) => {
		tagsMap.set(item, (tagsMap.get(item) || 0) + 1);
	});
});

const tagItems = Array.from(tagsMap.entries())
	.sort((a, b) => b[1] - a[1])
	.map(([name, count]) => ({
		name,
		count,
		href: `/tags/${name}/`,
	}));
---

<MagazineShell title={`标签：${tag}`} description={`带有「${tag}」标签的全部文章`}>
	<header class="tag-page-header">
		<p class="magazine-section-label">标签</p>
		<h1 id="tag-page-title">{tag}</h1>
	</header>

	<CategoryFilter categories={tagItems} activeCategory={tag} label='切换标签' />

	<div class="tag-entries">
		<section class="tag-section" aria-labelledby="tag-page-title">
			<ul class="tag-list">
				{
					posts.map((post) => (
						<li class="tag-item">
							<time class="tag-date" datetime={post.data.pubDate.toISOString()}>
								<FormattedDate date={post.data.pubDate} />
							</time>
							<a
								href={`/blog/${post.data.slug ?? post.id}.html`}
								class="tag-link"
								transition:name={`post-title-${post.id}`}
							>
								{post.data.title}
							</a>
							{INCLUDE_DRAFTS && post.data.draft && (
								<span class="draft-badge" aria-label="草稿">草稿</span>
							)}
						</li>
					))
				}
			</ul>
		</section>
	</div>
</MagazineShell>

<style>
	.tag-page-header {
		margin-bottom: clamp(0.9rem, 2.4vw, 1.35rem);
		padding-bottom: 0.65rem;
		border-bottom: 1px solid var(--paper-card-border-soft);
	}

	.tag-page-header .magazine-section-label {
		margin-bottom: 0.55rem;
	}

	.tag-page-header h1 {
		margin: 0;
		color: var(--heading-color);
		font-family: var(--display-font);
		font-size: clamp(1.55rem, 3.2vw, 2rem);
		font-weight: var(--weight-semibold, 600);
		line-height: 1.15;
		letter-spacing: -0.01em;
	}

	:global(.category-filter) {
		margin: 0 0 clamp(1rem, 2.6vw, 1.5rem);
		padding-bottom: 0.85rem;
		border-bottom: 1px solid var(--paper-card-border-soft);
	}

	:global(.category-filter .filter-label) {
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: 0.72rem;
		font-weight: var(--weight-medium);
		letter-spacing: 0.04em;
	}

	:global(.category-filter .filter-list) {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		column-gap: clamp(0.9rem, 2vw, 1.4rem);
		row-gap: 0;
		border-top: 1px solid var(--paper-card-border-soft);
	}

	:global(.category-filter .filter-chip) {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 0.32rem;
		min-height: 0;
		padding: 0.48rem 0;
		border: 0;
		border-bottom: 1px solid var(--paper-card-border-soft);
		border-radius: 0;
		background: transparent;
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: 0.74rem;
	}

	:global(.category-filter .filter-chip:hover),
	:global(.category-filter .filter-chip.active) {
		color: var(--heading-color);
		background: transparent;
		border-color: transparent;
	}

	.tag-entries {
		gap: 0;
	}

	.tag-section {
		padding: 0;
		border: 0;
		background: transparent;
		box-shadow: none;
	}

	.tag-list {
		margin: 0;
		padding: 0;
		list-style: none;
		border-top: 1px solid var(--paper-card-border-soft);
	}

	.tag-item {
		display: grid;
		grid-template-columns: 6rem minmax(0, 1fr) auto;
		gap: clamp(0.8rem, 2vw, 1.2rem);
		align-items: baseline;
		padding: 0.64rem 0;
		border-bottom: 1px solid var(--paper-card-border-soft);
	}

	.tag-date {
		color: var(--gray-color);
		font-family: var(--code-font);
		font-variant-numeric: tabular-nums;
		font-size: 0.76rem;
		font-weight: var(--weight-regular);
		min-width: 5.5rem;
		white-space: nowrap;
	}

	.tag-link {
		color: var(--heading-color);
		font-family: var(--display-font);
		font-size: clamp(0.96rem, 1.3vw, 1.08rem);
		font-weight: var(--weight-regular);
		line-height: 1.42;
		text-decoration: none;
	}

	.tag-link:hover {
		color: var(--accent-color);
	}

	@media (max-width: 720px) {
		:global(.category-filter .filter-list) {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.tag-item {
			grid-template-columns: 1fr;
			gap: 0.2rem;
		}
	}
</style>
