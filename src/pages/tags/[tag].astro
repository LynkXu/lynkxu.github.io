---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import CategoryFilter from '../../components/CategoryFilter.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import TaxonomyHero from '../../components/TaxonomyHero.astro';
import { INCLUDE_DRAFTS, filterDrafts } from '../../utils/drafts';

export async function getStaticPaths() {
	// 排除英文文章（en/ 前缀），英文标签页走 /en 侧
	const allPosts = filterDrafts(await getCollection('blog')).filter((post) => !post.id.startsWith('en/'));
	const tags = new Set();

	// 收集所有标签
	allPosts.forEach((post) => {
		if (post.data.tags) {
			post.data.tags.forEach((tag) => tags.add(tag));
		}
	});

	// 为每个标签创建页面
	return Array.from(tags).map((tag) => {
		const tagString = String(tag);
		const filteredPosts = allPosts
			.filter((post) => post.data.tags && post.data.tags.includes(tagString))
			.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

		return {
			params: { tag: tagString },
			props: { posts: filteredPosts, tag: tagString },
		};
	});
}

const { posts, tag } = Astro.props;
const allPosts = filterDrafts(await getCollection('blog')).filter((post) => !post.id.startsWith('en/'));
const tagsMap = new Map<string, number>();

allPosts.forEach((post) => {
	(post.data.tags || []).forEach((item) => {
		tagsMap.set(item, (tagsMap.get(item) || 0) + 1);
	});
});

const tagItems = Array.from(tagsMap.entries())
	.sort((a, b) => b[1] - a[1])
	.map(([name, count]) => ({
		name,
		count,
		href: `/tags/${name}/`,
	}));
---

<Base title={`Tag: ${tag}`} description={`All posts tagged "${tag}"`} className="blog-surface-layout">
	<div class="content-limit-width taxonomy-shell">
		<TaxonomyHero
			eyebrow='tag index'
			title={`#${tag}`}
			description={`${posts.length} posts in total.`}
		/>
		<CategoryFilter categories={tagItems} activeCategory={tag} label='All Tags' />
		<ul class='posts'>
			{
				posts.map((post) => (
					<li>
						<span>
							<FormattedDate date={post.data.pubDate} />
						</span>
						<div>
							<a href={`/blog/${post.data.slug ?? post.id}.html`} transition:name={`post-title-${post.id}`}>
								{post.data.title}
							</a>
							{INCLUDE_DRAFTS && post.data.draft && <span class="draft-badge" aria-label="Draft">Draft</span>}
						</div>
					</li>
				))
			}
		</ul>
	</div>
</Base>
