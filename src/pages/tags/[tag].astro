---
import { getCollection } from 'astro:content';
import MagazineShell from '../../layouts/MagazineShell.astro';
import ListingFrame from '../../components/ListingFrame.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import CategoryFilter from '../../components/CategoryFilter.astro';
import { INCLUDE_DRAFTS, filterDrafts } from '../../utils/drafts';

export async function getStaticPaths() {
	const allPosts = filterDrafts(await getCollection('blog'));
	const tags = new Set();

	allPosts.forEach((post) => {
		if (post.data.tags) {
			post.data.tags.forEach((tag) => tags.add(tag));
		}
	});

	return Array.from(tags).map((tag) => {
		const tagString = String(tag);
		const filteredPosts = allPosts
			.filter((post) => post.data.tags && post.data.tags.includes(tagString))
			.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

		return {
			params: { tag: tagString },
			props: { posts: filteredPosts, tag: tagString },
		};
	});
}

const { posts, tag } = Astro.props;
const allPosts = filterDrafts(await getCollection('blog'));
const tagsMap = new Map<string, number>();

allPosts.forEach((post) => {
	(post.data.tags || []).forEach((item) => {
		tagsMap.set(item, (tagsMap.get(item) || 0) + 1);
	});
});

const tagItems = Array.from(tagsMap.entries())
	.sort((a, b) => b[1] - a[1])
	.map(([name, count]) => ({
		name,
		count,
		href: `/tags/${name}/`,
	}));
---

<MagazineShell title={`Tag: ${tag}`} description={`All posts with tag "${tag}"`}>
	<ListingFrame
		eyebrow="Topic"
		title={tag}
		description={`${posts.length} ${posts.length === 1 ? 'entry' : 'entries'} filed under this topic.`}
	>
		<CategoryFilter categories={tagItems} activeCategory={tag} label='切换标签' />

		<div class="tag-entries">
			<section class="tag-section" aria-labelledby={`tag-heading-${tag}`}>
				<h2 class="tag-label" id={`tag-heading-${tag}`}>{tag}</h2>
				<ul class="tag-list">
					{
						posts.map((post) => (
							<li class="tag-item">
								<time class="tag-date" datetime={post.data.pubDate.toISOString()}>
									<FormattedDate date={post.data.pubDate} />
								</time>
								<a
									href={`/blog/${post.data.slug ?? post.id}.html`}
									class="tag-link"
									transition:name={`post-title-${post.id}`}
								>
									{post.data.title}
								</a>
								{INCLUDE_DRAFTS && post.data.draft && (
									<span class="draft-badge" aria-label="Draft">Draft</span>
								)}
							</li>
						))
					}
				</ul>
			</section>
		</div>
	</ListingFrame>
</MagazineShell>

<style>
	.tag-entries {
		display: flex;
		flex-direction: column;
		gap: 0.68rem;
		margin-top: 0.82rem;
	}

	.tag-section {
		display: grid;
		grid-template-columns: 4.5rem minmax(0, 1fr);
		gap: clamp(0.78rem, 1.8vw, 1rem);
		padding: clamp(0.72rem, 1.85vw, 0.92rem) clamp(0.82rem, 2.1vw, 1.05rem);
		border: 1px solid var(--paper-card-border-soft);
		border-radius: var(--paper-card-radius);
		background: var(--paper-card-bg);
		box-shadow: 0 1px 2px rgba(15, 23, 42, 0.02);
		transition: background 0.2s ease, border-color 0.2s ease;
		animation: fade-up 0.5s ease-out both;
	}

	.tag-section:hover {
		background: var(--paper-hover-bg);
		border-color: var(--paper-hover-border);
	}

	.tag-label {
		margin: 0;
		font-family: var(--field-font);
		font-size: 0.78rem;
		font-weight: 500;
		color: color-mix(in oklab, var(--heading-color) 82%, var(--gray-color));
		letter-spacing: 0.04em;
		line-height: 1.4;
		padding-top: 0.12rem;
	}

	.tag-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
	}

	.tag-item {
		display: flex;
		align-items: baseline;
		gap: 0.78rem;
		padding: 0.36rem 0;
		border-bottom: 1px solid color-mix(in oklab, var(--paper-card-border-soft) 36%, transparent);
		transition: background 0.15s ease;
	}

	.tag-item:last-child {
		border-bottom: none;
	}

	.tag-item:hover {
		background: var(--paper-hover-bg);
	}

	.tag-date {
		font-family: var(--field-font);
		font-size: 0.72rem;
		color: color-mix(in oklab, var(--gray-color) 82%, var(--paper-bg));
		font-variant-numeric: tabular-nums;
		letter-spacing: 0.02em;
		flex-shrink: 0;
		min-width: 2.4rem;
	}

	.tag-link {
		color: var(--heading-color);
		font-size: 0.9rem;
		font-weight: 500;
		letter-spacing: -0.005em;
		text-decoration: none;
		border-bottom: none !important;
		background: none !important;
		transition: color 0.2s ease;
		flex: 1;
	}

	.tag-link:hover {
		color: color-mix(in oklab, var(--accent-color) 42%, var(--heading-color));
	}

	.draft-badge {
		font-family: var(--field-font);
		font-size: 0.65rem;
		font-weight: 500;
		color: color-mix(in oklab, var(--color-warning) 65%, var(--gray-color));
		letter-spacing: 0.02em;
		flex-shrink: 0;
	}

	@keyframes fade-up {
		from { opacity: 0; transform: translateY(10px); }
		to { opacity: 1; transform: translateY(0); }
	}

	@media (max-width: 720px) {
		.tag-section {
			grid-template-columns: 1fr;
			gap: 0.5rem;
			padding: var(--space-sm);
		}

		.tag-label {
			font-size: 0.78rem;
			padding-bottom: 0.3rem;
			border-bottom: 1px solid var(--paper-card-border-soft);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.tag-section {
			animation: none;
		}
	}
</style>
