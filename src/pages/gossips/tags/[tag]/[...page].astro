---
import type { GetStaticPaths, Page } from 'astro'
import type { CollectionEntry } from 'astro:content'
import { render } from 'astro:content'

import { Paginator } from 'astro-pure/components/pages'
import { getBlogCollection, sortMDByDate } from 'astro-pure/server'
import { Button, Icon } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'

export const prerender = true

export const getStaticPaths = (async ({ paginate }) => {
  // 获取所有唯一的 tags
  function getUniqueTags(gossips: CollectionEntry<'gossips'>[]): ('life' | 'tech' | 'thought')[] {
    const tags = gossips
      .map((gossip) => gossip.data.tag)
      .filter((tag): tag is 'life' | 'tech' | 'thought' => tag !== undefined)
    return [...new Set(tags)].sort()
  }
  
  const allGossips = sortMDByDate(await getBlogCollection('gossips')) as CollectionEntry<'gossips'>[]
  const uniqueTags = getUniqueTags(allGossips)

  return uniqueTags.flatMap((tag) => {
    const filteredGossips = allGossips.filter((gossip) => gossip.data.tag === tag)
    return paginate(filteredGossips, {
      params: { tag },
      pageSize: 10,
      props: { tag, uniqueTags }
    })
  })
}) satisfies GetStaticPaths

interface Props {
  page: Page<CollectionEntry<'gossips'>>
  tag: string
  uniqueTags: ('life' | 'tech' | 'thought')[]
}

const { page, tag, uniqueTags } = Astro.props

const meta = {
  description: `View all gossips with the tag - ${tag}`,
  title: `Tag: ${tag}`
}

const paginationProps = {
  ...(page.url.prev && {
    prevUrl: {
      text: `← Previous`,
      url: page.url.prev
    }
  }),
  ...(page.url.next && {
    nextUrl: {
      text: `Next →`,
      url: page.url.next
    }
  })
}

const gossipCardClass =
  'group relative overflow-hidden rounded-2xl border border-border/60 bg-card/80 p-5 shadow-[0_14px_50px_-36px_hsl(var(--foreground)/0.55)] transition-all duration-300 hover:-translate-y-0.5 hover:border-primary/50 hover:shadow-[0_20px_60px_-40px_hsl(var(--primary)/0.45)]'

const tagBadgeClass =
  'inline-flex items-center rounded-full border border-primary/30 bg-primary/10 px-2.5 py-1 text-xs font-medium text-primary'
---

<PageLayout {meta} highlightColor='#B4A38B'>
  <Button title='Back' href='/gossips' variant='back' />
  <main class='mt-6 lg:mt-10'>
    <div id='content-header' class='animate mb-6 flex flex-col gap-y-2'>
      <h1 class='text-3xl font-bold sm:text-4xl'>
        Tag: <span class='text-primary'>{tag}</span>
      </h1>
      <p class='text-muted-foreground'>
        {page.total} gossip{page.total > 1 ? 's' : ''} with this tag
      </p>
    </div>

    {/* Tags Section */}
    {!!uniqueTags.length && (
      <section class='animate mb-8' id='tags'>
        <div class='flex flex-wrap gap-2'>
          {uniqueTags.map((t) => (
            <Button 
              title={t} 
              href={`/gossips/tags/${t}`} 
              variant={t === tag ? 'ahead' : 'pill'}
            />
          ))}
          <Button title='All gossips →' href='/gossips' variant='pill' class='text-muted-foreground' />
        </div>
      </section>
    )}

    <section aria-label='Gossips list' class='animate' id='content'>
      {/* header */}
      <div class='mb-4 text-sm text-muted-foreground'>
        Page {page.currentPage} - Showing {page.data.length} of {page.total} gossips
      </div>
      
      {/* gossips list */}
      <ul class='flex flex-col gap-y-6'>
        {
          await Promise.all(
            page.data.map(async (gossip) => {
              const { Content } = await render(gossip)
              const dateStr = gossip.data.publishDate.toISOString().split('T')[0]
              
              return (
                <li class={gossipCardClass}>
                  <span
                    aria-hidden='true'
                    class='pointer-events-none absolute inset-x-4 top-0 h-0.5 rounded-full bg-gradient-to-r from-transparent via-primary/50 to-transparent opacity-80 transition-opacity duration-300 group-hover:opacity-100'
                  />
                  <div class='flex w-full flex-wrap items-center justify-start gap-2 sm:gap-3 text-sm text-muted-foreground'>
                    <span class='inline-flex items-center gap-2 rounded-full bg-muted/60 px-3 py-1 text-foreground/80'>
                      <Icon name='calendar' class='size-4 text-primary/80' />
                      <time class='font-mono text-xs sm:text-sm' datetime={dateStr}>
                        {dateStr}
                      </time>
                    </span>
                    {gossip.data.tag && <span class={tagBadgeClass}>{gossip.data.tag}</span>}
                  </div>
                  <div class='mt-3 leading-relaxed text-foreground/90 prose prose-sm max-w-none group-hover:text-foreground'>
                    <Content />
                  </div>
                  {gossip.data.image && (
                    <img
                      src={gossip.data.image.src.src}
                      alt={gossip.data.image.alt || 'Gossip image'}
                      class='mt-4 w-full max-w-2xl rounded-xl border border-border/60 bg-muted object-cover'
                      loading='lazy'
                    />
                  )}
                </li>
              )
            })
          )
        }
      </ul>
      <Paginator {...paginationProps} />
    </section>
  </main>
</PageLayout>
