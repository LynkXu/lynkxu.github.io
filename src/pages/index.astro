---
import { Image } from 'astro:assets'

import { Quote } from 'astro-pure/advanced'
import { PostPreview } from 'astro-pure/components/pages'
import { getBlogCollection, sortMDByDate } from 'astro-pure/server'
import { Button, Card, Icon, Label } from 'astro-pure/user'
import PageLayout from '@/layouts/BaseLayout.astro'
import ProjectCard from '@/components/home/ProjectCard.astro'
import Section from '@/components/home/Section.astro'
import SkillLayout from '@/components/home/SkillLayout.astro'
import Typewriter from '@/components/home/Typewriter.astro'
import avatar from '@/assets/avatar.png'
import config from '@/site-config'

const languages = ['Html', 'JavaScript', 'CSS', 'Shell']
const frontend = ['TypeScript', 'Vite', 'Webpack', 'Astro']
const backend = ['Vercel', 'Waline']
const uspTags = ['Go/TS backend', 'Web3', 'Open source']
const heroKeywords = [
  'Exploring the intersection of backend development and Web3 technologies.',
  'Shipping reliable services with Go/TS across cloud and edge.',
  'Building open source tools and writing about them.'
]

const MAX_POSTS = 10
const allPosts = await getBlogCollection()
const allPostsByDate = sortMDByDate(allPosts).slice(0, MAX_POSTS)
---

<PageLayout meta={{ title: 'Home' }} highlightColor='#8BA3B4'>
  <main class='flex w-full flex-col'>
    <!-- Hero Section - 更紧凑的个人介绍 -->
    <section
      class='relative animate mb-10 overflow-hidden rounded-2xl border border-border/70 bg-card/70 px-5 py-6 sm:px-7 sm:py-8'
      id='content-header'
    >
      <div class='pointer-events-none absolute inset-0 -z-10 bg-gradient-to-br from-primary/15 via-transparent to-primary/10 dark:from-primary/20 dark:to-primary/5' />
      <div class='pointer-events-none hero-arc' aria-hidden='true' />
      <div class='pointer-events-none hero-blob hero-blob-1' aria-hidden='true' />
      <div class='pointer-events-none hero-blob hero-blob-2' aria-hidden='true' />
      <div class='pointer-events-none hero-shape hero-ribbon' aria-hidden='true' />
      <div class='pointer-events-none hero-shape hero-orb' aria-hidden='true' />

      <div class='flex flex-col gap-y-6 lg:flex-row lg:items-center lg:gap-x-10'>
        <div class='flex flex-col gap-y-4 lg:flex-1 min-w-0'>
          <div class='flex flex-col gap-y-2'>
            <h1 class='text-4xl sm:text-5xl font-bold tracking-tight leading-tight'>
              Hi, I'm <span class='text-primary'>{config.author}</span>
            </h1>
            <h2 class='text-xl text-muted-foreground font-medium'>
              Backend Developer & Web3 Enthusiast
            </h2>
          </div>

          <p class='text-base text-muted-foreground leading-relaxed max-w-2xl'>
            <Typewriter
              words={heroKeywords}
              speed={110}
              pause={1600}
              class='text-foreground font-medium'
            />
          </p>

          <div class='flex flex-wrap gap-2 text-sm'>
            {uspTags.map((tag) => (
              <Button
                as='span'
                title={tag}
                variant='pill'
                class='cursor-default border border-primary/20 bg-primary/10 text-primary hover:scale-[1.01] transition-transform'
              />
            ))}
          </div>

          <div class='flex flex-wrap items-center gap-x-5 gap-y-2 text-sm'>
            <Label title='China' aria-label='Location: China' class='hover:scale-105 transition-transform focus-visible:scale-105'>
              <Icon name='location' class='size-4' slot='icon' />
            </Label>
            <Label
              title='Github'
              as='a'
              href='https://github.com/lynkxu'
              target='_blank'
              aria-label='Github profile'
              class='hover:scale-105 transition-transform focus-visible:scale-105'
            >
              <Icon name='github' class='size-4' slot='icon' />
            </Label>
            <Label
              title='Email'
              as='a'
              href='mailto:xulinxiao@live.com'
              aria-label='Send email'
              class='hover:scale-105 transition-transform focus-visible:scale-105'
            >
              <Icon name='email' class='size-4' slot='icon' />
            </Label>
            <Label
              title='Twitter'
              as='a'
              href='https://x.com/lynk_xv'
              target='_blank'
              aria-label='Twitter profile'
              class='hover:scale-105 transition-transform focus-visible:scale-105'
            >
              <Icon name='x' class='size-4' slot='icon' />
            </Label>
          </div>

          <div class='flex gap-x-4'>
            <Button title='More about me' class='w-fit text-sm' href='/about' variant='ahead' />
            <Button title='View Projects' class='w-fit text-sm' href='/projects' variant='pill' />
          </div>
        </div>

        <div class='relative self-center lg:self-auto w-40 sm:w-48 lg:w-56 aspect-square overflow-hidden rounded-2xl border border-border/50 bg-gradient-to-br from-primary/10 via-muted to-background shadow-sm'>
          <Image
            src={avatar}
            alt={`${config.author} avatar`}
            class='h-full w-full object-cover'
            loading='lazy'
          />
        </div>
      </div>
    </section>

    <div id='content' class='animate flex flex-col gap-y-8 w-full'>
      <!-- 最新文章区域 -->
      {
        allPostsByDate.length > 0 && (
          <section>
            <div class='flex items-center justify-between mb-5'>
              <div>
                <h2 class='text-xl font-bold tracking-tight'>Recent Writing</h2>
                <p class='text-sm text-muted-foreground mt-1'>Latest thoughts and tutorials</p>
              </div>
              <a 
                href='/blog' 
                class='group flex items-center gap-1 text-sm text-muted-foreground hover:text-primary transition-colors'
              >
                <span>View all</span>
                <span class='group-hover:translate-x-1 transition-transform'>→</span>
              </a>
            </div>
            <div class='grid gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3'>
              {allPostsByDate.slice(0, 6).map((p) => {
                const data = p.data as any
                return (
                  <a 
                    href={`/blog/${p.id}`}
                    class='group block overflow-hidden rounded-lg border border-border/60 hover:border-primary/40 hover:shadow-md transition-all bg-card'
                  >
                    {'heroImage' in data && data.heroImage && (
                      <div class='relative w-full h-40 overflow-hidden bg-muted'>
                        <Image 
                          src={data.heroImage.src} 
                          alt={data.heroImage.alt || data.title}
                          class='w-full h-full object-cover group-hover:scale-105 transition-transform duration-300'
                          loading='lazy'
                        />
                      </div>
                    )}
                    <div class='p-4'>
                      <h3 class='font-semibold text-foreground group-hover:text-primary transition-colors line-clamp-2 mb-2'>
                        {data.title}
                      </h3>
                      {data.description && (
                        <p class='text-sm text-muted-foreground line-clamp-2 mb-3'>
                          {data.description}
                        </p>
                      )}
                      <div class='flex items-center gap-3 text-xs text-muted-foreground'>
                        <time datetime={data.publishDate?.toISOString()}>
                          {data.publishDate?.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
                        </time>
                        {data.tags && data.tags.length > 0 && (
                          <span class='flex items-center gap-1'>
                            <span>#</span>
                            {data.tags[0]}
                          </span>
                        )}
                      </div>
                    </div>
                  </a>
                )
              })}
            </div>
          </section>
        )
      }

