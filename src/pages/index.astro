---
import { getCollection } from 'astro:content';
import MagazineShell from '../layouts/MagazineShell.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { filterDrafts } from '../utils/drafts';
import { getAllGossips } from '../utils/gossips';
import { getRecentHomeTraces } from '../utils/home-traces';
import { toPlainExcerpt } from '../utils/plain-text';

const posts = filterDrafts(await getCollection('blog'))
	.filter((post) => !post.id.startsWith('en/'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const latestPosts = posts.slice(0, 8);
const latestGossips = (await getAllGossips()).slice(0, 3);
const recentTraces = getRecentHomeTraces(4);

function getPostHref(post: (typeof posts)[number]) {
	return `/blog/${post.data.slug ?? post.id}.html`;
}

function getPostSummary(post: (typeof posts)[number]) {
	const rawSummary = post.data.description || post.body || '';
	const plainSummary = toPlainExcerpt(rawSummary, 56);
	return plainSummary || post.data.tags?.slice(0, 2).join(' / ') || '';
}

function getReadingMinutes(post: (typeof posts)[number]) {
	const plainText = (post.body || '').replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
	return Math.max(1, Math.ceil(plainText.length / 520));
}

function formatTraceDate(date: Date) {
	const year = date.getFullYear();
	const month = String(date.getMonth() + 1).padStart(2, '0');
	return `${year}.${month}`;
}
---

<MagazineShell
	title={SITE_TITLE}
	description={SITE_DESCRIPTION}
	className="home-index-layout"
	showProfileCard={false}
>
	<section class="home-hub postcard-sheet" aria-label="站点近况">
		<section class="hub-block hub-block--writing" aria-labelledby="hub-writing-title">
			<header class="hub-block__head">
				<div class="hub-block__identity">
					<p id="hub-writing-title" class="hub-block__label hub-block__label--lead">Recent</p>
					<p class="hub-block__caption">近况索引 · 文章 {latestPosts.length}</p>
				</div>
				<a href="/blog" class="hub-block__more">
					<span>Archive</span>
					<span aria-hidden="true">→</span>
				</a>
			</header>

			<div class="hub-legend hub-legend--writing" aria-hidden="true">
				<span class="hub-legend__date">Date</span>
				<span class="hub-legend__title">Title</span>
				<span class="hub-legend__meta">Tag / Read</span>
			</div>

			<ol class="dispatch-list">
				{latestPosts.map((post) => {
					const primaryTag = post.data.tags?.[0] || post.data.categories?.[0];
					const summary = getPostSummary(post);
					return (
						<li class="dispatch-list__item">
							<a href={getPostHref(post)} class="dispatch-card">
								<span class="dispatch-field dispatch-card__date">
									<span class="dispatch-field__label">Date</span>
									<time class="dispatch-field__value" datetime={post.data.pubDate.toISOString()}>
										<FormattedDate date={post.data.pubDate} />
									</time>
								</span>
								<span class="dispatch-card__body">
									<span class="dispatch-field dispatch-card__title-field">
										<span class="dispatch-field__label">Title</span>
										<strong class="dispatch-card__title">{post.data.title}</strong>
									</span>
									{summary && <span class="dispatch-card__summary">{summary}</span>}
								</span>
								<span class="dispatch-card__aside">
									{primaryTag && <span class="dispatch-card__tag">{primaryTag}</span>}
									<span class="dispatch-card__read">{getReadingMinutes(post)} min</span>
								</span>
							</a>
						</li>
					);
				})}
			</ol>
		</section>

		<section class="hub-block hub-block--notes" aria-labelledby="hub-notes-title">
			<header class="hub-block__head">
				<div class="hub-block__identity">
					<p id="hub-notes-title" class="hub-block__label">Notes</p>
					<p class="hub-block__caption">碎语 · {latestGossips.length}</p>
				</div>
				<a href="/shuoshuo" class="hub-block__more">
					<span>全部</span>
					<span aria-hidden="true">→</span>
				</a>
			</header>

			{latestGossips.length > 0 ? (
				<ul class="notes-list">
					{latestGossips.map((gossip) => {
						const excerpt = toPlainExcerpt(gossip.body || '', 140);
						return (
							<li class="notes-list__item">
								<a href="/shuoshuo" class="notes-card">
									<span class="notes-card__date">
										<FormattedDate date={gossip.data.pubDate} />
									</span>
									<span class="notes-card__body">
										{excerpt || '（无文字）'}
									</span>
								</a>
							</li>
						);
					})}
				</ul>
			) : (
				<p class="hub-empty">还没有碎语。</p>
			)}
		</section>

		{recentTraces.length > 0 && (
			<section class="hub-block hub-block--traces" aria-labelledby="hub-traces-title">
				<header class="hub-block__head">
					<div class="hub-block__identity">
						<p id="hub-traces-title" class="hub-block__label">Traces</p>
						<p class="hub-block__caption">最近痕迹 · {recentTraces.length}</p>
					</div>
				</header>

				<ul class="traces-list">
					{recentTraces.map((trace) => (
						<li class="traces-list__item">
							<a href={trace.href} class="traces-card">
								<span class="traces-card__label">{trace.label}</span>
								<span class="traces-card__summary">{trace.summary}</span>
								<span class="traces-card__date">{formatTraceDate(trace.date)}</span>
							</a>
						</li>
					))}
				</ul>
			</section>
		)}
	</section>
</MagazineShell>

<style>
	:global(.home-index-layout .ledger-main) {
		display: flex;
		flex-direction: column;
		min-height: calc(100vh - clamp(5.5rem, 10vw, 8rem));
	}

	:global(.home-index-layout .ledger-main > footer) {
		margin-top: clamp(1.5rem, 4vw, 2.75rem);
		grid-template-columns: minmax(0, 1fr);
		max-width: var(--blog-shell-width);
		text-align: center;
	}

	:global(.home-index-layout .ledger-main > footer::before) {
		left: 50%;
		transform: translateX(-50%);
	}

	.home-hub {
		display: flex;
		flex-direction: column;
		width: 100%;
		max-width: 100%;
		padding: clamp(0.85rem, 1.8vw, 1.15rem) clamp(1rem, 2.2vw, 1.4rem) clamp(0.8rem, 1.6vw, 1.05rem);
		font-family: var(--ui-font);
	}

	.hub-block__head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		gap: 0.75rem;
		margin: 0 0 0.4rem;
		padding-bottom: 0.4rem;
		border-bottom: 1px solid color-mix(in oklab, var(--sheet-edge) 90%, transparent);
	}

	.hub-block--writing .hub-block__head {
		border-bottom: 0;
		margin-bottom: 0.3rem;
		padding-bottom: 0;
	}

	.hub-block__identity {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: 0.28rem 0.55rem;
		min-width: 0;
	}

	.hub-block__label {
		margin: 0;
		font-family: var(--field-font);
		font-size: 0.66rem;
		font-weight: var(--weight-medium);
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: color-mix(in oklab, var(--heading-color) 72%, var(--gray-color));
	}

	.hub-block__label--lead {
		font-family: var(--display-font);
		font-size: clamp(1.02rem, 1.7vw, 1.18rem);
		font-weight: 600;
		letter-spacing: -0.015em;
		text-transform: none;
		color: var(--heading-color);
	}

	.hub-block__caption {
		margin: 0;
		font-family: var(--field-font);
		font-size: 0.62rem;
		letter-spacing: 0.03em;
		color: var(--faint-color);
	}

	.hub-block__more {
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		border: 0 !important;
		color: var(--faint-color);
		font-family: var(--field-font);
		font-size: 0.66rem;
		line-height: 1.15;
		letter-spacing: 0.08em;
		text-decoration: none;
		text-transform: uppercase;
		white-space: nowrap;
		transition: color 0.18s ease;
	}

	.hub-block__more:hover {
		color: var(--heading-color);
	}

	.hub-legend {
		display: grid;
		gap: 0.5rem 0.75rem;
		padding: 0.1rem 0.1rem 0.28rem;
		border-bottom: 1px dashed color-mix(in oklab, var(--sheet-edge) 80%, transparent);
		color: var(--faint-color);
		font-family: var(--field-font);
		font-size: 0.56rem;
		font-weight: var(--weight-medium);
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.hub-legend--writing {
		grid-template-columns: 5.5rem minmax(0, 1fr) 3.4rem;
	}

	.hub-legend__meta {
		text-align: right;
	}

	.hub-block--notes,
	.hub-block--traces {
		min-width: 0;
		margin-top: clamp(0.85rem, 1.8vw, 1.15rem);
		padding-top: clamp(0.75rem, 1.6vw, 0.95rem);
		border-top: 1px solid color-mix(in oklab, var(--sheet-edge) 88%, transparent);
	}

	.hub-block--traces {
		border-top-style: dashed;
	}

	.dispatch-list,
	.notes-list,
	.traces-list {
		display: flex;
		flex-direction: column;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.dispatch-list__item + .dispatch-list__item,
	.notes-list__item + .notes-list__item,
	.traces-list__item + .traces-list__item {
		border-top: 1px solid color-mix(in oklab, var(--paper-card-border-soft) 85%, transparent);
	}

	.dispatch-card {
		display: grid;
		grid-template-columns: 5.5rem minmax(0, 1fr) 3.4rem;
		gap: 0.28rem 0.75rem;
		align-items: start;
		padding: 0.55rem 0.1rem;
		border: 0 !important;
		background: transparent !important;
		color: inherit;
		text-decoration: none;
		transition: background 0.18s ease;
	}

	.dispatch-card:hover,
	.notes-card:hover,
	.traces-card:hover {
		background: var(--paper-hover-bg) !important;
	}

	.dispatch-card:hover .dispatch-card__title {
		color: color-mix(in oklab, var(--accent-color) 32%, var(--heading-color));
	}

	.dispatch-card__date {
		flex-direction: column;
		align-items: flex-start;
		gap: 0.2rem;
		padding-top: 0.12rem;
	}

	.dispatch-card__date .dispatch-field__label,
	.dispatch-card__title-field .dispatch-field__label {
		display: none;
	}

	.dispatch-card__date .dispatch-field__value {
		font-family: var(--field-font);
		font-size: 0.74rem;
		color: color-mix(in oklab, var(--heading-color) 55%, var(--gray-color));
		font-variant-numeric: tabular-nums;
		white-space: nowrap;
	}

	.dispatch-card__body {
		display: flex;
		flex-direction: column;
		gap: 0.12rem;
		min-width: 0;
	}

	.dispatch-card__title-field {
		flex-direction: column;
		align-items: flex-start;
		gap: 0.16rem;
		width: 100%;
	}

	.dispatch-card__title {
		color: var(--heading-color);
		font-family: var(--display-font);
		font-size: clamp(0.96rem, 1.5vw, 1.08rem);
		font-weight: 600;
		line-height: 1.28;
		letter-spacing: -0.015em;
		overflow-wrap: anywhere;
		transition: color 0.18s ease;
	}

	.dispatch-card__summary {
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		color: color-mix(in oklab, var(--gray-color) 90%, var(--heading-color));
		font-family: var(--reading-font);
		font-size: 0.76rem;
		line-height: 1.35;
	}

	.dispatch-card__aside {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 0.14rem;
		padding-top: 0.12rem;
		min-width: 0;
		text-align: right;
	}

	.dispatch-card__tag {
		color: color-mix(in oklab, var(--heading-color) 62%, var(--gray-color));
		font-family: var(--ui-font);
		font-size: 0.68rem;
		line-height: 1.2;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
		max-width: 100%;
	}

	.dispatch-card__read {
		color: var(--faint-color);
		font-family: var(--field-font);
		font-size: 0.64rem;
		font-variant-numeric: tabular-nums;
		line-height: 1.2;
		white-space: nowrap;
	}

	.notes-card {
		display: grid;
		grid-template-columns: 5.5rem minmax(0, 1fr);
		gap: 0.3rem 0.75rem;
		align-items: start;
		padding: 0.58rem 0.1rem;
		border: 0 !important;
		background: transparent !important;
		color: inherit;
		text-decoration: none;
		transition: background 0.18s ease;
	}

	.notes-card__date {
		padding-top: 0.1rem;
		font-family: var(--field-font);
		font-size: 0.74rem;
		color: color-mix(in oklab, var(--heading-color) 48%, var(--gray-color));
		font-variant-numeric: tabular-nums;
		white-space: nowrap;
	}

	.notes-card__body {
		display: -webkit-box;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 2;
		overflow: hidden;
		color: color-mix(in oklab, var(--gray-color) 88%, var(--heading-color));
		font-family: var(--reading-font);
		font-size: 0.84rem;
		line-height: 1.55;
	}

	.traces-card {
		display: grid;
		grid-template-columns: 3.2rem minmax(0, 1fr) 3.4rem;
		gap: 0.3rem 0.65rem;
		align-items: baseline;
		padding: 0.42rem 0.1rem;
		border: 0 !important;
		background: transparent !important;
		color: inherit;
		text-decoration: none;
		transition: background 0.18s ease;
	}

	.traces-card__label {
		font-family: var(--field-font);
		font-size: 0.64rem;
		letter-spacing: 0.03em;
		color: color-mix(in oklab, var(--heading-color) 58%, var(--gray-color));
	}

	.traces-card__summary {
		min-width: 0;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		color: color-mix(in oklab, var(--gray-color) 92%, var(--heading-color));
		font-family: var(--ui-font);
		font-size: 0.74rem;
		line-height: 1.35;
	}

	.traces-card__date {
		text-align: right;
		font-family: var(--field-font);
		font-size: 0.62rem;
		font-variant-numeric: tabular-nums;
		color: var(--faint-color);
		white-space: nowrap;
	}

	.hub-empty {
		margin: 0.3rem 0.1rem 0.15rem;
		color: var(--faint-color);
		font-family: var(--field-font);
		font-size: 0.72rem;
	}

	@media (max-width: 720px) {
		.hub-legend--writing {
			display: none;
		}

		.dispatch-card {
			grid-template-columns: minmax(0, 1fr);
			gap: 0.22rem;
			padding: 0.7rem 0.08rem;
		}

		.dispatch-card__date {
			flex-direction: row;
			align-items: baseline;
			gap: 0.35rem;
			padding-top: 0;
		}

		.dispatch-card__date .dispatch-field__label,
		.dispatch-card__title-field .dispatch-field__label {
			display: inline;
		}

		.dispatch-card__aside {
			flex-direction: row;
			flex-wrap: wrap;
			align-items: baseline;
			justify-content: flex-start;
			gap: 0.4rem 0.75rem;
			text-align: left;
			padding-top: 0;
		}

		.dispatch-card__summary {
			white-space: normal;
			display: -webkit-box;
			-webkit-box-orient: vertical;
			-webkit-line-clamp: 1;
		}

		.notes-card {
			grid-template-columns: minmax(0, 1fr);
			gap: 0.2rem;
			padding: 0.65rem 0.08rem;
		}

		.traces-card {
			grid-template-columns: auto minmax(0, 1fr);
			grid-template-areas:
				'label date'
				'summary summary';
			gap: 0.16rem 0.5rem;
			padding: 0.5rem 0.08rem;
		}

		.traces-card__label {
			grid-area: label;
		}

		.traces-card__date {
			grid-area: date;
		}

		.traces-card__summary {
			grid-area: summary;
			white-space: normal;
		}
	}

	@media (max-width: 640px) {
		.home-hub {
			padding-inline: clamp(0.85rem, 3vw, 1.1rem);
		}

		.dispatch-card__title {
			font-size: 1rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.hub-block__more,
		.dispatch-card,
		.dispatch-card__title,
		.notes-card,
		.traces-card {
			transition: none;
		}
	}
</style>
