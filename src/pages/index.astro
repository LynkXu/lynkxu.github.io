---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import HeaderLink from '../components/HeaderLink.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { INCLUDE_DRAFTS, filterDrafts } from '../utils/drafts';

// 获取最新的博客文章（显示前 6 篇）
// 排除英文文章（en/ 前缀），英文文章只在 /en 下展示
const allPosts = filterDrafts(await getCollection('blog')).filter((post) => !post.id.startsWith('en/'));
const recentPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 6);

function getPostExcerpt(body = '', length = 150) {
	const text = body
		.replace(/```[\s\S]*?```/g, ' ')
		.replace(/^#{1,6}\s+.+$/gm, ' ')
		.replace(/<[^>]+>/g, ' ')
		.replace(/!\[[^\]]*\]\([^)]+\)/g, ' ')
		.replace(/\[[^\]]+\]\([^)]+\)/g, (match) => match.match(/\[([^\]]+)\]/)?.[1] ?? '')
		.replace(/[#>*_`~\-\u003c\u003e]/g, ' ')
		.replace(/\s+/g, ' ')
		.trim();

	return text.length > length ? `${text.slice(0, length).trim()}…` : text;
}

// 统计标签
const tagsMap = new Map<string, number>();
allPosts.forEach((post) => {
	(post.data.tags || []).forEach((tag) => {
		tagsMap.set(tag, (tagsMap.get(tag) || 0) + 1);
	});
});
const sortedTags = Array.from(tagsMap.entries()).sort((a, b) => b[1] - a[1]);
const featuredTopics = sortedTags.slice(0, 10);
---

<Base title={SITE_TITLE} description={SITE_DESCRIPTION} className="blog-surface-layout">
	<div class="content-limit-width asym-layout">
		<section class='home-hero' aria-labelledby='home-title'>
			<div class="hero-copy">
				<h1 id='home-title'>在做一些旁注和思考</h1>
				<p class="home-deck">
					代码、项目、心情状态，以及任何挥之不去的想法。
				</p>
			</div>
			<div class="hero-stats">
				<span>{allPosts.length} Entries</span>
				<span class="stats-sep">·</span>
				<span>{sortedTags.length} Topics</span>
				<span class="stats-sep">·</span>
				<span>Since 2021</span>
			</div>
		</section>

		<section class='home-journal' aria-labelledby='journal-title'>
			<div class='section-heading'>
				<div>
					<h2 id='journal-title'>Latest Entries</h2>
				</div>
				<HeaderLink class="view-all" href='/blog'>All Posts →</HeaderLink>
			</div>
			<div class="journal-grid">
				{
					recentPosts.map((post, index) => {
						const sizeClass = index === 0 ? 'card-featured' : index > 2 ? 'card-base' : 'card-side';
						const excerptLen = index === 0 ? 110 : index > 2 ? 70 : 85;
						const excerpt = post.data.description || getPostExcerpt(post.body, excerptLen);
						return (
							<article class={`journal-card ${sizeClass}`}>
								<a href={`/blog/${post.data.slug ?? post.id}.html`} class="card-link" transition:name={`post-title-${post.id}`}>
									<div class="card-meta">
										<FormattedDate date={post.data.pubDate} />
										{post.data.tags && post.data.tags[0] && (
											<span class="card-tag">{post.data.tags[0]}</span>
										)}
									</div>
									<h3 class="card-title">{post.data.title}</h3>
									<p class="card-excerpt">{excerpt}</p>
									{INCLUDE_DRAFTS && post.data.draft && <span class="draft-badge" aria-label="Draft">Draft</span>}
								</a>
							</article>
						);
					})
				}
			</div>
		</section>

		{featuredTopics.length > 0 && (
			<section class='home-topics'>
				<div class='section-heading'>
					<div>
						<h2 class='indextitle'>Topics</h2>
					</div>
					{sortedTags.length > featuredTopics.length && (
						<HeaderLink class="view-all" href='/tags/'>All Topics →</HeaderLink>
					)}
				</div>
				<div class='topics-row'>
					{featuredTopics.map(([tag, count]) => (
						<a href={`/tags/${tag}/`} class="topic-pill">
							<span class="topic-name">{tag}</span>
							<span class="topic-count">{count}</span>
						</a>
					))}
				</div>
			</section>
		)}
	</div>

	<style>
		.asym-layout {
			display: flex;
			flex-direction: column;
			gap: clamp(2.5rem, 6vw, 3.5rem);
			padding-top: 0.5rem;
		}

		.home-hero {
			display: flex;
			flex-direction: column;
			gap: 0.55rem;
			width: 100%;
			padding: clamp(1.4rem, 3.5vw, 2.2rem) clamp(1.15rem, 3vw, 1.55rem) clamp(1.2rem, 3vw, 1.8rem);
		}

		.hero-copy {
			display: flex;
			flex-direction: column;
			gap: 0.6rem;
			max-width: 44rem;
		}

		.home-hero h1 {
			max-width: 14em;
			margin: 0;
			color: var(--panel-title-color);
			font-family: var(--serif-font);
			font-size: clamp(1.45rem, 3.6vw, 2rem);
			font-weight: 500;
			line-height: 1.22;
			letter-spacing: 0;
			position: relative;
			z-index: 1;
		}

		.home-deck {
			max-width: 66ch;
			margin: 0;
			color: color-mix(in oklab, var(--text-color) 78%, var(--gray-color));
			font-size: 0.92rem;
			line-height: 1.65;
		}

		.hero-stats {
			display: flex;
			align-items: center;
			gap: 0.5rem;
			margin-top: 0.35rem;
			font-family: var(--field-font);
			font-size: 0.7rem;
			color: var(--gray-color);
			letter-spacing: 0.02em;
		}

		.stats-sep {
			opacity: 0.45;
		}

		@keyframes hero-fade-up {
			from {
				opacity: 0;
				transform: translateY(12px);
			}
			to {
				opacity: 1;
				transform: translateY(0);
			}
		}

		.home-hero h1 {
			animation: hero-fade-up 0.7s ease-out both;
		}

		.home-deck {
			animation: hero-fade-up 0.7s ease-out 0.12s both;
		}

		.hero-stats {
			animation: hero-fade-up 0.7s ease-out 0.22s both;
		}

		/* ── Journal Grid ── */
		.home-journal {
			display: flex;
			flex-direction: column;
			gap: 1.25rem;
		}

		.section-heading {
			display: flex;
			align-items: end;
			justify-content: space-between;
			gap: 1rem;
		}

		.section-heading h2, .indextitle {
			margin: 0;
			font-family: var(--serif-font);
			font-size: var(--text-lg);
			font-weight: 500;
			color: var(--heading-color);
			letter-spacing: -0.01em;
		}

		.view-all {
			color: var(--gray-color);
			font-family: var(--field-font);
			font-size: 0.72rem;
			letter-spacing: 0.04em;
			text-transform: none;
			text-decoration: none;
			border: none;
			background: transparent;
			padding: 0;
			transition: color 0.2s ease;
		}

		.view-all:hover {
			color: color-mix(in oklab, var(--accent-color) 34%, var(--heading-color));
			border-color: transparent;
			transform: none;
		}

		.journal-grid {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			grid-auto-rows: minmax(150px, auto);
			gap: var(--blog-card-gap);
		}

		/* ── Journal Cards ── */
		.journal-card {
			position: relative;
			border: 1px solid var(--paper-card-border-soft);
			border-radius: var(--paper-card-radius);
			background: var(--paper-card-bg);
			box-shadow: var(--paper-card-shadow);
			transition:
				transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1),
				background-color 0.2s ease,
				border-color 0.2s ease;
			overflow: hidden;
		}

		.journal-card:hover {
			transform: translateY(-2px);
			border-color: color-mix(in oklab, var(--accent-color) 12%, var(--paper-card-border-soft));
			background: color-mix(in oklab, var(--accent-soft-bg) 30%, var(--paper-card-bg));
		}

		.card-link {
			display: flex;
			flex-direction: column;
			height: 100%;
			padding: clamp(1rem, 2.6vw, 1.35rem);
			color: inherit;
			text-decoration: none;
			border-bottom: none !important;
			background: none !important;
		}

		.card-meta {
			display: flex;
			align-items: center;
			gap: 0.6rem;
			font-family: var(--field-font);
			font-size: 0.72rem;
			color: var(--gray-color);
			letter-spacing: 0.015em;
			line-height: 1;
		}

		.card-tag {
			display: inline-flex;
			align-items: center;
			padding: 0.18em 0.55em;
			background: color-mix(in oklab, var(--accent-soft-bg) 60%, var(--paper-card-bg));
			border: 1px solid color-mix(in oklab, var(--accent-color) 10%, var(--paper-card-border-soft));
			border-radius: 3px;
			font-size: 0.68rem;
			color: color-mix(in oklab, var(--accent-color) 50%, var(--gray-color));
			letter-spacing: 0.01em;
		}

		.card-title {
			margin: 0;
			font-family: var(--serif-font);
			font-weight: 500;
			color: var(--heading-color);
			letter-spacing: -0.01em;
			transition: color 0.2s ease;
		}

		.journal-card:hover .card-title {
			color: color-mix(in oklab, var(--accent-color) 38%, var(--heading-color));
		}

		.card-excerpt {
			margin: 0;
			color: var(--text-color);
			display: -webkit-box;
			-webkit-box-orient: vertical;
			overflow: hidden;
		}

		/* ── Featured card (index 0) ── */
		.journal-card.card-featured {
			grid-column: span 2;
			grid-row: span 2;
			background: color-mix(in oklab, var(--accent-soft-bg) 40%, var(--paper-card-bg));
			border-color: color-mix(in oklab, var(--accent-color) 10%, var(--paper-card-border-soft));
		}

		.journal-card.card-featured::before {
			content: "";
			position: absolute;
			top: 0;
			left: 0;
			width: 3px;
			height: 100%;
			background: color-mix(in oklab, var(--ink-accent) 60%, transparent);
			opacity: 0.6;
		}

		.journal-card.card-featured .card-link {
			padding: clamp(1.15rem, 2.8vw, 1.55rem);
		}

		.journal-card.card-featured .card-title {
			font-size: clamp(1.2rem, 1.9vw, 1.45rem);
			line-height: 1.26;
			margin: 0.55rem 0 0.75rem;
		}

		.journal-card.card-featured .card-excerpt {
			font-size: 0.93rem;
			line-height: 1.72;
			opacity: 0.82;
			-webkit-line-clamp: 5;
		}

		/* ── Side cards (index 1, 2) ── */
		.journal-card.card-side .card-title {
			font-size: 0.98rem;
			line-height: 1.38;
			margin: 0.5rem 0 0.45rem;
		}

		.journal-card.card-side .card-excerpt {
			font-size: 0.87rem;
			line-height: 1.6;
			opacity: 0.76;
			-webkit-line-clamp: 2;
		}

		/* ── Base cards (index 3, 4, 5) ── */
		.journal-card.card-base .card-title {
			font-size: 1rem;
			line-height: 1.4;
			margin: 0.5rem 0 0.45rem;
		}

		.journal-card.card-base .card-excerpt {
			font-size: 0.88rem;
			line-height: 1.62;
			opacity: 0.78;
			-webkit-line-clamp: 2;
		}

		/* ── Draft badge ── */
		.draft-badge {
			display: inline-flex;
			align-items: center;
			margin-top: auto;
			padding-top: 0.75rem;
			font-family: var(--field-font);
			font-size: 0.68rem;
			font-weight: 500;
			color: color-mix(in oklab, var(--color-warning) 65%, var(--gray-color));
			letter-spacing: 0.02em;
		}

		/* ── Topics ── */
		.home-topics {
			display: flex;
			flex-direction: column;
			gap: 1.25rem;
			margin-bottom: 2rem;
		}

		.topics-row {
			display: flex;
			flex-wrap: wrap;
			gap: 0.55rem;
		}

		.topic-pill {
			display: inline-flex;
			align-items: center;
			gap: 0.4rem;
			padding: 0.45rem 0.78rem;
			font-family: var(--field-font);
			font-size: 0.82rem;
			color: color-mix(in oklab, var(--text-color) 82%, var(--gray-color));
			text-decoration: none;
			border: 1px solid var(--paper-card-border-soft);
			border-radius: var(--paper-card-radius);
			background: var(--paper-field-bg);
			transition:
				transform 0.25s cubic-bezier(0.2, 0.8, 0.2, 1),
				color 0.2s ease,
				background 0.2s ease,
				border-color 0.2s ease;
		}

		.topic-pill:hover {
			transform: translateY(-1px);
			color: color-mix(in oklab, var(--accent-color) 42%, var(--heading-color));
			background: color-mix(in oklab, var(--accent-soft-bg) 55%, var(--paper-field-bg));
			border-color: color-mix(in oklab, var(--accent-color) 16%, var(--paper-card-border-soft));
		}

		.topic-count {
			color: var(--gray-color);
			font-size: 0.75rem;
			font-variant-numeric: tabular-nums;
			opacity: 0.65;
			transition: color 0.2s ease;
		}

		.topic-pill:hover .topic-count {
			color: color-mix(in oklab, var(--accent-color) 44%, var(--heading-color));
			opacity: 0.85;
		}

		/* ── Staggered fade-in ── */
		@keyframes card-fade-up {
			from {
				opacity: 0;
				transform: translateY(14px);
			}
			to {
				opacity: 1;
				transform: translateY(0);
			}
		}

		.journal-card {
			animation: card-fade-up 0.5s ease-out both;
		}

		.journal-card:nth-child(1) { animation-delay: 0.05s; }
		.journal-card:nth-child(2) { animation-delay: 0.10s; }
		.journal-card:nth-child(3) { animation-delay: 0.15s; }
		.journal-card:nth-child(4) { animation-delay: 0.20s; }
		.journal-card:nth-child(5) { animation-delay: 0.25s; }
		.journal-card:nth-child(6) { animation-delay: 0.30s; }

		/* ── Responsive: tablet ── */
		@media (min-width: 768px) {
			.home-journal,
			.home-topics {
				display: grid;
				grid-template-columns: 120px 1fr;
				gap: clamp(2rem, 5vw, 3.5rem);
				align-items: start;
			}

			.home-journal .section-heading,
			.home-topics .section-heading {
				flex-direction: column;
				align-items: flex-start;
				gap: 1.5rem;
				position: sticky;
				top: 2rem;
			}
		}

		@media (max-width: 1023px) and (min-width: 768px) {
			.journal-grid {
				grid-template-columns: repeat(2, 1fr);
			}

			.journal-card.card-featured {
				grid-column: span 2;
				grid-row: span 1;
			}

			.journal-card.card-featured .card-excerpt {
				-webkit-line-clamp: 3;
			}
		}

		/* ── Responsive: mobile ── */
		@media (max-width: 767px) {
			.journal-grid {
				grid-template-columns: 1fr;
				grid-auto-rows: auto;
			}

			.journal-card {
				grid-column: span 1 !important;
				grid-row: span 1 !important;
			}

			.journal-card.card-featured .card-title {
				font-size: 1.12rem;
			}

			.journal-card.card-featured .card-excerpt {
				-webkit-line-clamp: 3;
			}
		}

		/* ── Reduced motion ── */
		@media (prefers-reduced-motion: reduce) {
			.home-hero h1,
			.home-deck,
			.hero-stats,
			.journal-card {
				animation: none;
			}

			.journal-card,
			.topic-pill {
				transition: none;
			}
		}
	</style>
</Base>
