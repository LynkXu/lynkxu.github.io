---
import { getCollection } from 'astro:content';
import MagazineShell from '../layouts/MagazineShell.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { filterDrafts } from '../utils/drafts';

	const secondaryEntryLinks = [
		{
			href: '/photography',
			label: 'Photography',
			title: '光影瞬间',
		},
		{
			href: '/media',
			label: 'Media',
			title: '书影音',
		},
		{
			href: '/travel',
			label: 'Travel',
			title: '旅行足迹',
		},
		{
			href: '/sports',
			label: 'Sports',
			title: '运动记录',
		},
		{
			href: '/tools',
			label: 'Tools',
			title: '常用工具',
		},
		{
			href: '/copyright',
			label: 'Copyright',
			title: '版权声明',
		},
	];

const latestPosts = filterDrafts(await getCollection('blog'))
	.filter((post) => !post.id.startsWith('en/'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);

function getPostHref(post: (typeof latestPosts)[number]) {
	return `/blog/${post.data.slug ?? post.id}.html`;
}

function getPostSummary(post: (typeof latestPosts)[number]) {
	const rawSummary = post.data.description || post.body || '';
	const plainSummary = rawSummary
		.replace(/```[\s\S]*?```/g, ' ')
		.replace(/!\[[^\]]*]\([^)]+\)/g, ' ')
		.replace(/\[([^\]]+)]\([^)]+\)/g, '$1')
		.replace(/[#>*_`~-]/g, ' ')
		.replace(/\s+/g, ' ')
		.trim();

	if (plainSummary) {
		return plainSummary.length > 56 ? `${plainSummary.slice(0, 56).trim()}…` : plainSummary;
	}

	return post.data.tags?.slice(0, 2).join(' · ') || '';
}

function formatPostDate(date: Date) {
	return new Intl.DateTimeFormat('en', {
		month: 'short',
		day: '2-digit',
	}).format(date);
}
---

<MagazineShell title={SITE_TITLE} description={SITE_DESCRIPTION} className="home-index-layout">
	<section class="home-index" aria-labelledby="home-title">
		<div class="home-statement">
			<h1 id="home-title">
				<span>Do the right thing.</span>
				<span>Do things right.</span>
			</h1>
		</div>

		<div class="home-board">
			<section class="home-latest" aria-labelledby="home-latest-title">
				<div class="home-latest__head">
					<h2 id="home-latest-title" class="home-latest__title">Latest</h2>
				</div>

				<div class="home-latest__items">
					{latestPosts.map((post) => (
						<a href={getPostHref(post)} class="home-latest-card" title={post.data.title}>
							<span class="home-latest-card__title">{post.data.title}</span>
							{getPostSummary(post) && (
								<span class="home-latest-card__summary">{getPostSummary(post)}</span>
							)}
							<small>{formatPostDate(post.data.pubDate)}</small>
						</a>
					))}
				</div>
			</section>

			<nav class="home-entry-list" aria-label="专题入口">
				<div class="home-entry-list__head">
					<h2 class="home-entry-list__title">Index</h2>
				</div>
				<div class="home-entry-list__items">
					{secondaryEntryLinks.map((item) => (
						<a href={item.href} class="home-entry-link" title={item.title}>
							<span>{item.label}</span>
							<small>{item.title}</small>
							<span class="home-entry-link__arrow" aria-hidden="true">→</span>
						</a>
					))}
				</div>
			</nav>
		</div>

	</section>
</MagazineShell>

<style>
	.home-index {
		display: flex;
		flex-direction: column;
		gap: clamp(var(--space-lg), 3.2vw, var(--space-2xl));
		width: 100%;
		padding: clamp(var(--space-md), 2vw, var(--space-xl)) 0 clamp(var(--space-2xl), 7vw, var(--space-4xl));
	}

	.home-statement {
		max-width: none;
		animation: home-fade-up 0.5s ease-out both;
	}

	.home-statement h1 {
		display: flex;
		flex-wrap: wrap;
		gap: 0.18rem 0.45rem;
		margin: 0;
		font-family: var(--serif-font);
		font-size: clamp(1.02rem, 1.9vw, 1.2rem);
		font-weight: 500;
		line-height: 1.36;
		letter-spacing: -0.01em;
		color: color-mix(in oklab, var(--heading-color) 72%, var(--gray-color));
		text-wrap: balance;
	}

	.home-statement h1 span {
		display: inline;
	}

	.home-statement h1 span + span::before {
		content: "/";
		margin-right: 0.45rem;
		color: var(--faint-color);
		font-size: 0.82em;
	}

	.home-board {
		display: grid;
		grid-template-columns: minmax(0, 0.82fr) minmax(10.5rem, 0.32fr);
		align-items: start;
		gap: clamp(var(--space-lg), 2.4vw, var(--space-xl));
		width: 100%;
		min-width: 0;
		animation: home-fade-up 0.55s ease-out 0.12s both;
	}

	.home-latest,
	.home-entry-list {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
		width: 100%;
		min-width: 0;
	}

	.home-latest__head,
	.home-entry-list__head {
		display: flex;
		align-items: center;
		min-height: 1.35rem;
	}

	.home-latest__title,
	.home-entry-list__title {
		margin: 0;
		font-family: var(--field-font);
		font-size: 0.7rem;
		font-weight: 600;
		letter-spacing: 0.05em;
		line-height: 1.35;
		color: var(--gray-color);
	}

	.home-latest__items {
		display: grid;
		grid-template-rows: repeat(4, minmax(0, 1fr));
		align-items: stretch;
		gap: 0.52rem;
		position: relative;
		width: 100%;
		min-width: 0;
		flex: 1;
	}

	.home-latest__items::after {
		content: '';
		position: absolute;
		right: calc(-1 * clamp(0.8rem, 2.1vw, 1.4rem));
		top: 0;
		bottom: 0;
		width: 1px;
		background: color-mix(in oklab, var(--paper-card-border-soft) 60%, transparent);
	}

	.home-latest-card {
		display: inline-flex;
		flex-direction: column;
		align-items: flex-start;
		justify-content: center;
		gap: 0.22rem;
		box-sizing: border-box;
		width: 100%;
		min-width: 0;
		min-height: 0;
		padding: 0.64rem 0.82rem;
		border: 1px solid var(--paper-card-border-soft);
		border-radius: var(--paper-card-radius);
		color: var(--heading-color);
		font-family: var(--serif-font);
		font-size: 0.9rem;
		font-weight: 500;
		letter-spacing: -0.003em;
		line-height: 1.36;
		text-decoration: none;
		background: var(--paper-card-bg) !important;
		box-shadow: 0 1px 2px rgba(15, 23, 42, 0.018);
		transition:
			border-color 0.2s ease,
			background 0.2s ease,
			color 0.2s ease,
			transform 0.2s ease;
	}

	.home-latest-card__title {
		display: block;
		width: 100%;
	}

	.home-latest-card__summary {
		display: -webkit-box;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 1;
		overflow: hidden;
		width: 100%;
		font-family: var(--ui-font);
		font-size: 0.7rem;
		font-weight: 400;
		letter-spacing: 0;
		line-height: 1.5;
		color: color-mix(in oklab, var(--text-color) 65%, var(--gray-color));
	}

	.home-latest-card small {
		display: block;
		width: 100%;
		color: color-mix(in oklab, var(--gray-color) 72%, var(--paper-bg));
		font-family: var(--field-font);
		font-size: 0.58rem;
		font-weight: 400;
		letter-spacing: 0.02em;
		line-height: 1.35;
		opacity: 0.55;
	}

	.home-latest-card:hover .home-latest-card__summary {
		color: color-mix(in oklab, var(--text-color) 80%, var(--gray-color));
	}

	.home-latest-card:hover {
		border-color: var(--paper-hover-border);
		color: color-mix(in oklab, var(--accent-color) 42%, var(--heading-color));
		background: color-mix(in oklab, var(--accent-soft-bg) 36%, var(--paper-card-bg)) !important;
		transform: translateY(-1px);
	}

	.home-entry-list__items {
		display: flex;
		flex-direction: column;
		gap: 0.18rem;
		width: 100%;
		min-width: 0;
		flex: 1;
	}

	.home-entry-link {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.08rem;
		position: relative;
		padding: 0.5rem 1.1rem 0.5rem 0;
		color: color-mix(in oklab, var(--text-color) 78%, var(--gray-color));
		font-family: var(--field-font);
		font-size: 0.76rem;
		font-weight: 400;
		letter-spacing: 0.02em;
		line-height: 1.4;
		text-decoration: none;
		border-bottom: none !important;
		background: none !important;
		transition:
			color 0.2s ease,
			transform 0.2s ease;
	}

	.home-entry-link__arrow {
		position: absolute;
		right: 0;
		top: 50%;
		transform: translateY(-50%) translateX(-4px);
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: 0.72rem;
		font-weight: 400;
		line-height: 1;
		opacity: 0;
		transition:
			opacity 0.2s ease,
			transform 0.2s ease,
			color 0.2s ease;
	}

	.home-entry-link:hover {
		color: color-mix(in oklab, var(--accent-color) 42%, var(--heading-color));
		transform: translateX(3px);
	}

	.home-entry-link:hover .home-entry-link__arrow {
		color: color-mix(in oklab, var(--accent-color) 42%, var(--heading-color));
		opacity: 1;
		transform: translateY(-50%) translateX(0);
	}

	.home-entry-link span,
	.home-entry-link small {
		display: block;
	}

	.home-entry-link small {
		color: color-mix(in oklab, var(--gray-color) 72%, var(--paper-bg));
		font-family: var(--ui-font);
		font-size: 0.52rem;
		font-weight: 400;
		letter-spacing: 0.015em;
		line-height: 1.35;
		opacity: 0.48;
	}

	@keyframes home-fade-up {
		from {
			opacity: 0;
			transform: translateY(12px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (max-width: 760px) {
		.home-index,
		.home-board,
		.home-latest,
		.home-entry-list {
			max-width: 100%;
			overflow-x: hidden;
		}

		.home-board {
			grid-template-columns: 1fr;
		}

		.home-latest,
		.home-entry-list {
			width: 100%;
		}

	.home-latest__items {
		grid-template-columns: repeat(2, minmax(0, 1fr));
		grid-template-rows: none;
	}

		.home-entry-list__items {
			flex-direction: row;
			flex-wrap: wrap;
			gap: 0.42rem 1rem;
		}
	}

	@media (max-width: 520px) {
		.home-index {
			gap: var(--space-lg);
		}

		.home-statement h1 {
			font-size: 1.04rem;
		}

		.home-latest__items {
			grid-template-columns: minmax(0, 1fr);
			gap: 0.48rem;
		}

		.home-entry-list__items {
			flex-direction: column;
			gap: 0.18rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.home-statement,
		.home-board {
			animation: none;
		}

		.home-latest-card,
		.home-entry-link {
			transition: none;
		}
	}
</style>
