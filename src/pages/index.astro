---
import { getCollection } from 'astro:content';
import MagazineShell from '../layouts/MagazineShell.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { filterDrafts } from '../utils/drafts';

const posts = filterDrafts(await getCollection('blog'))
	.filter((post) => !post.id.startsWith('en/'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const latestPosts = posts.slice(0, 14);

function getPostHref(post: (typeof posts)[number]) {
	return `/blog/${post.data.slug ?? post.id}.html`;
}

function getReadingMinutes(post: (typeof posts)[number]) {
	const plainText = (post.body || '').replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
	return Math.max(1, Math.ceil(plainText.length / 520));
}

function formatIndexDate(date: Date) {
	const y = date.getFullYear();
	const m = String(date.getMonth() + 1).padStart(2, '0');
	const d = String(date.getDate()).padStart(2, '0');
	return `${y}.${m}.${d}`;
}
---

<MagazineShell
	title={SITE_TITLE}
	description={SITE_DESCRIPTION}
	className="home-index-layout"
	showProfileCard={false}
>
	<section class="home-index" aria-labelledby="home-latest-title">
		<header class="home-index__head">
			<div>
				<p class="home-index__eyebrow">Index</p>
				<h1 id="home-latest-title" class="home-index__title">最新文章</h1>
			</div>
			<a href="/blog" class="home-index__all">全部归档</a>
		</header>

		<ol class="home-index__list">
			{latestPosts.map((post) => {
				const primaryTag = post.data.tags?.[0] || post.data.categories?.[0];
				return (
					<li class="home-index__item">
						<a href={getPostHref(post)} class="home-index__link">
							<time class="home-index__date" datetime={post.data.pubDate.toISOString()}>
								{formatIndexDate(post.data.pubDate)}
							</time>
							<span class="home-index__post-title">{post.data.title}</span>
							<span class="home-index__aside">
								{primaryTag && <span class="home-index__tag">{primaryTag}</span>}
								<span class="home-index__read">{getReadingMinutes(post)} min</span>
							</span>
						</a>
					</li>
				);
			})}
		</ol>
	</section>
</MagazineShell>

<style>
	:global(.home-index-layout .ledger-main) {
		min-height: 0;
	}

	:global(.home-index-layout .ledger-main > footer) {
		margin-top: clamp(1.8rem, 4vw, 2.8rem);
	}

	.home-index {
		width: min(100%, var(--blog-content-max, 44rem));
		font-family: var(--ui-font);
	}

	.home-index__head {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 1rem;
		margin-bottom: clamp(0.85rem, 2vw, 1.15rem);
		padding-bottom: 0.7rem;
		border-bottom: 2px solid var(--heading-color);
	}

	.home-index__eyebrow {
		margin: 0 0 0.2rem;
		color: var(--faint-color);
		font-size: 0.68rem;
		font-weight: 500;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.home-index__title {
		margin: 0;
		color: var(--heading-color);
		font-family: var(--display-font);
		font-size: clamp(1.45rem, 2.6vw, 1.75rem);
		font-weight: 500;
		letter-spacing: -0.02em;
		line-height: 1.15;
	}

	.home-index__all {
		border: 0 !important;
		color: var(--gray-color);
		font-size: 0.74rem;
		font-weight: 500;
		text-decoration: none;
		white-space: nowrap;
	}

	.home-index__all:hover {
		color: var(--accent-color);
	}

	.home-index__list {
		display: flex;
		flex-direction: column;
		gap: 0;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.home-index__item {
		margin: 0;
		padding: 0;
		border-bottom: 1px solid var(--paper-card-border-soft);
	}

	.home-index__item:last-child {
		border-bottom: 0;
	}

	.home-index__link {
		display: grid;
		grid-template-columns: 5.6rem minmax(0, 1fr) auto;
		gap: 0.55rem 1rem;
		align-items: baseline;
		padding: 0.52rem 0;
		border: 0 !important;
		background: transparent !important;
		color: inherit;
		text-decoration: none;
	}

	.home-index__date {
		color: var(--faint-color);
		font-family: var(--code-font);
		font-size: 0.7rem;
		font-variant-numeric: tabular-nums;
		line-height: 1.35;
		white-space: nowrap;
	}

	.home-index__post-title {
		min-width: 0;
		color: var(--heading-color);
		font-family: var(--ui-font);
		font-size: 0.94rem;
		font-weight: 400;
		line-height: 1.35;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
		transition: color 0.18s ease;
	}

	.home-index__aside {
		display: inline-flex;
		align-items: baseline;
		gap: 0.45rem;
		color: var(--faint-color);
		font-size: 0.68rem;
		font-variant-numeric: tabular-nums;
		line-height: 1.3;
		white-space: nowrap;
	}

	.home-index__tag {
		color: color-mix(in oklab, var(--heading-color) 55%, var(--gray-color));
	}

	.home-index__link:hover .home-index__post-title {
		color: var(--accent-color);
	}

	@media (max-width: 720px) {
		.home-index__link {
			grid-template-columns: 5.2rem minmax(0, 1fr);
			gap: 0.2rem 0.75rem;
			padding: 0.62rem 0;
		}

		.home-index__post-title {
			white-space: normal;
		}

		.home-index__aside {
			grid-column: 2;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.home-index__post-title {
			transition: none;
		}
	}
</style>
