---
import { getCollection } from 'astro:content';
import MagazineShell from '../layouts/MagazineShell.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { filterDrafts } from '../utils/drafts';

const posts = filterDrafts(await getCollection('blog'))
	.filter((post) => !post.id.startsWith('en/'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const latestPosts = posts.slice(0, 12);

function getPostHref(post: (typeof posts)[number]) {
	return `/blog/${post.data.slug ?? post.id}.html`;
}

function getPostSummary(post: (typeof posts)[number]) {
	const rawSummary = post.data.description || post.body || '';
	const plainSummary = rawSummary
		.replace(/```[\s\S]*?```/g, ' ')
		.replace(/!\[[^\]]*]\([^)]+\)/g, ' ')
		.replace(/\[([^\]]+)]\([^)]+\)/g, '$1')
		.replace(/<[^>]+>/g, ' ')
		.replace(/[#>*_`~-]/g, ' ')
		.replace(/\s+/g, ' ')
		.trim();

	if (plainSummary) {
		return plainSummary.length > 108 ? `${plainSummary.slice(0, 108).trim()}...` : plainSummary;
	}

	return post.data.tags?.slice(0, 2).join(' / ') || '';
}

function getReadingMinutes(post: (typeof posts)[number]) {
	const plainText = (post.body || '').replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
	return Math.max(1, Math.ceil(plainText.length / 520));
}

function padIndex(n: number) {
	return String(n).padStart(2, '0');
}
---

<MagazineShell
	title={SITE_TITLE}
	description={SITE_DESCRIPTION}
	className="home-index-layout"
	showProfileCard={false}
>
	<section class="dispatch-index postcard-sheet" aria-labelledby="dispatch-title">
		<header class="dispatch-index__head">
			<div class="dispatch-index__identity">
				<p id="dispatch-title" class="dispatch-index__kicker">Recent dispatches</p>
				<p class="dispatch-index__sub">纸面上的近作 · {latestPosts.length} 封</p>
			</div>
			<a href="/blog" class="dispatch-index__archive">
				<span class="dispatch-field__label">Archive</span>
				<span aria-hidden="true">→</span>
			</a>
		</header>

		<div class="dispatch-index__legend" aria-hidden="true">
			<span class="dispatch-index__col dispatch-index__col--no">No.</span>
			<span class="dispatch-index__col dispatch-index__col--date">Date</span>
			<span class="dispatch-index__col dispatch-index__col--title">Title</span>
			<span class="dispatch-index__col dispatch-index__col--meta">Tag / Read</span>
		</div>

		<ol class="dispatch-list">
			{latestPosts.map((post, i) => {
				const primaryTag = post.data.tags?.[0] || post.data.categories?.[0];
				return (
					<li class="dispatch-list__item">
						<a href={getPostHref(post)} class="dispatch-card">
							<span class="dispatch-card__no" aria-hidden="true">{padIndex(i + 1)}</span>
							<span class="dispatch-field dispatch-card__date">
								<span class="dispatch-field__label">Date</span>
								<time class="dispatch-field__value" datetime={post.data.pubDate.toISOString()}>
									<FormattedDate date={post.data.pubDate} />
								</time>
							</span>
							<span class="dispatch-card__body">
								<span class="dispatch-field dispatch-card__title-field">
									<span class="dispatch-field__label">Title</span>
									<strong class="dispatch-card__title">{post.data.title}</strong>
								</span>
								<span class="dispatch-card__summary">{getPostSummary(post)}</span>
							</span>
							<span class="dispatch-card__aside">
								{primaryTag && <span class="dispatch-card__tag">{primaryTag}</span>}
								<span class="dispatch-card__read">{getReadingMinutes(post)} min</span>
							</span>
						</a>
					</li>
				);
			})}
		</ol>

		<footer class="dispatch-index__foot">
			<span class="dispatch-index__end" aria-hidden="true">◊</span>
			<a href="/blog">查看全部归档</a>
		</footer>
	</section>
</MagazineShell>

<style>
	:global(.home-index-layout .ledger-main) {
		display: flex;
		flex-direction: column;
		min-height: calc(100vh - clamp(5.5rem, 10vw, 8rem));
	}

	:global(.home-index-layout .ledger-main > footer) {
		margin-top: clamp(2rem, 5vw, 3.5rem);
	}

	:global(.home-index-layout footer) {
		grid-template-columns: minmax(0, 1fr);
		max-width: var(--blog-shell-width);
		text-align: center;
	}

	:global(.home-index-layout footer::before) {
		left: 50%;
		transform: translateX(-50%);
	}

	.dispatch-index {
		width: 100%;
		max-width: 100%;
		padding: clamp(1.15rem, 2.6vw, 1.65rem) clamp(1.05rem, 2.4vw, 1.55rem) clamp(1.2rem, 2.5vw, 1.55rem);
		font-family: var(--ui-font);
	}

	.dispatch-index__head {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 1rem;
		margin: 0 0 clamp(1rem, 2.2vw, 1.3rem);
		padding-bottom: 0.85rem;
		border-bottom: 1px solid var(--sheet-edge);
	}

	.dispatch-index__identity {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		min-width: 0;
	}

	.dispatch-index__kicker {
		margin: 0;
		font-family: var(--display-font);
		font-size: clamp(1.35rem, 2.4vw, 1.65rem);
		font-weight: 600;
		letter-spacing: -0.02em;
		line-height: 1.1;
		color: var(--heading-color);
	}

	.dispatch-index__sub {
		margin: 0;
		font-family: var(--field-font);
		font-size: 0.68rem;
		letter-spacing: 0.04em;
		color: var(--faint-color);
	}

	.dispatch-index__archive {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		border: 0 !important;
		color: var(--faint-color);
		font-size: 0.68rem;
		line-height: 1.15;
		text-decoration: none;
		white-space: nowrap;
		transition: color 0.18s ease;
	}

	.dispatch-index__archive .dispatch-field__label {
		letter-spacing: 0.1em;
	}

	.dispatch-index__archive:hover {
		color: var(--heading-color);
	}

	.dispatch-index__legend {
		display: grid;
		grid-template-columns: 1.75rem 5.75rem minmax(0, 1fr) 3.6rem;
		gap: 0.65rem 0.85rem;
		padding: 0.35rem 0.15rem 0.55rem;
		border-bottom: 1px dashed color-mix(in oklab, var(--sheet-edge) 80%, transparent);
		color: var(--faint-color);
		font-family: var(--field-font);
		font-size: 0.58rem;
		font-weight: var(--weight-medium);
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.dispatch-index__col--meta {
		text-align: right;
	}

	.dispatch-list {
		display: flex;
		flex-direction: column;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.dispatch-list__item + .dispatch-list__item {
		border-top: 1px solid color-mix(in oklab, var(--paper-card-border-soft) 85%, transparent);
	}

	.dispatch-card {
		display: grid;
		grid-template-columns: 1.75rem 5.75rem minmax(0, 1fr) 3.6rem;
		gap: 0.5rem 0.85rem;
		align-items: start;
		padding: clamp(0.72rem, 1.5vw, 0.9rem) 0.15rem;
		border: 0 !important;
		background: transparent !important;
		color: inherit;
		text-decoration: none;
		transition: background 0.18s ease;
	}

	.dispatch-card:hover {
		background: var(--paper-hover-bg) !important;
	}

	.dispatch-card:hover .dispatch-card__title {
		color: color-mix(in oklab, var(--accent-color) 32%, var(--heading-color));
	}

	.dispatch-card__no {
		padding-top: 0.2rem;
		color: var(--faint-color);
		font-family: var(--field-font);
		font-size: 0.68rem;
		font-variant-numeric: tabular-nums;
		letter-spacing: 0.04em;
		line-height: 1.2;
	}

	.dispatch-card__date {
		flex-direction: column;
		align-items: flex-start;
		gap: 0.28rem;
		padding-top: 0.1rem;
	}

	.dispatch-card__date .dispatch-field__label {
		display: none;
	}

	.dispatch-card__date .dispatch-field__value {
		font-family: var(--field-font);
		font-size: 0.78rem;
		color: color-mix(in oklab, var(--heading-color) 55%, var(--gray-color));
		font-variant-numeric: tabular-nums;
		white-space: nowrap;
	}

	.dispatch-card__body {
		display: flex;
		flex-direction: column;
		gap: 0.28rem;
		min-width: 0;
	}

	.dispatch-card__title-field {
		flex-direction: column;
		align-items: flex-start;
		gap: 0.22rem;
		width: 100%;
	}

	.dispatch-card__title-field .dispatch-field__label {
		display: none;
	}

	.dispatch-card__title {
		color: var(--heading-color);
		font-family: var(--display-font);
		font-size: clamp(1.02rem, 1.7vw, 1.18rem);
		font-weight: 600;
		line-height: 1.32;
		letter-spacing: -0.015em;
		overflow-wrap: anywhere;
		transition: color 0.18s ease;
	}

	.dispatch-card__summary {
		display: -webkit-box;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 2;
		overflow: hidden;
		max-width: none;
		color: color-mix(in oklab, var(--gray-color) 90%, var(--heading-color));
		font-family: var(--reading-font);
		font-size: 0.82rem;
		line-height: 1.5;
	}

	.dispatch-card__aside {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 0.2rem;
		padding-top: 0.15rem;
		min-width: 0;
		text-align: right;
	}

	.dispatch-card__tag {
		color: color-mix(in oklab, var(--heading-color) 62%, var(--gray-color));
		font-family: var(--ui-font);
		font-size: 0.72rem;
		line-height: 1.2;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
		max-width: 100%;
	}

	.dispatch-card__read {
		color: var(--faint-color);
		font-family: var(--field-font);
		font-size: 0.68rem;
		font-variant-numeric: tabular-nums;
		line-height: 1.2;
		white-space: nowrap;
	}

	.dispatch-index__foot {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		margin-top: 0.35rem;
		padding-top: 0.95rem;
		border-top: 1px solid var(--sheet-edge);
	}

	.dispatch-index__end {
		color: var(--faint-color);
		font-family: var(--display-font);
		font-size: 0.85rem;
		line-height: 1;
	}

	.dispatch-index__foot a {
		border: 0 !important;
		color: var(--gray-color);
		font-family: var(--field-font);
		font-size: 0.72rem;
		letter-spacing: 0.02em;
		text-decoration: none;
	}

	.dispatch-index__foot a:hover {
		color: var(--heading-color);
	}

	@media (max-width: 720px) {
		.dispatch-index__legend {
			display: none;
		}

		.dispatch-card {
			grid-template-columns: 1.6rem minmax(0, 1fr);
			grid-template-areas:
				"no date"
				"no body"
				"no aside";
			gap: 0.35rem 0.75rem;
			padding: 0.95rem 0.1rem;
		}

		.dispatch-card__no {
			grid-area: no;
			padding-top: 0.15rem;
		}

		.dispatch-card__date {
			grid-area: date;
			flex-direction: row;
			align-items: baseline;
			gap: 0.4rem;
		}

		.dispatch-card__date .dispatch-field__label {
			display: inline;
		}

		.dispatch-card__body {
			grid-area: body;
		}

		.dispatch-card__title-field .dispatch-field__label {
			display: inline;
		}

		.dispatch-card__aside {
			grid-area: aside;
			flex-direction: row;
			flex-wrap: wrap;
			align-items: baseline;
			justify-content: flex-start;
			gap: 0.45rem 0.85rem;
			text-align: left;
		}
	}

	@media (max-width: 640px) {
		.dispatch-index {
			max-width: 100%;
			padding-inline: clamp(0.9rem, 3vw, 1.15rem);
		}

		.dispatch-card__title {
			font-size: 1.05rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.dispatch-index__archive,
		.dispatch-card,
		.dispatch-card__title {
			transition: none;
		}
	}
</style>
