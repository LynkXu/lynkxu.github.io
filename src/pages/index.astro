---
import MagazineShell from '../layouts/MagazineShell.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const entryLinks = [
	{
		href: '/blog',
		label: 'Archive',
		title: '长文档案',
		description: '所有长文。',
	},
	{
		href: '/shuoshuo',
		label: 'Memos',
		title: '短句记录',
		description: '短句和日常。',
	},
	{
		href: '/photography',
		label: 'Photography',
		title: '光影瞬间',
		description: '一些照片。',
	},
	{
		href: '/media',
		label: 'Media',
		title: '书影音',
		description: '书、电影、游戏。',
	},
	{
		href: '/travel',
		label: 'Travel',
		title: '旅行足迹',
		description: '去过的地方。',
	},
	{
		href: '/sports',
		label: 'Sports',
		title: '运动记录',
		description: '训练和比赛。',
	},
	{
		href: '/tools',
		label: 'Tools',
		title: '常用工具',
		description: '设备和软件。',
	},
	{
		href: '/message',
		label: 'Leaves',
		title: '留言',
		description: '留下些什么。',
	},
];
---

<MagazineShell title={SITE_TITLE} description={SITE_DESCRIPTION} className="home-index-layout">
	<section class="home-index" aria-labelledby="home-title">
		<div class="home-statement">
			<h1 id="home-title">
				<span>Do the right thing.</span>
				<span>Do things right.</span>
			</h1>
		</div>

		<nav class="home-entry-list" aria-label="站点入口">
			{entryLinks.map((item) => (
				<a href={item.href} class="home-entry">
					<span class="home-entry__label">{item.label}</span>
					<span class="home-entry__body">
						<strong>{item.title}</strong>
						<span>{item.description}</span>
					</span>
				</a>
			))}
		</nav>

	</section>
</MagazineShell>

<style>
	.home-index {
		display: flex;
		flex-direction: column;
		gap: clamp(var(--space-lg), 4vw, var(--space-2xl));
		padding: clamp(0.35rem, 1vw, 0.65rem) 0 clamp(var(--space-2xl), 7vw, var(--space-4xl));
		animation: home-fade-up 0.55s ease-out both;
	}

	.home-statement {
		max-width: 35rem;
	}

	.home-statement h1 {
		max-width: 14ch;
		margin: 0;
		font-family: var(--serif-font);
		font-size: clamp(1.62rem, 4.25vw, 2.85rem);
		font-weight: 500;
		line-height: 1.12;
		letter-spacing: 0;
		color: var(--heading-color);
		text-wrap: balance;
	}

	.home-statement h1 span {
		display: block;
	}

	.home-entry-list {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		border-top: 1px solid var(--paper-card-border-soft);
	}

	.home-entry {
		display: grid;
		grid-template-columns: minmax(5.5rem, 0.34fr) minmax(0, 1fr);
		gap: clamp(var(--space-sm), 2vw, var(--space-lg));
		min-height: 5.2rem;
		padding: clamp(var(--space-md), 2.4vw, var(--space-lg)) clamp(var(--space-xs), 1.6vw, var(--space-sm));
		color: inherit;
		text-decoration: none;
		border-bottom: 1px solid var(--paper-card-border-soft) !important;
		background: none !important;
		transition:
			background 0.2s ease,
			color 0.2s ease,
			padding-inline 0.2s ease;
	}

	.home-entry:nth-child(odd) {
		border-right: 1px solid var(--paper-card-border-soft);
	}

	.home-entry:hover {
		background: color-mix(in oklab, var(--accent-soft-bg) 42%, transparent) !important;
		padding-inline: clamp(var(--space-sm), 2vw, var(--space-md));
	}

	.home-entry__label {
		font-family: var(--field-font);
		font-size: 0.7rem;
		font-weight: 600;
		letter-spacing: 0.04em;
		color: var(--gray-color);
		line-height: 1.45;
	}

	.home-entry__body {
		display: flex;
		flex-direction: column;
		gap: 0.26rem;
		min-width: 0;
	}

	.home-entry__body strong {
		font-family: var(--serif-font);
		font-size: 1rem;
		font-weight: 500;
		line-height: 1.35;
		color: var(--heading-color);
		transition: color 0.2s ease;
	}

	.home-entry:hover .home-entry__body strong {
		color: color-mix(in oklab, var(--accent-color) 44%, var(--heading-color));
	}

	.home-entry__body span {
		max-width: 23rem;
		font-size: 0.84rem;
		line-height: 1.58;
		color: color-mix(in oklab, var(--text-color) 74%, var(--gray-color));
	}

	@keyframes home-fade-up {
		from {
			opacity: 0;
			transform: translateY(12px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (max-width: 760px) {
		.home-entry-list {
			grid-template-columns: 1fr;
		}

		.home-entry {
			grid-template-columns: minmax(4.7rem, 0.28fr) minmax(0, 1fr);
		}

		.home-entry:nth-child(odd) {
			border-right: none;
		}
	}

	@media (max-width: 520px) {
		.home-index {
			gap: var(--space-lg);
		}

		.home-statement h1 {
			font-size: clamp(1.58rem, 8.8vw, 2.25rem);
		}

		.home-entry {
			grid-template-columns: 1fr;
			gap: var(--space-xs);
			min-height: 0;
			padding-inline: 0;
		}

		.home-entry:hover {
			padding-inline: var(--space-xs);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.home-index {
			animation: none;
		}

		.home-entry {
			transition: none;
		}
	}
</style>
