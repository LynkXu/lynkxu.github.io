<style>
  .hero-blob {
    position: absolute;
    border-radius: 999px;
    filter: blur(72px);
    opacity: 0.65;
    mix-blend-mode: screen;
    transform-origin: center;
    z-index: -5; /* keep under content but above base gradient */
  }

  .hero-arc {
    position: absolute;
    width: 420px;
    height: 220px;
    left: 12%;
    bottom: -140px;
    background: radial-gradient(ellipse at 50% 100%, hsl(var(--primary) / 0.2) 0%, hsl(var(--primary) / 0.12) 45%, transparent 65%);
    filter: blur(48px);
    opacity: 0.7;
    z-index: -6;
    transform: rotate(-2deg);
  }

  .hero-blob-1 {
    width: 340px;
    height: 340px;
    top: -140px;
    right: -120px;
    background: radial-gradient(circle at 30% 30%, hsl(var(--primary) / 0.45), transparent 65%);
    animation: blob-move-1 16s ease-in-out infinite alternate;
  }

  .hero-blob-2 {
    width: 280px;
    height: 280px;
    left: -120px;
    bottom: -80px;
    background: radial-gradient(circle at 40% 40%, hsl(var(--primary) / 0.35), transparent 65%);
    animation: blob-move-2 18s ease-in-out infinite alternate;
  }

  @keyframes blob-move-1 {
    0% {
      transform: translate3d(0, 0, 0) scale(1);
    }
    50% {
      transform: translate3d(18px, 12px, 0) scale(1.05);
    }
    100% {
      transform: translate3d(-14px, 24px, 0) scale(1.1);
    }
  }

  @keyframes blob-move-2 {
    0% {
      transform: translate3d(0, 0, 0) scale(1);
    }
    50% {
      transform: translate3d(-12px, -8px, 0) scale(1.04) rotate(2deg);
    }
    100% {
      transform: translate3d(10px, 18px, 0) scale(1.1) rotate(-1deg);
    }
  }

  @media (max-width: 640px) {
    .hero-blob {
      filter: blur(60px);
      opacity: 0.45;
    }
    .hero-arc {
      width: 300px;
      height: 180px;
      left: 6%;
      bottom: -150px;
      filter: blur(42px);
      opacity: 0.55;
    }
    .hero-blob-1 {
      width: 240px;
      height: 240px;
      top: -120px;
      right: -120px;
    }
    .hero-blob-2 {
      width: 200px;
      height: 200px;
      left: -100px;
      bottom: -120px;
    }
    .hero-ribbon {
      width: 260px;
      height: 160px;
      bottom: -80px;
      left: -20px;
      transform: rotate(-4deg);
    }
    .hero-orb {
      width: 170px;
      height: 170px;
      top: 18%;
      right: 6%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-blob {
      animation: none !important;
    }
  }

  .hero-shape {
    position: absolute;
    z-index: -4;
    mix-blend-mode: screen;
  }

  .hero-ribbon {
    width: 360px;
    height: 200px;
    bottom: -60px;
    left: -40px;
    background: linear-gradient(
      120deg,
      hsl(var(--primary) / 0.16) 0%,
      hsl(var(--primary) / 0.1) 45%,
      hsl(var(--primary) / 0.05) 70%,
      transparent 100%
    );
    border-radius: 55% 65% 45% 35%;
    filter: blur(2px);
    transform: rotate(-6deg);
  }

  .hero-orb {
    width: 260px;
    height: 260px;
    top: 14%;
    right: 10%;
    background: radial-gradient(
      circle at 35% 35%,
      hsl(var(--primary) / 0.32),
      hsl(var(--primary) / 0.18) 55%,
      hsl(var(--primary) / 0.08) 72%,
      transparent 86%
    );
    border-radius: 999px;
    filter: blur(1px);
    box-shadow:
      0 18px 48px hsl(var(--primary) / 0.18),
      0 -8px 24px hsl(var(--primary) / 0.08);
  }
</style>
