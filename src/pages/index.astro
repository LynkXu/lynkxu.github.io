---
import MagazineShell from '../layouts/MagazineShell.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const primaryEntryLinks = [
	{
		href: '/blog',
		label: 'Archive',
		title: '长文档案',
		description: '所有长文。',
	},
	{
		href: '/tags',
		label: 'Topics',
		title: '主题索引',
		description: '按主题浏览。',
	},
	{
		href: '/shuoshuo',
		label: 'Memos',
		title: '短句记录',
		description: '短句和日常。',
	},
];

const secondaryEntryLinks = [
	{
		href: '/photography',
		label: 'Photography',
		title: '光影瞬间',
	},
	{
		href: '/media',
		label: 'Media',
		title: '书影音',
	},
	{
		href: '/travel',
		label: 'Travel',
		title: '旅行足迹',
	},
	{
		href: '/sports',
		label: 'Sports',
		title: '运动记录',
	},
	{
		href: '/tools',
		label: 'Tools',
		title: '常用工具',
	},
];
---

<MagazineShell title={SITE_TITLE} description={SITE_DESCRIPTION} className="home-index-layout">
	<section class="home-index" aria-labelledby="home-title">
		<div class="home-statement">
			<h1 id="home-title">
				<span>Do the right thing.</span>
				<span>Do things right.</span>
			</h1>
		</div>

		<nav class="home-entry-list" aria-label="站点入口">
			<div class="home-entry-primary">
				{primaryEntryLinks.map((item) => (
					<a href={item.href} class="home-entry home-entry--primary">
						<span class="home-entry__label">{item.label}</span>
						<span class="home-entry__body">
							<strong>{item.title}</strong>
							<span>{item.description}</span>
						</span>
					</a>
				))}
			</div>

			<div class="home-entry-secondary" aria-label="专题入口">
				{secondaryEntryLinks.map((item) => (
					<a href={item.href} class="home-secondary-link" title={item.title}>
						{item.label}
					</a>
				))}
			</div>
		</nav>

	</section>
</MagazineShell>

<style>
	.home-index {
		display: flex;
		flex-direction: column;
		gap: clamp(var(--space-xl), 5vw, var(--space-3xl));
		padding: clamp(0.35rem, 1vw, 0.65rem) 0 clamp(var(--space-2xl), 7vw, var(--space-4xl));
		animation: home-fade-up 0.55s ease-out both;
	}

	.home-statement {
		max-width: 35rem;
	}

	.home-statement h1 {
		max-width: 14ch;
		margin: 0;
		font-family: var(--serif-font);
		font-size: clamp(1.62rem, 4.25vw, 2.85rem);
		font-weight: 500;
		line-height: 1.12;
		letter-spacing: 0;
		color: var(--heading-color);
		text-wrap: balance;
	}

	.home-statement h1 span {
		display: block;
	}

	.home-entry-list {
		display: flex;
		flex-direction: column;
		border-top: 1px solid var(--paper-card-border-soft);
	}

	.home-entry-primary {
		display: grid;
		grid-template-columns: 1fr;
	}

	.home-entry-secondary {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.38rem clamp(0.85rem, 2vw, 1.35rem);
		padding: 0.78rem clamp(var(--space-xs), 1.6vw, var(--space-sm));
		border-bottom: 1px solid var(--paper-card-border-soft);
	}

	.home-entry {
		display: grid;
		grid-template-columns: minmax(5.5rem, 0.34fr) minmax(0, 1fr);
		gap: clamp(var(--space-sm), 2vw, var(--space-lg));
		color: inherit;
		text-decoration: none;
		background: none !important;
		transition:
			background 0.2s ease,
			color 0.2s ease;
	}

	.home-entry--primary {
		min-height: 4.85rem;
		padding: clamp(0.88rem, 2vw, 1.1rem) clamp(var(--space-xs), 1.6vw, var(--space-sm));
		border-bottom: 1px solid var(--paper-card-border-soft) !important;
	}

	.home-entry:hover {
		background: color-mix(in oklab, var(--accent-soft-bg) 34%, transparent) !important;
	}

	.home-secondary-link {
		display: inline-flex;
		align-items: center;
		color: color-mix(in oklab, var(--text-color) 62%, var(--gray-color));
		font-family: var(--field-font);
		font-size: 0.72rem;
		font-weight: 500;
		letter-spacing: 0.025em;
		line-height: 1.35;
		text-decoration: none;
		background: none !important;
		transition: color 0.2s ease;
	}

	.home-secondary-link:hover {
		color: color-mix(in oklab, var(--accent-color) 42%, var(--heading-color));
	}

	.home-entry__label {
		font-family: var(--field-font);
		font-size: 0.7rem;
		font-weight: 600;
		letter-spacing: 0.04em;
		color: var(--gray-color);
		line-height: 1.45;
	}

	.home-entry__body {
		display: flex;
		flex-direction: column;
		gap: 0.26rem;
		min-width: 0;
	}

	.home-entry__body strong {
		font-family: var(--serif-font);
		font-size: 1rem;
		font-weight: 500;
		line-height: 1.35;
		color: var(--heading-color);
		transition: color 0.2s ease;
	}

	.home-entry:hover .home-entry__body strong {
		color: color-mix(in oklab, var(--accent-color) 44%, var(--heading-color));
	}

	.home-entry__body span {
		max-width: 23rem;
		font-size: 0.84rem;
		line-height: 1.58;
		color: color-mix(in oklab, var(--text-color) 74%, var(--gray-color));
	}

	@keyframes home-fade-up {
		from {
			opacity: 0;
			transform: translateY(12px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (max-width: 760px) {
		.home-entry-secondary {
			gap: 0.42rem 1rem;
		}

		.home-entry {
			grid-template-columns: minmax(4.7rem, 0.28fr) minmax(0, 1fr);
		}
	}

	@media (max-width: 520px) {
		.home-index {
			gap: var(--space-xl);
		}

		.home-statement h1 {
			font-size: clamp(1.58rem, 8.8vw, 2.25rem);
		}

		.home-entry {
			grid-template-columns: 1fr;
			gap: var(--space-xs);
			padding-inline: 0;
		}

		.home-entry--primary {
			min-height: 4.2rem;
		}

		.home-entry-secondary {
			padding: 0.68rem 0;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.home-index {
			animation: none;
		}

		.home-entry {
			transition: none;
		}

		.home-secondary-link {
			transition: none;
		}
	}
</style>
