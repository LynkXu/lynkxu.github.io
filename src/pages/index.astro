---
import { getCollection } from 'astro:content';
import MagazineShell from '../layouts/MagazineShell.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { filterDrafts } from '../utils/drafts';

const posts = filterDrafts(await getCollection('blog'))
	.filter((post) => !post.id.startsWith('en/'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const latestPosts = posts.slice(0, 10);
const featuredPost = latestPosts[0];
const recentPosts = latestPosts.slice(1);

function getPostHref(post: (typeof posts)[number]) {
	return `/blog/${post.data.slug ?? post.id}.html`;
}

function getPostSummary(post: (typeof posts)[number]) {
	const rawSummary = post.data.description || post.body || '';
	const plainSummary = rawSummary
		.replace(/```[\s\S]*?```/g, ' ')
		.replace(/!\[[^\]]*]\([^)]+\)/g, ' ')
		.replace(/\[([^\]]+)]\([^)]+\)/g, '$1')
		.replace(/<[^>]+>/g, ' ')
		.replace(/[#>*_`~-]/g, ' ')
		.replace(/\s+/g, ' ')
		.trim();

	if (plainSummary) {
		return plainSummary.length > 108 ? `${plainSummary.slice(0, 108).trim()}...` : plainSummary;
	}

	return post.data.tags?.slice(0, 2).join(' / ') || '';
}

function getReadingMinutes(post: (typeof posts)[number]) {
	const plainText = (post.body || '').replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
	return Math.max(1, Math.ceil(plainText.length / 520));
}

function getMonth(date: Date) {
	return new Intl.DateTimeFormat('en', { month: 'short' }).format(date);
}
---

<MagazineShell
	title={SITE_TITLE}
	description={SITE_DESCRIPTION}
	className="home-index-layout"
	showProfileCard={false}
>
	<section class="home-dashboard" aria-labelledby="home-latest-title">
		<div class="home-overview-grid">
			<section class="home-panel home-latest-panel" aria-labelledby="home-latest-title">
				<header class="home-panel-head">
					<p id="home-latest-title" class="magazine-section-label">Latest entry</p>
					<a href="/blog" class="home-all-link">Archive <span aria-hidden="true">→</span></a>
				</header>

				{featuredPost && (
					<a href={getPostHref(featuredPost)} class="home-featured-row">
						<time class="home-post-date home-post-date--featured" datetime={featuredPost.data.pubDate.toISOString()}>
							<span>{getMonth(featuredPost.data.pubDate)}</span>
							<strong>{String(featuredPost.data.pubDate.getDate()).padStart(2, '0')}</strong>
						</time>
						<span class="home-post-copy home-post-copy--featured">
							<strong>{featuredPost.data.title}</strong>
							<span>{getPostSummary(featuredPost)}</span>
						</span>
					</a>
				)}

				<div class="home-latest-list" role="list" aria-label="Recent entries">
					{recentPosts.map((post) => {
						const primaryTag = post.data.tags?.[0] || post.data.categories?.[0];
						return (
							<a href={getPostHref(post)} class="home-latest-row" role="listitem">
								<time class="home-post-date" datetime={post.data.pubDate.toISOString()}>
									<span>{getMonth(post.data.pubDate)}</span>
									<strong>{String(post.data.pubDate.getDate()).padStart(2, '0')}</strong>
								</time>
								<span class="home-post-copy">
									<strong>{post.data.title}</strong>
									<small class="home-post-meta">
										{primaryTag && <span class="home-tag">{primaryTag}</span>}
										<span>{getReadingMinutes(post)} min read</span>
									</small>
									<span>{getPostSummary(post)}</span>
								</span>
							</a>
						);
					})}
				</div>
			</section>
		</div>
	</section>
</MagazineShell>

<style>
	:global(.home-index-layout .ledger-main) {
		display: flex;
		flex-direction: column;
		min-height: calc(100vh - clamp(5.5rem, 10vw, 8rem));
	}

	:global(.home-index-layout .ledger-main > footer) {
		margin-top: clamp(2rem, 5vw, 3.5rem);
	}

	:global(.home-index-layout footer) {
		grid-template-columns: minmax(0, 1fr);
		max-width: var(--blog-shell-width);
		text-align: center;
	}

	:global(.home-index-layout footer::before) {
		left: 50%;
		transform: translateX(-50%);
	}

	.home-dashboard {
		width: 100%;
		max-width: min(100%, 820px);
		font-family: var(--ui-font);
	}

	.home-overview-grid {
		display: grid;
		grid-template-areas: "latest";
		grid-template-columns: 1fr;
		align-items: start;
	}

	.home-panel {
		min-width: 0;
	}

	.home-latest-panel {
		grid-area: latest;
	}

	.home-panel-head {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr) auto;
		align-items: baseline;
		gap: 1rem;
		margin: 0;
		padding-bottom: 0.65rem;
		border-bottom: 1px solid var(--paper-card-border-soft);
	}

	.home-panel-head .magazine-section-label {
		margin: 0;
		color: var(--gray-color);
		font-size: 0.72rem;
		font-weight: var(--weight-medium);
		letter-spacing: 0.04em;
	}

	.home-all-link {
		grid-column: 3;
		border: 0 !important;
		color: var(--faint-color);
		font-size: 0.68rem;
		font-weight: var(--weight-regular);
		line-height: 1.15;
		text-decoration: none;
		white-space: nowrap;
	}

	.home-all-link:hover {
		color: var(--gray-color);
	}

	.home-featured-row {
		display: grid;
		grid-template-columns: 5rem minmax(0, 1fr);
		gap: clamp(1.25rem, 2.4vw, 1.8rem);
		align-items: start;
		padding: clamp(1.35rem, 3vw, 1.85rem) 0;
		border: 0 !important;
		border-bottom: 1px solid var(--paper-card-border-soft) !important;
		background: transparent !important;
		color: var(--heading-color);
		text-decoration: none;
	}

	.home-latest-list {
		display: flex;
		flex-direction: column;
		gap: 0;
	}

	.home-latest-row {
		display: grid;
		grid-template-columns: 4.2rem minmax(0, 1fr);
		gap: clamp(1rem, 2.2vw, 1.55rem);
		align-items: baseline;
		min-height: 0;
		padding: clamp(1.12rem, 2.1vw, 1.32rem) 0;
		border: 0 !important;
		border-bottom: 1px solid var(--paper-card-border-soft) !important;
		border-radius: 0;
		background: transparent !important;
		color: var(--heading-color);
		box-shadow: none;
		text-decoration: none;
		transition: color 0.18s ease;
	}

	.home-featured-row:hover,
	.home-latest-row:hover {
		color: var(--heading-color);
		transform: none;
	}

	.home-post-date {
		display: inline-flex;
		gap: 0.16rem;
		min-height: 0;
		border-radius: 0;
		background: transparent;
		color: var(--gray-color);
		font-variant-numeric: tabular-nums;
		line-height: 1.35;
		text-align: left;
	}

	.home-post-date span,
	.home-post-date strong {
		color: inherit;
		font-size: 0.74rem;
		font-weight: var(--weight-regular);
		line-height: 1.35;
	}

	.home-post-date span::after {
		content: ".";
	}

	.home-post-date--featured {
		display: grid;
		gap: 0.18rem;
		align-self: start;
		line-height: 1;
	}

	.home-post-date--featured span {
		font-size: 0.72rem;
		line-height: 1;
		text-transform: uppercase;
	}

	.home-post-date--featured span::after {
		content: "";
	}

	.home-post-date--featured strong {
		color: color-mix(in oklab, var(--accent-color) 58%, var(--heading-color));
		font-size: clamp(1.8rem, 4vw, 2.65rem);
		font-weight: var(--weight-semibold);
		line-height: 0.92;
	}

	.home-post-copy {
		display: flex;
		flex-direction: column;
		min-width: 0;
		gap: 0.28rem;
	}

	.home-post-copy strong {
		color: var(--heading-color);
		font-size: 1rem;
		font-weight: var(--weight-medium);
		line-height: 1.34;
	}

	.home-post-copy span {
		display: -webkit-box;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 2;
		overflow: hidden;
		color: var(--gray-color);
		font-size: 0.8rem;
		line-height: 1.5;
	}

	.home-post-meta {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		min-width: 0;
		color: var(--faint-color);
		font-size: 0.68rem;
		font-weight: var(--weight-regular);
		line-height: 1.2;
		white-space: nowrap;
	}

	.home-post-meta span {
		display: inline;
		-webkit-line-clamp: unset;
		overflow: visible;
		color: inherit;
		font-size: inherit;
		line-height: inherit;
	}

	.home-tag::before {
		content: "#";
		opacity: 0.55;
	}

	.home-post-copy--featured strong {
		font-size: clamp(1.34rem, 3.1vw, 2.15rem);
		line-height: 1.22;
		text-wrap: balance;
	}

	.home-post-copy--featured span {
		display: block;
		-webkit-line-clamp: unset;
		margin-top: 0.34rem;
		font-size: 0.9rem;
		line-height: 1.62;
	}

	@media (max-width: 640px) {
		.home-featured-row,
		.home-latest-row {
			grid-template-columns: 3.65rem minmax(0, 1fr);
		}
	}
</style>
