---
import { getCollection } from 'astro:content';
import MagazineShell from '../layouts/MagazineShell.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { INCLUDE_DRAFTS, filterDrafts } from '../utils/drafts';

const allPosts = filterDrafts(await getCollection('blog')).filter((post) => !post.id.startsWith('en/'));
const recentPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 8);

function getPostExcerpt(body = '', length = 150) {
	const text = body
		.replace(/```[\s\S]*?```/g, ' ')
		.replace(/^#{1,6}\s+.+$/gm, ' ')
		.replace(/<[^>]+>/g, ' ')
		.replace(/!\[[^\]]*\]\([^)]+\)/g, ' ')
		.replace(/\[[^\]]+\]\([^)]+\)/g, (match) => match.match(/\[([^\]]+)\]/)?.[1] ?? '')
		.replace(/[#>*_`~\-\u003c\u003e]/g, ' ')
		.replace(/\s+/g, ' ')
		.trim();

	return text.length > length ? `${text.slice(0, length).trim()}…` : text;
}

const tagsMap = new Map<string, number>();
allPosts.forEach((post) => {
	(post.data.tags || []).forEach((tag) => {
		tagsMap.set(tag, (tagsMap.get(tag) || 0) + 1);
	});
});
const sortedTags = Array.from(tagsMap.entries()).sort((a, b) => b[1] - a[1]);
const featuredTopics = sortedTags.slice(0, 10);
---

<MagazineShell title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<!-- <h2 id="recent-heading" class="section-heading">Recent</h2> -->

	<div class="bento-grid">
		{
			recentPosts.map((post, index) => {
				const isFeatured = index === 0;
				return (
					<article class={`bento-card ${isFeatured ? 'bento-card--featured' : 'bento-card--medium'}`}>
						<a
							href={`/blog/${post.data.slug ?? post.id}.html`}
							class="bento-link"
							transition:name={isFeatured ? `post-title-${post.id}` : undefined}
						>
							<div class="bento-meta">
								<FormattedDate date={post.data.pubDate} />
								{post.data.tags?.[0] && (
									<span class="bento-tag">{post.data.tags[0]}</span>
								)}
							</div>
							<h3 class="bento-title">{post.data.title}</h3>
							<p class="bento-excerpt">
								{post.data.description || getPostExcerpt(post.body, isFeatured ? 140 : 75)}
							</p>
							{INCLUDE_DRAFTS && post.data.draft && (
								<span class="draft-badge" aria-label="Draft">Draft</span>
							)}
							{isFeatured && (
								<span class="bento-cta">Read →</span>
							)}
						</a>
					</article>
				);
			})
		}
	</div>
<!-- 
	<div class="archive-link-wrap">
		<a href="/blog" class="archive-link">View all posts →</a>
	</div> -->

	<!-- Topics -->
	{
		featuredTopics.length > 0 && (
			<section class="home-topics" aria-labelledby="topics-heading">
				{/* <h2 id="topics-heading" class="topics-heading">Topics</h2> */}
				<div class="topics-row">
					{featuredTopics.map(([tag, count]) => (
						<a href={`/tags/${tag}/`} class="topic-pill">
							<span class="topic-name">{tag}</span>
							<span class="topic-count">{count}</span>
						</a>
					))}
				</div>
			</section>
		)
	}
</MagazineShell>

<style>
	/* ── Section headings ── */
	.section-heading {
		margin: 0 0 clamp(1rem, 2.2vw, 1.25rem);
		font-family: var(--serif-font);
		font-size: var(--text-lg);
		font-weight: 500;
		color: var(--heading-color);
		letter-spacing: -0.01em;
		animation: fade-up 0.5s ease-out both;
	}

	/* ── Bento Grid ── */
	.bento-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		grid-template-areas:
			"feat feat c2"
			"feat feat c3"
			"c4   c5   c5"
			"c6   c7   c8";
		gap: var(--blog-card-gap, 0.9rem);
		grid-auto-rows: minmax(140px, auto);
	}

	.bento-grid .bento-card:nth-child(1) { grid-area: feat; }
	.bento-grid .bento-card:nth-child(2) { grid-area: c2; }
	.bento-grid .bento-card:nth-child(3) { grid-area: c3; }
	.bento-grid .bento-card:nth-child(4) { grid-area: c4; }
	.bento-grid .bento-card:nth-child(5) { grid-area: c5; }
	.bento-grid .bento-card:nth-child(6) { grid-area: c6; }
	.bento-grid .bento-card:nth-child(7) { grid-area: c7; }
	.bento-grid .bento-card:nth-child(8) { grid-area: c8; }

	/* ── Bento Card ── */
	.bento-card {
		position: relative;
		border: 1px solid var(--paper-card-border-soft);
		border-radius: var(--paper-card-radius);
		background: var(--paper-card-bg);
		box-shadow: var(--paper-card-shadow);
		transition:
			transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1),
			background-color 0.2s ease,
			border-color 0.2s ease;
		overflow: hidden;
		animation: fade-up 0.5s ease-out both;
	}

	.bento-card:hover {
		transform: translateY(-2px);
		border-color: color-mix(in oklab, var(--accent-color) 12%, var(--paper-card-border-soft));
		background: color-mix(in oklab, var(--accent-soft-bg) 25%, var(--paper-card-bg));
	}

	.bento-link {
		display: flex;
		flex-direction: column;
		gap: 0.45rem;
		padding: clamp(0.9rem, 2.2vw, 1.15rem) clamp(1rem, 2.4vw, 1.3rem);
		color: inherit;
		text-decoration: none;
		border-bottom: none !important;
		background: none !important;
		height: 100%;
	}

	.bento-card--featured .bento-link {
		padding: clamp(1.1rem, 2.8vw, 1.45rem) clamp(1.2rem, 2.8vw, 1.55rem);
		gap: 0.55rem;
	}

	.bento-meta {
		display: flex;
		align-items: baseline;
		flex-wrap: wrap;
		gap: 0.35rem;
		font-family: var(--field-font);
		font-size: 0.68rem;
		line-height: 1.35;
		color: var(--gray-color);
		letter-spacing: 0.025em;
		font-variant-numeric: tabular-nums;
	}

	.bento-tag {
		display: inline-flex;
		align-items: center;
		padding: 0.12em 0.45em;
		background: color-mix(in oklab, var(--accent-soft-bg) 60%, var(--paper-card-bg));
		border: 1px solid color-mix(in oklab, var(--accent-color) 10%, var(--paper-card-border-soft));
		border-radius: 3px;
		font-size: 0.62rem;
		color: color-mix(in oklab, var(--accent-color) 50%, var(--gray-color));
		letter-spacing: 0.01em;
	}

	.bento-title {
		margin: 0;
		font-family: var(--serif-font);
		font-size: clamp(0.95rem, 1.2vw, 1.08rem);
		font-weight: 500;
		color: var(--heading-color);
		letter-spacing: -0.01em;
		line-height: 1.32;
		transition: color 0.2s ease;
	}

	.bento-card--featured .bento-title {
		font-size: clamp(1.15rem, 1.8vw, 1.42rem);
		line-height: 1.22;
		letter-spacing: -0.014em;
	}

	.bento-card:hover .bento-title {
		color: color-mix(in oklab, var(--accent-color) 38%, var(--heading-color));
	}

	.bento-excerpt {
		margin: 0;
		color: var(--text-color);
		font-size: 0.86rem;
		line-height: 1.58;
		opacity: 0.78;
		display: -webkit-box;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 2;
		overflow: hidden;
	}

	.bento-card--featured .bento-excerpt {
		font-size: 0.92rem;
		line-height: 1.62;
		opacity: 0.82;
		-webkit-line-clamp: 3;
		max-width: 52ch;
	}

	.bento-cta {
		display: inline-flex;
		align-items: center;
		margin-top: auto;
		padding-top: 0.35rem;
		font-family: var(--field-font);
		font-size: 0.78rem;
		font-weight: 500;
		color: color-mix(in oklab, var(--accent-color) 55%, var(--gray-color));
		letter-spacing: 0.02em;
		transition: color 0.2s ease;
	}

	.bento-card:hover .bento-cta {
		color: color-mix(in oklab, var(--accent-color) 78%, var(--heading-color));
	}

	/* ── Draft badge ── */
	.draft-badge {
		display: inline-flex;
		align-items: center;
		font-family: var(--field-font);
		font-size: 0.65rem;
		font-weight: 500;
		color: color-mix(in oklab, var(--color-warning) 65%, var(--gray-color));
		letter-spacing: 0.02em;
	}

	/* ── Archive link ── */
	.archive-link-wrap {
		display: flex;
		justify-content: center;
		margin-top: clamp(1.2rem, 2.8vw, 1.6rem);
		animation: fade-up 0.5s ease-out 0.4s both;
	}

	.archive-link {
		font-family: var(--field-font);
		font-size: 0.82rem;
		color: var(--gray-color);
		text-decoration: none;
		border-bottom: 1px solid transparent;
		transition: color 0.2s ease, border-color 0.2s ease;
		padding: 0.3rem 0;
	}

	.archive-link:hover {
		color: var(--heading-color);
		border-bottom-color: color-mix(in oklab, var(--gray-color) 40%, transparent);
	}

	/* ── Topics ── */
	.home-topics {
		display: flex;
		flex-direction: column;
		gap: 0.9rem;
		margin-top: clamp(1.5rem, 3vw, 2rem);
		animation: fade-up 0.5s ease-out 0.48s both;
	}

	.topics-heading {
		margin: 0;
		font-family: var(--serif-font);
		font-size: var(--text-lg);
		font-weight: 500;
		color: var(--heading-color);
		letter-spacing: -0.01em;
	}

	.topics-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.topic-pill {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.4rem 0.72rem;
		font-family: var(--field-font);
		font-size: 0.8rem;
		color: color-mix(in oklab, var(--text-color) 82%, var(--gray-color));
		text-decoration: none;
		border: 1px solid var(--paper-card-border-soft);
		border-radius: var(--paper-card-radius);
		background: var(--paper-field-bg);
		transition:
			transform 0.25s cubic-bezier(0.2, 0.8, 0.2, 1),
			color 0.2s ease,
			background 0.2s ease,
			border-color 0.2s ease;
	}

	.topic-pill:hover {
		transform: translateY(-1px);
		color: color-mix(in oklab, var(--accent-color) 42%, var(--heading-color));
		background: color-mix(in oklab, var(--accent-soft-bg) 55%, var(--paper-field-bg));
		border-color: color-mix(in oklab, var(--accent-color) 16%, var(--paper-card-border-soft));
	}

	.topic-count {
		color: var(--gray-color);
		font-size: 0.72rem;
		font-variant-numeric: tabular-nums;
		opacity: 0.6;
		transition: color 0.2s ease;
	}

	.topic-pill:hover .topic-count {
		color: color-mix(in oklab, var(--accent-color) 44%, var(--heading-color));
		opacity: 0.85;
	}

	/* ── Animations ── */
	@keyframes fade-up {
		from {
			opacity: 0;
			transform: translateY(12px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.bento-grid .bento-card:nth-child(1) { animation-delay: 0.06s; }
	.bento-grid .bento-card:nth-child(2) { animation-delay: 0.1s; }
	.bento-grid .bento-card:nth-child(3) { animation-delay: 0.14s; }
	.bento-grid .bento-card:nth-child(4) { animation-delay: 0.18s; }
	.bento-grid .bento-card:nth-child(5) { animation-delay: 0.22s; }
	.bento-grid .bento-card:nth-child(6) { animation-delay: 0.26s; }
	.bento-grid .bento-card:nth-child(7) { animation-delay: 0.30s; }
	.bento-grid .bento-card:nth-child(8) { animation-delay: 0.34s; }

	/* ── Responsive: tablet ── */
	@media (max-width: 1023px) {
		.bento-grid {
			grid-template-columns: repeat(2, 1fr);
			grid-template-areas:
				"feat feat"
				"c2   c3"
				"c4   c5"
				"c6   c7"
				"c8   c8";
			grid-auto-rows: minmax(120px, auto);
		}
	}

	/* ── Responsive: mobile ── */
	@media (max-width: 767px) {
		.bento-grid {
			grid-template-columns: 1fr;
			grid-template-areas:
				"feat"
				"c2"
				"c3"
				"c4"
				"c5"
				"c6"
				"c7"
				"c8";
			grid-auto-rows: auto;
		}

		.bento-card--featured .bento-title {
			font-size: 1.12rem;
		}

		.bento-title {
			font-size: 1.02rem;
		}

		.bento-excerpt {
			-webkit-line-clamp: 2;
			font-size: 0.84rem;
		}
	}

	/* ── Reduced motion ── */
	@media (prefers-reduced-motion: reduce) {
		.bento-card,
		.home-topics,
		.archive-link-wrap,
		.section-heading {
			animation: none;
		}

		.bento-card,
		.topic-pill {
			transition: none;
		}
	}
</style>
