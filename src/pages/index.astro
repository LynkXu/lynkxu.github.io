---
import { getCollection } from 'astro:content';
import MagazineShell from '../layouts/MagazineShell.astro';
import stravaData from '../data/strava/activities.min.json';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { filterDrafts } from '../utils/drafts';

const posts = filterDrafts(await getCollection('blog'))
	.filter((post) => !post.id.startsWith('en/'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const latestPosts = posts.slice(0, 4);
const photographyImages = import.meta.glob('../content/photography/*.{jpg,jpeg,png,webp,gif,heic,HEIC}');
const stravaActivities = Array.isArray(stravaData) ? stravaData : [];

const indexLinks = [
	{
		href: '/photography',
		icon: 'camera',
		label: 'Photography',
		title: '光影瞬间',
		meta: `${Object.keys(photographyImages).length} images with EXIF`,
	},
	{
		href: '/media',
		icon: 'book',
		label: 'Media',
		title: '书影音',
		meta: 'books / movies / music',
	},
	{
		href: '/travel',
		icon: 'pin',
		label: 'Travel',
		title: '旅行足迹',
		meta: 'places / map pins',
	},
	{
		href: '/sports',
		icon: 'activity',
		label: 'Sports',
		title: '运动记录',
		meta: `${stravaActivities.length} Strava activities`,
	},
];

const iconPaths: Record<string, string> = {
	code: '<polyline points="8 9 4 12 8 15"></polyline><polyline points="16 9 20 12 16 15"></polyline><path d="m14 7-4 10"></path><rect x="3" y="4" width="18" height="16" rx="2"></rect>',
	edit: '<path d="M12 20h9"></path><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"></path>',
	sync: '<path d="M21 12a9 9 0 0 0-15.4-6.4L3 8"></path><path d="M3 3v5h5"></path><path d="M3 12a9 9 0 0 0 15.4 6.4L21 16"></path><path d="M16 16h5v5"></path>',
	camera: '<path d="M6 8h2l1.4-2h5.2L16 8h2a2 2 0 0 1 2 2v7a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2Z"></path><circle cx="12" cy="13" r="3"></circle>',
	book: '<path d="M4 5.5A2.5 2.5 0 0 1 6.5 3H20v16H7a3 3 0 0 0-3 3Z"></path><path d="M4 5.5v16"></path><path d="M20 3v16"></path>',
	pin: '<path d="M20 10c0 5-8 11-8 11S4 15 4 10a8 8 0 1 1 16 0Z"></path><circle cx="12" cy="10" r="2.7"></circle>',
	activity: '<path d="M5 17h14"></path><path d="m5 17 4-9 3 6 2-4 5 7"></path>',
	github: '<path d="M15 22v-4a3.7 3.7 0 0 0-1-2.8c3.4-.4 7-1.7 7-7.5A5.8 5.8 0 0 0 19.4 4 5.4 5.4 0 0 0 19.3.3S18 0 15 1.8a12.4 12.4 0 0 0-6 0C6 0 4.7.3 4.7.3A5.4 5.4 0 0 0 4.6 4 5.8 5.8 0 0 0 3 7.7c0 5.8 3.6 7.1 7 7.5a3.7 3.7 0 0 0-1 2.8v4"></path><path d="M9 18c-3 .9-5-1-6-3"></path>',
	x: '<path d="M18.9 2.2h2.8l-6.1 7 7.2 9.6h-5.6l-4.4-5.8-5 5.8H5l6.5-7.5-6.9-9.1h5.8l4 5.2 4.5-5.2Zm-1 14.9h1.6L9.6 3.8H7.9l10 13.3Z" fill="currentColor" stroke="none"></path>',
	rss: '<path d="M4 11a9 9 0 0 1 9 9"></path><path d="M4 4a16 16 0 0 1 16 16"></path><circle cx="5" cy="19" r="1"></circle>',
	mastodon: '<path d="M5.8 15.2c-.4-2-.5-4.2-.3-6.2.3-3.6 2.8-4.7 6.5-4.7s6.2 1.1 6.5 4.7c.2 1.8.1 3.3-.2 4.6-.5 2.3-3.1 2.7-5.5 2.7h-1.7c-1 0-1.8.6-1.8 1.4 0 1.2 1.6 1.5 3.2 1.5 1.4 0 2.8-.2 4.1-.6"></path><path d="M8.7 12.4V8.9c0-1 .7-1.8 1.7-1.8s1.6.7 1.6 1.7v2"></path><path d="M12 8.8c0-1 .7-1.7 1.6-1.7s1.7.8 1.7 1.8v3.5"></path>',
	neodb: '<path d="M6.2 6.3A7.9 7.9 0 0 1 12 4c4.4 0 8 3.6 8 8s-3.6 8-8 8-8-3.6-8-8"></path><path d="M7.6 16.4V7.7l8.8 8.6V7.6"></path>',
	strava: '<path d="m7.2 15.1 4.8-9.5 4.8 9.5h-3l-1.8-3.7-1.8 3.7H7.2Z"></path><path d="m10.2 18.4 1.8-3.7 1.8 3.7h-3.6Z"></path>',
};

function getPostHref(post: (typeof posts)[number]) {
	return `/blog/${post.data.slug ?? post.id}.html`;
}

function getPostSummary(post: (typeof posts)[number]) {
	const rawSummary = post.data.description || post.body || '';
	const plainSummary = rawSummary
		.replace(/```[\s\S]*?```/g, ' ')
		.replace(/!\[[^\]]*]\([^)]+\)/g, ' ')
		.replace(/\[([^\]]+)]\([^)]+\)/g, '$1')
		.replace(/<[^>]+>/g, ' ')
		.replace(/[#>*_`~-]/g, ' ')
		.replace(/\s+/g, ' ')
		.trim();

	if (plainSummary) {
		return plainSummary.length > 58 ? `${plainSummary.slice(0, 58).trim()}...` : plainSummary;
	}

	return post.data.tags?.slice(0, 2).join(' / ') || '';
}

function getReadingMinutes(post: (typeof posts)[number]) {
	const plainText = (post.body || '').replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
	return Math.max(1, Math.ceil(plainText.length / 520));
}

function getMonth(date: Date) {
	return new Intl.DateTimeFormat('en', { month: 'short' }).format(date);
}
---

<MagazineShell
	title={SITE_TITLE}
	description={SITE_DESCRIPTION}
	className="home-index-layout"
	showProfileCard={false}
>
	<section class="home-dashboard" aria-labelledby="home-title">
		<div class="home-overview-grid">
			<div class="home-intro">
				<h1 id="home-title">LynkXu</h1>

				<section class="home-panel home-index-panel" aria-labelledby="home-index-title">
					<header class="home-panel-head">
						<p id="home-index-title" class="magazine-section-label">Index</p>
					</header>

					<div class="home-index-grid">
						{indexLinks.map((item) => (
							<a href={item.href} class="home-index-card">
								<span class="home-index-icon" aria-hidden="true">
									<svg viewBox="0 0 24 24" set:html={iconPaths[item.icon]}></svg>
								</span>
								<span>
									<strong>{item.label}</strong>
									<em>{item.title}</em>
								</span>
							</a>
						))}
					</div>
				</section>
			</div>

			<section class="home-panel home-latest-panel" aria-labelledby="home-latest-title">
				<header class="home-panel-head">
					<p id="home-latest-title" class="magazine-section-label">Latest</p>
					<a href="/blog" class="home-all-link">View all entries <span aria-hidden="true">→</span></a>
				</header>

				<div class="home-latest-list" role="list">
					{latestPosts.map((post) => {
						const primaryTag = post.data.tags?.[0] || post.data.categories?.[0];
						return (
							<a href={getPostHref(post)} class="home-latest-row" role="listitem">
								<time class="home-post-date" datetime={post.data.pubDate.toISOString()}>
									<span>{getMonth(post.data.pubDate)}</span>
									<strong>{String(post.data.pubDate.getDate()).padStart(2, '0')}</strong>
								</time>
								<span class="home-post-copy">
									<strong>{post.data.title}</strong>
									<span>{getPostSummary(post)}</span>
								</span>
								<span class="home-post-meta">
									{primaryTag && <span class="home-tag">{primaryTag}</span>}
									<small>{getReadingMinutes(post)} min read</small>
								</span>
							</a>
						);
					})}
				</div>
			</section>
		</div>
	</section>
</MagazineShell>

<style>
	:global(.home-index-layout) {
		--blog-shell-width: 1160px;
		--blog-card-gap: clamp(1rem, 2vw, 1.45rem);
	}

	:global(.home-index-layout .magazine-shell) {
		padding-top: clamp(1.15rem, 2.4vw, 1.7rem);
		padding-bottom: clamp(2rem, 4vw, 3rem);
	}

	:global(.home-index-layout footer) {
		grid-template-columns: minmax(0, 1fr);
		max-width: var(--blog-shell-width);
		text-align: center;
	}

	:global(.home-index-layout footer::before) {
		left: 50%;
		transform: translateX(-50%);
	}

	:global(.home-index-layout footer .social-links) {
		grid-column: 1;
		justify-content: center;
	}

	.home-dashboard {
		display: flex;
		flex-direction: column;
		gap: clamp(1.2rem, 2vw, 1.55rem);
		width: 100%;
		font-family: var(--ui-font);
	}

	.home-hero-grid,
	.home-content-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(23rem, 0.96fr);
		gap: clamp(1.2rem, 2.1vw, 1.7rem);
	}

	.home-hero-grid {
		align-items: center;
		min-height: clamp(14rem, 20vw, 16.25rem);
	}

	.home-content-grid {
		align-items: stretch;
	}

	.home-intro {
		display: flex;
		flex-direction: column;
		justify-content: center;
		min-width: 0;
		padding: clamp(1rem, 1.8vw, 1.35rem) 0;
	}

	.home-intro h1 {
		display: flex;
		flex-direction: column;
		gap: 0.12em;
		margin: 0;
		color: color-mix(in oklab, var(--heading-color) 88%, var(--gray-color));
		font-family: var(--ui-font);
		font-size: clamp(2.55rem, 4.05vw, 3.75rem);
		font-weight: var(--weight-display);
		letter-spacing: 0;
		line-height: 0.98;
		text-wrap: balance;
	}

	.home-stats {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 8.75rem));
		gap: clamp(0.7rem, 1.4vw, 1rem);
		margin-top: clamp(1rem, 1.8vw, 1.25rem);
	}

	.home-stat-card,
	.home-profile-card {
		border: 1px solid var(--paper-card-border-soft);
		border-radius: var(--paper-card-radius);
		background: var(--paper-card-bg);
		box-shadow: var(--paper-card-shadow);
	}

	.home-stat-card {
		min-height: 3.95rem;
		padding: 0.84rem 1rem;
		box-shadow: none;
	}

	.home-stat-card strong {
		display: block;
		color: color-mix(in oklab, var(--accent-color) 72%, var(--heading-color));
		font-size: clamp(1.16rem, 1.7vw, 1.32rem);
		font-weight: var(--weight-bold);
		line-height: 1;
	}

	.home-stat-card span {
		display: block;
		margin-top: 0.34rem;
		color: var(--heading-color);
		font-size: 0.78rem;
		font-weight: var(--weight-medium);
	}

	.home-profile-card {
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: clamp(1.08rem, 1.9vw, 1.35rem);
		min-height: clamp(13.2rem, 18vw, 15.4rem);
		padding: clamp(1.35rem, 2.4vw, 1.7rem);
		box-shadow: none;
	}

	.home-profile-main {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr);
		gap: clamp(1rem, 1.7vw, 1.3rem);
		align-items: center;
	}

	.home-profile-avatar {
		width: clamp(4.2rem, 5.8vw, 5.2rem);
		height: clamp(4.2rem, 5.8vw, 5.2rem);
		border-radius: 50%;
		object-fit: cover;
		background: var(--paper-field-bg);
	}

	.home-profile-copy h2 {
		margin: 0;
		color: var(--heading-color);
		font-size: clamp(1.25rem, 1.9vw, 1.48rem);
		font-weight: var(--weight-bold);
		line-height: 1.1;
	}

	.home-profile-rows {
		display: flex;
		flex-direction: column;
		gap: 0.68rem;
		padding-top: 1.02rem;
		border-top: 1px solid var(--paper-card-border-soft);
	}

	.home-profile-row {
		display: grid;
		grid-template-columns: 1.55rem 5.4rem minmax(0, 1fr);
		gap: 0.72rem;
		align-items: center;
		min-width: 0;
		color: var(--gray-color);
		font-size: 0.86rem;
		line-height: 1.4;
	}

	.home-profile-row strong {
		color: var(--heading-color);
		font-weight: var(--weight-semibold);
	}

	.home-profile-row span:last-child {
		min-width: 0;
		overflow-wrap: anywhere;
	}

	.home-icon,
	.home-index-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--heading-color);
	}

	.home-icon svg,
	.home-index-icon svg,
	.home-socials svg,
	.home-stream-links svg {
		width: 1.25rem;
		height: 1.25rem;
		fill: none;
		stroke: currentColor;
		stroke-width: 1.8;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	.home-socials {
		display: flex;
		gap: 0.72rem;
		padding-top: 1.02rem;
		border-top: 1px solid var(--paper-card-border-soft);
	}

	.home-socials a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2.25rem;
		height: 2.25rem;
		border: 1px solid var(--paper-card-border-soft);
		border-radius: 7px;
		background: color-mix(in oklab, var(--paper-card-bg) 86%, var(--paper-field-bg));
		color: var(--heading-color);
		text-decoration: none;
		transition: border-color 0.18s ease, background 0.18s ease, color 0.18s ease, transform 0.18s ease;
	}

	.home-socials a:hover {
		border-color: var(--paper-hover-border);
		background: var(--paper-hover-bg);
		color: color-mix(in oklab, var(--accent-color) 62%, var(--heading-color));
		transform: translateY(-1px);
	}

	.home-panel {
		display: flex;
		flex-direction: column;
		gap: 0;
		min-width: 0;
		padding: 0;
	}

	.home-index-panel {
		min-height: 100%;
	}

	.home-panel-head {
		display: grid;
		grid-template-columns: auto minmax(0, 1fr) auto;
		align-items: start;
		gap: 1rem;
		margin-bottom: 0.72rem;
	}

	.home-panel-head .magazine-section-label {
		margin: 0;
		color: color-mix(in oklab, var(--blog-section-label-color) 62%, var(--gray-color));
		font-size: 0.8rem;
		font-weight: var(--weight-medium);
		letter-spacing: 0.035em;
	}

	.home-panel-head .magazine-section-label::after {
		width: 2.1rem;
		height: 1px;
		opacity: 0.75;
	}

	.home-latest-list {
		display: grid;
		gap: 0.58rem;
	}

	.home-latest-row {
		display: grid;
		grid-template-columns: 4.35rem minmax(0, 1fr) auto;
		gap: clamp(0.72rem, 1.2vw, 0.95rem);
		align-items: center;
		min-width: 0;
		min-height: 4.25rem;
		padding: 0.68rem 0.82rem;
		border: 1px solid var(--paper-card-border-soft);
		border-radius: var(--paper-card-radius);
		color: var(--heading-color);
		text-decoration: none;
		background: color-mix(in oklab, var(--paper-card-bg) 90%, var(--paper-field-bg)) !important;
		transition: border-color 0.18s ease, background 0.18s ease, color 0.18s ease, transform 0.18s ease;
	}

	.home-latest-row:hover {
		border-color: var(--paper-hover-border);
		background: var(--paper-hover-bg) !important;
		color: color-mix(in oklab, var(--accent-color) 60%, var(--heading-color));
		transform: translateY(-1px);
	}

	.home-post-date {
		display: grid;
		gap: 0.18rem;
		place-items: center;
		align-self: stretch;
		min-height: 2.95rem;
		border-radius: calc(var(--paper-card-radius) - 1px);
		background: color-mix(in oklab, var(--accent-soft-bg) 42%, var(--paper-card-bg));
		color: color-mix(in oklab, var(--accent-color) 75%, var(--heading-color));
		font-variant-numeric: tabular-nums;
		line-height: 1;
		text-align: center;
		text-transform: uppercase;
	}

	.home-post-date span {
		color: color-mix(in oklab, var(--accent-color) 58%, var(--gray-color));
		font-size: 0.68rem;
		font-weight: var(--weight-medium);
		line-height: 1;
	}

	.home-post-date strong {
		color: inherit;
		font-size: 1.18rem;
		font-weight: var(--weight-semibold);
		line-height: 1;
	}

	.home-post-copy {
		display: flex;
		flex-direction: column;
		gap: 0.26rem;
		min-width: 0;
	}

	.home-post-copy strong {
		display: block;
		color: var(--heading-color);
		font-size: 0.98rem;
		font-weight: var(--weight-semibold);
		line-height: 1.35;
	}

	.home-post-copy span {
		display: -webkit-box;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 1;
		overflow: hidden;
		color: var(--gray-color);
		font-size: 0.82rem;
		font-weight: var(--weight-medium);
		line-height: 1.5;
	}

	.home-post-meta {
		display: flex;
		align-items: center;
		justify-content: flex-end;
		gap: 0.7rem;
		min-width: 7.6rem;
		color: var(--gray-color);
		white-space: nowrap;
	}

	.home-tag {
		display: inline-flex;
		align-items: center;
		min-height: 1.72rem;
		padding: 0 0.72rem;
		border-radius: 5px;
		background: color-mix(in oklab, var(--accent-soft-bg) 46%, var(--paper-card-bg));
		color: color-mix(in oklab, var(--accent-color) 64%, var(--gray-color));
		font-size: 0.76rem;
		font-weight: var(--weight-medium);
	}

	.home-post-meta small {
		color: var(--gray-color);
		font-size: 0.78rem;
		font-weight: var(--weight-medium);
	}

	.home-all-link {
		width: fit-content;
		margin-top: 0;
		grid-column: 3;
		justify-self: end;
		border: 0 !important;
		color: color-mix(in oklab, var(--accent-color) 58%, var(--gray-color));
		font-size: 0.8rem;
		font-weight: var(--weight-medium);
		line-height: 1.15;
		text-decoration: none;
		white-space: nowrap;
	}

	.home-index-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.64rem;
		margin-bottom: 0.72rem;
	}

	.home-index-card {
		display: grid;
		grid-template-columns: 2.35rem minmax(0, 1fr) auto;
		gap: 0.68rem;
		align-items: center;
		min-height: 4.55rem;
		padding: 0.72rem 0.82rem;
		border: 1px solid var(--paper-card-border-soft);
		border-radius: var(--paper-card-radius);
		background: color-mix(in oklab, var(--paper-card-bg) 90%, var(--paper-field-bg)) !important;
		color: var(--heading-color);
		text-decoration: none;
		transition: border-color 0.18s ease, background 0.18s ease, color 0.18s ease, transform 0.18s ease;
	}

	.home-index-card:hover {
		border-color: var(--paper-hover-border);
		background: var(--paper-hover-bg) !important;
		color: color-mix(in oklab, var(--accent-color) 62%, var(--heading-color));
		transform: translateY(-1px);
	}

	.home-index-card span:nth-child(2) {
		display: flex;
		flex-direction: column;
		min-width: 0;
	}

	.home-index-card strong,
	.home-index-card em,
	.home-index-card small {
		display: block;
		min-width: 0;
		overflow-wrap: anywhere;
		font-style: normal;
	}

	.home-index-card strong {
		font-size: 0.9rem;
		font-weight: var(--weight-semibold);
		line-height: 1.2;
	}

	.home-index-card em {
		margin-top: 0.14rem;
		color: var(--heading-color);
		font-size: 0.82rem;
		font-weight: var(--weight-regular);
		line-height: 1.25;
	}

	.home-index-card small {
		margin-top: 0.28rem;
		color: var(--gray-color);
		font-size: 0.74rem;
		font-weight: var(--weight-medium);
		line-height: 1.35;
	}

	.home-index-card i {
		color: var(--heading-color);
		font-size: 1.8rem;
		font-style: normal;
		font-weight: 300;
		line-height: 1;
	}

	.home-stream-card {
		position: relative;
		display: flex;
		flex-direction: column;
		gap: 0;
		min-height: 6.45rem;
		margin-top: auto;
		padding: 0.95rem 1.05rem;
		border: 1px solid color-mix(in oklab, var(--accent-color) 16%, var(--paper-card-border-soft));
		border-radius: var(--paper-card-radius);
		background:
