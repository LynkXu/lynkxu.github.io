---
import { getCollection } from 'astro:content';
import MagazineShell from '../layouts/MagazineShell.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { filterDrafts } from '../utils/drafts';

const secondaryEntryLinks = [
	{
		href: '/photography',
		label: 'Photography',
		title: '光影瞬间',
	},
	{
		href: '/media',
		label: 'Media',
		title: '书影音',
	},
	{
		href: '/travel',
		label: 'Travel',
		title: '旅行足迹',
	},
	{
		href: '/sports',
		label: 'Sports',
		title: '运动记录',
	},
	{
		href: '/tools',
		label: 'Tools',
		title: '常用工具',
	},
];

const latestPosts = filterDrafts(await getCollection('blog'))
	.filter((post) => !post.id.startsWith('en/'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const [featuredPost, ...morePosts] = latestPosts;

function getPostHref(post: (typeof latestPosts)[number]) {
	return `/blog/${post.data.slug ?? post.id}.html`;
}

function getPostTopic(post: (typeof latestPosts)[number]) {
	return post.data.tags?.[0] || '';
}

function getPostSummary(post: (typeof latestPosts)[number]) {
	const rawSummary = post.data.description || post.body || '';
	const plainSummary = rawSummary
		.replace(/```[\s\S]*?```/g, ' ')
		.replace(/!\[[^\]]*]\([^)]+\)/g, ' ')
		.replace(/\[([^\]]+)]\([^)]+\)/g, '$1')
		.replace(/[#>*_`~-]/g, ' ')
		.replace(/\s+/g, ' ')
		.trim();

	if (plainSummary) {
		return plainSummary.length > 82 ? `${plainSummary.slice(0, 82).trim()}…` : plainSummary;
	}

	return post.data.tags?.slice(0, 2).join(' · ') || '';
}

function formatPostDate(date: Date) {
	return new Intl.DateTimeFormat('en', {
		month: 'short',
		day: '2-digit',
	}).format(date);
}
---

<MagazineShell title={SITE_TITLE} description={SITE_DESCRIPTION} className="home-index-layout">
	<section class="home-index" aria-labelledby="home-title">
		<div class="home-statement">
			<h1 id="home-title">
				<span>Do the right thing.</span>
				<span>Do things right.</span>
			</h1>
		</div>

		<div class="home-board">
			<section class="home-latest" aria-labelledby="home-latest-title">
				<div class="home-latest__head">
					<h2 id="home-latest-title" class="home-latest__title">Latest</h2>
				</div>

				<div class="home-latest__panel">
					{featuredPost && (
						<a href={getPostHref(featuredPost)} class="home-post home-post--featured">
							<span class="home-post__meta">
								<time datetime={featuredPost.data.pubDate.toISOString()}>{formatPostDate(featuredPost.data.pubDate)}</time>
								{getPostTopic(featuredPost) && <span>{getPostTopic(featuredPost)}</span>}
							</span>
							<span class="home-post__body">
								<strong>{featuredPost.data.title}</strong>
								{getPostSummary(featuredPost) && <span class="home-post__summary">{getPostSummary(featuredPost)}</span>}
							</span>
						</a>
					)}

					{morePosts.length > 0 && (
						<div class="home-latest__more">
							{morePosts.map((post) => (
								<a href={getPostHref(post)} class="home-post home-post--compact">
									<span class="home-post__meta">
										<time datetime={post.data.pubDate.toISOString()}>{formatPostDate(post.data.pubDate)}</time>
										{getPostTopic(post) && <span>{getPostTopic(post)}</span>}
									</span>
									<span class="home-post__body">
										<strong>{post.data.title}</strong>
										{getPostSummary(post) && <span>{getPostSummary(post)}</span>}
									</span>
								</a>
							))}
						</div>
					)}
				</div>
			</section>

			<nav class="home-entry-list" aria-label="专题入口">
				<div class="home-entry-list__head">
					<h2 class="home-entry-list__title">Index</h2>
				</div>
				<div class="home-entry-list__items">
					{secondaryEntryLinks.map((item) => (
						<a href={item.href} class="home-secondary-link" title={item.title}>
							<span>{item.label}</span>
							<small>{item.title}</small>
						</a>
					))}
				</div>
			</nav>
		</div>

	</section>
</MagazineShell>

<style>
	.home-index {
		display: flex;
		flex-direction: column;
		gap: clamp(var(--space-md), 2.8vw, var(--space-lg));
		width: 100%;
		padding: clamp(0.2rem, 0.8vw, 0.45rem) 0 clamp(var(--space-2xl), 7vw, var(--space-4xl));
		animation: home-fade-up 0.55s ease-out both;
	}

	.home-statement {
		max-width: none;
	}

	.home-statement h1 {
		display: flex;
		flex-wrap: wrap;
		gap: 0.18rem 0.45rem;
		margin: 0;
		font-family: var(--serif-font);
		font-size: clamp(0.92rem, 1.45vw, 1.04rem);
		font-weight: 500;
		line-height: 1.4;
		letter-spacing: -0.01em;
		color: color-mix(in oklab, var(--heading-color) 72%, var(--gray-color));
		text-wrap: balance;
	}

	.home-statement h1 span {
		display: inline;
	}

	.home-statement h1 span + span::before {
		content: "/";
		margin-right: 0.45rem;
		color: var(--faint-color);
		font-size: 0.82em;
	}

	.home-board {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(9.8rem, 0.34fr);
		align-items: stretch;
		gap: clamp(0.72rem, 1.8vw, 1rem);
		width: 100%;
		min-width: 0;
	}

	.home-latest {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
		width: 100%;
		min-width: 0;
	}

	.home-latest__head {
		display: flex;
		align-items: center;
	}

	.home-latest__title {
		margin: 0;
		font-family: var(--field-font);
		font-size: 0.7rem;
		font-weight: 600;
		letter-spacing: 0.05em;
		line-height: 1.35;
		color: var(--gray-color);
	}

	.home-latest__panel {
		display: grid;
		grid-template-columns: minmax(0, 1.18fr) minmax(11rem, 0.82fr);
		min-height: clamp(20.5rem, 34vw, 23rem);
		min-width: 0;
		overflow: hidden;
		border: 1px solid var(--paper-card-border-soft);
		border-radius: var(--paper-card-radius);
		background: var(--paper-card-bg);
		box-shadow:
			0 1px 2px rgba(15, 23, 42, 0.032),
			0 10px 24px rgba(15, 23, 42, 0.032);
	}

	.home-post {
		min-width: 0;
		color: inherit;
		text-decoration: none;
		background: transparent !important;
		border-bottom: none !important;
		transition:
			background 0.2s ease,
			color 0.2s ease;
	}

	.home-post:hover {
		background: color-mix(in oklab, var(--accent-soft-bg) 34%, transparent) !important;
	}

	.home-post--featured {
		display: flex;
		flex-direction: column;
		justify-content: flex-start;
		gap: clamp(1rem, 2.4vw, 1.45rem);
		min-height: 100%;
		padding: clamp(1.15rem, 2.6vw, 1.42rem) clamp(1.05rem, 2.4vw, 1.34rem);
	}

	.home-post__meta {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.35rem 0.55rem;
		color: var(--gray-color);
		font-family: var(--field-font);
		font-size: 0.68rem;
		font-weight: 600;
		letter-spacing: 0.035em;
		line-height: 1.35;
	}

	.home-post__meta span::before {
		content: "";
		display: inline-block;
		width: 3px;
		height: 3px;
		margin-right: 0.55rem;
		border-radius: 999px;
		background: currentColor;
		opacity: 0.42;
		vertical-align: 0.12em;
	}

	.home-post--featured .home-post__body {
		display: flex;
		flex-direction: column;
		gap: 0.62rem;
		margin-top: auto;
	}

	.home-post--featured .home-post__body strong {
		display: block;
		margin-top: 0;
		color: var(--heading-color);
		font-family: var(--serif-font);
		font-size: clamp(1.12rem, 2.35vw, 1.32rem);
		font-weight: 500;
		letter-spacing: -0.01em;
		line-height: 1.28;
		transition: color 0.2s ease;
	}

	.home-post--featured:hover strong,
	.home-post--compact:hover strong {
		color: color-mix(in oklab, var(--accent-color) 32%, var(--heading-color));
	}

	.home-post__summary {
		display: -webkit-box;
		width: 100%;
		max-width: 100%;
		margin-top: 0.62rem;
		overflow: hidden;
		overflow-wrap: anywhere;
		word-break: break-word;
		color: color-mix(in oklab, var(--text-color) 72%, var(--gray-color));
		font-family: var(--serif-font);
		font-size: 0.84rem;
		line-height: 1.62;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 3;
	}

	.home-post--featured .home-post__summary {
		margin-top: 0;
		font-size: 0.84rem;
		line-height: 1.62;
		-webkit-line-clamp: 3;
	}

	.home-latest__more {
		display: grid;
		align-content: stretch;
		min-width: 0;
		border-left: 1px solid var(--paper-card-border-soft);
	}

	.home-post--compact {
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 0.48rem;
		min-width: 0;
		padding: 0.95rem clamp(0.88rem, 2vw, 1.08rem);
	}

	.home-post--compact + .home-post--compact {
		border-top: 1px solid color-mix(in oklab, var(--paper-card-border-soft) 58%, transparent) !important;
	}

	.home-post--compact .home-post__meta {
		font-size: 0.64rem;
		letter-spacing: 0.03em;
	}

	.home-post--compact time {
		color: var(--gray-color);
		font-family: var(--field-font);
		font-weight: 600;
		font-variant-numeric: tabular-nums;
		white-space: nowrap;
	}

	.home-post__body {
		display: flex;
		flex-direction: column;
		gap: 0.24rem;
		min-width: 0;
	}

	.home-post__body strong {
		overflow-wrap: anywhere;
		color: var(--heading-color);
		font-family: var(--serif-font);
		font-size: 0.94rem;
		font-weight: 500;
		letter-spacing: -0.006em;
		line-height: 1.35;
		transition: color 0.2s ease;
	}

	.home-post__body span {
		display: -webkit-box;
		min-width: 0;
		overflow: hidden;
		overflow-wrap: anywhere;
		color: color-mix(in oklab, var(--text-color) 72%, var(--gray-color));
		font-family: var(--serif-font);
		font-size: 0.8rem;
		font-weight: 400;
		letter-spacing: 0.002em;
		line-height: 1.6;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 2;
	}

	.home-entry-list {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
		width: 100%;
		min-width: 0;
	}

	.home-entry-list__head {
		display: flex;
		align-items: center;
		min-height: 1.35rem;
	}

	.home-entry-list__title {
		margin: 0;
		font-family: var(--field-font);
		font-size: 0.7rem;
		font-weight: 600;
		letter-spacing: 0.05em;
		line-height: 1.35;
		color: var(--gray-color);
	}

	.home-entry-list__items {
		display: grid;
		grid-template-rows: repeat(5, minmax(0, 1fr));
		align-items: stretch;
		gap: 0.52rem;
		width: 100%;
		min-width: 0;
		flex: 1;
	}

	.home-secondary-link {
		display: inline-flex;
		flex-direction: column;
		align-items: flex-start;
		justify-content: center;
		gap: 0.22rem;
		box-sizing: border-box;
		width: 100%;
		min-width: 0;
		min-height: 0;
		padding: 0.66rem 0.72rem;
		border: 1px solid var(--paper-card-border-soft);
		border-radius: var(--paper-card-radius);
		color: color-mix(in oklab, var(--text-color) 62%, var(--gray-color));
		font-family: var(--field-font);
		font-size: 0.7rem;
		font-weight: 500;
		letter-spacing: 0.025em;
		line-height: 1.35;
		text-decoration: none;
		background: var(--paper-card-bg) !important;
		box-shadow: 0 1px 2px rgba(15, 23, 42, 0.018);
		transition:
			border-color 0.2s ease,
			background 0.2s ease,
			color 0.2s ease,
			transform 0.2s ease;
	}

	.home-secondary-link span,
	.home-secondary-link small {
		display: block;
	}

	.home-secondary-link small {
		color: var(--gray-color);
		font-family: var(--ui-font);
		font-size: 0.62rem;
		font-weight: 400;
		letter-spacing: 0.01em;
		line-height: 1.35;
		opacity: 0.78;
	}

	.home-secondary-link:hover {
		border-color: var(--paper-hover-border);
		color: color-mix(in oklab, var(--accent-color) 42%, var(--heading-color));
		background: color-mix(in oklab, var(--accent-soft-bg) 36%, var(--paper-card-bg)) !important;
		transform: translateY(-1px);
	}

	@keyframes home-fade-up {
		from {
			opacity: 0;
			transform: translateY(12px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (max-width: 760px) {
		.home-index,
		.home-board,
		.home-latest,
		.home-latest__panel,
		.home-post {
			max-width: 100%;
			overflow-x: hidden;
		}

		.home-board {
			grid-template-columns: 1fr;
		}

		.home-latest {
			width: 100%;
		}

		.home-latest__panel {
			display: flex;
			flex-direction: column;
			grid-template-columns: 1fr;
			width: min(100%, calc(100vw - 2 * var(--space-lg)));
			max-width: calc(100vw - 2 * var(--space-lg));
			min-height: 0;
		}

		.home-post--featured {
			justify-content: flex-end;
			min-height: 9.5rem;
			padding-inline: clamp(0.9rem, 5vw, 1.08rem);
		}

		.home-latest__more {
			border-top: 1px solid var(--paper-card-border-soft);
			border-left: 0;
		}

		.home-post--compact {
			display: flex;
			flex-direction: column;
			align-items: stretch;
			padding-inline: clamp(0.9rem, 5vw, 1.08rem);
		}

		.home-post__summary,
		.home-post__body span {
			width: auto;
			max-width: calc(100vw - 2 * var(--space-lg) - 2.16rem);
			white-space: normal;
			word-break: break-all;
		}

		.home-entry-list__items {
			grid-template-columns: repeat(3, minmax(0, 1fr));
			grid-template-rows: none;
		}
	}

	@media (max-width: 520px) {
		.home-index {
			gap: var(--space-lg);
		}

		.home-statement h1 {
			font-size: 1.04rem;
		}

		.home-entry-list__items {
			grid-template-columns: minmax(0, 1fr);
			gap: 0.48rem;
		}

		.home-post--compact {
			gap: 0.18rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.home-index {
			animation: none;
		}

		.home-secondary-link,
		.home-post,
		.home-post--featured strong,
		.home-post--compact strong {
			transition: none;
		}
	}
</style>
