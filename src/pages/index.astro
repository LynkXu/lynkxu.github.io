---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import HeaderLink from '../components/HeaderLink.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { INCLUDE_DRAFTS, filterDrafts } from '../utils/drafts';

// 获取最新的博客文章（显示前8篇）
// 排除英文文章（en/ 前缀），英文文章只在 /en 下展示
const allPosts = filterDrafts(await getCollection('blog')).filter((post) => !post.id.startsWith('en/'));
const recentPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 5);

function getPostExcerpt(body = '', length = 150) {
	const text = body
		.replace(/```[\s\S]*?```/g, ' ')
		.replace(/^#{1,6}\s+.+$/gm, ' ')
		.replace(/<[^>]+>/g, ' ')
		.replace(/!\[[^\]]*\]\([^)]+\)/g, ' ')
		.replace(/\[[^\]]+\]\([^)]+\)/g, (match) => match.match(/\[([^\]]+)\]/)?.[1] ?? '')
		.replace(/[#>*_`~\-\u003c\u003e]/g, ' ')
		.replace(/\s+/g, ' ')
		.trim();

	return text.length > length ? `${text.slice(0, length).trim()}…` : text;
}

// 统计标签（同 tags 页风格）
const tagsMap = new Map<string, number>();
allPosts.forEach((post) => {
	(post.data.tags || []).forEach((tag) => {
		tagsMap.set(tag, (tagsMap.get(tag) || 0) + 1);
	});
});
const sortedTags = Array.from(tagsMap.entries()).sort((a, b) => b[1] - a[1]);
const featuredTags = sortedTags.slice(0, 8);
---

<Base title={SITE_TITLE} description={SITE_DESCRIPTION} className="blog-surface-layout">
	<div class="content-limit-width asym-layout">
		<section class='home-hero' aria-labelledby='home-title'>
			<div class="hero-left">
				<p class='home-kicker'>
					<span class="home-kicker__line">notebook</span>
					<span class="home-kicker__line home-kicker__line--muted">notes</span>
				</p>
			</div>
			<div class="hero-right">
				<h1 id='home-title'>Notes on input, output, and the road between.</h1>
			</div>
		</section>

		<section class='thought-stream' aria-labelledby='thought-stream-title'>
			<div class='section-heading'>
				<div>
					<h2 id='thought-stream-title'>Recent Posts</h2>
				</div>
				<HeaderLink class="view-all" href='/blog'>All Posts →</HeaderLink>
			</div>
			<div class="stream-list paper-ledger">
				{
					recentPosts.map((post) => (
						<article class='stream-card'>
							<div class='stream-meta'>
								<FormattedDate date={post.data.pubDate} />
							</div>
							<div class='stream-body'>
								<h3>
									<a href={`/blog/${post.data.slug ?? post.id}.html`} transition:name={`post-title-${post.id}`}>
										{post.data.title}
									</a>
								</h3>
								{post.data.description ? (
									<p>{post.data.description}</p>
								) : (
									<p>{getPostExcerpt(post.body, 90)}</p>
								)}
								{INCLUDE_DRAFTS && post.data.draft && <span class="draft-badge" aria-label="Draft">Draft</span>}
							</div>
						</article>
					))
				}
			</div>
		</section>

		{sortedTags.length > 0 && (
			<section class='home-tags'>
			<div class='section-heading'>
				<div>
					<h2 class='indextitle'>Tags</h2>
					</div>
				{sortedTags.length > featuredTags.length && (
					<HeaderLink class="view-all" href='/tags/'>All Tags →</HeaderLink>
				)}
				</div>
				<div class='tags'>
					{featuredTags.map(([tag, count]) => (
						<a href={`/tags/${tag}/`}>
							<span class="tag-prefix">#</span>
							<span class="tag-name">{tag}</span>
							<span class="tag-count">{count}</span>
						</a>
					))}
				</div>
			</section>
		)}
	</div>

	<style>
		.asym-layout {
			display: flex;
			flex-direction: column;
			gap: clamp(2.5rem, 6vw, 3.5rem);
			padding-top: 0.5rem;
		}

		.home-hero, .thought-stream, .home-tags {
			display: flex;
			flex-direction: column;
			gap: 1.25rem;
		}

		.home-hero {
			padding: clamp(1.35rem, 4vw, 2rem) clamp(1.35rem, 4vw, 2rem) clamp(1.2rem, 3vw, 1.65rem);
		}

		.home-kicker,
		.section-eyebrow {
			margin: 0 0 0.75rem;
			color: var(--gray-color);
			font-size: 0.72rem;
			letter-spacing: 0.14em;
			text-transform: uppercase;
			line-height: 1.45;
		}

		.home-kicker {
			display: inline-flex;
			flex-direction: column;
			gap: 0.35rem;
			padding: 0;
			border: none;
			background: transparent;
		}

		.home-kicker__line {
			display: block;
			white-space: nowrap;
		}

		.home-kicker__line:first-child {
			color: var(--ink-accent);
			opacity: 0.88;
		}

		.home-kicker__line--muted {
			letter-spacing: 0.12em;
			opacity: 0.68;
		}

		.home-hero h1 {
			max-width: 16em;
			margin: 0;
			color: var(--panel-title-color);
			font-size: clamp(1.55rem, 4vw, 2.15rem);
			font-weight: 500;
			line-height: 1.28;
			letter-spacing: -0.012em;
			position: relative;
			z-index: 1;
		}

		.section-heading {
			display: flex;
			align-items: baseline;
			justify-content: space-between;
			gap: 1rem;
		}

		.section-heading h2, .indextitle {
			margin: 0;
		}

		.view-all {
			color: var(--gray-color);
			font-family: var(--field-font);
			font-size: 0.72rem;
			letter-spacing: 0.08em;
			text-transform: uppercase;
			text-decoration: none;
			border: none;
			background: transparent;
			padding: 0;
			transition: color 0.2s ease;
		}

		.view-all:hover {
			color: color-mix(in oklab, var(--ink-accent) 55%, var(--heading-color));
			border-color: transparent;
			transform: none;
		}

		.stream-list {
			display: flex;
			flex-direction: column;
			gap: 0;
		}

		.stream-card {
			display: grid;
			grid-template-columns: 6.2rem minmax(0, 1fr);
			gap: clamp(0.95rem, 2.4vw, 1.2rem);
			padding: clamp(0.95rem, 2.8vw, 1.18rem) clamp(1rem, 3vw, 1.25rem);
			transition: background-color 0.2s ease;
		}

		.stream-card:first-child {
			padding-top: clamp(1.05rem, 3vw, 1.3rem);
		}

		.stream-meta {
			color: var(--gray-color);
			font-family: var(--field-font);
			font-size: 0.7rem;
			letter-spacing: 0.02em;
			padding-top: 0.15rem;
			white-space: nowrap;
			transition: color 0.2s ease;
			font-variant-numeric: tabular-nums;
		}

		.stream-card:hover .stream-meta {
			color: color-mix(in oklab, var(--ink-accent) 52%, var(--gray-color));
		}

		.stream-card h3 {
			margin: 0 0 0.35rem;
			font-size: 1.02rem;
			font-weight: 560;
			line-height: 1.42;
			letter-spacing: -0.01em;
		}

		.stream-card h3 a {
			color: var(--heading-color);
			text-decoration: none;
			border-bottom: 1px solid transparent;
			transition: color 0.2s ease;
		}

		.stream-card h3 a:hover {
			color: color-mix(in oklab, var(--ink-accent) 48%, var(--heading-color));
			border-bottom-color: color-mix(in oklab, var(--ink-accent) 35%, transparent);
		}

		.stream-card p {
			margin: 0;
			color: var(--text-color);
			font-size: 0.93rem;
			line-height: 1.65;
			opacity: 0.84;
		}

		.tags {
			display: flex;
			flex-wrap: wrap;
			align-items: baseline;
			gap: 0;
			row-gap: 0.35rem;
		}

		.tags a {
			display: inline-flex;
			align-items: baseline;
			gap: 0.18rem;
			padding: 0.12rem 0;
			font-size: 0.86rem;
			color: var(--text-color);
			text-decoration: none;
			border: none;
			background: transparent;
			transition: color 0.2s ease;
		}

		.tags a:hover {
			color: color-mix(in oklab, var(--ink-accent) 42%, var(--heading-color));
		}

		.tags a + a::before {
			content: "·";
			margin: 0 0.55rem 0 0.35rem;
			color: var(--gray-color);
			opacity: 0.45;
			pointer-events: none;
		}

		.tags a .tag-prefix {
			color: var(--gray-color);
			opacity: 0.5;
			margin-right: 0;
			transition: all 0.2s ease;
		}

		.tags a .tag-count {
			color: var(--gray-color);
			font-size: 0.75rem;
			margin-left: 0.3rem;
			transition: all 0.2s ease;
		}

		.tags a:hover .tag-prefix,
		.tags a:hover .tag-count {
			color: color-mix(in oklab, var(--ink-accent) 48%, var(--heading-color));
			opacity: 0.85;
		}

		.home-tags {
			margin-top: 0;
			margin-bottom: 2rem;
		}

		@media (min-width: 768px) {
			.home-hero, .thought-stream, .home-tags {
				display: grid;
				grid-template-columns: 120px 1fr;
				gap: clamp(2rem, 5vw, 3.5rem);
				align-items: baseline;
			}

			.home-hero {
				align-items: center;
			}

			.home-hero h1 {
				max-width: 16.5em;
				font-size: clamp(1.95rem, 3vw, 2.15rem);
				line-height: 1.16;
			}

			.section-heading {
				flex-direction: column;
				align-items: flex-start;
				gap: 1.5rem;
				position: sticky;
				top: 2rem;
			}
		}

		@media (max-width: 640px) {
			.stream-card {
				grid-template-columns: 1fr;
				gap: 0.45rem;
			}

			.stream-meta {
				padding-top: 0;
			}
		}
	</style>
</Base>
