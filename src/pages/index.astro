---
import { getCollection } from 'astro:content';
import MagazineShell from '../layouts/MagazineShell.astro';
import ListingFrame from '../components/ListingFrame.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { filterDrafts } from '../utils/drafts';

const latestPosts = filterDrafts(await getCollection('blog'))
	.filter((post) => !post.id.startsWith('en/'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 4);

function getPostHref(post: (typeof latestPosts)[number]) {
	return `/blog/${post.data.slug ?? post.id}.html`;
}

function getPostSummary(post: (typeof latestPosts)[number]) {
	const rawSummary = post.data.description || post.body || '';
	const plainSummary = rawSummary
		.replace(/```[\s\S]*?```/g, ' ')
		.replace(/!\[[^\]]*]\([^)]+\)/g, ' ')
		.replace(/\[([^\]]+)]\([^)]+\)/g, '$1')
		.replace(/[#>*_`~-]/g, ' ')
		.replace(/\s+/g, ' ')
		.trim();

	if (plainSummary) {
		return plainSummary.length > 56 ? `${plainSummary.slice(0, 56).trim()}…` : plainSummary;
	}

	return post.data.tags?.slice(0, 2).join(' · ') || '';
}

function formatPostDate(date: Date) {
	return new Intl.DateTimeFormat('en', {
		month: 'short',
		day: '2-digit',
	}).format(date);
}
---

<MagazineShell title={SITE_TITLE} description={SITE_DESCRIPTION} className="home-index-layout">
	<ListingFrame eyebrow="Front page" title="Do the right thing. / Do things right." bodyWidth="40rem">
		<div class="home-board">
			<section class="home-latest" aria-labelledby="home-latest-title">
				<div class="home-latest__head">
					<h2 id="home-latest-title" class="home-latest__title">Latest</h2>
				</div>

				<div class="home-latest__items">
					{latestPosts.map((post) => (
						<a href={getPostHref(post)} class="home-latest-card" title={post.data.title}>
							<span class="home-latest-card__title">{post.data.title}</span>
							{getPostSummary(post) && (
								<span class="home-latest-card__summary">{getPostSummary(post)}</span>
							)}
							<small>{formatPostDate(post.data.pubDate)}</small>
						</a>
					))}
				</div>
			</section>

		</div>
	</ListingFrame>
</MagazineShell>

<style>
	.home-board {
		display: flex;
		flex-direction: column;
		gap: clamp(var(--space-xl), 4vw, var(--space-2xl));
		width: 100%;
		min-width: 0;
		animation: home-fade-up 0.55s ease-out 0.12s both;
	}

	.home-latest {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
		width: 100%;
		min-width: 0;
	}

	.home-latest__head {
		display: flex;
		align-items: center;
		min-height: 1.35rem;
	}

	.home-latest__title {
		margin: 0;
		font-family: var(--field-font);
		font-size: 0.7rem;
		font-weight: 600;
		letter-spacing: 0.05em;
		line-height: 1.35;
		color: var(--gray-color);
	}

	.home-latest__items {
		display: grid;
		grid-template-rows: repeat(4, minmax(0, 1fr));
		align-items: stretch;
		gap: var(--space-xs);
		position: relative;
		width: 100%;
		min-width: 0;
		flex: 1;
	}

	.home-latest__items::after {
		content: none;
	}

	.home-latest-card {
		display: inline-flex;
		flex-direction: column;
		align-items: flex-start;
		justify-content: center;
		gap: 0.22rem;
		box-sizing: border-box;
		width: 100%;
		min-width: 0;
		min-height: 0;
		padding: 0.64rem 0.82rem;
		border: 1px solid var(--paper-card-border-soft);
		border-radius: var(--paper-card-radius);
		color: var(--heading-color);
		font-family: var(--serif-font);
		font-size: 0.9rem;
		font-weight: 500;
		letter-spacing: -0.003em;
		line-height: 1.36;
		text-decoration: none;
		background: var(--paper-card-bg) !important;
		box-shadow: 0 1px 2px rgba(15, 23, 42, 0.018);
		transition:
			border-color 0.2s ease,
			background 0.2s ease,
			color 0.2s ease,
			transform 0.2s ease;
	}

	.home-latest-card__title {
		display: block;
		width: 100%;
		min-width: 0;
		overflow-wrap: anywhere;
	}

	.home-latest-card__summary {
		display: -webkit-box;
		-webkit-box-orient: vertical;
		-webkit-line-clamp: 1;
		overflow: hidden;
		width: 100%;
		min-width: 0;
		font-family: var(--ui-font);
		font-size: 0.7rem;
		font-weight: 400;
		letter-spacing: 0;
		line-height: 1.5;
		color: color-mix(in oklab, var(--text-color) 65%, var(--gray-color));
		overflow-wrap: anywhere;
	}

	.home-latest-card small {
		display: block;
		width: 100%;
		min-width: 0;
		color: color-mix(in oklab, var(--gray-color) 72%, var(--paper-bg));
		font-family: var(--field-font);
		font-size: 0.58rem;
		font-weight: 400;
		letter-spacing: 0.02em;
		line-height: 1.35;
		opacity: 0.55;
	}

	.home-latest-card:hover .home-latest-card__summary {
		color: color-mix(in oklab, var(--text-color) 80%, var(--gray-color));
	}

	.home-latest-card:hover {
		border-color: var(--paper-hover-border);
		color: color-mix(in oklab, var(--accent-color) 42%, var(--heading-color));
		background: color-mix(in oklab, var(--accent-soft-bg) 36%, var(--paper-card-bg)) !important;
		transform: translateY(-1px);
	}

	@keyframes home-fade-up {
		from {
			opacity: 0;
			transform: translateY(12px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	@media (max-width: 760px) {
		.home-board,
		.home-latest {
			max-width: 100%;
			overflow-x: hidden;
		}

		.home-latest {
			width: 100%;
		}

		.home-latest__items {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			grid-template-rows: none;
		}

	}

	@media (max-width: 520px) {
		.home-latest__items {
			grid-template-columns: minmax(0, 1fr);
			gap: 0.48rem;
		}

	}

	@media (prefers-reduced-motion: reduce) {
		.home-board {
			animation: none;
		}

		.home-latest-card {
			transition: none;
		}
	}
</style>
