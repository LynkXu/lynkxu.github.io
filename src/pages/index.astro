---
import { getCollection } from 'astro:content';
import MagazineShell from '../layouts/MagazineShell.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { INCLUDE_DRAFTS, filterDrafts } from '../utils/drafts';

const allPosts = filterDrafts(await getCollection('blog')).filter((post) => !post.id.startsWith('en/'));
const recentPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 6);

function getPostExcerpt(body = '', length = 150) {
	const text = body
		.replace(/```[\s\S]*?```/g, ' ')
		.replace(/^#{1,6}\s+.+$/gm, ' ')
		.replace(/<[^>]+>/g, ' ')
		.replace(/!\[[^\]]*\]\([^)]+\)/g, ' ')
		.replace(/\[[^\]]+\]\([^)]+\)/g, (match) => match.match(/\[([^\]]+)\]/)?.[1] ?? '')
		.replace(/[#>*_`~\-\u003c\u003e]/g, ' ')
		.replace(/\s+/g, ' ')
		.trim();

	return text.length > length ? `${text.slice(0, length).trim()}…` : text;
}

const tagsMap = new Map<string, number>();
allPosts.forEach((post) => {
	(post.data.tags || []).forEach((tag) => {
		tagsMap.set(tag, (tagsMap.get(tag) || 0) + 1);
	});
});
const sortedTags = Array.from(tagsMap.entries()).sort((a, b) => b[1] - a[1]);
const featuredTopics = sortedTags.slice(0, 10);
---

<MagazineShell title={SITE_TITLE} description={SITE_DESCRIPTION}>
	<!-- Hero -->
	<!-- <section class="home-hero" aria-label="Welcome">
		<div class="hero-inner">
			<h1 class="hero-title">👋 I am Lynk</h1>
			<p class="hero-role">Fullstack Engineer</p>
			<p class="hero-desc">生活需要被记录</p>
		</div>
	</section> -->

	<!-- Recent posts heading -->
	<h2 id="recent-heading" class="section-heading">Recent</h2>

	<!-- Featured -->
	{
		recentPosts[0] && (
			<article class="bento-card bento-featured">
				<a
					href={`/blog/${recentPosts[0].data.slug ?? recentPosts[0].id}.html`}
					class="card-link"
					transition:name={`post-title-${recentPosts[0].id}`}
				>
					<div class="card-meta">
						<FormattedDate date={recentPosts[0].data.pubDate} />
						{recentPosts[0].data.tags && recentPosts[0].data.tags[0] && (
							<span class="card-tag">{recentPosts[0].data.tags[0]}</span>
						)}
					</div>
					<h3 class="card-title">{recentPosts[0].data.title}</h3>
					<p class="card-excerpt">
						{recentPosts[0].data.description || getPostExcerpt(recentPosts[0].body, 120)}
					</p>
					{INCLUDE_DRAFTS && recentPosts[0].data.draft && (
						<span class="draft-badge" aria-label="Draft">Draft</span>
					)}
				</a>
			</article>
		)
	}

	<!-- Medium cards (2) -->
	<div class="bento-row bento-row-medium">
		{
			recentPosts.slice(1, 3).map((post) => (
				<article class="bento-card">
					<a
						href={`/blog/${post.data.slug ?? post.id}.html`}
						class="card-link"
						transition:name={`post-title-${post.id}`}
					>
						<div class="card-meta">
							<FormattedDate date={post.data.pubDate} />
							{post.data.tags && post.data.tags[0] && (
								<span class="card-tag">{post.data.tags[0]}</span>
							)}
						</div>
						<h3 class="card-title">{post.data.title}</h3>
						<p class="card-excerpt">{post.data.description || getPostExcerpt(post.body, 45)}</p>
						{INCLUDE_DRAFTS && post.data.draft && (
							<span class="draft-badge" aria-label="Draft">Draft</span>
						)}
					</a>
				</article>
			))
		}
	</div>

	<!-- Small cards (3) -->
	<div class="bento-row bento-row-small">
		{
			recentPosts.slice(3, 6).map((post) => (
				<article class="bento-card">
					<a
						href={`/blog/${post.data.slug ?? post.id}.html`}
						class="card-link"
						transition:name={`post-title-${post.id}`}
					>
						<div class="card-meta">
							<FormattedDate date={post.data.pubDate} />
							{post.data.tags && post.data.tags[0] && (
								<span class="card-tag">{post.data.tags[0]}</span>
							)}
						</div>
						<h3 class="card-title">{post.data.title}</h3>
						<p class="card-excerpt">{post.data.description || getPostExcerpt(post.body, 35)}</p>
						{INCLUDE_DRAFTS && post.data.draft && (
							<span class="draft-badge" aria-label="Draft">Draft</span>
						)}
					</a>
				</article>
			))
		}
	</div>

	<!-- Topics -->
	{
		featuredTopics.length > 0 && (
			<section class="home-topics" aria-labelledby="topics-heading">
				<h2 id="topics-heading" class="topics-heading">Topics</h2>
				<div class="topics-row">
					{featuredTopics.map(([tag, count]) => (
						<a href={`/tags/${tag}/`} class="topic-pill">
							<span class="topic-name">{tag}</span>
							<span class="topic-count">{count}</span>
						</a>
					))}
				</div>
			</section>
		)
	}
</MagazineShell>

<style>
	/* ── Hero ── */
	.home-hero {
		position: relative;
		border: 1px solid var(--paper-card-border-soft);
		border-radius: var(--paper-card-radius);
		background:
			linear-gradient(180deg, color-mix(in oklab, var(--accent-soft-bg) 35%, var(--paper-card-bg)) 0%, var(--paper-card-bg) 100%);
		box-shadow: var(--paper-card-shadow);
		overflow: hidden;
		animation: fade-up 0.6s ease-out both;
	}

	.home-hero::before {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 2px;
		background: color-mix(in oklab, var(--ink-accent) 40%, transparent);
		opacity: 0.45;
	}

	.hero-inner {
		padding: clamp(1.5rem, 3.6vw, 2.2rem) clamp(1.2rem, 3vw, 1.8rem);
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
	}

	.hero-title {
		margin: 0;
		font-family: var(--serif-font);
		font-size: clamp(1.35rem, 2.4vw, 1.75rem);
		font-weight: 500;
		color: var(--panel-title-color);
		letter-spacing: -0.018em;
		line-height: 1.2;
	}

	.hero-role {
		margin: 0;
		font-family: var(--field-font);
		font-size: 0.82rem;
		color: var(--gray-color);
		letter-spacing: 0.01em;
	}

	.hero-desc {
		margin: 0.35rem 0 0;
		font-size: clamp(0.9rem, 1.2vw, 0.98rem);
		color: color-mix(in oklab, var(--gray-color) 55%, var(--text-color));
		line-height: 1.6;
		max-width: 48ch;
	}

	/* ── Section headings ── */
	.section-heading {
		margin: 0;
		font-family: var(--serif-font);
		font-size: var(--text-lg);
		font-weight: 500;
		color: var(--heading-color);
		letter-spacing: -0.01em;
		animation: fade-up 0.5s ease-out 0.08s both;
	}

	/* ── Bento Cards ── */
	.bento-card {
		position: relative;
		border: 1px solid var(--paper-card-border-soft);
		border-radius: var(--paper-card-radius);
		background: var(--paper-card-bg);
		box-shadow: var(--paper-card-shadow);
		transition:
			transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1),
			background-color 0.2s ease,
			border-color 0.2s ease;
		overflow: hidden;
	}

	.bento-card:hover {
		transform: translateY(-2px);
		border-color: color-mix(in oklab, var(--accent-color) 12%, var(--paper-card-border-soft));
		background: color-mix(in oklab, var(--accent-soft-bg) 30%, var(--paper-card-bg));
	}

	.card-link {
		display: flex;
		flex-direction: column;
		height: 100%;
		padding: clamp(1rem, 2.4vw, 1.3rem);
		color: inherit;
		text-decoration: none;
		border-bottom: none !important;
		background: none !important;
	}

	.card-meta {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		font-family: var(--field-font);
		font-size: 0.72rem;
		color: var(--gray-color);
		letter-spacing: 0.015em;
		line-height: 1;
	}

	.card-tag {
		display: inline-flex;
		align-items: center;
		padding: 0.18em 0.55em;
		background: color-mix(in oklab, var(--accent-soft-bg) 60%, var(--paper-card-bg));
		border: 1px solid color-mix(in oklab, var(--accent-color) 10%, var(--paper-card-border-soft));
		border-radius: 3px;
		font-size: 0.68rem;
		color: color-mix(in oklab, var(--accent-color) 50%, var(--gray-color));
		letter-spacing: 0.01em;
	}

	.card-title {
		margin: 0;
		font-family: var(--serif-font);
		font-weight: 500;
		color: var(--heading-color);
		letter-spacing: -0.01em;
		transition: color 0.2s ease;
	}

	.bento-card:hover .card-title {
		color: color-mix(in oklab, var(--accent-color) 38%, var(--heading-color));
	}

	.card-excerpt {
		margin: 0;
		color: var(--text-color);
		display: -webkit-box;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	/* ── Featured ── */
	.bento-featured .card-title {
		font-size: clamp(1.1rem, 1.7vw, 1.32rem);
		line-height: 1.28;
		margin: 0.5rem 0 0.55rem;
	}

	.bento-featured .card-excerpt {
		font-size: 0.9rem;
		line-height: 1.65;
		opacity: 0.82;
		-webkit-line-clamp: 2;
	}

	/* ── Medium row ── */
	.bento-row-medium {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--blog-card-gap);
	}

	.bento-row-medium .card-title {
		font-size: 1.02rem;
		line-height: 1.36;
		margin: 0.5rem 0 0.5rem;
	}

	.bento-row-medium .card-excerpt {
		font-size: 0.88rem;
		line-height: 1.62;
		opacity: 0.78;
		-webkit-line-clamp: 1;
	}

	/* ── Small row ── */
	.bento-row-small {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--blog-card-gap);
	}

	.bento-row-small .card-title {
		font-size: 0.97rem;
		line-height: 1.38;
		margin: 0.45rem 0 0.4rem;
	}

	.bento-row-small .card-excerpt {
		font-size: 0.86rem;
		line-height: 1.58;
		opacity: 0.76;
		-webkit-line-clamp: 1;
	}

	/* ── Draft badge ── */
	.draft-badge {
		display: inline-flex;
		align-items: center;
		margin-top: auto;
		padding-top: 0.6rem;
		font-family: var(--field-font);
		font-size: 0.68rem;
		font-weight: 500;
		color: color-mix(in oklab, var(--color-warning) 65%, var(--gray-color));
		letter-spacing: 0.02em;
	}

	/* ── Topics ── */
	.home-topics {
		display: flex;
		flex-direction: column;
		gap: 0.9rem;
		margin-top: 0.5rem;
	}

	.topics-heading {
		margin: 0;
		font-family: var(--serif-font);
		font-size: var(--text-lg);
		font-weight: 500;
		color: var(--heading-color);
		letter-spacing: -0.01em;
	}

	.topics-row {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.topic-pill {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.4rem 0.72rem;
		font-family: var(--field-font);
		font-size: 0.8rem;
		color: color-mix(in oklab, var(--text-color) 82%, var(--gray-color));
		text-decoration: none;
		border: 1px solid var(--paper-card-border-soft);
		border-radius: var(--paper-card-radius);
		background: var(--paper-field-bg);
		transition:
			transform 0.25s cubic-bezier(0.2, 0.8, 0.2, 1),
			color 0.2s ease,
			background 0.2s ease,
			border-color 0.2s ease;
	}

	.topic-pill:hover {
		transform: translateY(-1px);
		color: color-mix(in oklab, var(--accent-color) 42%, var(--heading-color));
		background: color-mix(in oklab, var(--accent-soft-bg) 55%, var(--paper-field-bg));
		border-color: color-mix(in oklab, var(--accent-color) 16%, var(--paper-card-border-soft));
	}

	.topic-count {
		color: var(--gray-color);
		font-size: 0.72rem;
		font-variant-numeric: tabular-nums;
		opacity: 0.6;
		transition: color 0.2s ease;
	}

	.topic-pill:hover .topic-count {
		color: color-mix(in oklab, var(--accent-color) 44%, var(--heading-color));
		opacity: 0.85;
	}

	/* ── Animations ── */
	@keyframes fade-up {
		from {
			opacity: 0;
			transform: translateY(12px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.bento-featured {
		animation: fade-up 0.6s ease-out 0.08s both;
	}

	.bento-row-medium .bento-card:nth-child(1) {
		animation: fade-up 0.5s ease-out 0.14s both;
	}

	.bento-row-medium .bento-card:nth-child(2) {
		animation: fade-up 0.5s ease-out 0.2s both;
	}

	.bento-row-small .bento-card:nth-child(1) {
		animation: fade-up 0.5s ease-out 0.26s both;
	}

	.bento-row-small .bento-card:nth-child(2) {
		animation: fade-up 0.5s ease-out 0.32s both;
	}

	.bento-row-small .bento-card:nth-child(3) {
		animation: fade-up 0.5s ease-out 0.38s both;
	}

	.home-topics {
		animation: fade-up 0.5s ease-out 0.44s both;
	}

	/* ── Responsive: tablet ── */
	@media (max-width: 1023px) and (min-width: 768px) {
		.bento-row-small {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	/* ── Responsive: mobile ── */
	@media (max-width: 767px) {
		.bento-row-medium,
		.bento-row-small {
			grid-template-columns: 1fr;
		}

		.bento-featured .card-title {
			font-size: 1.12rem;
		}

		.bento-featured .card-excerpt {
			-webkit-line-clamp: 3;
		}
	}

	/* ── Reduced motion ── */
	@media (prefers-reduced-motion: reduce) {
		.bento-card,
		.home-topics {
			animation: none;
		}

		.bento-card,
		.topic-pill {
			transition: none;
		}
	}
</style>
