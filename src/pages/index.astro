---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import HeaderLink from '../components/HeaderLink.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { INCLUDE_DRAFTS, filterDrafts } from '../utils/drafts';

// 获取最新的博客文章（显示前8篇）
// 排除英文文章（en/ 前缀），英文文章只在 /en 下展示
const allPosts = filterDrafts(await getCollection('blog')).filter((post) => !post.id.startsWith('en/'));
const recentPosts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 5);

function getPostExcerpt(body = '', length = 150) {
	const text = body
		.replace(/```[\s\S]*?```/g, ' ')
		.replace(/^#{1,6}\s+.+$/gm, ' ')
		.replace(/<[^>]+>/g, ' ')
		.replace(/!\[[^\]]*\]\([^)]+\)/g, ' ')
		.replace(/\[[^\]]+\]\([^)]+\)/g, (match) => match.match(/\[([^\]]+)\]/)?.[1] ?? '')
		.replace(/[#>*_`~\-\u003c\u003e]/g, ' ')
		.replace(/\s+/g, ' ')
		.trim();

	return text.length > length ? `${text.slice(0, length).trim()}…` : text;
}

// 统计标签（同 tags 页风格）
const tagsMap = new Map<string, number>();
allPosts.forEach((post) => {
	(post.data.tags || []).forEach((tag) => {
		tagsMap.set(tag, (tagsMap.get(tag) || 0) + 1);
	});
});
const sortedTags = Array.from(tagsMap.entries()).sort((a, b) => b[1] - a[1]);
const featuredTopics = sortedTags.slice(0, 8);
---

<Base title={SITE_TITLE} description={SITE_DESCRIPTION} className="blog-surface-layout">
	<div class="content-limit-width asym-layout">
		<section class='home-hero' aria-labelledby='home-title'>
			<div class="hero-copy">
				<p class='home-kicker'>Marginalia</p>
				<h1 id='home-title'>Still making notes in the margins.</h1>
				<p class="home-deck">
					Code, projects, weather reports, and whatever refused to leave quietly.
				</p>
			</div>
		</section>

		<section class='thought-stream' aria-labelledby='thought-stream-title'>
			<div class='section-heading'>
				<div>
					<h2 id='thought-stream-title'>Latest Entries</h2>
				</div>
				<HeaderLink class="view-all" href='/blog'>All Posts →</HeaderLink>
			</div>
			<div class="stream-list paper-ledger">
				{
					recentPosts.map((post) => (
						<article class='stream-card'>
							<div class='stream-meta'>
								<FormattedDate date={post.data.pubDate} />
							</div>
							<div class='stream-body'>
								<h3>
									<a href={`/blog/${post.data.slug ?? post.id}.html`} transition:name={`post-title-${post.id}`}>
										{post.data.title}
									</a>
								</h3>
								{post.data.description ? (
									<p>{post.data.description}</p>
								) : (
									<p>{getPostExcerpt(post.body, 90)}</p>
								)}
								{INCLUDE_DRAFTS && post.data.draft && <span class="draft-badge" aria-label="Draft">Draft</span>}
							</div>
						</article>
					))
				}
			</div>
		</section>

		{featuredTopics.length > 0 && (
			<section class='home-tags'>
			<div class='section-heading'>
				<div>
					<h2 class='indextitle'>Topics</h2>
					</div>
				{sortedTags.length > featuredTopics.length && (
					<HeaderLink class="view-all" href='/tags/'>All Topics →</HeaderLink>
				)}
				</div>
				<div class='tags'>
					{featuredTopics.map(([tag, count]) => (
						<a href={`/tags/${tag}/`}>
							<span class="tag-prefix">#</span>
							<span class="tag-name">{tag}</span>
							<span class="tag-count">{count}</span>
						</a>
					))}
				</div>
			</section>
		)}
	</div>

	<style>
		.asym-layout {
			display: flex;
			flex-direction: column;
			gap: clamp(2.5rem, 6vw, 3.5rem);
			padding-top: 0.5rem;
		}

		.home-hero, .thought-stream, .home-tags {
			display: flex;
			flex-direction: column;
			gap: 1.25rem;
		}

		.home-hero {
			padding: clamp(1.1rem, 3vw, 1.45rem) clamp(1.15rem, 3vw, 1.55rem) clamp(1.05rem, 2.6vw, 1.3rem);
			gap: 0.75rem;
			width: 100%;
		}

		.home-kicker,
		.section-eyebrow {
			margin: 0 0 0.75rem;
			color: var(--gray-color);
			font-size: 0.72rem;
			letter-spacing: 0.03em;
			text-transform: none;
			line-height: 1.45;
		}

		.home-kicker {
			display: inline-flex;
			align-items: center;
			gap: 0.45rem;
			margin-bottom: 0;
			font-family: var(--meta-font);
			font-weight: 500;
			color: color-mix(in oklab, var(--gray-color) 84%, var(--heading-color));
		}

		.home-kicker::before {
			content: "";
			width: 0.38rem;
			height: 0.38rem;
			border-radius: 999px;
			background: color-mix(in oklab, var(--accent-color) 46%, var(--content-bg));
			flex: 0 0 auto;
			opacity: 0.9;
		}

		.hero-copy {
			display: flex;
			flex-direction: column;
			gap: 0.5rem;
			max-width: 38rem;
		}

		.home-hero h1 {
			max-width: 11.5em;
			margin: 0;
			color: var(--panel-title-color);
			font-family: var(--serif-font);
			font-size: clamp(1.72rem, 4.2vw, 2.22rem);
			font-weight: 500;
			line-height: 1.18;
			letter-spacing: -0.024em;
			position: relative;
			z-index: 1;
		}

		.home-deck {
			max-width: 34ch;
			margin: 0;
			color: color-mix(in oklab, var(--text-color) 78%, var(--gray-color));
			font-size: 0.92rem;
			line-height: 1.66;
		}

		.section-heading {
			display: flex;
			align-items: end;
			justify-content: space-between;
			gap: 1rem;
		}

		.section-heading h2, .indextitle {
			margin: 0;
		}

		.view-all {
			color: var(--gray-color);
			font-family: var(--field-font);
			font-size: 0.72rem;
			letter-spacing: 0.04em;
			text-transform: none;
			text-decoration: none;
			border: none;
			background: transparent;
			padding: 0;
			transition: color 0.2s ease;
		}

		.view-all:hover {
			color: color-mix(in oklab, var(--accent-color) 34%, var(--heading-color));
			border-color: transparent;
			transform: none;
		}

		.stream-list {
			display: flex;
			flex-direction: column;
			gap: var(--blog-card-gap);
		}

		.stream-card {
			display: grid;
			grid-template-columns: var(--blog-meta-col) minmax(0, 1fr);
			gap: 1.15rem;
			padding: clamp(1rem, 3vw, 1.25rem);
			transition: background-color 0.2s ease;
		}

		.stream-meta {
			color: var(--gray-color);
			font-size: 0.74rem;
			letter-spacing: 0.02em;
			padding-top: 0.15rem;
			white-space: nowrap;
			transition: color 0.2s ease;
		}

		.stream-card:hover .stream-meta {
			color: color-mix(in oklab, var(--accent-color) 44%, var(--gray-color));
		}

		.stream-card h3 {
			margin: 0 0 0.35rem;
			font-size: 1.08rem;
			font-weight: 600;
			line-height: 1.42;
			letter-spacing: -0.01em;
		}

		.stream-card h3 a {
			color: var(--heading-color);
			text-decoration: none;
			border-bottom: 1px solid transparent;
			transition: color 0.2s ease;
		}

		.stream-card h3 a:hover {
			color: color-mix(in oklab, var(--accent-color) 42%, var(--heading-color));
			border-bottom-color: color-mix(in oklab, var(--accent-color) 26%, transparent);
		}

		.stream-card p {
			margin: 0;
			color: var(--text-color);
			font-size: 0.95rem;
			line-height: 1.65;
			opacity: 0.84;
		}

		.tags {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(8.75rem, 1fr));
			gap: var(--blog-card-gap, 0.75rem);
		}

		.tags a {
			display: inline-flex;
			align-items: baseline;
			justify-content: space-between;
			gap: 0.45rem;
			min-height: 2.55rem;
			padding: 0.58rem 0.72rem;
			font-family: var(--field-font);
			font-size: 0.82rem;
			font-weight: 500;
			letter-spacing: 0.015em;
			color: color-mix(in oklab, var(--text-color) 82%, var(--gray-color));
			text-decoration: none;
			border: 1px solid var(--paper-card-border-soft);
			border-radius: var(--paper-card-radius);
			background: var(--paper-field-bg);
			transition:
				color 0.2s ease,
				background 0.2s ease,
				border-color 0.2s ease;
		}

		.tags a:hover {
			color: color-mix(in oklab, var(--accent-color) 42%, var(--heading-color));
			background: color-mix(in oklab, var(--accent-soft-bg) 55%, var(--paper-field-bg));
			border-color: color-mix(in oklab, var(--accent-color) 16%, var(--paper-card-border-soft));
		}

		.tags a + a::before {
			content: none;
		}

		.tags a .tag-prefix {
			color: var(--gray-color);
			opacity: 0.5;
			margin-right: 0;
			transition: all 0.2s ease;
		}

		.tags a .tag-name {
			flex: 1;
			min-width: 0;
		}

		.tags a .tag-count {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			min-width: 1.35rem;
			color: var(--gray-color);
			font-size: 0.75rem;
			margin-left: 0.3rem;
			font-family: var(--field-font);
			font-variant-numeric: tabular-nums;
			transition: all 0.2s ease;
		}

		.tags a:hover .tag-prefix,
		.tags a:hover .tag-count {
			color: color-mix(in oklab, var(--accent-color) 44%, var(--heading-color));
			opacity: 0.85;
		}

		.home-tags {
			margin-top: 0;
			margin-bottom: 2rem;
		}

		@media (min-width: 768px) {
			.thought-stream,
			.home-tags {
				display: grid;
				grid-template-columns: 120px 1fr;
				gap: clamp(2rem, 5vw, 3.5rem);
				align-items: baseline;
			}

			.home-hero h1 {
				max-width: 12em;
				font-size: clamp(1.96rem, 3vw, 2.28rem);
				line-height: 1.16;
			}

			.section-heading {
				flex-direction: column;
				align-items: flex-start;
				gap: 1.5rem;
				position: sticky;
				top: 2rem;
			}
		}

		@media (max-width: 640px) {
			.stream-card {
				grid-template-columns: 1fr;
				gap: 0.45rem;
			}

			.stream-meta {
				padding-top: 0;
			}
		}
	</style>
</Base>
