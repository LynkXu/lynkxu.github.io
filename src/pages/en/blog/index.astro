---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import { SITE_DESCRIPTION } from '../../../consts';
import { INCLUDE_DRAFTS, filterDrafts } from '../../../utils/drafts';
import { useTranslations } from '../../../i18n/utils';

const t = useTranslations('en');

const posts = filterDrafts(await getCollection('blog'))
    .filter(p => p.id.startsWith('en/'))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Group by year
const postsByYear: Record<number, typeof posts> = {};
posts.forEach((post) => {
	const year = post.data.pubDate.getFullYear();
	if (!postsByYear[year]) {
		postsByYear[year] = [];
	}
	postsByYear[year].push(post);
});

// Sort years desc
const years = Object.keys(postsByYear)
	.map(Number)
	.sort((a, b) => b - a);

function getArchiveDate(date: Date) {
	const month = String(date.getMonth() + 1).padStart(2, '0');
	const day = String(date.getDate()).padStart(2, '0');
	return `${month}.${day}`;
}
---

<Base title={t('nav.blog')} description={SITE_DESCRIPTION}>
	<div class="content-limit-width">
		<section class='archive-hero' aria-labelledby='archive-title'>
			<h1 id='archive-title'>{t('nav.blog')}</h1>
			<p>{posts.length} entries, sorted by year.</p>
		</section>
		<div class='posts-archive'>
			{
				years.map((year) => (
					<div class='year-group'>
						<h3 class='year-title'>{year}</h3>
						<ul class='posts'>
							{postsByYear[year].map((post) => {
								const slug = (post.data.slug ?? post.id).replace(/^en\//, '');
								return (
								<li>
									<span>
										<time datetime={post.data.pubDate.toISOString()}>{getArchiveDate(post.data.pubDate)}</time>
									</span>
									<div>
										<a href={`/en/blog/${slug}.html`} transition:name={`post-title-${post.id}`}>
											{post.data.title}
										</a>
										{INCLUDE_DRAFTS && post.data.draft && <span class="draft-badge" aria-label="Draft">{t('home.draft')}</span>}
									</div>
								</li>
							)})}
						</ul>
					</div>
				))
			}
		</div>
	</div>

	<button class='search-fab' id='search-trigger' type='button' aria-label='Search' title='Search'>
		<svg xmlns='http://www.w3.org/2000/svg' width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'>
			<circle cx='11' cy='11' r='8'></circle>
			<path d='m21 21-4.35-4.35'></path>
		</svg>
	</button>
</Base>

<script is:inline>
	function initSearchTrigger() {
		var searchTrigger = document.getElementById('search-trigger');
		if (searchTrigger) {
			searchTrigger.addEventListener('click', function () {
				if (window.openSearchModal) {
					window.openSearchModal();
				}
			});
		}
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initSearchTrigger);
	} else {
		initSearchTrigger();
	}
</script>

<style>
	.archive-hero {
		margin: 0 0 1.5rem;
		padding: 0.25rem 0 0.5rem;
	}

	.archive-kicker {
		margin: 0 0 0.55rem;
		color: var(--gray-color);
		font-family: ui-monospace, SFMono-Regular, "SF Mono", Menlo, Monaco, Consolas, monospace;
		font-size: 0.72rem;
		letter-spacing: 0.13em;
		text-transform: uppercase;
	}

	.archive-hero h1 {
		margin: 0 0 0.75rem;
		color: var(--heading-color);
		font-size: clamp(1.8rem, 5vw, 2.85rem);
		font-weight: 500;
		line-height: 1.16;
		letter-spacing: -0.055em;
	}

	.archive-hero p:last-child {
		max-width: 38rem;
		margin: 0;
		color: var(--gray-color);
		line-height: 1.6;
	}

	.posts-archive {
		margin-top: 0;
		border-top: 1px solid color-mix(in oklab, var(--gray-color) 14%, transparent);
	}

	.year-group {
		display: grid;
		grid-template-columns: 3.5rem minmax(0, 1fr);
		column-gap: 1.25rem;
		align-items: start;
		padding: 1.25rem 0;
	}

	.year-group + .year-group {
		border-top: 1px solid color-mix(in oklab, var(--gray-color) 8%, transparent);
	}

	.year-title {
		position: sticky;
		top: 1.5rem;
		align-self: start;
		margin: 0;
		color: var(--heading-color);
		font-size: 1.15rem;
		line-height: 1.4;
		font-weight: 600;
		letter-spacing: -0.01em;
	}

	.year-group :global(ul.posts) {
		margin: 0;
		display: grid;
		gap: 0.5rem;
	}

	.year-group :global(ul.posts li) {
		display: grid;
		grid-template-columns: 2.8rem minmax(0, 1fr);
		column-gap: 1.25rem;
		align-items: baseline;
		margin: 0;
		margin-left: 0;
		padding: 0;
		line-height: 1.5;
	}

	.year-group :global(ul.posts li:hover) {
		background: transparent !important;
	}

	.year-group :global(ul.posts li > span) {
		display: block;
		flex: none;
		font-size: 0.85rem;
		color: var(--gray-color);
		font-variant-numeric: tabular-nums;
		font-family: inherit;
		letter-spacing: 0.01em;
	}

	.year-group :global(ul.posts li > div) {
		min-width: 0;
		display: flex;
		align-items: baseline;
		flex-wrap: wrap;
		column-gap: 0.6rem;
		row-gap: 0.25rem;
	}

	.year-group :global(ul.posts li a) {
		font-size: 0.95rem;
		line-height: 1.5;
	}

	@media (max-width: 640px) {
		.year-group {
			grid-template-columns: 1fr;
			gap: 0.75rem;
			padding: 1.25rem 0;
		}

		.year-group :global(ul.posts li) {
			grid-template-columns: 3.2rem minmax(0, 1fr);
			column-gap: 1rem;
		}

		.year-title {
			position: static;
			padding-top: 0;
			font-size: 1.15rem;
		}
	}

	.search-fab {
		position: fixed;
		right: 18px;
		bottom: 70px;
		z-index: 999;
		width: 42px;
		height: 42px;
		border-radius: 999px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--text-color);
		background: rgba(127, 127, 127, 0.10);
		border: 1px solid rgba(127, 127, 127, 0.25);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
		box-shadow: 0 8px 22px rgba(0, 0, 0, 0.12);
		cursor: pointer;
		transition: all 0.2s ease;
	}

	.search-fab:hover {
		background: rgba(127, 127, 127, 0.16);
		border-color: rgba(127, 127, 127, 0.35);
	}

	.search-fab:focus-visible {
		outline: 2px solid rgba(106, 176, 229, 0.9);
		outline-offset: 3px;
	}

	.search-fab svg {
		display: block;
	}
</style>


