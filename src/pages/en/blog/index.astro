---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import { SITE_DESCRIPTION } from '../../../consts';
import { INCLUDE_DRAFTS, filterDrafts } from '../../../utils/drafts';
import { useTranslations } from '../../../i18n/utils';

const t = useTranslations('en');

const posts = filterDrafts(await getCollection('blog'))
    .filter(p => p.id.startsWith('en/'))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const postsByYear: Record<number, typeof posts> = {};
posts.forEach((post) => {
	const year = post.data.pubDate.getFullYear();
	if (!postsByYear[year]) {
		postsByYear[year] = [];
	}
	postsByYear[year].push(post);
});

const years = Object.keys(postsByYear)
	.map(Number)
	.sort((a, b) => b - a);

function getArchiveDate(date: Date) {
	const month = String(date.getMonth() + 1).padStart(2, '0');
	const day = String(date.getDate()).padStart(2, '0');
	return `${month}.${day}`;
}
---

<Base title={t('nav.blog')} description={SITE_DESCRIPTION} className="blog-surface-layout">
	<div class="content-limit-width list-stack archive-stack">
		<section class="list-surface list-surface--lead">
			<header class="page-rail">
				<h1 id='archive-title'>{t('nav.blog')}</h1>
				<p class="page-rail__meta">{posts.length} entries · by year</p>
			</header>
			<div class="list-main list-main--spacer" aria-hidden="true"></div>
		</section>

		<div class="archive-ledger paper-ledger">
			{
				years.map((year) => (
					<section class="list-surface list-surface--year" aria-labelledby={`archive-year-${year}`}>
						<div class="page-rail page-rail--year">
							<h2 class="year-rail" id={`archive-year-${year}`}>{year}</h2>
						</div>
						<div class="list-main">
							<ul class="year-posts posts">
								{postsByYear[year].map((post) => {
									const slug = (post.data.slug ?? post.id).replace(/^en\//, '');
									return (
									<li>
										<span>
											<time datetime={post.data.pubDate.toISOString()}>{getArchiveDate(post.data.pubDate)}</time>
										</span>
										<div>
											<a href={`/en/blog/${slug}.html`} transition:name={`post-title-${post.id}`}>
												{post.data.title}
											</a>
											{INCLUDE_DRAFTS && post.data.draft && <span class="draft-badge" aria-label="Draft">{t('home.draft')}</span>}
										</div>
									</li>
								)})}
							</ul>
						</div>
					</section>
				))
			}
		</div>
	</div>

	<button class='search-fab' id='search-trigger' type='button' aria-label='Search' title='Search'>
		<svg xmlns='http://www.w3.org/2000/svg' width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2'>
			<circle cx='11' cy='11' r='8'></circle>
			<path d='m21 21-4.35-4.35'></path>
		</svg>
	</button>
</Base>

<script is:inline>
	function initSearchTrigger() {
		var searchTrigger = document.getElementById('search-trigger');
		if (searchTrigger) {
			searchTrigger.addEventListener('click', function () {
				if (window.openSearchModal) {
					window.openSearchModal();
				}
			});
		}
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initSearchTrigger);
	} else {
		initSearchTrigger();
	}
</script>

<style>
	.search-fab {
		position: fixed;
		right: 18px;
		bottom: 70px;
		z-index: 999;
		width: 42px;
		height: 42px;
		border-radius: 0;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: var(--text-color);
		background: var(--paper-card-bg);
		border: 1px solid var(--paper-card-border);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
		box-shadow: var(--paper-card-shadow);
		cursor: pointer;
		transition: transform 0.2s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.2s ease, background 0.2s ease, border-color 0.2s ease;
	}

	.search-fab:hover {
		background: color-mix(in oklab, var(--paper-card-bg) 92%, var(--content-bg));
		border-color: var(--paper-card-border);
		transform: none;
		box-shadow: var(--paper-card-shadow);
	}

	.search-fab:active {
		transform: translateY(0);
	}

	.search-fab:focus-visible {
		outline: 2px solid var(--accent-color);
		outline-offset: 3px;
	}

	.search-fab svg {
		display: block;
	}
</style>
